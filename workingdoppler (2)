/* ---------- MAGNIFIER LENS SYSTEM ---------- */
let lensState = { active: false, tracks: [], config: {} };
const lensItemImageCache = new Map();

function lensLoop() {
  if (!lensState.active) return;
  const canvas = document.getElementById("lensCanvas");
  if (!canvas) { lensState.active = false; return; }
  const ctx = canvas.getContext("2d");

  // Sync canvas dimensions
  if (canvas.width !== canvas.offsetWidth || canvas.height !== canvas.offsetHeight) {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }

  const { width, height } = canvas;
  const centerX = width / 2;
  const centerY = height / 2;
  
  // Increased lens radius for a larger view to provide more room from top to bottom
  const lensRadius = Math.min(width, height) * 0.42; 
  const zoomFactor = 1.1;

  ctx.clearRect(0, 0, width, height);

  // Helper to draw the strip content at a specific scale and brightness
  const drawLensContent = (targetScale, brightness = 1.0, isMagnified = false) => {
    if (!lensState.config) return;
    const { ITEM_WIDTH, GAP, TRACK_PADDING, IMG_SIZE, numToOpen, ROW_HEIGHT } = lensState.config;
    const slotFullWidth = ITEM_WIDTH + GAP;

    lensState.tracks.forEach((trackData, rowIdx) => {
      const trackEl = trackData.el;
      const style = window.getComputedStyle(trackEl);
      const matrix = new WebKitCSSMatrix(style.transform);
      const currentX = matrix.m41;

      // Track vertical position: Ensure it is centered in the canvas
      // Calculate offset based on number of rows
      const totalTracksHeight = (numToOpen * ROW_HEIGHT) + ((numToOpen - 1) * 20);
      const startY = centerY - (totalTracksHeight / 2) + (ROW_HEIGHT / 2);
      const rowY = startY + rowIdx * (ROW_HEIGHT + 20);

      trackData.items.forEach((it, idx) => {
        // Horizontal position
        const itemCenterRelative = TRACK_PADDING + (idx * slotFullWidth) + currentX + (ITEM_WIDTH / 2);
        
        // Final draw coordinates relative to canvas center
        const drawX = centerX + (itemCenterRelative - centerX) * targetScale;
        const drawY = centerY + (rowY - centerY) * targetScale;
        
        const cardW = ITEM_WIDTH * targetScale;
        const cardH = (ROW_HEIGHT - 10) * targetScale;
        const iconSize = IMG_SIZE * targetScale;

        // Culling
        if (drawX + cardW < 0 || drawX - cardW > width) return;

        // Apply brightness/dimming
        ctx.globalAlpha = brightness;

        // Draw Card Base (Gradient or Solid) with Fade Effect
        const rarity = (it.rarity && (it.rarity.name || it.rarity)) || "Mil-Spec";
        const rarityColor = RARITY_COLORS[rarity] || "#ccc";
        
        const cardGrad = ctx.createLinearGradient(drawX, drawY - cardH/2, drawX, drawY + cardH/2);
        if (rarity === "Gold") {
          cardGrad.addColorStop(0, "#e4ae39");
          cardGrad.addColorStop(1, "#fcd34d");
        } else {
          cardGrad.addColorStop(0, "#A8A8A8");
          cardGrad.addColorStop(0.8, "#A8A8A8");
          cardGrad.addColorStop(1, rarityColor); // Bottom fade to rarity color
        }
        ctx.fillStyle = cardGrad;
        
        // Draw the main card box
        ctx.fillRect(drawX - cardW/2, drawY - cardH/2, cardW, cardH);
        ctx.shadowBlur = 0; // reset shadow

        // Draw Rarity Accent Bar
        ctx.fillStyle = RARITY_COLORS[rarity] || "#ccc";
        const borderSize = (isMagnified ? 24 : 18) * targetScale;
        ctx.fillRect(drawX - cardW/2, drawY + cardH/2 - borderSize, cardW, borderSize);

        // Draw Item Image
        let imgUrl = trackData.images[idx];
        let imgObj = lensItemImageCache.get(imgUrl);
        if (!imgObj) {
          imgObj = new Image();
          imgObj.src = imgUrl;
          lensItemImageCache.set(imgUrl, imgObj);
        }
        if (imgObj.complete) {
          const iw = iconSize;
          const ih = iconSize * 0.75;
          ctx.drawImage(imgObj, drawX - iw/2, drawY - ih/2 - (borderSize/4), iw, ih);
        }


        
        ctx.globalAlpha = 1.0;
      });
    });
  };

  /* PASS 1: DRAW BACKGROUND (Unmagnified, Blurred) */
  ctx.save();
  ctx.beginPath();
  ctx.rect(0, 0, width, height);
  ctx.arc(centerX, centerY, lensRadius, 0, Math.PI * 2, true); 
  ctx.clip();
  ctx.filter = "blur(2px)"; // Reduced blur intensity on case strip non-magnified area
  drawLensContent(1.0, 1.0, false); 
  ctx.restore();

  /* PASS 2: DRAW MAGNIFIED AREA (Zoomed, Sharp, Dark Tinted) */
  ctx.save();
  ctx.beginPath();
  ctx.arc(centerX, centerY, lensRadius, 0, Math.PI * 2);
  ctx.clip();
  
  // Fill the circle with a dark opacity background like before
  ctx.fillStyle = "rgba(0, 0, 0, 0.5)";
  ctx.fill();
  
  ctx.filter = "none"; // Ensure magnified area is sharp
  drawLensContent(zoomFactor, 1.0, true);
  
  ctx.restore();

  /* PASS 3: CENTER LINE (NO RIM) */
  
  if (lensState.config) {
    const { numToOpen, ROW_HEIGHT } = lensState.config;
    const cardH = (ROW_HEIGHT - 10) * zoomFactor;
    const totalHeight = (numToOpen * cardH) + ((numToOpen - 1) * 20 * zoomFactor);
    
    // Draw Center Yellow Line (Selector) - perfectly fitted to the magnified item boxes
    ctx.fillStyle = "#ffd400";
    ctx.fillRect(centerX - 1.5, centerY - (totalHeight / 2), 3, totalHeight);
  }

  requestAnimationFrame(lensLoop);
}

/**
 * Update the UI of the Purchase Result navigation modal (Redesigned "NEW ITEM" style).
 */
/**
 * Processes pending items and displays the results modal.
 * Now supports appending items to an already visible modal.
 * Logic ensures it always shows if there is content to display.
 */
function showGroupedPurchaseResult() {
  // Defensive initialization to avoid uncaught TypeErrors when globals or DOM are missing.
  if (!Array.isArray(purchaseResultList)) purchaseResultList = [];
  if (!Array.isArray(pendingPurchaseResults)) pendingPurchaseResults = [];
  if (typeof currentPurchaseResultIdx !== "number") currentPurchaseResultIdx = 0;

  const modal = document.getElementById("purchaseResultModal");
  if (!modal) {
    console.warn("showGroupedPurchaseResult aborted: purchaseResultModal not found.");
    return;
  }

  // If a case opening modal is currently visible, defer showing the NEW ITEM popup until after it's closed.
  const caseOpening = document.getElementById("caseOpeningModal");
  if (caseOpening && !caseOpening.classList.contains("hidden")) {
    return;
  }

  // Ensure seenPurchaseIds exists
  if (!state.seenPurchaseIds) state.seenPurchaseIds = [];

  // Filtering removed per user request: "NO MATTER WHAT... PLEASE show THE NEW ITEMS POPUp"

  // If there are new items to process, append them to the active purchase-result session (stacking).
  if (pendingPurchaseResults.length > 0) {
    const isAlreadyOpen = !modal.classList.contains("hidden");
    if (!isAlreadyOpen) currentPurchaseResultIdx = 0;

    // Move from pending queue to navigation list
    purchaseResultList = [...purchaseResultList, ...pendingPurchaseResults];
    pendingPurchaseResults = [];

    updatePurchaseResultView();
    // Reset shown flag so fresh additions trigger the display below
    hasShownNewItemPopup = false;
  }

  // If popup was already shown for the current list and nothing is pending, abort.
  if (hasShownNewItemPopup || purchaseResultList.length === 0) {
    return;
  }

  // Always show or refresh the NEW ITEM modal when there are items in the list.
  if (purchaseResultList.length > 0) {
    // If a caller requested the next NEW ITEM popup to be shown without the dark overlay,
    // apply a transparent background for this one-shot display and then clear the flag.
    if (window._noBackdropForNextNewItem) {
      modal.style.background = "transparent";
      modal.style.pointerEvents = "auto";
      try { window._noBackdropForNextNewItem = false; } catch (e) {}
    } else {
      modal.style.background = "transparent";
    }

    // Ensure this modal remains visually lower than other modals (we set z-index in HTML/CSS),
    // but still visible and interactive so it won't block higher-priority dialogs.
    modal.classList.remove("hidden");
    modal.style.display = "flex";
    
    // Optional audio for NEW ITEM popup.
    if (state.newItemPopupSound !== false) {
      try { playAwardSound("Industrial"); } catch(e) {}
    }

    // Update the counter to show total stacked count of pending new items
    const counterEl = document.getElementById("purchaseResultCounter");
    if (counterEl) {
      const total = purchaseResultList.length;
      counterEl.textContent = `${total}`;
    }
    // mark that we've shown the popup for this batch (prevents accidental reopen on other modal closes)
    hasShownNewItemPopup = true;
  }
}

function updatePurchaseResultView() {
  const item = purchaseResultList[currentPurchaseResultIdx];
  if (!item) {
    // Safety check to clear stuck loaders if item data is missing
    const imageWrap = document.querySelector(".new-item-image-wrap");
