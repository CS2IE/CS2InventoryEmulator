let botSessionUsedNametags = new Set();

function getUniqueBotNametag() {
  const available = RARE_NAMETAGS.filter(tag => !botSessionUsedNametags.has(tag));
  if (available.length === 0) {
    botSessionUsedNametags.clear();
    return RARE_NAMETAGS[Math.floor(Math.random() * RARE_NAMETAGS.length)];
  }
  const picked = available[Math.floor(Math.random() * available.length)];
  botSessionUsedNametags.add(picked);
  return picked;
}

function maybeApplyRareNametag(item) {
  // Logic: Stop naming stickers and applying stickers to stickers
  const isWeapon = item.name && (item.name.includes("|") || item.name.includes("★"));
  const isSticker = item.name && item.name.toLowerCase().includes("sticker");
  const source = String(item?.source || "").toLowerCase();
  
  if (isWeapon && !isSticker && (source.includes("bot trade") || source.includes("bidskin"))) {
    if (Math.random() < 0.15 && !item.nametag) {
      item.nametag = getUniqueBotNametag();
    }
  }
}

