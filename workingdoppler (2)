function findContainerNameForItem(item) {
  let containerName = null;
  try {
    if (item?.source && typeof item.source === "string" && item.source.includes("from ")) {
      containerName = item.source.split("from ")[1];
    } else if (item?.source === "Traded") {
      containerName = "Traded Items";
    } else if (item?.source === "Purchased") {
      containerName = "Market Purchase";
    } else if (item?.source === "Trade Up Contract") {
      containerName = "Trade Up Collection";
    }
  } catch (e) {}

  if (containerName && containerName !== "Unknown Collection") return containerName;

  try {
    const rawName = String(item?.name || "").trim();
    const normalizedName = normalizeContainerLookupItemName(rawName);
    const candidateCaseNames = Array.from(new Set([
      ...Object.keys(CASE_CONTENTS_DB || {}),
      ...apiCrates.map(crate => crate?.name).filter(Boolean)
    ]));
    for (const caseName of candidateCaseNames) {
      const groups = resolveCaseContentsData(caseName);
      if (!groups) continue;
      for (const rarityGroup of Object.values(groups)) {
        if (!Array.isArray(rarityGroup)) continue;
        if (rarityGroup.some(ci => {
          const candidateRaw = String(ci?.name || "").trim();
          const candidateNormalized = normalizeContainerLookupItemName(candidateRaw);
          return candidateRaw === rawName || candidateRaw === normalizedName || candidateNormalized === rawName || candidateNormalized === normalizedName;
        })) {
          return caseName;
        }
      }
    }
  } catch (e) {}

  return (item?.source && typeof item.source === "string") ? item.source : "Inventory";
}

