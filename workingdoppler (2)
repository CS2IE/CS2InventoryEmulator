function readChunkedStorage(baseKey, storage) {
  try {
    if (!storage) return null;
    const count = parseInt(storage.getItem(`${baseKey}_count`) || "", 10);
    if (!Number.isInteger(count) || count <= 0) return null;
    const parts = [];
    for (let i = 0; i < count; i++) {
      const chunk = storage.getItem(`${baseKey}_${i}`);
      if (typeof chunk !== "string") return null;
      parts.push(chunk);
    }
    return parts.join("");
  } catch (err) {
    return null;
  }
}

function clearChunkedStorage(baseKey, storage) {
  try {
    if (!storage) return;
    const count = parseInt(storage.getItem(`${baseKey}_count`) || "", 10);
    if (Number.isInteger(count) && count > 0) {
      for (let i = 0; i < count; i++) {
        storage.removeItem(`${baseKey}_${i}`);
      }
    }
    storage.removeItem(`${baseKey}_count`);
  } catch (err) {}
}

function writeChunkedStorage(baseKey, value, storage, chunkSize = 240000) {
  try {
    if (!storage || typeof value !== "string") return false;
    clearChunkedStorage(baseKey, storage);
    const parts = [];
    for (let idx = 0; idx < value.length; idx += chunkSize) {
      parts.push(value.slice(idx, idx + chunkSize));
    }
    parts.forEach((part, index) => storage.setItem(`${baseKey}_${index}`, part));
    storage.setItem(`${baseKey}_count`, String(parts.length));
    return true;
  } catch (err) {
    clearChunkedStorage(baseKey, storage);
    return false;
  }
}

function writeStringWithFallback(baseKey, value) {
  let wrotePrimary = false;
  try {
    localStorage.setItem(baseKey, value);
    wrotePrimary = true;
    clearChunkedStorage(baseKey, localStorage);
  } catch (err) {
    try { localStorage.removeItem(baseKey); } catch (removeErr) {}
    wrotePrimary = writeChunkedStorage(baseKey, value, localStorage);
  }

  const sessionBase = baseKey === STORAGE_KEY ? STORAGE_SESSION_KEY : `${baseKey}_session`;
  if (!writeChunkedStorage(sessionBase, value, sessionStorage)) {
    try { sessionStorage.setItem(sessionBase, value); } catch (err) {}
  }

  return wrotePrimary;
}

