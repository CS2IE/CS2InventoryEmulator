      ["collectibles", "https://raw.githubusercontent.com/ByMykel/CSGO-API/main/public/api/en/collectibles.json"],
      ["graffiti", "https://raw.githubusercontent.com/ByMykel/CSGO-API/main/public/api/en/graffiti.json"],
      ["music_kits", "https://raw.githubusercontent.com/ByMykel/CSGO-API/main/public/api/en/music_kits.json"],
      ["tools", "https://raw.githubusercontent.com/ByMykel/CSGO-API/main/public/api/en/tools.json"],
      ["keychains", "https://raw.githubusercontent.com/ByMykel/CSGO-API/main/public/api/en/keychains.json"]
    ];

    const settled = await Promise.allSettled(endpoints.map(async ([key, url]) => {
      const response = await fetch(url);
      if (!response.ok) throw new Error(`${key}: ${response.status}`);
      return [key, await response.json()];
    }));
    const payloads = {};
    settled.forEach((result, idx) => {
      const [key] = endpoints[idx];
      if (result.status === "fulfilled") {
        payloads[key] = result.value[1];
      } else {
        console.warn(`Failed to load ${key} from CSGO API:`, result.reason);
      }
    });

    apiAllItems = (payloads.all && typeof payloads.all === "object" && !Array.isArray(payloads.all)) ? payloads.all : {};
    apiSkins = Array.isArray(payloads.skins) ? payloads.skins : [];
    apiSkinVariants = Array.isArray(payloads.skins_not_grouped) ? payloads.skins_not_grouped : [];
    apiCrates = Array.isArray(payloads.crates) ? payloads.crates : [];

    allSkins = [
      ...apiSkins,
      ...(Array.isArray(payloads.stickers) ? payloads.stickers : []),
      ...(Array.isArray(payloads.sticker_slabs) ? payloads.sticker_slabs : []),
      ...(Array.isArray(payloads.agents) ? payloads.agents : []),
      ...apiCrates,
      ...(Array.isArray(payloads.keys) ? payloads.keys : []),
      ...(Array.isArray(payloads.collectibles) ? payloads.collectibles : []),
      ...(Array.isArray(payloads.graffiti) ? payloads.graffiti : []),
      ...(Array.isArray(payloads.music_kits) ? payloads.music_kits : []),
      ...(Array.isArray(payloads.tools) ? payloads.tools : []),
      ...(Array.isArray(payloads.keychains) ? payloads.keychains : [])
    ];
    try {
      allSkins = allSkins.filter(Boolean);
    } catch (e) {}
    indexApiData();
    
    // Persist to storage to speed up next visits
    try {
      const serializedDb = JSON.stringify({
        allSkins,
        apiAllItems,
        apiCrates,
        apiSkins,
        apiSkinVariants
      });
      writeStringWithFallback(SKINS_CACHE_DB_KEY, serializedDb);
      try { localStorage.removeItem(LEGACY_SKINS_CACHE_KEY); } catch (removeErr) {}
    } catch (e) {
      console.warn("Couldn't cache skins database.", e);
    }

    status.textContent = "Database ready. Search skins, cases, stickers, agents!";
  } catch (err) {
    console.error("API Error:", err);
    status.textContent = "Error loading database. Please refresh.";
  }
}

/**
 * Centralized Confirm Purchase modal helper.
 * items: array of { name, price, qty }
 * onConfirm: function called when user confirms purchase
 */
function showBuyConfirm(items, onConfirm) {
  const buyModal = document.getElementById("buyConfirmModal");
  const buyBody = document.getElementById("buyConfirmBody");
  const confirmBtn = document.getElementById("confirmBuyBundleBtn");
  const cancelBtn = document.getElementById("cancelBuyBundleBtn");
  const freeCashBtn = document.getElementById("freeCashBtn");
  const qtyInput = document.getElementById("buyConfirmQtyInput");
  const qtySlider = document.getElementById("buyConfirmQtySlider");
  const qtyArea = document.getElementById("buyConfirmQtyArea");
  const activeAccount = getActiveAccount();
  if (confirmBtn) confirmBtn.disabled = false;

  // Wire up free purchase button inside grouped confirm
  if (freeCashBtn) {
    freeCashBtn.onclick = (e) => {
      e.stopPropagation();
      items.forEach(it => {
        const itemCopy = JSON.parse(JSON.stringify(it));
        const count = itemCopy.qty || 1;
        for (let i = 0; i < count; i++) {
          addItemToAccount({ ...itemCopy, qty: 1, source: "Purchased" });
        }
      });
      // Close all modals immediately including search
      document.querySelectorAll('.modal-overlay').forEach(m => m.classList.add('hidden'));
      // Trigger new item popup show
      hasShownNewItemPopup = false;
      showGroupedPurchaseResult();
    };
  }
  
  // Initialize qty from the first item in the batch
  let currentQty = items[0].qty || 1;
  qtyInput.value = currentQty;
  qtySlider.value = currentQty;
  const isStorage = items.some(it => String(it?.name || "").toLowerCase().includes("storage unit"));
  if (qtyArea) qtyArea.style.display = isStorage ? "none" : "block";

  const renderBuyBody = () => {
    // Update items' qty based on common input
    items.forEach(it => it.qty = currentQty);
    lastBuyConfirmItems = items;

    const displayTotalCost = items.reduce((s, it) => s + (((it && typeof it.price === "number") ? it.price : 0) * (it.qty || 1)), 0);
    const totalCost = items.reduce((s, it) => s + (getPurchaseCost(it) * (it.qty || 1)), 0);
    const currentBalance = activeAccount ? (activeAccount.walletBalance || 0) : 0;
    const balanceAfter = currentBalance - displayTotalCost;
    
    // Update confirm button to show balance after purchase on the button itself
    confirmBtn.textContent = (state && state.walletlessMode) ? `Confirm (FREE)` : `Confirm (${formatPrice(balanceAfter)})`;
    confirmBtn.disabled = false;

    // Build items list HTML (include 'Owned' count before purchase)
    const account = getActiveAccount();
    
    // Wire up slider sync immediately
    const qtyInput = document.getElementById("buyConfirmQtyInput");
    const qtySlider = document.getElementById("buyConfirmQtySlider");
    if (qtyInput && qtySlider) {
        qtySlider.max = 200;
        qtyInput.max = 200;
        qtySlider.oninput = (e) => { 
          const val = parseInt(e.target.value);
          qtyInput.value = val; 
          currentQty = val; 
          renderBuyBody(); 
        };
        qtyInput.oninput = (e) => { 
          const val = Math.max(1, Math.min(200, parseInt(e.target.value) || 1));
          qtySlider.value = val; 
          currentQty = val; 
          renderBuyBody(); 
        };
    }

    const itemsHtml = items.map(it => {
      const unit = formatPrice((it && typeof it.price === "number") ? it.price : 0);
      const qty = it.qty || 1;
      const displayName = it.nametag ? `"${it.nametag}"` : it.name;
      // Count how many the active account already owns (match by name + nametag)
      let ownedCount = 0;
      try {
        if (account && Array.isArray(account.items)) {
          ownedCount = account.items.reduce((c, ai) => {
            if (!ai || !ai.name) return c;
            if (ai.name === it.name && ((ai.nametag || "") === (it.nametag || ""))) return c + (ai.qty || 1);
            // also check inside storage units
            if (ai.contents && Array.isArray(ai.contents)) {
              ai.contents.forEach(ch => {
                if (ch && ch.name === it.name && ((ch.nametag || "") === (it.nametag || ""))) c += (ch.qty || 1);
              });
            }
            return c;
          }, 0);
        }
      } catch (e) {
        ownedCount = 0;
      }

      return `<div style="display:flex; flex-direction:column; gap:6px; padding:6px 0; border-bottom:1px solid rgba(255,255,255,0.03);">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <div style="min-width:0; overflow:hidden; text-overflow:ellipsis;">${escapeHtml(displayName)}</div>
          <div style="text-align:right; margin-left:12px; color:#a4d007; font-weight:700;">${unit} × ${qty}</div>
        </div>
        <div style="font-size:12px; color:#94a3b8;">Owned before purchase: <strong style="color:#fff">${ownedCount}</strong></div>
      </div>`;
    }).join("");

    const walletlessNoteHtml = (state && state.walletlessMode) ? `
        <div style="margin-top:10px; padding-top:10px; border-top:1px solid rgba(255,255,255,0.04); color:#94a3b8; font-size:12px;">
          Walletless Mode is enabled. You will not be charged.
        </div>
        <div style="display:flex; justify-content:space-between; margin-top:6px;">
          <div style="color:#94a3b8; font-size:12px; text-transform:uppercase;">Effective Cost</div>
          <div style="color:#a4d007; font-weight:900;">${formatPrice(totalCost)}</div>
        </div>
    ` : "";

    const walletInfoHtml = (state && state.walletlessMode) ? "" : `
        <div style="display:flex; justify-content:space-between; margin-top:6px;">
          <div style="color:#94a3b8; font-size:12px;">Current Wallet</div>
          <div style="color:#fff; font-weight:700;">${formatPrice(currentBalance)}</div>
        </div>
        <div style="display:flex; justify-content:space-between; margin-top:6px;">
          <div style="color:#94a3b8; font-size:12px;">Wallet After Purchase</div>
          <div style="color:${balanceAfter < 0 ? '#eb4b4b' : '#a4d007'}; font-weight:900;">${formatPrice(balanceAfter)}</div>
        </div>
    `;

    buyBody.innerHTML = `
      <div style="margin-bottom:12px; font-size: 13px; color: #94a3b8; text-align:left;">Confirm purchase of the following item${items.length>1?'s':''}:</div>
      <div style="background: rgba(0,0,0,0.3); border: 1px solid #334155; padding: 12px; border-radius: 8px; text-align:left; max-height:240px; overflow:auto;">
        ${itemsHtml}
        <div style="display:flex; justify-content:space-between; margin-top:10px; padding-top:10px; border-top:1px solid rgba(255,255,255,0.04);">
          <div style="color:#94a3b8; font-size:12px; text-transform:uppercase;">Total Cost</div>
          <div style="color:#a4d007; font-weight:900;">${formatPrice(displayTotalCost)}</div>
        </div>
        ${walletInfoHtml}
        ${walletlessNoteHtml}
      </div>
    `;
  };

  const syncQty = (newVal) => {
    currentQty = Math.max(1, Math.min(100, parseInt(newVal) || 1));
    qtyInput.value = currentQty;
    qtySlider.value = currentQty;
    renderBuyBody();
  };

  qtyInput.oninput = (e) => syncQty(e.target.value);
  qtySlider.oninput = (e) => syncQty(e.target.value);

  renderBuyBody();
  buyModal.classList.remove("hidden");

  // Ensure single-click semantics: process purchase, close popups, add items.
  confirmBtn.onclick = (e) => {
    if (confirmBtn.disabled) return;
    confirmBtn.disabled = true;

    // Perform the purchase logic
    const success = attemptPurchase(items);
    
    if (success) {
      // Force close all relevant purchase overlays only on success
      if (buyModal) buyModal.classList.add("hidden");
      const searchSheet = document.getElementById("searchSheet");
      if (searchSheet) searchSheet.classList.add("hidden");
      const wearModal = document.getElementById("wearModal");
      if (wearModal) wearModal.classList.add("hidden");
      
      try { if (onConfirm) onConfirm(); } catch (e) {}
    } else {
      // Re-enable if purchase was blocked by redundancy guards
      confirmBtn.disabled = false;
    }
    
    // Global safety: Recalculate blur when confirming purchase
    updateModalBlurState();
  };

  cancelBtn.onclick = () => {
    buyModal.classList.add("hidden");
    if (confirmBtn) confirmBtn.disabled = false;
    confirmBtn.onclick = null;
    cancelBtn.onclick = null;
  };
}

/**
 * Opens the Edit Market Item modal prefilled with the last-selected search result (selectedSearchItem).
 * If no search result is selected, attempts to auto-select the first visible result.
 */
function showEditMarketModal() {
  // Ensure "Bot Marketplace" title is only shown during bot trade additions
  const searchTitle = document.getElementById("searchModalTitle");
  if (searchTitle) {
      searchTitle.textContent = marketAddTargetHandler ? "Bot Marketplace" : "CS2 Market Search";
  }

  const wearSelect = document.getElementById("editMarketWear");
  if (wearSelect) {
    wearSelect.onchange = () => {
       if (selectedSearchItem && selectedSearchItem.raw) {
          const syncIt = { ...selectedSearchItem.raw, wear: wearSelect.value };
          const newImg = getStableDisplayImage(syncIt);
          const preview = document.getElementById("editMarketImgPreview");
          if (preview) preview.src = newImg;
          const urlInp = document.getElementById("editMarketImg");
          if (urlInp) urlInp.value = newImg;
       }
    };
  }

  if (!selectedSearchItem) {
    const firstCard = document.querySelector("#results .card");
    if (firstCard) firstCard.click();
    if (!selectedSearchItem) {
      alert("No search result selected to edit.");
      return;
    }
  }

  // Populate modal fields
  const modal = document.getElementById("editMarketItemModal");
  if (!modal) return;

  const fullSelectedName = String(selectedSearchItem.name || "");
  const hasStatTrakPrefix = /^StatTrak(?:™|â„¢)\s+/i.test(fullSelectedName);
  const withoutStatTrak = fullSelectedName.replace(/^StatTrak(?:™|â„¢)\s+/i, "");
  const hasBlueGemPrefix = /^'Blue Gem'\s+/i.test(withoutStatTrak);
  const baseDisplayName = withoutStatTrak.replace(/^'Blue Gem'\s+/i, "").trim();

  document.getElementById("editMarketImgPreview").src = selectedSearchItem.image || selectedSearchItem.img || getDisplayImage({ name: selectedSearchItem.name });
  document.getElementById("editMarketName").value = baseDisplayName || selectedSearchItem.name || "";
  document.getElementById("editMarketImg").value = selectedSearchItem.image || selectedSearchItem.img || "";
  document.getElementById("editMarketPrice").value = (selectedSearchItem.price !== undefined) ? Number(selectedSearchItem.price).toFixed(2) : "";
  if (wearSelect) wearSelect.value = selectedSearchItem.wear || "";
  const mfrSelect = document.getElementById("editMarketFloatRank");
  if (mfrSelect) mfrSelect.value = selectedSearchItem.floatRank || 0;

  const qtyField = document.getElementById("editMarketQty");
  if (qtyField) qtyField.value = Math.max(1, parseInt(selectedSearchItem.qty, 10) || parseInt(selectedSearchItem.raw?.qty, 10) || 1);
  const statTrakSelect = document.getElementById("editMarketStatTrak");
  if (statTrakSelect) statTrakSelect.value = hasStatTrakPrefix ? "yes" : "no";
  const blueGemSelect = document.getElementById("editMarketBlueGem");
  if (blueGemSelect) blueGemSelect.value = hasBlueGemPrefix ? "yes" : "no";
  // Try to set rarity select if present
  const raritySelect = document.getElementById("editMarketRarity");
  if (raritySelect) {
    const r = (selectedSearchItem.rarity && (selectedSearchItem.rarity.name || selectedSearchItem.rarity)) ? String(selectedSearchItem.rarity.name || selectedSearchItem.rarity) : "";
    // Resilient lookup: match either exact, or partial contains (e.g. "Mil-Spec" vs "Mil-Spec Grade")
    for (let i = 0; i < raritySelect.options.length; i++) {
      const optVal = raritySelect.options[i].value.toLowerCase();
      const rLower = r.toLowerCase();
      if (optVal === rLower || optVal.includes(rLower) || rLower.includes(optVal)) {
        raritySelect.selectedIndex = i;
        break;
      }
    }
  }

  modal.classList.remove("hidden");
}

