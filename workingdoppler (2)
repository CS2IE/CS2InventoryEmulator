async function loadStateFromDB() {
  const fullCandidates = [];
  const criticalCandidates = [];

  try {
    const idbState = await loadFromIDB(STORAGE_KEY);
    if (idbState) fullCandidates.push({ parsed: idbState, timestamp: getStoredSnapshotTimestamp(idbState), source: "IndexedDB" });

    [
      parseStoredSnapshot(localStorage.getItem(STORAGE_KEY), "localStorage primary"),
      parseStoredSnapshot(localStorage.getItem(STORAGE_BACKUP_KEY), "localStorage backup"),
      parseStoredSnapshot(readChunkedStorage(STORAGE_KEY, localStorage), "localStorage chunked"),
      parseStoredSnapshot(readChunkedStorage(STORAGE_BACKUP_KEY, localStorage), "localStorage backup chunked"),
      parseStoredSnapshot(localStorage.getItem(STORAGE_EXPORT_MIRROR_KEY), "localStorage export mirror"),
      parseStoredSnapshot(readChunkedStorage(STORAGE_EXPORT_MIRROR_KEY, localStorage), "localStorage export mirror chunked"),
      parseStoredSnapshot(localStorage.getItem(STORAGE_REFRESH_SAFE_KEY), "localStorage refresh safe"),
      parseStoredSnapshot(readChunkedStorage(STORAGE_REFRESH_SAFE_KEY, localStorage), "localStorage refresh safe chunked"),
      parseStoredSnapshot(readWindowNameSnapshot(), "window.name refresh snapshot"),
      parseStoredSnapshot(sessionStorage.getItem(STORAGE_SESSION_KEY), "sessionStorage primary"),
      parseStoredSnapshot(readChunkedStorage(STORAGE_SESSION_KEY, sessionStorage), "sessionStorage chunked")
    ].filter(Boolean).forEach(candidate => fullCandidates.push(candidate));

    const criticalCandidate = parseStoredSnapshot(localStorage.getItem(STORAGE_CRITICAL_KEY), "localStorage critical");
    if (criticalCandidate) criticalCandidates.push(criticalCandidate);
  } catch (e) {
    console.warn("Web storage read failed:", e);
  }

  const bestSnapshot = (fullCandidates
    .filter(c => c && c.parsed)
    .sort((a, b) => {
      const timeDiff = (b.timestamp || 0) - (a.timestamp || 0);
      if (timeDiff !== 0) return timeDiff;
      return getSnapshotRichnessScore(b) - getSnapshotRichnessScore(a);
    })[0]) || (criticalCandidates
    .filter(c => c && c.parsed)
    .sort((a, b) => {
      const timeDiff = (b.timestamp || 0) - (a.timestamp || 0);
      if (timeDiff !== 0) return timeDiff;
      return getSnapshotRichnessScore(b) - getSnapshotRichnessScore(a);
    })[0]);

  if (bestSnapshot && bestSnapshot.parsed) {
    state = JSON.parse(JSON.stringify(bestSnapshot.parsed));
    console.log(`State loaded successfully from ${bestSnapshot.source} (Timestamp: ${bestSnapshot.timestamp}).`);
    try {
      const refreshedSnapshotStr = JSON.stringify(buildStateSnapshotObject());
      mirrorSnapshotToAllStores(refreshedSnapshotStr);
    } catch (e) {}
  } else {
    console.warn("No valid save state found in any storage source. Using defaults.");
  }

  normalizeState();

  if (state.priceOverrides && typeof state.priceOverrides === "object") {
    Object.assign(PRICE_FIXES, state.priceOverrides);
  }

  isStateLoaded = true;
  return true;
}

async function saveStateToDB() {
  if (!isStateLoaded) return false;
  if (isSaving) {
    saveRequested = true;
    return savePromise;
  }
  
  isSaving = true;
  isDirty = false;
  saveRequested = false;

  savePromise = (async () => {
    let idbSuccess = false;
    try {
      const snapshotObj = buildStateSnapshotObject();
      state.__lastSavedAt = snapshotObj.__lastSavedAt;

      let snapshotStr;
      let criticalSnapshotStr;
      try {
        snapshotStr = JSON.stringify(snapshotObj);
        criticalSnapshotStr = JSON.stringify(buildCriticalStateSnapshot(snapshotObj));
      } catch (err) {
        console.error("Critical Save Error: Stringification failed", err);
        isSaving = false;
        if (saveRequested) setTimeout(saveStateToDB, 50);
        return false;
      }

      // Primary persistent save to IndexedDB (async)
      try {
        // Re-parse from string to ensure zero proxy/DOM object leakage and perfect clonability
        const pureObj = JSON.parse(snapshotStr);
        idbSuccess = await saveToIDB(STORAGE_KEY, pureObj);
      } catch(e) {
        console.warn("IDB Save Failed", e);
      }

      // Fallback LocalStorage save paths
      try {
        writeStringWithFallback(STORAGE_KEY, snapshotStr);
        writeStringWithFallback(STORAGE_BACKUP_KEY, snapshotStr);
        localStorage.setItem(STORAGE_CRITICAL_KEY, criticalSnapshotStr);
        writeStringWithFallback(STORAGE_EXPORT_MIRROR_KEY, snapshotStr);
        writeWindowNameSnapshot(snapshotStr);
        const refreshSafeStr = JSON.stringify(buildRefreshSafeSnapshotObject());
        writeStringWithFallback(STORAGE_REFRESH_SAFE_KEY, refreshSafeStr);
      } catch(e) {
        console.error("LocalStorage Save Failed", e);
      }
    } catch (globalErr) {
      console.error("Global Save Error:", globalErr);
    }
    
    isSaving = false;
    if (saveRequested) {
      setTimeout(saveStateToDB, 50);
    }
    
    return idbSuccess;
  })();

  return savePromise;
}

let saveDebounceTimer = null;
function saveState() {
  if (!isStateLoaded) return;
  isDirty = true;
  
  // Also force a synchronous full save update immediately to prevent data loss on refresh
  try {
    const snapshotObj = buildStateSnapshotObject();
    const str = JSON.stringify(snapshotObj);
    localStorage.setItem(STORAGE_CRITICAL_KEY, str);
    writeStringWithFallback(STORAGE_KEY, str);
    writeStringWithFallback(STORAGE_BACKUP_KEY, str);
    writeStringWithFallback(STORAGE_EXPORT_MIRROR_KEY, str);
    writeWindowNameSnapshot(str);
    const refreshSafeStr = JSON.stringify(buildRefreshSafeSnapshotObject());
    writeStringWithFallback(STORAGE_REFRESH_SAFE_KEY, refreshSafeStr);
  } catch(e) {}

  if (saveDebounceTimer) clearTimeout(saveDebounceTimer);
  // Debounce rapid state changes for the full chunked/IDB save
  saveDebounceTimer = setTimeout(async () => {
    saveDebounceTimer = null;
    await saveStateToDB();
  }, 50);
}

// Pulse save every 2 seconds to guarantee persistence against crashes
setInterval(() => {
  if (isStateLoaded && isDirty) {
    saveStateToDB();
  }
}, 2000);

// Ensure state is saved when the user leaves the page or switches tabs
const forceSaveNow = () => {
  if (isStateLoaded && isDirty) {
    try {
      const snapshotObj = buildStateSnapshotObject();
      state.__lastSavedAt = snapshotObj.__lastSavedAt;
      const criticalStr = JSON.stringify(buildCriticalStateSnapshot(snapshotObj));
      
      // Critical sync writes to LocalStorage to beat page death
      try { localStorage.setItem(STORAGE_CRITICAL_KEY, criticalStr); } catch (e) {}
      
        try {
          const snapshotStr = JSON.stringify(snapshotObj);
          writeStringWithFallback(STORAGE_KEY, snapshotStr);
          writeStringWithFallback(STORAGE_BACKUP_KEY, snapshotStr);
          writeStringWithFallback(STORAGE_EXPORT_MIRROR_KEY, snapshotStr);
          writeWindowNameSnapshot(snapshotStr);
          const refreshSafeStr = JSON.stringify(buildRefreshSafeSnapshotObject());
          writeStringWithFallback(STORAGE_REFRESH_SAFE_KEY, refreshSafeStr);
        } catch (err) {}
    } catch (err) {
      console.warn("Final synchronous save failed:", err);
    }
    isDirty = false;
  }
};

