                        ${h.userItems.map((it, iIdx) => `<img src="${it.img || getStableDisplayImage(it)}" style="width: 24px; height: 18px; object-fit: contain; cursor: pointer; background: rgba(0,0,0,0.2); border-radius: 2px;" title="${escapeHtml(it.name)}" onclick="window._cfHistoryInspect('${h.id}', 'user', ${iIdx})">`).join('')}
                      </div>
                    </div>
                  </td>
                  <td style="padding: 12px;">
                    <div style="display: flex; flex-direction: column; gap: 4px;">
                      <div style="font-weight: 800; color: #fff;">${formatPrice(h.botValue)}</div>
                      <div style="display: flex; gap: 3px; flex-wrap: wrap; max-width: 150px;">
                        ${h.botItems.map((it, iIdx) => `<img src="${it.img || getStableDisplayImage(it)}" style="width: 24px; height: 18px; object-fit: contain; cursor: pointer; background: rgba(0,0,0,0.2); border-radius: 2px;" title="${escapeHtml(it.name)}" onclick="window._cfHistoryInspect('${h.id}', 'bot', ${iIdx})">`).join('')}
                      </div>
                    </div>
                  </td>
                  <td style="padding: 12px; text-align: center;">
                    <span style="padding: 4px 10px; border-radius: 4px; font-weight: 900; font-size: 10px; background: ${h.isTie ? 'rgba(148, 163, 184, 0.1)' : (h.userWon ? 'rgba(164, 208, 7, 0.1)' : 'rgba(235, 75, 75, 0.1)')}; color: ${h.isTie ? '#94a3b8' : (h.userWon ? '#a4d007' : '#eb4b4b')};">
                      ${h.isTie ? 'TIE' : (h.userWon ? 'WON' : 'LOST')}
                    </span>
                  </td>
                  <td style="padding: 12px; text-align: right; font-weight: 900; color: #e4ae39;">${formatPrice(h.totalValue)}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        `}
      </div>
    </div>
  `;
  document.body.appendChild(overlay);
  overlay.querySelector("#closeCfHistory").onclick = () => overlay.remove();
}

function optOutCoinflip(id) {
  const flipIdx = state.activeCoinflips.findIndex(f => f.id === id);
  if (flipIdx === -1) return;
  const flip = state.activeCoinflips[flipIdx];

  const account = getActiveAccount();
  if (account) {
    // Refund items
    flip.userItems.forEach(it => account.items.push(it));
    
    // Record as tie in history
    if (!account.coinflipHistory) account.coinflipHistory = [];
    account.coinflipHistory.unshift({
      ...flip,
      userWon: false,
      isTie: true,
      finishedAt: Date.now()
    });
    if (account.coinflipHistory.length > 20) account.coinflipHistory.pop();
  }

  state.activeCoinflips.splice(flipIdx, 1);
  saveState();
  refreshInventoryView();
  renderCoinflipLobby();
}

function closeCoinflipResult() {
  const modal = document.getElementById("coinflipAnimModal");
  if (modal) modal.classList.add("hidden");
}

function showTransactionsModal() {
  const acc = getActiveAccount();
  if (!acc) return;
  const modal = document.getElementById("transactionsModal");
  const list = document.getElementById("transactionsList");
  const total = document.getElementById("transactionTotalHeader");
  
  list.innerHTML = "";
  const history = acc.transactions || [];
  let sum = 0;

  if (history.length === 0) {
    list.innerHTML = `<div style="text-align:center; color:#94a3b8; padding:40px;">No transactions recorded.</div>`;
  } else {
    // Sort transactions newest to oldest
    const sorted = [...history].sort((a,b) => b.timestamp - a.timestamp);
    sorted.forEach(t => {
      sum += (t.price * t.qty);
      const row = document.createElement("div");
      row.style.display = "flex";
      row.style.alignItems = "center";
      row.style.gap = "10px";
      row.style.background = "rgba(255,255,255,0.03)";
      row.style.padding = "10px";
      row.style.borderRadius = "6px";
      row.innerHTML = `
        <img src="${t.img}" style="width:60px; height:45px; object-fit:contain; background:rgba(0,0,0,0.2); border-radius:4px;">
        <div style="flex:1; min-width:0;">
          <div style="font-weight:bold; font-size:13px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${t.name}</div>
          <div style="font-size:11px; color:#94a3b8;">${new Date(t.timestamp).toLocaleString()}</div>
        </div>
        <div style="text-align:right;">
          <div style="color:#a4d007; font-weight:800;">${formatPrice(t.price * t.qty)}</div>
          <div style="font-size:10px; color:#64748b;">Qty: ${t.qty}</div>
        </div>
      `;
      list.appendChild(row);
    });
  }
  total.textContent = `Total Account Spending: ${formatPrice(sum)}`;
  modal.classList.remove("hidden");
}

(function bindWalletTransactions() {
  const btn = document.getElementById("viewTransactionsBtn");
  if (btn) btn.onclick = showTransactionsModal;
  const close = document.getElementById("closeTransactionsBtn");
  if (close) close.onclick = () => document.getElementById("transactionsModal").classList.add("hidden");
})();

