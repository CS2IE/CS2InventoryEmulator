function buildCaseSearchResults(query = "") {
  const q = String(query || "").trim().toLowerCase();
  const seen = new Set();
  const results = [];
  const pushResult = (entry) => {
    if (!entry || !entry.name || seen.has(entry.name)) return;
    seen.add(entry.name);
    results.push(entry);
  };

  Object.keys(CASE_CONTENTS_DB || {}).forEach(caseName => {
    const lower = caseName.toLowerCase();
    if (q && !lower.includes(q)) return;
    const price = PRICE_FIXES[caseName] !== undefined ? PRICE_FIXES[caseName] : mockPrice({ name: caseName });
    pushResult({
      name: caseName,
      image: getDisplayImage({ name: caseName }),
      price,
      price_text: formatPrice(price),
      rarity: { name: "Base Grade" },
      type: "Custom Container"
    });
  });

  (MARKET_KEYS || []).forEach(it => {
    const name = String(it?.name || "");
    const lower = name.toLowerCase();
    const isKey = isKeyItem({ name });
    const isContainerLike = isContainer({ name }) && !isKey;
    const isCollection = lower.includes("collection");
    if (!isContainerLike && !isCollection && !isKey) return;
    if (q && !lower.includes(q)) return;
    const price = PRICE_FIXES[name] !== undefined ? PRICE_FIXES[name] : (it.price || mockPrice(it));
    pushResult({
      name,
      image: it.img || it.image || getDisplayImage(it),
      price,
      price_text: formatPrice(price),
      rarity: { name: it.rarity?.name || "Base Grade" },
      type: isKey ? "Key" : (isCollection ? "Custom Collection" : "Container")
    });
  });

  // User: Sort Custom -> Terminals -> Sticker Capsules -> Packages -> Collections -> Rest
  return results.sort((a, b) => {
     const getScore = (res) => {
        const n = res.name.toLowerCase();
        if (res.type === "Custom Container") return 1;
        if (n.includes("terminal")) return 2;
        if (n.includes("sticker capsule")) return 3;
        if (n.includes("package")) return 4;
        if (n.includes("collection")) return 5;
        return 10;
     };
     const scoreA = getScore(a);
     const scoreB = getScore(b);
     if (scoreA !== scoreB) return scoreA - scoreB;
     return a.name.localeCompare(b.name);
  });
}

