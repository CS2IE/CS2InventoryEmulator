function updateSettingsStats() {
  const statsContainer = document.getElementById("settingsStats");
  if (!statsContainer) return;

  // Build per-account stats and global aggregates
  const perAccountStats = state.accounts.map(acc => {
    let accValue = 0;
    let accCount = 0;
    let accCasesOpened = 0; // items whose source indicates they were pulled from cases
    acc.items.forEach(it => {
      const val = getItemValue(it);
      accValue += val;
      accCount++;
      // treat items with source containing "pulled" or "pulled from" or "pulled from case" as case-open results
      if (it.source && String(it.source).toLowerCase().includes("pulled")) accCasesOpened++;
      if (it.contents && Array.isArray(it.contents)) {
        it.contents.forEach(sub => {
          accValue += getItemValue(sub);
          // Do not double count items inside storage for the main count if desired, but here we count them as separate inventory entries
          accCount++;
          if (sub.source && String(sub.source).toLowerCase().includes("pulled")) accCasesOpened++;
        });
      }
    });
    return {
      id: acc.id,
      name: acc.name,
      value: accValue,
      count: accCount,
      casesOpened: accCasesOpened,
      wallet: acc.walletBalance || 0,
      totalDeposited: acc.totalDeposited || 0,
      totalLost: acc.totalLost || 0,
      jackpotWagered: acc.jackpotWagered || 0,
      jackpotProfit: acc.jackpotProfit || 0,
      diceWagered: acc.diceWagered || 0,
      diceProfit: acc.diceProfit || 0
    };
  });

  // Global aggregates across all accounts
  const global = perAccountStats.reduce((g, a) => {
    g.totalValue += a.value;
    g.totalItems += a.count;
    g.totalCasesOpened += a.casesOpened;
    g.totalWallet += a.wallet;
    return g;
  }, { totalValue: 0, totalItems: 0, totalCasesOpened: 0, totalWallet: 0 });

  // Best pulled item globally (by value) - look at all accounts' items
  let bestPulled = null;
  state.accounts.forEach(acc => {
    acc.items.forEach(it => {
      if (it.source && String(it.source).toLowerCase().includes("pulled")) {
        if (!bestPulled || getItemValue(it) > getItemValue(bestPulled)) bestPulled = it;
      }
    });
  });

  // Favorite case globally (most owned)
  const caseCounts = {};
  state.accounts.forEach(acc => {
    acc.items.forEach(it => {
      if (isContainer(it)) caseCounts[it.name] = (caseCounts[it.name] || 0) + 1;
      if (it.contents && Array.isArray(it.contents)) {
        it.contents.forEach(sub => {
          if (isContainer(sub)) caseCounts[sub.name] = (caseCounts[sub.name] || 0) + 1;
        });
      }
    });
  });
  let favoriteCase = null;
  let maxCaseCount = 0;
  Object.entries(caseCounts).forEach(([name, count]) => {
    if (count > maxCaseCount) {
      maxCaseCount = count;
      favoriteCase = name;
    }
  });

  // Build HTML: show a compact global summary and then per-account breakdown (so stats are both per-account and global)
  // Fix: Inventory Net Value now excludes sticker value
  const globalTotalValueNoStickers = perAccountStats.reduce((s, a) => {
    const acc = state.accounts.find(x => x.id === a.id);
    let val = 0;
    acc.items.forEach(it => val += (it.price || 0));
    return s + val;
  }, 0);

  let html = `<h3 style="color: #66c0f4; margin-bottom: 10px; border-bottom: 1px solid #334155; padding-bottom: 5px;">Global Summary</h3>`;
  html += `<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 12px;">
    <div style="background: rgba(255,255,255,0.02); padding:10px; border-radius:6px;">
      <div style="color:#94a3b8; font-size:11px;">Total Inventory Value (Skins)</div>
      <div style="font-weight:900; color:#a4d007; font-size:18px;">${formatPrice(globalTotalValueNoStickers)}</div>
    </div>
    <div style="background: rgba(255,255,255,0.02); padding:10px; border-radius:6px;">
      <div style="color:#94a3b8; font-size:11px;">Total Items</div>
      <div style="font-weight:900; color:#fff; font-size:18px;">${global.totalItems}</div>
    </div>
    <div style="background: rgba(255,255,255,0.02); padding:10px; border-radius:6px;">
      <div style="color:#94a3b8; font-size:11px;">Total Cases Opened</div>
      <div style="font-weight:900; color:#fff; font-size:18px;">${global.totalCasesOpened}</div>
    </div>
  </div>`;

  html += `<div style="display:flex; gap:10px; align-items:center; margin-bottom:12px;">
    <div style="flex:1;">
      <div style="color:#94a3b8; font-size:11px;">Favorite Case (Global)</div>
      <div style="font-weight:800; color:#e4ae39;">${favoriteCase || "None"}</div>
    </div>
    <div style="flex:1;">
      <div style="color:#94a3b8; font-size:11px;">Best Pulled Item (Global)</div>
      <div style="font-weight:800; color:#eb4b4b;">${bestPulled ? bestPulled.name : "None"}</div>
    </div>
    ${state && state.walletlessMode ? "" : `
    <div style="flex:1;">
      <div style="color:#94a3b8; font-size:11px;">Combined Wallets</div>
      <div style="font-weight:800; color:#66c0f4;">${formatPrice(global.totalWallet)}</div>
