function confirmPotDeposit() {
  if (jackpotSelectedSkins.length === 0) return;
  const account = getActiveAccount();
  if (!account) return;

  // Consume skins from inventory
  const selectedIds = jackpotSelectedSkins.map(s => s.id);
  account.items = account.items.filter(it => !selectedIds.includes(it.id));

  // Compute value of newly selected skins
  const addedValue = jackpotSelectedSkins.reduce((s, x) => s + getItemValue(x), 0);
  
  // Mark that the user has participated in the Jackpot mode
  account.hasGambledJackpot = true;
  account.jackpotWagered = (account.jackpotWagered || 0) + addedValue;

  // Find existing user participant in the current pot (if any)
  const existingUserIdx = jackpotPotParticipants.findIndex(p => p && p.id === "user" && p.name === account.name);

  if (existingUserIdx !== -1) {
    // Append new skins to the existing user's entry and update value
    const existing = jackpotPotParticipants[existingUserIdx];
    existing.items = existing.items.concat(jackpotSelectedSkins);
    existing.value = (existing.value || 0) + addedValue;
  } else {
    // Create new participant for this user and start the round
    const userParticipant = {
      id: "user",
      name: account.name,
      avatar: "https://i.imgur.com/Vki8GHi.png",
      value: addedValue,
      items: [...jackpotSelectedSkins],
      color: "#66c0f4",
      chance: 0
    };
    // If pot is currently empty, start a new round; otherwise just append
    if (!jackpotPotParticipants || jackpotPotParticipants.length === 0) {
      jackpotPotParticipants = [userParticipant];
    } else {
      jackpotPotParticipants.push(userParticipant);
    }
  }

  // Update the UI: change Deposit Skins -> Add Weapons
  try {
    const potBtn = document.getElementById("potAddSkinsBtn");
    if (potBtn) {
      potBtn.textContent = "Add Weapons";
      potBtn.onclick = () => { if (jackpotSpinning) return; openSkinPicker(); };
    }
  } catch (e) {}

  document.getElementById("skinPickerModal").classList.add("hidden");
  
  saveState();
  refreshInventoryView();

  // Only start a new jackpot round if the pot was empty before this deposit (existingUserIdx === -1 && previous pot empty)
  // If the pot already had participants, just update UI and let the current round continue.
  if (jackpotPotParticipants.length === 1 && existingUserIdx === -1) {
    startJackpotRound();
  } else {
    // If appending to an ongoing pot, refresh pot UI so the new items are reflected immediately
    updatePotUI();
  }
}

function startJackpotRound() {
  const timerEl = document.getElementById("potTimer");
  timerEl.textContent = "Summoning bots...";
  
  // Clear any existing timer
  if (jackpotCountdown) clearInterval(jackpotCountdown);

  // Sequence bot joins
  let botIdx = 0;
  const botNames = ["s1mple_bot", "ZywOo_reaper", "SkinLord", "GabenFan_99", "TraderJoe", "RushB_CYKA", "KarambitKing"];
  const userValue = jackpotPotParticipants[0].value;

  // Most rounds will now have 3-6 bots (typical), with a small chance to allow more participants.
  let targetBotCount;
  if (Math.random() < 0.85) {
    // common case: 3..6 bots
    targetBotCount = Math.floor(Math.random() * 4) + 3; // yields 3,4,5,6
  } else {
    // rare case: 7..12 bots (kept as occasional larger rounds)
    targetBotCount = Math.floor(Math.random() * 6) + 7; // yields 7..12
  }

  const joinInterval = setInterval(() => {
    const botName = botNames[Math.floor(Math.random() * botNames.length)];
    // Bot value logic: Usually lower, occasionally higher
    let variance;
    const rng = Math.random();
    if (rng < 0.8) {
      // 80% chance: slightly lower (0.4 to 0.95)
      variance = (Math.random() * 0.55) + 0.4;
    } else {
      // 20% chance: slightly higher (1.05 to 1.35)
      variance = (Math.random() * 0.3) + 1.05;
    }
    
    const botValue = userValue * variance;
    
    // Generate random items for bot (guns/knives only)
    const botItems = generateBotItems(botValue);
    const finalBotValue = botItems.reduce((s, x) => s + (x.price || 0), 0);

    const botParticipant = {
      id: "bot_" + botIdx,
      name: botName,
      avatar: "https://i.imgur.com/4mvaOsy.png",
      value: finalBotValue,
      items: botItems,
      color: `hsl(${Math.random() * 360}, 70%, 50%)`,
      chance: 0
    };

    jackpotPotParticipants.push(botParticipant);
    updatePotUI();
    botIdx++;

    if (botIdx >= targetBotCount) {
      clearInterval(joinInterval);
      runPotCountdown();
    }
  }, 750); // Slightly faster join speed for higher bot counts
}

function generateRandomAppliedStickers(item, count) {
  const stickers = [];
  const sourcePool = allSkins.filter(s => {
    const n = String(s?.name || "").toLowerCase();
    const isSticker = n.includes("sticker");
    const isCapsule = n.includes("capsule") || n.includes("package") || n.includes("crate") || n.includes("storage unit");
    const isBlacklisted = n.includes("rio 2022 storage unit with paper stickers") || n.includes("rio 2022 storage unit with glitter stickers");
    return isSticker && !isCapsule && !isBlacklisted;
  });
  
  if (sourcePool.length === 0) return [];
  
  const actualCount = Math.min(count, 5);
  for (let i = 0; i < actualCount; i++) {
    const s = sourcePool[Math.floor(Math.random() * sourcePool.length)];
    stickers.push({
      name: s.name,
      img: getDisplayImage(s),
      price: PRICE_FIXES[s.name] || mockPrice(s),
      rarity: s.rarity?.name || "High Grade",
      scratchPercent: 0
    });
  }
  return stickers;
}

function generateBotItems(targetValue) {
  // Bots must ONLY interact with Weapons, Knives, and Gloves.
  const skinsPool = allSkins.filter(s => {
    const n = (s.name || "").toLowerCase();
    const matchesStrictType = n.includes("gun") || n.includes("knife") || n.includes("glove") || (n.includes("|") && !n.includes("sticker") && !n.includes("capsule"));
    if (!matchesStrictType) return false;
    const isRestricted = n.includes("sticker") || n.includes("capsule") || n.includes("graffiti") ||
                         n.includes("agent") || n.includes("operator") || n.includes("package") || 
                         n.includes("storage unit") || n.includes("music kit") || n.includes("charm");
    if (isRestricted) return false;
    return true;
  }).map(s => {
    const p = PRICE_FIXES[s.name] || mockPrice(s);
    return { ...s, price: p };
  });

  // Sort pool descending to use the least amount of items (pick most expensive first)
  skinsPool.sort((a, b) => b.price - a.price);

  let currentVal = 0;
  const items = [];

  // Greedy approach: try to pick most expensive items that fit within target
  for (const pick of skinsPool) {
    if (currentVal >= targetValue * 0.99) break;
    const remaining = targetValue - currentVal;
    
    if (pick.price <= remaining * 1.1) {
      const botItem = {
        name: pick.name,
        img: getDisplayImage(pick),
        price: pick.price,
        rarity: pick.rarity?.name || "Mil-Spec",
        stickers: [],
        nametag: null,
        wear: getBotTradeWear(pick.name, pick.rarity?.name)
      };
      botItem.floatVal = getBotTradeFloatForWear(pick.name, botItem.wear, botItem.rarity);

      const nLower = String(pick.name).toLowerCase();
      const isKnifeLike = nLower.includes("★") || nLower.includes("knife") || nLower.includes("gloves");

      // Add flair sometimes (Nametags are common in Jackpot)
      if (Math.random() < 0.25) {
        botItem.nametag = getUniqueBotNametag();
      }
      // Never put stickers on knives/gloves
      if (!isKnifeLike && Math.random() < 0.28) {
        botItem.stickers = generateRandomAppliedStickers(botItem, Math.random() < 0.35 ? 4 : (Math.random() < 0.6 ? 2 : 1));
      } else {
        botItem.stickers = [];
      }

      items.push(botItem);
      currentVal += getItemValue(botItem);
      
      // Safety cap
      if (items.length >= 10) break; 
    }
  }

  // If still significantly under budget, pick any cheap item to fill gap
  if (currentVal < targetValue * 0.9) {
    const cheap = skinsPool.filter(s => s.price < 5).sort((a,b) => b.price - a.price);
    for (const pick of cheap) {
      if (currentVal >= targetValue * 0.98 || items.length >= 15) break;
      const botItem = {
        name: pick.name,
        img: getDisplayImage(pick),
        price: pick.price,
        rarity: pick.rarity?.name || "Mil-Spec",
        stickers: [],
        nametag: null,
        wear: getBotTradeWear(pick.name, pick.rarity?.name)
      };
      botItem.floatVal = getBotTradeFloatForWear(pick.name, botItem.wear, botItem.rarity);
      if (Math.random() < 0.22) {
        botItem.nametag = getUniqueBotNametag();
      }
      if (Math.random() < 0.22) {
        botItem.stickers = generateRandomAppliedStickers(botItem, Math.random() < 0.5 ? 2 : 1);
      }
      items.push(botItem);
      currentVal += getItemValue(botItem);
    }
  }

  return items;
}

function clampBotTradeItemsToRange(items, minTarget, maxTarget) {
  let safeItems = Array.isArray(items) ? [...items] : [];
  if (safeItems.length === 0) return safeItems;

  let total = safeItems.reduce((s, x) => s + getItemValue(x), 0);

  safeItems.sort((a, b) => getItemValue(a) - getItemValue(b));
  while (safeItems.length > 1 && total > maxTarget) {
    const smallest = safeItems[0];
    const smallestVal = getItemValue(smallest);
    if ((total - smallestVal) < minTarget) break;
    safeItems.shift();
    total -= smallestVal;
  }

  let guard = 0;
  while (total < minTarget && guard < 12) {
    const deficit = minTarget - total;
    const extraItems = generateBotItems(Math.max(deficit, minTarget * 0.15));
    if (!Array.isArray(extraItems) || extraItems.length === 0) break;
    extraItems.forEach(it => {
      safeItems.push({
        ...it,
        id: it.id || ("bot_fill_" + Date.now() + "_" + Math.random().toString(36).slice(2))
      });
    });
    total = safeItems.reduce((s, x) => s + getItemValue(x), 0);
    safeItems.sort((a, b) => getItemValue(a) - getItemValue(b));
    while (safeItems.length > 1 && total > maxTarget) {
      const smallest = safeItems[0];
      const smallestVal = getItemValue(smallest);
      if ((total - smallestVal) < minTarget) break;
      safeItems.shift();
      total -= smallestVal;
    }
    guard++;
  }

  return safeItems;
}

function updatePotUI() {
  const totalValue = jackpotPotParticipants.reduce((s, p) => s + p.value, 0);
  jackpotPotValue = totalValue;
  document.getElementById("potTotalValue").textContent = formatPrice(totalValue);

  const list = document.getElementById("potParticipantsList");
  list.innerHTML = "";

  const allItemsList = document.getElementById("potItemsList");
  allItemsList.innerHTML = "";

  // Enforce a minimum participation percentage per participant (1.2%) and renormalize to 100%
  jackpotPotParticipants.forEach(p => {
    p._rawChance = (p.value / totalValue) * 100;
  });

  // Ensure minimum floor (1.2%) and re-scale remaining probabilities proportionally
  const MIN_CHANCE = 1.2;
  let flooredTotal = 0;
  jackpotPotParticipants.forEach(p => {
    if (p._rawChance < MIN_CHANCE) {
      p._assigned = MIN_CHANCE;
    } else {
      p._assigned = p._rawChance;
    }
    flooredTotal += p._assigned;
  });

  // If flooredTotal != 100, scale down items above MIN_CHANCE proportionally so total becomes 100
  if (flooredTotal !== 100 && flooredTotal > 0) {
    // compute total reserved for floored participants
    const reserved = jackpotPotParticipants.reduce((s, p) => s + (p._assigned === MIN_CHANCE ? MIN_CHANCE : 0), 0);
    const adjustablePool = jackpotPotParticipants.filter(p => p._assigned > MIN_CHANCE);
    const adjustableSum = adjustablePool.reduce((s, p) => s + p._rawChance, 0) || 1;
    const remainingForAdjustable = Math.max(0, 100 - reserved);

    adjustablePool.forEach(p => {
      // scale original raw chance proportionally into remaining space
      p._assigned = (p._rawChance / adjustableSum) * remainingForAdjustable;
      // ensure it doesn't go below MIN_CHANCE inadvertently
      if (p._assigned < MIN_CHANCE) p._assigned = MIN_CHANCE;
    });
  }

  // Finally commit chance values and cleanup temporary fields
  jackpotPotParticipants.forEach(p => {
    p.chance = Number((p._assigned || MIN_CHANCE).toFixed(4));
    delete p._rawChance;
    delete p._assigned;
  });

  jackpotPotParticipants.forEach(p => {
    const div = document.createElement("div");
