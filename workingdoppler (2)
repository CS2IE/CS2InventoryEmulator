  }
}

/**
 * Attempt to purchase one or more items using the active account wallet.
 * items: array of objects compatible with addItemToAccount.
 * Returns true if purchase succeeded, false otherwise.
 */
function attemptPurchase(items) {
  const account = getActiveAccount();
  if (!account) return false;
  const storageItems = (items || []).filter(it => String(it?.name || "").toLowerCase().includes("storage unit"));
  if (storageItems.length > 0) {
    const storageSignature = storageItems
      .map(it => `${String(it.name || "").toLowerCase()}|${it.qty || 1}|${it.nametag || ""}`)
      .sort()
      .join("::");
    const now = Date.now();
    if (storageSignature && storageSignature === lastStoragePurchaseSignature && (now - lastStoragePurchaseAt) < 400) {
      return false;
    }
    lastStoragePurchaseSignature = storageSignature;
    lastStoragePurchaseAt = now;
  }
  const purchaseTxnId = `txn_${Date.now()}_${Math.random().toString(16).slice(2)}`;

  // Calculate total cost but exclude storage units (storage units are free)
  const totalCost = items.reduce((sum, it) => {
    const isStorageUnit = String(it.name || "").toLowerCase().includes("storage unit");
    const qty = it.qty || 1;
    if (isStorageUnit) return sum;
    const unitCost = getPurchaseCost(it);
    return sum + (unitCost * qty);
  }, 0);

  const currentBalance = (state && state.walletlessMode) ? 0 : (account.walletBalance || 0);
  if (!(state && state.walletlessMode) && totalCost > 0 && currentBalance < totalCost) {
    alert(`Not enough wallet balance.\nNeeded: ${formatPrice(totalCost)}\nYou have: ${formatPrice(currentBalance)}`);
    return false;
  }

  // Deduct from wallet
  if (!(state && state.walletlessMode) && totalCost > 0) {
    account.walletBalance = currentBalance - totalCost;
    account.moneySpent = (account.moneySpent || 0) + totalCost;
    account.totalLost = (account.totalLost || 0) + totalCost;
    
    // Log transaction
    if (!account.transactions) account.transactions = [];
    items.forEach(it => {
      account.transactions.push({
        name: it.name,
        img: it.img || getStableDisplayImage(it),
        price: getPurchaseCost(it),
        qty: it.qty || 1,
        timestamp: Date.now()
      });
    });
  }

  // Clear previous pending results to ensure clean state
  pendingPurchaseResults = [];
  hasShownNewItemPopup = false;

  // Hand off to addItemToAccount
  items.forEach(it => {
    // If it's a key/case being bought from confirm flow, it might already have a qty.
    // addItemToAccount handles its own qty loop internally, so we pass it through.
    addItemToAccount({ ...it, _purchaseTxnId: purchaseTxnId });
  });

  saveState();
  updateWalletDisplay();
  refreshInventoryView();

  return true;
}

// Force periodic save state to ensure data persistence against browser closing/refreshing
