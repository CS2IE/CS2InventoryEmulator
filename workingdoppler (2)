function openDB() {
  return new Promise((resolve, reject) => {
    const request = indexedDB.open(DB_NAME, DB_VERSION);
    request.onupgradeneeded = (e) => {
      const db = e.target.result;
      if (!db.objectStoreNames.contains(STORE_NAME)) {
        db.createObjectStore(STORE_NAME);
      }
    };
    request.onsuccess = (e) => resolve(e.target.result);
    request.onerror = (e) => reject(e.target.error);
    request.onblocked = () => reject(new Error("IDB blocked"));
  });
}

function saveToIDB(key, value) {
  return new Promise(async (resolve) => {
    const timeoutId = setTimeout(() => {
      console.warn("IDB Save timed out");
      resolve(false);
    }, 3000);

    try {
      const db = await openDB();
      const tx = db.transaction(STORE_NAME, "readwrite");
      const store = tx.objectStore(STORE_NAME);
      store.put(value, key);
      tx.oncomplete = () => { clearTimeout(timeoutId); resolve(true); };
      tx.onerror = () => { clearTimeout(timeoutId); resolve(false); };
      tx.onabort = () => { clearTimeout(timeoutId); resolve(false); };
    } catch (e) {
      clearTimeout(timeoutId);
      console.error("IndexedDB Save Failed:", e);
      resolve(false);
    }
  });
}

function loadFromIDB(key) {
  return new Promise(async (resolve) => {
    const timeoutId = setTimeout(() => {
      console.warn("IDB Load timed out");
      resolve(null);
    }, 3000);

    try {
      const db = await openDB();
      const tx = db.transaction(STORE_NAME, "readonly");
      const store = tx.objectStore(STORE_NAME);
      const request = store.get(key);
      request.onsuccess = () => { clearTimeout(timeoutId); resolve(request.result); };
      request.onerror = () => { clearTimeout(timeoutId); resolve(null); };
    } catch (e) {
      clearTimeout(timeoutId);
      console.error("IndexedDB Load Failed:", e);
      resolve(null);
    }
  });
}

function deleteFromIDB(key) {
  return new Promise(async (resolve) => {
    try {
      const db = await openDB();
      const tx = db.transaction(STORE_NAME, "readwrite");
      const store = tx.objectStore(STORE_NAME);
      store.delete(key);
      tx.oncomplete = () => resolve(true);
      tx.onerror = () => resolve(false);
      tx.onabort = () => resolve(false);
    } catch (e) {
      console.error("IndexedDB Delete Failed:", e);
      resolve(false);
    }
  });
}

