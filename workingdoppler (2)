};

function getStickerSlabLinkedStickerName(itemOrName) {
  const rawName = String(typeof itemOrName === "string" ? itemOrName : (itemOrName?.name || itemOrName?.market_hash_name || "")).trim();
  if (!rawName) return "";

  const directTransforms = [
    rawName.replace(/^Sticker Slab\s*\|\s*/i, "Sticker | "),
    rawName.replace(/^Sticker Slab\s+/i, "Sticker "),
    rawName.replace(/^Sticker Slab/i, "Sticker")
  ].map(v => v.replace(/\s+/g, " ").trim()).filter(Boolean);

  const candidates = Array.from(new Set([...directTransforms, rawName]));
  for (const candidate of candidates) {
    const found = allSkins.find(entry => String(entry?.name || entry?.market_hash_name || "").trim().toLowerCase() === candidate.toLowerCase());
    if (found) return found.name || found.market_hash_name || candidate;
  }
  return directTransforms[0] || "";
}

function getStickerSlabReferencePrice(item) {
  if (!isStickerSlabItem(item)) return null;
  const stickerName = getStickerSlabLinkedStickerName(item);
  if (!stickerName) return null;
  const stickerItem = allSkins.find(entry => {
    const candidate = String(entry?.name || entry?.market_hash_name || "").trim().toLowerCase();
    return candidate === stickerName.toLowerCase();
  });
  const stickerPrice = PRICE_FIXES[stickerName] ??
    state.priceOverrides?.[stickerName] ??
    (typeof stickerItem?.price === "number" && !isNaN(stickerItem.price) ? stickerItem.price : null);
  if (!Number.isFinite(stickerPrice) || stickerPrice <= 0) return null;
  return Math.max(0.03, Math.round((stickerPrice * 0.92) * 100) / 100);
}

