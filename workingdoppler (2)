  `;
}

function initSearchSidebar() {
  const sidebar = document.getElementById("searchSidebar");
  if (!sidebar) return;
  sidebar.innerHTML = "";

  // Sort categories alphabetically, but keep "All" at the top
  const sortedCategories = [...SEARCH_CATEGORIES].sort((a, b) => {
    if (a.id === "") return -1;
    if (b.id === "") return 1;
    return a.label.localeCompare(b.label);
  });

  sortedCategories.forEach(cat => {
    const btn = document.createElement("button");
    btn.className = "search-tab-btn";
    if (state.searchCategory === cat.id) btn.classList.add("active");
    btn.innerHTML = `<span style="font-size:16px;">${cat.icon}</span> <span>${cat.label}</span>`;
    btn.onclick = () => {
      document.querySelectorAll(".search-tab-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      state.searchCategory = cat.id;
      // Triggers specific filtering logic
      searchByCategory(cat.id);
    };
    sidebar.appendChild(btn);
  });
}

async function searchByCategory(catId) {
  updateSearchStatus(`Filtering category: ${catId || 'All'}`);
  const statusEl = document.getElementById("searchStatus");
  if (statusEl) statusEl.style.color = "#94a3b8"; // Grey category status
  const cat = String(catId || "").toLowerCase();
  
  if (cat === "") {
    searchResults = allSkins.slice(0, 100);
    searchPage = 1;
    updateSearchDisplay();
    return;
  }

  if (cat === "custom") {
    searchResults = [];
    const seen = new Set();
    Object.keys(CASE_CONTENTS_DB).forEach(caseName => {
       const cPrice = PRICE_FIXES[caseName] ?? mockPrice({ name: caseName });
       searchResults.push({
         name: caseName,
         image: getDisplayImage({ name: caseName }),
         price: cPrice, price_text: formatPrice(cPrice),
         rarity: { name: "Base Grade" },
         type: "Custom Container"
       });
    });
    searchPage = 1;
    updateSearchDisplay();
    return;
  }

  searchResults = allSkins.filter(item => matchesSearchCategoryStrict(item, cat));
  // USER REQUEST: Sort the OCNTENTS OF EACH TAB ALPHEBETICALORDER
  searchResults.sort((a, b) => (a.name || "").localeCompare(b.name || ""));
  searchPage = 1;
  updateSearchDisplay();
  return;

  searchResults = allSkins.filter(item => {
      const name = (item.name || "").toLowerCase();
      const catName = (item.category?.name || "").toLowerCase();
      const weapon = (item.weapon?.name || "").toLowerCase();
      
      if (cat === "charm" || cat === "filled_cases") {
        return matchesSearchCategoryStrict(item, "charm");
      }
      
      // Strict category matching
      if (cat === "stickers") return (name.includes("sticker") || catName.includes("sticker")) && !name.includes("capsule");
      if (cat === "case") return (name.includes("case") || name.includes("capsule") || name.includes("package") || name.includes("collection")) && !name.includes("|") && !name.includes("sticker |");
      if (cat === "key") return name.includes("key") || catName.includes("key");
      if (cat === "knife") return name.includes("★") || name.includes("knife");
      if (cat === "gloves") return name.includes("gloves") || catName.includes("gloves");
      if (["rifle", "pistol", "smg", "shotgun", "sniper"].includes(cat)) {
          return (weapon.includes(cat) || catName.includes(cat)) && !name.includes("sticker");
      }
      return name.includes(cat) || catName.includes(cat);
  });

  searchPage = 1;
  updateSearchDisplay();
}

function refreshInventoryView() {
  const activeAccount = getActiveAccount();
  const viewingProfile = state.viewingProfileId ? state.accounts.find(a => a.id === state.viewingProfileId) : null;
  const targetAccount = viewingProfile || activeAccount;
  
  const grid = document.getElementById("inventoryGrid");
  const filterVal = document.getElementById("filterInput").value.toLowerCase();
  const breadcrumb = document.getElementById("storageBreadcrumb");
  const unitNameSpan = document.getElementById("viewingUnitName");
  
  // Sync tab active state
  document.querySelectorAll(".inv-tab").forEach(t => {
      t.classList.toggle("active", t.dataset.tab === state.inventoryTab);
  });
  
  if (!targetAccount) {
    grid.innerHTML = "";
    updateWalletDisplay();
    return;
  }

  let sourceItems = targetAccount.items;
  breadcrumb.classList.add("hidden");

  // Handle Reworked Storage Selection Mode
  const isStorageSelection = !!state.storageSelectionMode;

  // Always recalculate blur state on inventory refresh
  updateModalBlurState();

  // Ensure loadout button text is correct
  const loadoutBtn = document.getElementById("loadoutBtn");
  if (loadoutBtn) {
    const isLoadoutOpen = !document.getElementById("loadoutModal").classList.contains("hidden");
    loadoutBtn.textContent = isLoadoutOpen ? "INVENTORY" : "Loadout";
  }

  // User requested: items in storage unit should NOT be filtered by search
  const isViewingStorage = !!state.viewingStorageUnitId || (state.viewingProfileId && !!state.viewingProfileId);

  // Pre-resolve source items based on current view/mode context
  // This allows primary filtering into 'items' to happen early, avoiding ReferenceErrors in UI blocks below.
  if (isStorageSelection) {
    const targetUnit = targetAccount.items.find(i => i.id === state.storageSelectionTargetId);
    if (state.storageSelectionMode === 'withdraw' && targetUnit) {
      sourceItems = targetUnit.contents || [];
    }
  } else if (isViewingStorage && !viewingProfile) {
    const unit = targetAccount.items.find(i => i.id === state.viewingStorageUnitId);
    if (unit) sourceItems = unit.contents || [];
  }

  // 1. Filter (Search text + Rarity dropdown + Tab) - Moved up to avoid ReferenceError in selection logic
  const sort = state.currentSort || "recent";
  const activeRarityFilter = state.rarityFilter || "all";
  if (sort === "favorites") {
      document.querySelectorAll(".inv-tab").forEach(t => {
          if (t.dataset.tab === "favorites") t.classList.add("active");
          else t.classList.remove("active");
      });
  }
  const equippedIds = Array.isArray(targetAccount.equippedItemIds) ? targetAccount.equippedItemIds : [];
  
  // Save search status color based on category request (grey not green)
  const statusEl = document.getElementById("searchStatus");
  if (statusEl) statusEl.style.color = "#94a3b8";
  const activeTab = state.inventoryTab || "everything";
  
  let items = sourceItems.filter(it => {
    // If in deposit mode, never show equipped items or other storage units
    if (state.storageSelectionMode === 'deposit') {
      if (equippedIds.includes(it.id)) return false;
      if (it.name && it.name.toLowerCase().includes("storage unit")) return false;
    }

    // Tab filtering
    if (activeTab === "equipment") {
        const n = (it.name || "").toLowerCase();
        // Equipment ONLY shows Storage Units as requested
        if (!n.includes("storage unit")) return false;
    } else if (activeTab === "favorites") {
        if (!Array.isArray(state.favoriteItemIds) || !state.favoriteItemIds.includes(it.id)) return false;
    } else if (activeTab === "containers") {
        if (!isContainer(it) && !isKeyItem(it)) return false;
    } else if (activeTab === "display") {
        // Display strictly only shows equipped items
        if (!equippedIds.includes(it.id)) return false;
    }

    // searching in storage unit not allowed (always match search when viewing storage)
    const matchesSearch = (isViewingStorage || (isStorageSelection && state.storageSelectionMode === 'withdraw')) ? true : (it.name.toLowerCase().includes(filterVal) || 
                          (it && it.nametag && it.nametag.toLowerCase().includes(filterVal)));
    const matchesRarity = activeRarityFilter === "all" || it.rarity === activeRarityFilter;
    return matchesSearch && matchesRarity;
  });

  // Ensure we scroll to top when entering a storage unit or selection mode
  const currentInvViewId = state.viewingStorageUnitId || state.storageSelectionMode || state.viewingProfileId;
  if (currentInvViewId && !window._lastInvViewId) {
      window.scrollTo({ top: 0, behavior: 'smooth' });
      const gridWrap = document.querySelector(".inventory-grid-wrapper");
      if (gridWrap) gridWrap.scrollTop = 0;
  }
  window._lastInvViewId = currentInvViewId;

  if (viewingProfile) {
    breadcrumb.classList.remove("hidden");
    breadcrumb.style.width = "100%";
    breadcrumb.style.justifyContent = "center";
    let profileVal = 0;
    viewingProfile.items.forEach(it => profileVal += getInventoryItemValue(it));
    unitNameSpan.style.display = "block";
    unitNameSpan.style.width = "100%";
    unitNameSpan.innerHTML = `
      <div style="display:flex; flex-direction:row; align-items:center; justify-content:center; width:100%; max-width:700px; margin: 10px auto; text-align:left; background:rgba(0,0,0,0.4); padding:10px 20px; border-radius:8px; border:1px solid rgba(255,255,255,0.1); position: relative; left: 50%; transform: translateX(-50%); gap:15px; box-shadow:0 10px 30px rgba(0,0,0,0.5);">
        <img src="${escapeHtml(viewingProfile.pfp || 'https://i.imgur.com/zFydkgL.png')}" style="width:48px; height:48px; border-radius:50%; border:2px solid #66c0f4; object-fit:cover;">
        <div style="flex:1; text-align:center;">
          <div style="font-size:18px; font-weight:900; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${escapeHtml(viewingProfile.name)}'s Inventory</div>
          <div style="font-size:12px; color:#a4d007; font-weight:bold;">Value: ${formatPrice(profileVal)} • ${viewingProfile.items.length} items</div>
        </div>
        <button id="exitProfileBtn" class="steam-btn highlight" style="padding:6px 20px; font-size:12px; font-weight:900; height:36px;">CLOSE</button>
      </div>
    `;
    setTimeout(() => {
      const exitBtn = document.getElementById("exitProfileBtn");
      if (exitBtn) exitBtn.onclick = () => {
        state.viewingProfileId = null;
        saveState();
        refreshInventoryView();
      };
    }, 0);
  } else if (isStorageSelection) {
    breadcrumb.classList.remove("hidden");
    const gridWrapper = document.querySelector(".inventory-grid-wrapper");
    if (gridWrapper) gridWrapper.scrollTop = 0;
    const targetUnit = targetAccount.items.find(i => i.id === state.storageSelectionTargetId);
    
    unitNameSpan.innerHTML = `
      ${getStorageHeaderMarkup(targetUnit)}
      <div class="storage-header-layout" style="margin-top:0;">
        <button id="cancelStorageModeBtn" class="steam-btn highlight" style="padding: 6px 15px; font-size: 12px; font-weight: 800; margin-top:10px;">DONE ORGANIZING</button>
      </div>
    `;
    
    // Wire up cancel button
    setTimeout(() => {
        const btn = document.getElementById("cancelStorageModeBtn");
        if (btn) btn.onclick = () => {
            resetInventoryViewState();
            refreshInventoryView();
        };
    }, 0);

    // Fix: define count and selectedValue for storage selection bar to prevent UI crash
    const count = state.storageSelectedIds.length;
    let selectedValue = 0;
    const allSearchableSelection = state.storageSelectionMode === 'withdraw' 
        ? (targetAccount.items.find(u => u.id === state.storageSelectionTargetId)?.contents || [])
        : targetAccount.items;
    allSearchableSelection.forEach(it => {
        if (state.storageSelectedIds.includes(it.id)) {
            selectedValue += getItemValue(it);
        }
    });

    // Update selection bar visibility
    const selBar = document.getElementById("selectionActionBar");
    const moveAllSelectBtn = document.getElementById("moveAllSelectionBtn");
    
    if (isStorageSelection) {
      selBar.classList.remove("hidden");
      document.getElementById("selectionCount").textContent = `${count} item${count > 1 ? 's' : ''} selected`;
      document.getElementById("selectionValue").textContent = formatPrice(selectedValue);
      
      // Show Select All if rarity filter is active OR if user has typed a search query
      const isSearching = filterVal.trim().length > 0;
      if ((activeRarityFilter !== "all" || isSearching) && items.length > 0) {
        moveAllSelectBtn.classList.remove("hidden");
        moveAllSelectBtn.onclick = () => {
          items.forEach(it => {
            if (!state.storageSelectedIds.includes(it.id)) {
              state.storageSelectedIds.push(it.id);
            }
          });
          refreshInventoryView();
        };
      } else {
        moveAllSelectBtn.classList.add("hidden");
      }
    } else {
      selBar.classList.add("hidden");
    }

  } else if (isViewingStorage) {
    const unit = targetAccount.items.find(i => i.id === state.viewingStorageUnitId);
    if (unit) {
      const storageUsdTotal = (unit.contents || []).reduce((sum, child) => sum + getItemValue(child), 0);
      breadcrumb.classList.remove("hidden");
      unitNameSpan.innerHTML = `
        <div class="storage-header-layout">
          <div class="storage-header-main">
            <img src="${getDisplayImage(unit)}" class="storage-header-icon">
            <div class="storage-header-details">
              <div style="font-size: 20px; font-weight: 900; color: #fff;">${unit.nametag || unit.name}</div>
              <div style="font-size: 13px; color: #a4d007; font-weight: 800;">USD Total ${formatPrice(storageUsdTotal)}</div>
              <div style="font-size: 13px; color: #94a3b8;">Storage Unit Contents • ${sourceItems.length} items</div>
            </div>
          </div>
          <button id="backToInvBtn" class="steam-btn highlight" style="padding: 6px 15px; font-size: 12px; font-weight: 800;">BACK TO INVENTORY</button>
        </div>
      `;
      unitNameSpan.innerHTML = `
        ${getStorageHeaderMarkup(unit)}
        <div class="storage-header-layout" style="margin-top:0;">
          <button id="backToInvBtn" class="steam-btn highlight" style="padding: 6px 15px; font-size: 12px; font-weight: 800;">BACK TO INVENTORY</button>
        </div>
      `;
      setTimeout(() => {
        const bBtn = document.getElementById("backToInvBtn");
        if (bBtn) bBtn.onclick = () => {
          resetInventoryViewState();
          refreshInventoryView();
        };
      }, 0);
    } else {
      state.viewingStorageUnitId = null;
    }
  } else {
    // Hide selection bar if not in selection mode
    document.getElementById("selectionActionBar").classList.add("hidden");
  }

  // Hide Stats for Nerds if context menu is visible
  const ctxMenu = document.getElementById("contextMenu");
  if (ctxMenu && !ctxMenu.classList.contains("hidden")) {
    hideNerdTooltip();
  }

  // Auto-scroll to top when viewing storage unit contents
  if (isViewingStorage && !window._hasScrolledToStorageTop) {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    const gridWrap = document.querySelector(".inventory-grid-wrapper");
    if (gridWrap) gridWrap.scrollTop = 0;
    window._hasScrolledToStorageTop = true;
  } else if (!isViewingStorage) {
    window._hasScrolledToStorageTop = false;
  }

  // Clear search bar on view contents
  if (isViewingStorage) {
    const filterInput = document.getElementById("filterInput");
    if (filterInput && filterInput.value !== "") {
      filterInput.value = "";
    }
  }

  // 2. Sort (explicit ordering: equipped items -> recently-updated storage units (3hrs) -> other sort)
  const isKnifeLike = (n) => {
    const nl = String(n || "").toLowerCase();
    return nl.includes("★") || nl.includes("knife") || nl.includes("gloves");
  };

  // Only pin equipped items when the inventory is explicitly sorted by Equipped or Favorites.
  const shouldPinEquipped = (sort === "equipped" || sort === "favorites");

  const equippedItems = [];
  const nonEquipped = [];

  if (shouldPinEquipped) {
    items.forEach(it => {
      if (equippedIds.includes(it.id)) equippedItems.push(it);
      else nonEquipped.push(it);
    });
  } else {
    // Treat all items equally for sorting
    nonEquipped.push(...items);
  }

  // Keep equipped items pinned for non-equipped sorts, but still sort them by the chosen dropdown.
  applyInventorySort(nonEquipped, sort);
  if (shouldPinEquipped) applyInventorySort(equippedItems, sort);

  // Then elevate recently-updated storage units within non-equipped items (they should appear immediately after equipped items),
  // but always place storage units themselves at the very end of the list.
  const now = Date.now();
  const threeHours = 3 * 60 * 60 * 1000;
  const updatedUnits = [];
  const otherNonUpdated = [];
  const storageUnits = [];

  nonEquipped.forEach(it => {
    const isStorageUnit = String(it.name).toLowerCase().includes("storage unit");
    if (isStorageUnit) {
      // Collect storage units to append at the very end
      storageUnits.push(it);
      return;
    }
    const isRecentlyUpdated = it.lastUpdated && (now - it.lastUpdated < threeHours);
    if (isRecentlyUpdated) updatedUnits.push(it);
    else otherNonUpdated.push(it);
  });

  // Final items order: equippedItems -> updatedUnits -> otherNonUpdated -> storageUnits (storage are always last)
  if (shouldPinEquipped) {
    items = [...equippedItems, ...updatedUnits, ...otherNonUpdated, ...storageUnits];
  } else {
    // If not pinning, merge each group only once and keep storage units at bottom
    items = [...updatedUnits, ...otherNonUpdated, ...storageUnits];
    // Re-apply sort to full list if not pinning equipped
    if (sort === "priceDesc") items.sort((a,b) => getItemValue(b) - getItemValue(a));
    else if (sort === "priceAsc") items.sort((a,b) => getItemValue(a) - getItemValue(b));
    else if (sort === "name") items.sort((a,b) => a.name.localeCompare(b.name));
    // and keep storage units strictly at bottom
    const justStorage = items.filter(it => String(it.name).toLowerCase().includes("storage unit"));
    const notStorage = items.filter(it => !String(it.name).toLowerCase().includes("storage unit"));
    items = [...notStorage, ...justStorage];
  }

  // NEW badges expire per-item after 2 minutes (no global cap)
  const NEW_BADGE_WINDOW = 2 * 60 * 1000; // 2 minutes
  const newBadgeIds = items
    .filter(it => it && it.acquiredAt && (now - it.acquiredAt < NEW_BADGE_WINDOW))
    .map(it => it.id);

  // Apply storage selection highlights
  if (state.storageSelectionMode) {
    items.forEach(it => {
        if (state.storageSelectedIds.includes(it.id)) {
            // will be handled in loop below
        }
    });
  }

  // 3. Stats (Context-aware: Profile vs Storage Unit vs Account)
  // Ensure nametag rule: Red color
  document.querySelectorAll('.inv-item-name').forEach(el => {
    if (el.textContent && el.textContent.includes('"')) {
       el.style.setProperty('color', '#eb4b4b', 'important');
    }
  });

  const headerGameTitle = document.getElementById("headerGameTitle");
  if (headerGameTitle) {
      headerGameTitle.textContent = state.tabTitle || "Counter-Strike 2";
  }

  if (state.viewingStorageUnitId) {
    const unit = targetAccount.items.find(i => i.id === state.viewingStorageUnitId);
    if (unit) {
      const unitValue = (unit.contents || []).reduce((sum, child) => sum + getItemValue(child), 0);
      breadcrumb.innerHTML = `
        <button id="backFromStorageBtn" class="steam-btn highlight" style="padding: 4px 10px; font-size: 12px;">← Back to Main</button>
        <div style="display:flex; align-items:center; gap:6px;">
          <img src="${getDisplayImage({name: unit.name})}" style="width:24px;height:24px;object-fit:contain;">
          <span style="color:#a4d007; font-weight:900; font-size:14px;">${formatPrice(unitValue)}</span>
        </div>
        <span id="viewingUnitName" style="color: #66c0f4; font-weight: bold;"></span>
      `;
      document.getElementById("backFromStorageBtn").onclick = () => {
        state.viewingStorageUnitId = null;
        state.viewingProfileId = null;
        state.currentPage = 1;
        saveState();
        refreshInventoryView();
      };
    }
  }

  let displayedValue = 0;
  let displayedCount = 0;
  items.forEach(it => {
    displayedValue += getInventoryItemValue(it) * (it.qty || 1);
    displayedCount += (it.qty || 1);
  });
  
  // Update the main toolbar stats to reflect what's actually being viewed
  document.getElementById("totalInventoryValue").textContent = formatPrice(displayedValue);
  document.getElementById("totalItemsCount").textContent = displayedCount + " items";
  
  // Fix gap between bottom of name and top of item under it
  const gridEl = document.getElementById("inventoryGrid");
  if (gridEl) {
      gridEl.style.gap = "120px 12px";
      gridEl.style.paddingTop = "40px"; // More top padding
  }
  const toolbarItemsCount = document.getElementById("totalItemsToolbarCount");
  if (toolbarItemsCount) toolbarItemsCount.textContent = `${displayedCount} Items`;
  const headerInventoryValue = document.getElementById("headerInventoryValue");
  if (headerInventoryValue) {
      if (state.disableInventoryTotal) {
          headerInventoryValue.style.display = "none";
      } else {
          headerInventoryValue.style.display = "block";
          headerInventoryValue.textContent = `Inventory: ${formatPrice(displayedValue)}`;
      }
  }
  updateWalletDisplay();

  // Bulk Sell Bar Logic
  const bulkBar = document.getElementById("bulkSellBar");
  if (state.bulkSellMode) {
    bulkBar.classList.remove("hidden");
    let sellSum = 0;
    // Calculate sum based on IDs
    sourceItems.forEach(it => {
      if (state.bulkSelectedIds.includes(it.id)) sellSum += getItemValue(it);
    });
    document.getElementById("bulkSellTotal").textContent = formatPrice(sellSum);
    document.getElementById("bulkSellCount").textContent = `(${state.bulkSelectedIds.length} items)`;
  } else {
    bulkBar.classList.add("hidden");
  }

  // Breadcrumb detailed update
  if (state.viewingStorageUnitId) {
    const unit = targetAccount.items.find(i => i.id === state.viewingStorageUnitId);
    if (unit) {
      const insideCount = unit.contents ? unit.contents.length : 0;
      const storageUsdTotal = (unit.contents || []).reduce((sum, child) => sum + getItemValue(child), 0);
      unitNameSpan.textContent = `Viewing Unit: ${unit.nametag || unit.name} (${insideCount} items, ${formatPrice(storageUsdTotal)})`;
    }
  }

  // 4. Pagination
  if (state.viewingStorageUnitId || state.storageSelectionMode) {
    const gridWrapper = document.querySelector(".inventory-grid-wrapper");
    if (gridWrapper) gridWrapper.scrollTop = 0;
    const limiter = document.querySelector(".grid-scroll-limiter");
    if (limiter) limiter.scrollTop = 0;
    window.scrollTo(0, 0);
  }

  const ACTUAL_PAGE_SIZE = state.disablePagination ? items.length : 30; // 3 rows of 10 or similar
  applyPaginationSetting(!!state.disablePagination);
  const totalPages = Math.max(1, Math.ceil(items.length / ACTUAL_PAGE_SIZE));
  if (state.currentPage > totalPages) state.currentPage = totalPages;
  if (state.currentPage < 1) state.currentPage = 1;
  document.getElementById("pageIndicator").textContent = `${state.currentPage} / ${totalPages}`;
  
  const start = (state.currentPage - 1) * ACTUAL_PAGE_SIZE;
  let pageItems = state.disablePagination ? items : items.slice(start, start + ACTUAL_PAGE_SIZE);

  // If filters/pagination accidentally produce an empty page despite items existing,
  // fallback to showing the first page slice so the user always sees inventory items.
  if ((!pageItems || pageItems.length === 0) && items && items.length > 0) {
    state.currentPage = 1;
    saveState();
    pageItems = state.disablePagination ? items : items.slice(0, PAGE_SIZE);
  }

  grid.innerHTML = "";

  if (pageItems.length === 0 && filterVal.trim().length > 0) {
    const noResults = document.createElement("div");
    noResults.style.gridColumn = "1 / -1";
    noResults.style.padding = "60px 20px";
    noResults.style.textAlign = "center";
    noResults.style.color = "#94a3b8";
    noResults.style.fontSize = "18px";
    noResults.style.fontWeight = "800";
    noResults.textContent = `No results for "${filterVal}"`;
    grid.appendChild(noResults);
  }

  pageItems.forEach(item => {
    const rarityColor = RARITY_COLORS[item.rarity] || RARITY_COLORS["Consumer"];
    const isStorageUnit = item.name.toLowerCase().includes("storage unit");
    // Logic Fix: For storage unit items, only count items INSIDE that unit
    const matchingQtyInSource = (sourceItems || []).reduce((sum, si) => {
      if (!si) return sum;
      if (si.name === item.name && (si.nametag || "") === (item.nametag || "")) {
        return sum + (si.qty || 1);
      }
      return sum;
    }, 0);
    const totalMatching = state.viewingStorageUnitId
      ? matchingQtyInSource
      : countExactMatchingItems(targetAccount, item);
    
    const now = Date.now();
    const isRecentlyUpdated = isStorageUnit && item.lastUpdated && (now - item.lastUpdated < 3 * 60 * 60 * 1000);
    // Only consider item a "NEW" badge if it's in the precomputed newBadgeIds (caps at 20)
    const isNew = Array.isArray(newBadgeIds) ? newBadgeIds.includes(item.id) : (item.acquiredAt && (now - item.acquiredAt < 20 * 60 * 1000));

    const rank = parseInt(item.floatRank) || 0;
    let floatRankBadge = "";
    if (rank >= 1 && rank <= 3) {
      floatRankBadge = `<div class="inv-float-rank-badge low">LOW #${rank}</div>`;
    } else if (rank >= 4 && rank <= 6) {
      floatRankBadge = `<div class="inv-float-rank-badge high">HIGH #${rank - 3}</div>`;
    }

    const loadoutSides = getLoadoutSidesForItem(item.id);
    const isEquipped = equippedIds.includes(item.id) || loadoutSides.length > 0;

    const isBulkSelected = state.bulkSellMode && state.bulkSelectedIds.includes(item.id);
    const isStorageSelected = !!state.storageSelectionMode && state.storageSelectedIds.includes(item.id);

    // Create wrapper to contain the item box and the name label below it
    const wrapper = document.createElement("div");
    wrapper.className = "inv-item-container";

    const div = document.createElement("div");
    let selectionClass = "";
    if (isStorageSelected) {
        selectionClass = state.storageSelectionMode === 'deposit' ? " storage-selected-deposit" : " storage-selected-withdraw";
    }

    div.className = "inv-item" + 
      (item.id === state.selectedItemId ? " active" : "") + 
      (isEquipped ? " is-equipped" : "") +
      (rank > 0 ? " has-float-rank" : "") +
      (isNew ? " has-new-badge" : "") +
      (isBulkSelected ? " bulk-selecting" : "") +
      selectionClass;
    // Mark storage units so we can style their quantity badge differently
    if (isStorageUnit) div.setAttribute('data-is-storage', 'true');
    const floatRankDecor = getFloatRankBorderDecoration(rank);
    if (floatRankDecor) {
      div.style.borderColor = floatRankDecor.borderColor;
      div.style.boxShadow = floatRankDecor.boxShadow;
    }
    // Fake tag generation for UI (e.g. FN/MW)
    const wearShort = item.wear ? item.wear.split(' ').map(w=>w[0]).join('') : '';
    const nametagEmoji = item.nametag ? "🏷️" : "";

    // Calculate background based on price (Grey to Red)
    const price = getItemValue(item);
    // Use rarity colour as the base background; fall back to grey.
    // Apply slight darkening for non-gold rarities to keep text readable.
    let bg = rarityColor || '#4b4b4b';

    if (isEquipped) {
      div.style.zIndex = "5";
    } else if (isStorageUnit) {
      // Storage units remain neutral
      bg = '#3c3c3c';
    } else if (state.cs2InvColor) {
      // CS2 Inv Color mode: Use grey background for everything
      bg = '#3c3c3c';
    } else {
      // Gold stays bright; other rarity colours are slightly shaded/darkened
      if (rarityColor === RARITY_COLORS["Gold"]) {
        bg = RARITY_COLORS["Gold"];
      } else {
        bg = shadeColor(rarityColor || '#4b4b4b', -18);
      }
    }
    
    div.style.background = bg;

    const unitPrice = getItemValue(item);
    const totalPrice = unitPrice * totalMatching;
    // Additionally compute how many copies of this same item exist inside any storage unit (separate quantity)
    // Only relevant for top-level items (not when rendering a storage unit itself)
    let storageCountAcrossUnits = 0;
    if (!isStorageUnit && targetAccount) {
      storageCountAcrossUnits = countItemsInStorageUnits(targetAccount, item.name, item.nametag);
    }

    // Hide main quantity if it is 1 or less (per user request). Storage unit amounts should only appear in sidebar/view popup.
    // Logic: Storage unit cards always show their item count; weapons show only if qty > 1
    const qtyToDisplay = isStorageUnit ? (item.contents?.length || 0) : totalMatching;
    const mainQtyHtml = (qtyToDisplay > 1 || isStorageUnit) ? `<div class="inv-qty-badge" style="margin-bottom: 2px; color: ${isStorageUnit ? '#66c0f4' : '#ffca00'};">${isStorageUnit ? '' : 'x'}${qtyToDisplay}</div>` : '';
    const storageQtyHtml = '';
    const badgeHtml = `<div style="display:flex; flex-direction:column; align-items:flex-end;">${mainQtyHtml}${storageQtyHtml}</div>`;

    const stickersOnGridEnabled = state.showStickersOnGrid !== false;
    const gridStickers = (Array.isArray(item.stickers) && stickersOnGridEnabled) ? [...item.stickers] : [];
    if (item.charm) {
        gridStickers.unshift({ ...item.charm, isCharm: true });
    }
    
    let stattrakHtml = "";
    if (String(item.name || "").toLowerCase().includes("stattrak") && state.showStatTrakOverlay !== false) {
      stattrakHtml = `<img src="https://i.imgur.com/TRtzFCo.png" class="inv-sticker-mini inv-sticker-stattrak" title="StatTrak™">`;
    }

    const finalStickersHtml = gridStickers.slice(0, 5).map(s => {
      const grey = (s.scratchPercent || 0) / 100;
      return `<img src="${s.img}" class="inv-sticker-mini" alt="" title="${s.name}" style="filter: grayscale(${grey}) brightness(${1 - grey * 0.4});">`;
    }).join('') + stattrakHtml;

    const addedValueInfo = getInventoryAddedValueBreakdown(item);
    let priceDisplayHtml = "";
    if (!isStorageUnit && !state.hidePrices) {
        priceDisplayHtml = `<div class="inv-price-overlay">
          <div>${formatPrice(unitPrice)}</div>
          ${addedValueInfo ? `<div class="inv-added-price-overlay" title="${escapeHtml(addedValueInfo.parts.join(" • "))}">${formatPrice(addedValueInfo.totalAdded)}</div>` : ""}
        </div>`;
    }

    const showBar = state.cs2InvColor && !isStorageUnit;

    let floatBarHtml = "";
    
    // Logic: Move info to left if prices are hidden
    const infoAlignment = state.hidePrices ? 'justify-content: flex-start; text-align: left;' : 'justify-content: space-between; text-align: right;';
    const innerAlignment = state.hidePrices ? 'align-items: flex-end;' : 'align-items: flex-end;';
    const bottomRowStyle = state.hidePrices ? 'display:flex; flex-direction: column; align-items: flex-start; gap: 2px;' : '';

    div.innerHTML = `
      <img src="${getStableDisplayImage(item)}" alt="Item" style="margin-bottom: 5px;">
      ${getInventoryEquipIndicatorHtml(item.id, targetAccount)}
      ${isRecentlyUpdated ? '<div class="inv-updated-badge">UPDATED</div>' : ''}
      ${isNew ? '<div class="inv-new-badge">NEW</div>' : ''}
      ${showBar ? `<div class="inv-rarity-bar" style="background: ${rarityColor}"></div>` : ''}
      <div class="inv-info-overlay">
         <div class="inv-top-row">
            <div class="inv-sticker-list">${finalStickersHtml}</div>
         </div>
         <div class="inv-bottom-row" style="${bottomRowStyle}">
            ${state.hidePrices ? `
              ${badgeHtml}
              ${floatRankBadge}
              <div class="inv-wear">${wearShort}</div>
            ` : `
              <div style="display:flex; width: 100%; justify-content: space-between; align-items: flex-end;">
                 ${priceDisplayHtml}
                 <div style="min-width: 60px; display:flex; flex-direction:column; align-items:flex-end;">
                    ${badgeHtml}
                    ${floatRankBadge}
                    <div class="inv-wear" style="margin-top: 2px;">${wearShort}</div>
                 </div>
              </div>
            `}
         </div>
      </div>
    `;

    // Create and attach the bold white name label UNDER the box
    const nameLabel = document.createElement("div");
    nameLabel.className = "inv-item-name";
    
    let nameColorStyle = "";
    if (state.colorItemNames) {
      if (item.name.includes("Souvenir ")) nameColorStyle = "color: #ffd700 !important;";
      else if (item.name.includes("StatTrak™")) nameColorStyle = "color: #cf6a32 !important;";
      else if (item.name.includes("'Blue Gem'")) nameColorStyle = "color: #66c0f4 !important;";
    }

    const fullName = item.name || "";
    let typePart = "";
    let skinPart = "";
    if (fullName.includes(" | ")) {
        [typePart, skinPart] = fullName.split(" | ");
    } else {
        typePart = item.type || "Item";
        skinPart = fullName;
    }

    // Enhanced name parsing for Doppler phases and Vanilla labeling
    let finalSkinName = getDisplayItemName(skinPart);
    const isKnife = item.name.includes("★") || item.name.toLowerCase().includes("knife");
    
    const phase = getExplicitDopplerPhaseLabel(item) || deriveDopplerPhaseLabel(item);
    if (isKnife) {
       if (phase) {
          finalSkinName += ` (${phase})`;
       } else if (!item.name.includes("|")) {
          finalSkinName += " (Vanilla)";
       }
    }

    const nameToDisplay = isStorageUnit ? "Storage Unit" : typePart;
    nameLabel.innerHTML = `
        <div style="${nameColorStyle || 'color: #fff;'} font-weight: 800; font-size: 16px; margin-bottom: 2px;">${escapeHtml(nameToDisplay)}</div>
        <div style="font-size: 14px; color: #94a3b8;">${escapeHtml(finalSkinName).replace('|', '')}</div>
        ${item.nametag ? `<div style="font-size: 12px; color: #eb4b4b !important; font-weight: 800; margin-top: 2px;">"${escapeHtml(item.nametag)}"</div>` : ''}
    `;

    wrapper.appendChild(div);
    wrapper.appendChild(nameLabel);
    
    // Attach click events to the item box (div) as before
    div.addEventListener("click", (e) => {
      // Prioritize selection mode for storage
      if (state.storageSelectionMode) {
        e.preventDefault();
        e.stopPropagation();
        
        if (state.storageNoConfirm) {
           // Instant Move Logic
           const acc = getActiveAccount();
           const targetUnitId = state.storageSelectionTargetId;
           const targetUnit = acc.items.find(u => u.id === targetUnitId);
           if (!targetUnit) return;
           
           if (state.storageSelectionMode === 'deposit') {
              const idx = acc.items.findIndex(ai => ai.id === item.id);
              if (idx !== -1) {
                const [moved] = acc.items.splice(idx, 1);
                if (!targetUnit.contents) targetUnit.contents = [];
                targetUnit.contents.push(moved);
                targetUnit.lastUpdated = Date.now();
              }
           } else {
              if (targetUnit.contents) {
                const cIdx = targetUnit.contents.findIndex(ci => ci.id === item.id);
                if (cIdx !== -1) {
                  const [moved] = targetUnit.contents.splice(cIdx, 1);
                  acc.items.push(moved);
                  targetUnit.lastUpdated = Date.now();
                }
              }
           }
           saveState();
           refreshInventoryView();
           return;
        }

        const isSelected = state.storageSelectedIds.includes(item.id);
        if (isSelected) {
          state.storageSelectedIds = state.storageSelectedIds.filter(id => id !== item.id);
        } else {
          state.storageSelectedIds.push(item.id);
        }
        refreshInventoryView();
        return;
      }

      if (state.bulkSellMode) {
        if (state.bulkSelectedIds.includes(item.id)) {
          state.bulkSelectedIds = state.bulkSelectedIds.filter(id => id !== item.id);
        } else {
          state.bulkSelectedIds.push(item.id);
        }
        refreshInventoryView();
        return;
      }

      // Show selection page for cases and keys on click
      if (isContainer(item) || isKeyItem(item)) {
          handleContextMenu(e, item);
          return;
      }

      if (state.twoClickSidebar) {
        // Single click logic: show context menu at cursor
        handleContextMenu(e, item);
        return;
      }

      if (state.selectedItemId === item.id) return;
      state.selectedItemId = item.id;
      saveState();
      refreshInventoryView();
      showDetails(item);
    });

    div.addEventListener("dblclick", (e) => {
      if (!state.twoClickSidebar || state.bulkSellMode) return;
      
      state.selectedItemId = item.id;
      saveState();
      refreshInventoryView();
      // On double-click, show details; force modal popup if sidebar is hidden
      const useModal = state.hideSidebar;
      showDetails(item, useModal);
      
      // Close the context menu if it was opened by the first click
      document.getElementById("contextMenu").classList.add("hidden");
    });

    div.addEventListener("contextmenu", (e) => {
    hideNerdTooltip();
    handleContextMenu(e, item);
  });

    // Stats for Nerds Hover Logic
    const itemImgEl = div.querySelector('img');
    if (itemImgEl) {
      itemImgEl.addEventListener("mouseenter", (e) => {
        if (!state.statsForNerds) return;
        showNerdTooltip(e, item);
      });
      itemImgEl.addEventListener("mouseleave", () => {
        hideNerdTooltip();
      });
    }

    grid.appendChild(wrapper);
  });

  // Only auto-update the sidebar IF it's already visible (Desktop sidebar mode)
  // Stop auto-showing the modal popup.
  if (state.selectedItemId && !state.hideSidebar && window.innerWidth > 800 && !state.viewingProfileId) {
    const selected = targetAccount.items.find(it => it.id === state.selectedItemId);
    if (selected) showDetails(selected, false); // false = don't force modal
    else clearDetails();
  } else if (!state.selectedItemId && !state.hideSidebar) {
    clearDetails();
  }
}

/* ---------- 3D Viewer helper ----------
   Lightweight drag + inertia initializer for any container element that contains an <img> (or selector)
   Usage: init3DViewer(containerSelector, imageSelector)
*/
function init3DViewer(containerSelector, imageSelector) {
  try {
    const container = document.querySelector(containerSelector);
    if (!container) return;
    const image = container.querySelector(imageSelector) || container.querySelector('img');
    if (!image) return;

    // rotation / velocity state kept per-container using WeakMap-like attach
    if (!container._viewer) {
      container._viewer = {
        rotX: 0, rotY: 0,
        velX: 0, velY: 0,
        dragging: false,
        lastX: 0, lastY: 0,
        raf: null
      };
    }
    const s = container._viewer;

    function applyTransform() {
      const inner = container.querySelector('.unlocked-inner-3d') || container;
      inner.style.transform = `perspective(1200px) rotateX(${s.rotX}deg) rotateY(${s.rotY}deg)`;
      
      const gloss = container.querySelector('.gloss-overlay');
      if (gloss) {
        const shift = (s.rotY % 360);
        gloss.style.background = `linear-gradient(${135 + shift}deg, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0) 60%)`;
        gloss.style.setProperty('--mask-url', `url(${image.src})`);
      }
    }

    function inertiaLoop() {
      if (s.dragging) return;
      s.rotY += s.velX;
      s.rotX += s.velY;
      s.velX *= 0.92;
      s.velY *= 0.92;
      applyTransform();
      if (Math.abs(s.velX) > 0.01 || Math.abs(s.velY) > 0.01) {
        s.raf = requestAnimationFrame(inertiaLoop);
      } else {
        s.raf = null;
        container.classList.remove("is-dragging");
      }
    }

    function start(e) {
      if (e.button !== undefined && e.button !== 0) return;
      s.dragging = true;
      if (s.raf) cancelAnimationFrame(s.raf);
      const cx = e.touches ? e.touches[0].clientX : e.clientX;
      const cy = e.touches ? e.touches[0].clientY : e.clientY;
      s.lastX = cx; s.lastY = cy;
      s.velX = 0; s.velY = 0;
    }

    function move(e) {
      if (!s.dragging) return;
      const cx = e.touches ? e.touches[0].clientX : e.clientX;
      const cy = e.touches ? e.touches[0].clientY : e.clientY;
      const dx = cx - s.lastX;
      const dy = cy - s.lastY;
      s.velX = dx * 0.35;
      s.velY = -dy * 0.35;
      s.rotY += s.velX;
      s.rotX += s.velY;
      container.classList.add("is-dragging");
      applyTransform();
      s.lastX = cx; s.lastY = cy;
    }

    function end() {
      if (!s.dragging) return;
      s.dragging = false;
      if (s.raf) cancelAnimationFrame(s.raf);
      s.raf = requestAnimationFrame(inertiaLoop);
    }

    // Attach handlers (ensure not duplicated)
    container.style.cursor = "grab";
    container.onmousedown = start;
    container.ontouchstart = start;

    // Attach global move/up listeners in a managed way so we don't overwrite other modules' handlers
    if (container._viewerListeners) {
      window.removeEventListener('mousemove', container._viewerListeners.move, { passive: false });
      window.removeEventListener('mouseup', container._viewerListeners.end);
      window.removeEventListener('touchmove', container._viewerListeners.move, { passive: false });
      window.removeEventListener('touchend', container._viewerListeners.end);
    }
    const boundMove = move.bind(container);
    const boundEnd = end.bind(container);
    window.addEventListener('mousemove', boundMove, { passive: false });
    window.addEventListener('mouseup', boundEnd);
    window.addEventListener('touchmove', boundMove, { passive: false });
    window.addEventListener('touchend', boundEnd);
    container._viewerListeners = { move: boundMove, end: boundEnd };
  } catch (e) {
    console.warn("init3DViewer failed:", e);
  }
}

/* Lightweight inspect-style 3D drag + inertia viewer used by the Inspect modal.
   This mirrors the interactive behavior used in showInspect: click/drag to rotate,
   inertia continues rotation after release, and a simple cleanup pattern is used
   so multiple viewers don't leave behind global listeners. 
   Usage: initInspectLikeViewer(containerSelector, imageSelector)
*/
function initInspectLikeViewer(containerSelector, imageSelector) {
  try {
    const container = document.querySelector(containerSelector);
    if (!container) return;
    const image = container.querySelector(imageSelector) || container.querySelector('img');
    if (!image) return;

    // Per-container state
    if (!container._inspectViewer) {
      container._inspectViewer = {
        rotX: 0, rotY: 0,
        velX: 0, velY: 0,
        dragging: false,
        lastX: 0, lastY: 0,
        raf: null,
        moved: false
      };
    }
    const s = container._inspectViewer;

    const inner = container.querySelector('.unlocked-inner-3d') || container;
    const applyTransform = () => {
      inner.style.transform = `perspective(1200px) rotateX(${s.rotX}deg) rotateY(${s.rotY}deg)`;
    };

    function inertiaLoop() {
      if (s.dragging) return;
      s.rotY += s.velX;
      s.rotX += s.velY;
      s.velX *= 0.92;
      s.velY *= 0.92;
      applyTransform();
      if (Math.abs(s.velX) > 0.01 || Math.abs(s.velY) > 0.01) {
        s.raf = requestAnimationFrame(inertiaLoop);
      } else {
        s.raf = null;
      }
    }

    function start(e) {
      if (e.button !== undefined && e.button !== 0) return;
      s.dragging = true;
      s.moved = false;
      if (s.raf) cancelAnimationFrame(s.raf);
      const cx = e.touches ? e.touches[0].clientX : e.clientX;
      const cy = e.touches ? e.touches[0].clientY : e.clientY;
      s.lastX = cx; s.lastY = cy;
      s.velX = 0; s.velY = 0;
    }

    function move(e) {
      if (!s.dragging) return;
      s.moved = true;
      const cx = e.touches ? e.touches[0].clientX : e.clientX;
      const cy = e.touches ? e.touches[0].clientY : e.clientY;
      const dx = cx - s.lastX;
      const dy = cy - s.lastY;
      s.velX = dx * 0.35;
      s.velY = -dy * 0.35;
      s.rotY += s.velX;
      s.rotX += s.velY;
      applyTransform();
      s.lastX = cx; s.lastY = cy;
    }

    function end() {
      if (!s.dragging) return;
      s.dragging = false;
      if (s.raf) cancelAnimationFrame(s.raf);
      s.raf = requestAnimationFrame(inertiaLoop);
    }

    // Cleanup existing listeners if present (prevents duplicates)
    if (container._inspectListeners) {
      window.removeEventListener('mousemove', container._inspectListeners.move);
      window.removeEventListener('mouseup', container._inspectListeners.end);
      window.removeEventListener('touchmove', container._inspectListeners.move);
      window.removeEventListener('touchend', container._inspectListeners.end);
    }

    container.style.cursor = "grab";
    container.onmousedown = start;
    container.ontouchstart = start;
    const boundMove = move.bind(container);
    const boundEnd = end.bind(container);
    window.addEventListener('mousemove', boundMove);
    window.addEventListener('mouseup', boundEnd);
    window.addEventListener('touchmove', boundMove);
    window.addEventListener('touchend', boundEnd);

    container._inspectListeners = { move: boundMove, end: boundEnd };

    // Click behavior: if user clicks without dragging, treat as a simple click (allow modal to close)
    container.onclick = (e) => {
      if (!s.moved) {
        const maybeModal = container.closest('.modal-overlay');
        if (maybeModal && maybeModal.id === 'purchaseResultModal') {
          // Do not auto-close; keep parity with inspect which closes only via explicit controls.
          // So here we do nothing on click to match inspect popup behavior.
        }
      }
    };

    // initial transform
    applyTransform();
  } catch (err) {
    console.warn("initInspectLikeViewer failed:", err);
  }
}

