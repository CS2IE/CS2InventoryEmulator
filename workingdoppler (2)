      sImg.style.filter = `grayscale(${grayscaleVal}) contrast(${1 - grayscaleVal * 0.3})`;
      sImg.style.opacity = "1";

      // Instead of a small label under the sticker, show a compact red percent to the right of the image only when scraped
      const pctRight = document.createElement('div');
      pctRight.style.position = 'absolute';
      pctRight.style.right = '-8px';
      pctRight.style.top = '50%';
      pctRight.style.transform = 'translateY(-50%)';
      pctRight.style.fontSize = '12px';
      pctRight.style.fontWeight = '700';
      pctRight.style.color = '#ff4d4f'; // red
      pctRight.style.background = 'rgba(0,0,0,0.45)';
      pctRight.style.padding = '2px 6px';
      pctRight.style.borderRadius = '6px';
      pctRight.style.pointerEvents = 'none';
      pctRight.style.boxShadow = '0 2px 6px rgba(0,0,0,0.6)';
      pctRight.textContent = (sticker.scratchPercent || 0) > 0 ? `${sticker.scratchPercent}%` : '';
      pctRight.style.display = (sticker.scratchPercent || 0) > 0 ? 'block' : 'none';

      // Left click = remove (use in-screen confirm)
      if (!sticker.isStatTrakModule) {
        wrapper.onclick = (e) => {
          e.stopPropagation();
          showInScreenConfirm(`Remove ${sticker.name}?`, () => {
            addItemToAccount({
              name: sticker.name,
              img: sticker.img,
              price: sticker.price,
              rarity: sticker.rarity || "High Grade",
              type: "Sticker",
              source: "Removed from weapon"
            });
            const sourceIndex = (typeof sticker._sourceIndex === "number") ? sticker._sourceIndex : idx;
            if (Array.isArray(item.stickers) && sourceIndex >= 0 && sourceIndex < item.stickers.length) {
              item.stickers.splice(sourceIndex, 1);
            }
            saveState();
            populateDetailsDOM(root, item);
            refreshInventoryView();
          });
