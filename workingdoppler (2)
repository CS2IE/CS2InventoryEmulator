                floatRank: parseInt(document.getElementById("editMarketFloatRank")?.value) || 0,
                isSpecial: it.name.includes("★") || (it.type || "").toLowerCase().includes("knife")
              });

              account.items = account.items.filter(x => x.id !== it.id);
              saveState();
              refreshInventoryView();
              document.getElementById("editMarketItemModal").classList.add("hidden");
              document.querySelector("#editMarketItemModal h2").textContent = oldTitle;
              overlay.remove();
              openBidSkinMarket();
