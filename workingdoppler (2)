function clampCaseHardenedPrice(name, price) {
  const itemName = String(name || "");
  const numericPrice = Number(price);
  if (!itemName.toLowerCase().includes("case hardened") || !Number.isFinite(numericPrice) || numericPrice <= 0) {
    return numericPrice;
  }

  const lowerName = itemName.toLowerCase();
  let min = 80;
  let max = 2200;

  if (lowerName.includes("five-seven") || lowerName.includes("mac-10")) {
    min = 15;
    max = 300;
  } else if (lowerName.includes("ak-47")) {
    min = 180;
    max = 2800;
  } else if (lowerName.includes("karambit") || lowerName.includes("m9 bayonet")) {
    min = 500;
    max = 2400;
  } else if (lowerName.includes("bayonet") || lowerName.includes("flip knife")) {
    min = 300;
    max = 1400;
  } else if (lowerName.includes("gut knife") || lowerName.includes("navaja") || lowerName.includes("shadow daggers")) {
    min = 120;
    max = 650;
  } else if (
    lowerName.includes("falchion") ||
    lowerName.includes("huntsman") ||
    lowerName.includes("bowie") ||
    lowerName.includes("ursus") ||
    lowerName.includes("stiletto") ||
    lowerName.includes("talon") ||
    lowerName.includes("nomad") ||
    lowerName.includes("paracord") ||
    lowerName.includes("skeleton") ||
    lowerName.includes("survival") ||
    lowerName.includes("classic knife") ||
    lowerName.includes("kukri")
  ) {
    min = 180;
    max = 1600;
  } else if (lowerName.includes("gloves")) {
    min = 120;
    max = 950;
  }

  return Math.round(Math.min(max, Math.max(min, numericPrice)) * 100) / 100;
}

