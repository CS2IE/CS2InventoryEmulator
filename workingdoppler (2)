function createCoinflipObject(forceUserWin = false) {
  if (coinflipSelectedSkins.length === 0) {
    alert("Select at least 1 item!");
    return null;
  }
  const account = getActiveAccount();
  if (!account) return null;

  const userValue = coinflipSelectedSkins.reduce((s, x) => s + getItemValue(x), 0);
  
  // Bot total bet must yield ~45-50% chance (bot value 82-100% of user value)
  const minBot = userValue * 0.82;
  const maxBot = userValue * 1.00;
  const targetBot = userValue * (0.82 + Math.random() * 0.18);

  let botItems = generateBotItems(targetBot);
  let botValue = botItems.reduce((s, x) => s + getItemValue(x), 0);

  // Bot items are used with their actual prices as requested

  // Top up until at least minBot
  let guard = 0;
  while (botValue < minBot && guard < 25) {
    const addItems = generateBotItems(Math.max(0.01, minBot - botValue));
    addItems.forEach(it => botItems.push(it));
    botValue = botItems.reduce((s, x) => s + getItemValue(x), 0);
    guard++;
  }

  // Trim if over maxBot (remove smallest items first)
  botItems.sort((a, b) => getItemValue(a) - getItemValue(b));
  while (botValue > maxBot && botItems.length > 1) {
    const removed = botItems.shift();
    botValue -= getItemValue(removed);
  }

  // "minimize the number of items used for bot trading, such as in coinflip"
  // Try to replace multiple cheap items with fewer expensive items
  botItems.sort((a, b) => getItemValue(b) - getItemValue(a)); // Descending
  let consolidated = [];
  let sum = 0;
  for (const it of botItems) {
    if (consolidated.length >= 3) break; // Limit bot to ~3 items max ideally
    consolidated.push(it);
    sum += getItemValue(it);
  }
  if (sum < minBot) {
    // If we dropped too much value by minimizing, we need to top up with a single expensive item
    const deficit = minBot - sum;
    const extra = generateBotItems(Math.max(0.01, deficit));
    if (extra.length > 0) {
      extra.sort((a,b) => getItemValue(b) - getItemValue(a));
      consolidated.push(extra[0]); 
      sum += getItemValue(extra[0]);
    }
  }
  botItems = consolidated;
  botValue = sum;

  // If trimming dropped below minBot, top up again
  guard = 0;
  while (botValue < minBot && guard < 25) {
    const addItems = generateBotItems(Math.max(0.01, minBot - botValue));
    addItems.forEach(it => botItems.push(it));
    botValue = botItems.reduce((s, x) => s + getItemValue(x), 0);
    guard++;
  }

  // Final exact clamp: adjust last item price to fit range
  if (botItems.length > 0) {
    if (botValue < minBot) {
      const diff = minBot - botValue;
      botItems[botItems.length - 1].price = (botItems[botItems.length - 1].price || 0) + diff;
      botValue = botItems.reduce((s, x) => s + getItemValue(x), 0);
    } else if (botValue > maxBot) {
      const diff = botValue - maxBot;
      botItems[botItems.length - 1].price = Math.max(0.01, (botItems[botItems.length - 1].price || 0) - diff);
      botValue = botItems.reduce((s, x) => s + getItemValue(x), 0);
    }
  }

  // Coinflip bots sometimes have stickers
  botItems.forEach(bit => {
      if (Math.random() < 0.2) {
          const sPool = allSkins.filter(s => String(s.name).toLowerCase().includes("sticker") && !String(s.name).toLowerCase().includes("capsule"));
          if (sPool.length > 0) {
              const count = Math.floor(Math.random() * 5);
              bit.stickers = [];
              for(let i=0; i<count; i++) {
                  const s = sPool[Math.floor(Math.random()*sPool.length)];
                  bit.stickers.push({
                      name: s.name,
                      img: getDisplayImage(s),
                      price: PRICE_FIXES[s.name] || mockPrice(s),
                      rarity: s.rarity?.name || "High Grade",
                      scratchPercent: 0
                  });
              }
          }
      }
  });
  
  const ids = coinflipSelectedSkins.map(s => s.id);
  account.items = account.items.filter(it => !ids.includes(it.id));
  
  const flip = {
    id: "cf_" + Date.now(),
    userName: account.name,
    userAvatar: account.pfp || "https://i.imgur.com/zFydkgL.png",
    userSide: coinflipSelectedSide,
    userItems: [...coinflipSelectedSkins],
    userValue: userValue,
    botName: "Bot_" + (Math.floor(Math.random() * 900) + 100),
    botAvatar: "https://i.imgur.com/4mvaOsy.png",
    botItems: botItems,
    botValue: botValue,
    totalValue: userValue + botValue,
    forceWin: forceUserWin,
    timestamp: Date.now()
  };

  return flip;
}

