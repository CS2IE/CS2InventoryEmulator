          showCaseConfirmForCaseName(targetCaseName, null, null, true);
        } else {
          showCaseConfirmForCaseName(rawName, null, null, true);
        }
      };
    }

    const addBtn = card.querySelector(".add-btn");
    
    // In Bot Marketplace mode, rename the button and hide inspect/edit
    if (marketAddTargetHandler) {
        addBtn.textContent = "Add to Bot Trade";
        card.querySelector(".inspect-search-btn").style.display = "none";
        card.querySelector(".edit-market-btn").style.display = "none";
        const viewContentsBtn = card.querySelector(".view-contents-btn");
        if (viewContentsBtn) viewContentsBtn.style.display = "none";
    }

    addBtn.onclick = (e) => {
      e.preventDefault();
      e.stopPropagation();
      const isCaseResult = item.type === "Container" || item.type === "Custom Container" || rawName.toLowerCase().includes("case") || rawName.toLowerCase().includes("capsule") || rawName.toLowerCase().includes("package") || rawName.toLowerCase().includes("collection");
      
      if (isCaseResult) {
          promptWearSelection(item, numericPrice, (wear, qty, finalPrice, isCustom, extra = {}) => {
            addItemToAccount({
              name: rawName,
              img: item.img || item.image || getDisplayImage(item),
              price: finalPrice,
              rarity: item.rarity?.name || item.rarity || "Base Grade",
              qty,
              isCustomPrice: isCustom,
              source: "Purchased"
            });
            if (extra.bundlePartner) {
              addItemToAccount(extra.bundlePartner);
            }
            showGroupedPurchaseResult();
          }, { confirmMode: "purchase" });
          return;
      }

      promptWearSelection(item, numericPrice, (selectedWear, qty, finalPrice, isCustom, extra = {}) => {
        const account = getActiveAccount();
        if (!account) return;

        // Ensure "Bot Marketplace" title is set correctly before processing
        const searchTitle = document.getElementById("searchModalTitle");
        if (searchTitle) searchTitle.textContent = marketAddTargetHandler ? "Bot Marketplace" : "CS2 Market Search";

        // Handle Direct Apply Mode for stickers on guns (still requires wallet)
        if (directApplyTargetId && name.toLowerCase().includes('sticker')) {
          const gun = account.items.find(it => it.id === directApplyTargetId);
          if (gun) {
            const itemsToBuy = [{
              name,
              img,
              price: finalPrice,
              cost: (state && state.walletlessMode) ? 0 : finalPrice,
              rarity: item.rarity?.name || item.rarity || "Consumer Grade",
              wear: selectedWear,
              type: item.weapon?.name || item.type || "Sticker",
              qty,
              isCustomPrice: isCustom,
              source: item.forceSource || "Purchased",
              prevOwners: 1
            }];
            if (!attemptPurchase(itemsToBuy)) return;

            if (!gun.stickers) gun.stickers = [];
            if (gun.stickers.length < 5) {
              gun.stickers.push({ 
                name, 
                img, 
                price: finalPrice, 
                rarity: item.rarity?.name || "High Grade" 
              });
              for (let idx = account.items.length - 1; idx >= 0; idx--) {
                const ownedSticker = account.items[idx];
                if (!ownedSticker) continue;
                if (ownedSticker.id === gun.id) continue;
                if ((ownedSticker.name || "") !== name) continue;
                if (!String(ownedSticker.type || "").toLowerCase().includes("sticker")) continue;
                account.items.splice(idx, 1);
                break;
              }
              saveState();
              refreshInventoryView();
              showGunStickerManager(gun.id);
              document.getElementById("searchSheet").classList.add("hidden");
              directApplyTargetId = null;
              return;
            }
          }
        }

        const normalizedStickerLoadout = Array.isArray(extra.stickers)
          ? extra.stickers.map(sticker => ({
              name: sticker.name,
              img: sticker.img || sticker.image || getDisplayImage(sticker),
              price: sticker.price,
              rarity: sticker.rarity || "High Grade",
              scratchPercent: typeof sticker.scratchPercent === "number" ? sticker.scratchPercent : 0
            }))
          : [];

        const explicitDopplerPhase = extractExplicitDopplerPhase((extra && extra.nameOverride) ? extra.nameOverride : name);
        // Clean Doppler phase names from added items
        const cleanRawName = ((extra && extra.nameOverride) ? extra.nameOverride : name)
           .replace(/\s+\((Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)\)$/i, "")
           .replace(/\s+(Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)$/i, "");

        const itemData = {
          name: extra.nameOverride || name,
          img,
          price: finalPrice,
          cost: (state && state.walletlessMode) ? 0 : finalPrice,
          rarity: (item.rarity && item.rarity.name) ? item.rarity.name : (item.rarity || "Consumer Grade"),
          wear: selectedWear,
          type: item.weapon?.name || item.type || "Skin",
          qty,
          isCustomPrice: isCustom,
          source: item.forceSource || "Purchased",
          nametag: (extra && extra.nametag) ? extra.nametag : null,
          dopplerPhase: (extra && extra.dopplerPhase) ? extra.dopplerPhase : explicitDopplerPhase,
          floatVal: extra?.floatVal,
          stickers: normalizedStickerLoadout,
          randomizeWearEach: !!extra?.randomizeWearEach,
          prevOwners: 1
        };

        const itemsToConfirm = [itemData];
        if (extra.bundlePartner) {
            itemsToConfirm.push(extra.bundlePartner);
        }

        // Newest to oldest lobby sort
        if (state.activeCoinflips) {
            state.activeCoinflips.sort((a,b) => b.timestamp - a.timestamp);
        }

        if (marketAddTargetHandler) {
          const marketTradeItem = {
            ...itemData,
            qty: 1,
            price: finalPrice,
            cost: 0,
            rarity: item.rarity?.name || "Consumer Grade"
          };
          try {
            marketAddTargetHandler(marketTradeItem);
          } finally {
            const wearModal = document.getElementById("wearModal");
            if (wearModal) wearModal.classList.add("hidden");
            document.getElementById("searchSheet").classList.add("hidden");
          }
          return;
        }

        // Single item confirmation flow
        const buyBody = document.getElementById("buyConfirmBody");
      
      const purchaseST = !!document.getElementById("purchaseStatTrakCheck")?.checked;
      const finalN = purchaseST ? ("StatTrak™ " + name) : name;
      const finalP = purchaseST ? (numericPrice * 1.15) : numericPrice;

        const totalCost = (finalP || 0) * (qty || 1);
        const currentBalance = account.walletBalance || 0;
        const balanceAfter = currentBalance - totalCost;

        buyBody.innerHTML = `
          <div style="margin-bottom:12px; font-size: 14px; color: #94a3b8;">You are about to purchase the following item:</div>
          <div style="background: rgba(0,0,0,0.3); border: 1px solid #334155; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
            <div style="font-weight:900; font-size: 18px; color: #fff; margin-bottom: 4px;">${escapeHtml(itemData.name)}</div>
            <div style="font-size:13px; color:#66c0f4; margin-bottom: 12px;">Quantity: ${itemData.qty} • Wear: ${itemData.wear || 'N/A'}</div>
            <div style="display:flex; justify-content: space-between; align-items: baseline; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 10px;">
              <span style="font-size: 12px; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;">Total Cost</span>
              <span class="price-related" style="color:#a4d007; font-size: 24px; font-weight: 900;">${formatPrice(totalCost)}</span>
            </div>
          </div>
          <div class="price-related" style="display: flex; flex-direction: column; gap: 6px; font-size: 14px; padding: 0 5px;">
            <div style="display: flex; justify-content: space-between;">
              <span style="color: #94a3b8;">Your Current Wallet:</span>
              <span style="color: #fff;">${formatPrice(currentBalance)}</span>
            </div>
            <div style="display: flex; justify-content: space-between; font-weight: bold; border-top: 1px dashed #334155; padding-top: 6px; margin-top: 4px;">
              <span style="color: #94a3b8;">Wallet After Purchase:</span>
              <span style="color: ${balanceAfter < 0 ? '#eb4b4b' : '#a4d007'};">${formatPrice(balanceAfter)}</span>
            </div>
          </div>
        `;

        // Use centralized confirm modal that shows total, current balance, and balance after
        showBuyConfirm(itemsToConfirm, () => {
          // Success is handled by showBuyConfirm internally calling attemptPurchase
          modal.classList.add("hidden");
          const searchSheet = document.getElementById("searchSheet");
          if (searchSheet) searchSheet.classList.add("hidden");
        });
      }, { confirmMode: "none" });
    };

    container.appendChild(card);
  });
}

async function fetchSteamPrice(marketHashName) {
  // Build Steam priceoverview URL (do not double-encode when passing through our proxy)
  const url = `https://steamcommunity.com/market/priceoverview/?appid=730&currency=1&market_hash_name=${encodeURIComponent(marketHashName)}`;
  try {
    // The configured proxy expects the full URL appended as-is (not double-encoded)
    const res = await fetch(PROXY + url);
    const data = await res.json();
    // Steam returns lowest_price as a string like "$1.23" — parse to numeric cents/dollars using existing helper
    if (data && data.lowest_price) {
      // parsePriceText is a utility in this file that strips currency symbols and returns a number
      const numeric = parsePriceText(String(data.lowest_price));
      return numeric || 0;
    }
    return 0;
  } catch (e) {
    console.warn("fetchSteamPrice error:", e);
    return 0;
  }
}

async function fetchSteamSearch(query) {
  // Build the Steam Market search URL and pass it through the CORS proxy without double-encoding.
  const url = `https://steamcommunity.com/market/search/render/?appid=730&norender=1&count=100&query=${encodeURIComponent(query)}`;
  try {
    // proxy expects the full URL appended, don't encode the entire URL again
    const res = await fetch(PROXY + url);
    const data = await res.json();
    return data;
  } catch (e) {
    console.error("Steam Search Error:", e);
    return null;
  }
}

async function search() {
  const query = document.getElementById("search").value.trim();
  const queryWords = query.toLowerCase().split(/\s+/).filter(Boolean);
  const category = getActiveSearchCategory();
  // If user selected a category, show all local DB items matching that category (tools, cases, keys, stickers, knives, etc.)
  if (category && category !== "") {
    updateSearchStatus(`Showing items for category: ${category}`);
    searchResults = [];
    const cat = category.toLowerCase();

    // Special-case: "custom" should surface all user-defined/custom containers/items (everything in CASE_CONTENTS_DB)
    if (cat === "custom") {
      // Pull every entry from CASE_CONTENTS_DB into the searchResults list (flatten by rarity buckets)
      try {
        const seen = new Set();
        Object.keys(CASE_CONTENTS_DB || {}).forEach(caseName => {
          const groups = CASE_CONTENTS_DB[caseName];
          if (!groups || typeof groups !== "object") return;
          Object.keys(groups).forEach(rarity => {
            const list = groups[rarity];
            if (!Array.isArray(list)) return;
            list.forEach(it => {
              if (!it || !it.name) return;
              if (seen.has(it.name)) return;
              seen.add(it.name);
              const price = PRICE_FIXES[it.name] !== undefined ? PRICE_FIXES[it.name] : (it.price || mockPrice(it));
              searchResults.push({
                name: it.name,
                image: it.img || getDisplayImage(it),
                price,
                price_text: formatPrice(price),
                rarity: { name: rarity },
                type: "Custom Case Item",
                fromCustomDB: caseName
              });
            });
          });
        });
        // Also include the case entries themselves as container results
        Object.keys(CASE_CONTENTS_DB || {}).forEach(caseName => {
          const cPrice = PRICE_FIXES[caseName] !== undefined ? PRICE_FIXES[caseName] : mockPrice({ name: caseName });
          searchResults.unshift({
            name: caseName,
            image: getDisplayImage({ name: caseName }),
            price: cPrice,
            price_text: formatPrice(cPrice),
            rarity: { name: "Base Grade" },
            type: "Custom Container",
            fromCustomDB: caseName
          });
        });

        // Add any additional items from the global list that match the "Collection" keyword
        const extraCollections = [
          ...allSkins.filter(s => (s.name || "").toLowerCase().includes("collection") && !s.name.includes("|")),
          ...MARKET_KEYS.filter(k => (k.name || "").toLowerCase().includes("collection") && !k.name.includes("|"))
        ];

        extraCollections.forEach(it => {
          if (!seen.has(it.name)) {
            seen.add(it.name);
            const price = PRICE_FIXES[it.name] !== undefined ? PRICE_FIXES[it.name] : (it.price || mockPrice(it));
            searchResults.push({
              name: it.name,
              image: it.image || it.img || getDisplayImage(it),
              price,
              price_text: formatPrice(price),
              rarity: { name: it.rarity?.name || it.rarity || "Base Grade" },
              type: "Custom Collection",
              fromCustomDB: it.name
            });
          }
        });
      } catch (e) {
        console.warn("Failed to build custom category results:", e);
      }
      searchPage = 1;
      updateSearchDisplay();
      return;
    }

    if (cat === "key") {
      searchResults = getActualContainerKeyResults(queryWords);
      searchPage = 1;
      updateSearchDisplay();
      return;
    }

    const matches = allSkins.filter(item => {
      if (!item || !item.name) return false;
      if (cat !== "filled_cases" && cat !== "charm") {
        if (!matchesSearchCategoryStrict(item, cat)) return false;
        if (!queryWords.length) return true;
        const name = (item.name || "").toLowerCase();
        const catName = (item.category?.name || "").toLowerCase();
        const weapon = (item.weapon?.name || "").toLowerCase();
        const type = (item.type || item.category?.name || "").toLowerCase();
        return queryWords.every(word => name.includes(word) || catName.includes(word) || weapon.includes(word) || type.includes(word));
      }
      const name = (item.name || "").toLowerCase();
      const catName = (item.category?.name || "").toLowerCase();
      const weapon = (item.weapon?.name || "").toLowerCase();
      
      // Category filtering
      if (cat === "filled_cases" || cat === "charm") {
        return matchesSearchCategoryStrict(item, "charm");
      }
      
      if (cat === "stickers") return name.includes("sticker") || catName.includes("sticker");
      if (cat === "tool") return catName.includes("tool") || name.includes("storage unit") || name.includes("name tag");
      if (cat === "case" || cat === "case/crate") return catName.includes("case") || name.includes("case") || name.includes("crate") || catName.includes("crate") || name.includes("package") || name.includes("collection");
      if (cat === "key") return name.includes("key") || catName.includes("key");
      if (cat === "sticker" || cat === "capsule") return name.includes("sticker") || catName.includes("sticker") || name.includes("capsule");
      if (cat === "knife") return name.includes("★") || name.includes("knife") || catName.includes("knife");
      if (cat === "gloves") return name.includes("gloves") || catName.includes("gloves");
      if (cat === "rifle" || cat === "pistol" || cat === "smg" || cat === "shotgun" || cat === "sniper") {
        return weapon.includes(cat) || catName.includes(cat) || name.includes(cat);
      }
      if (cat === "agent") return catName.includes("agent") || name.includes("agent");
      if (cat === "music_kit" || cat === "music kit") return catName.includes("music") || name.toLowerCase().includes("music");
      if (cat === "graffiti") return catName.includes("graffiti") || name.toLowerCase().includes("graffiti");
      if (cat === "charm" || cat === "charm/collectible") return matchesSearchCategoryStrict(item, "charm");
      // fallback: match if category string appears anywhere in name/category/weapon
      return name.includes(cat) || catName.includes(cat) || weapon.includes(cat);
    });

    // Deduplicate by name and push
    const seen = new Set();
    matches.forEach(it => {
      if (!seen.has(it.name)) {
        seen.add(it.name);
        // Offer price override if exists
        const price = PRICE_FIXES[it.name] !== undefined ? PRICE_FIXES[it.name] : (it.price || mockPrice(it));
        searchResults.push({
          name: it.name,
          image: it.image || it.img || getDisplayImage(it),
          price,
          price_text: formatPrice(price),
          rarity: { name: it.rarity?.name || mockRarity(it.name, price) },
          type: it.type || it.category?.name || "Item",
          fromLocalDB: true
        });
      }
    });

    searchPage = 1;
    updateSearchDisplay();
    return;
  }

  // Default full-text query flow (falls back to Steam + DB like before)
  if (query.length < 1) return;

  updateSearchStatus("Searching...");
  searchResults = [];
  const seenNames = new Set();
  
  searchPage = 1;
  const qLower = query.toLowerCase();

  // Fetch from Steam Market
  const steamData = await fetchSteamSearch(query);
  
  if (steamData && steamData.results && steamData.results.length > 0) {
    steamData.results.forEach(item => {
      const icon = item.asset_description.icon_url;
      const image = `https://community.cloudflare.steamstatic.com/economy/image/${icon}/200fx200f`;
      const priceText = item.sell_price_text || "No price";
      const numericPrice = parsePriceText(priceText);
      
      // Ensure search result price matches hardcoded medians in container view
      const itemName = item.hash_name || item.name;
      const baseName = itemName.split(' (')[0].trim();
      const hardcodedKey = MARKET_KEYS.find(k => k.name === itemName || k.name === baseName);
      
      // Look for explicit overrides for full name or base name (median)
      const overridePrice = PRICE_FIXES[itemName] ?? PRICE_FIXES[baseName] ?? undefined;
      
      const finalPrice = overridePrice ?? (hardcodedKey && typeof hardcodedKey.price === "number" && hardcodedKey.price > 0 ? hardcodedKey.price : numericPrice);
      const finalPriceText = overridePrice ? formatPrice(overridePrice) : ((hardcodedKey && hardcodedKey.price > 0) ? formatPrice(hardcodedKey.price) : priceText);

      searchResults.push({
        name: item.hash_name,
        image,
        price: finalPrice,
        price_text: finalPriceText,
        rarity: { name: mockRarity(item.hash_name, finalPrice) },
        type: item.asset_description?.type || "Market Item",
        isSteamResult: true
      });
      seenNames.add(item.hash_name);
    });
    updateSearchStatus(searchResults.length + " items found");
  } else {
    updateSearchStatus("No items found on Steam Market, checking database...");
  }

  // Inject custom Cobblestone package if matched
  if (qLower.includes("false") || qLower.includes("odds") || qLower.includes("cobblestone")) {
    searchResults.unshift({
      name: "Cobblestone Package",
      image: "https://i.imgur.com/qaCy0xR.png",
      price: 5303.00,
      price_text: "$5,303.00",
      rarity: { name: "Consumer" },
      type: "Container"
    });
    seenNames.add("Cobblestone Package");
  }

  // Inject custom "Norse Case" if matched
  if (qLower.includes("norse")) {
    searchResults.unshift({
      name: "Norse Case",
      image: "https://i.imgur.com/Yd8GqjV.png",
      price: 31.00,
      price_text: "$31.00",
      rarity: { name: "Consumer" },
      type: "Container"
    });
    seenNames.add("Norse Case");
  }

  if (qLower.includes("anubis collection")) {
    searchResults.unshift({
      name: "The Anubis Collection",
      image: "https://i.imgur.com/TG1qTdY.png",
      price: 5.45,
      price_text: "$5.45",
      rarity: { name: "Base Grade" },
      type: "Container"
    });
    seenNames.add("The Anubis Collection");
  }

  // Inject Ambush and Espionage capsules if matched
  if (qLower.includes("ambush")) {
    searchResults.unshift({
      name: "Ambush Sticker Capsule",
      image: "https://i.imgur.com/DT33UYz.png",
      price: 0.71,
      price_text: "$0.71",
      rarity: { name: "Base Grade" },
      type: "Sticker Capsule"
    });
    seenNames.add("Ambush Sticker Capsule");
  }
  if (qLower.includes("espionage")) {
    searchResults.unshift({
      name: "Espionage Sticker Capsule",
      image: "https://i.imgur.com/mgsfylD.png",
      price: 0.72,
      price_text: "$0.72",
      rarity: { name: "Base Grade" },
      type: "Sticker Capsule"
    });
    seenNames.add("Espionage Sticker Capsule");
  }

  // Inject hardcoded keys if they match the query words
  const marketQueryWords = qLower.split(/\s+/).filter(w => w.length > 0);
  MARKET_KEYS.forEach(k => {
    if (seenNames.has(k.name)) return;
    const kName = k.name.toLowerCase();
    if (marketQueryWords.every(word => kName.includes(word))) {
      // Prioritize hardcoded image, then API match, then generic key image
      const apiMatch = allSkins.find(s => s.name === k.name);
      searchResults.push({
        name: k.name,
        image: k.img || (apiMatch ? apiMatch.image : "https://community.cloudflare.steamstatic.com/economy/image/-9a81dlWLwJ2UUGcVs_nsVtzdOEdtWwKGZZLQHTxDZ7I56KU0Zwwo4NUX4oFJZEHLbXU5A1PIYQNqhpOSV-fRPasw8rsUFJ5KBFZpbz3fVp00v_NfDxB7c7lw9PfkaSuY-iIkz0J6sZz0r-YrIr30ALm_BVvY2nydY-WJgM-ZAnSr0-_l7pX"),
        price: k.price,
        price_text: k.price > 0 ? formatPrice(k.price) : "No Price Data",
        rarity: { name: "Base Grade" },
        type: "Key"
      });
      seenNames.add(k.name);
    }
  });

  // Augment with local database
  const localMatch = allSkins.filter(it => {
    if (!it || !it.name || seenNames.has(it.name)) return false;
    const name = it.name.toLowerCase();
    const weapon = (it.weapon?.name || "").toLowerCase();
    return marketQueryWords.every(word => name.includes(word) || weapon.includes(word));
  });

  localMatch.forEach(it => {
    searchResults.push(it);
    seenNames.add(it.name);
  });

  updateSearchDisplay();
}

