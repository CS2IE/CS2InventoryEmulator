  // Trade Up Profit Logic
  let tradeUpProfitHtml = "";
  if (item.source === "Trade Up Contract" && !state.hidePrices) {
    try {
      const account = getActiveAccount();
      // find history entry to get profit
      const lastTradeUp = state.tradeHistory.find(h => h.leftAccountId === account.id && h.rightItems && h.rightItems.some(ri => ri.name === item.name));
