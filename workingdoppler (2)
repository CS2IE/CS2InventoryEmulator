function openBidSkinMarket(forceRefresh = false) {
  const searchSheet = document.getElementById("searchSheet");
  if (searchSheet) searchSheet.classList.add("hidden");

  if (forceRefresh) {
    state.bidSkinListings = [];
    state.pinnedListingIds = [];
    bidSkinPage = 1;
    state.bidSkinPage = 1;
  }

  // Load page from state to save position
  bidSkinPage = state.bidSkinPage || 1;

  let modal = document.getElementById("bidSkinModal");
  if (!modal) {
    modal = document.createElement("div");
    modal.id = "bidSkinModal";
    modal.className = "modal-overlay";
    modal.style.zIndex = 3000;
    document.body.appendChild(modal);
  }

  if (!allSkins.length) {
    alert("Database is still loading. Please try again in a moment.");
    return;
  }

  const getListingFloatValue = (listing) => {
    const raw = (typeof listing?.item?.floatVal === "number" && !isNaN(listing.item.floatVal))
      ? listing.item.floatVal
      : parseFloat(listing?.float);
    return Number.isFinite(raw) ? raw : 0;
  };

  const getListingPatternValue = (listing) => {
    const raw = listing?.item?.pattern ?? listing?.pattern ?? 0;
    const parsed = parseInt(raw, 10);
    return Number.isFinite(parsed) ? parsed : 0;
  };

  const getSortedBidListings = () => {
    const queryWords = bidSkinSearch.trim().toLowerCase().split(/\s+/).filter(Boolean);
    const filtered = (state.bidSkinListings || [])
      .filter(l => l && l.item && isSkinBidsEligibleItem(l.item) && String(l.wear || "").toLowerCase() !== "battle-scarred")
      .filter(l => {
        const haystack = normalizeSkinBidsSearchText(l);
        if (!queryWords.length) return true;
        return queryWords.every(word => haystack.includes(word));
      });

    const currentSort = state.bidSkinSort || "none";
    const currentSort2 = state.bidSkinSort2 || "none";
    let sortedPool = filtered.filter(l => passesSkinBidsListingFilter(l, currentSort));

    const applySelectedSort = (pool, s) => {
        if (s === "priceAsc") pool.sort((a,b) => a.price - b.price);
        else if (s === "priceDesc") pool.sort((a,b) => b.price - a.price);
        else if (s === "discount") pool.sort((a,b) => b.discountPercent - a.discountPercent);
        else if (s === "mostStickers") pool.sort((a,b) => (b.stickers?.length || 0) - (a.stickers?.length || 0));
        else if (s === "quality") {
          const wearOrder = { "Factory New": 0, "Minimal Wear": 1, "Field-Tested": 2, "Well-Worn": 3, "Battle-Scarred": 4 };
          pool.sort((a,b) => (wearOrder[a.wear] ?? 99) - (wearOrder[b.wear] ?? 99) || getListingFloatValue(a) - getListingFloatValue(b));
        } else if (s === "floatAsc") pool.sort((a,b) => getListingFloatValue(a) - getListingFloatValue(b));
        else if (s === "floatDesc") pool.sort((a,b) => getListingFloatValue(b) - getListingFloatValue(a));
        else if (s === "name") pool.sort((a,b) => a.item.name.localeCompare(b.item.name));
    };

    applySelectedSort(sortedPool, currentSort);
    if (currentSort2 !== "none") {
        applySelectedSort(sortedPool, currentSort2);
    }

    return sortedPool.sort((a,b) => {
      const aPinned = state.pinnedListingIds.includes(a.id);
      const bPinned = state.pinnedListingIds.includes(b.id);
      if (aPinned && !bPinned) return -1;
      if (!aPinned && bPinned) return 1;
      return 0;
    });
  };

  modal.classList.remove("hidden");

  if (Array.isArray(state.bidSkinListings) && state.bidSkinListings.length) {
    state.bidSkinListings.forEach(listing => {
      if (!listing || !listing.item || !/doppler/i.test(listing.item.name || "")) return;
      const dopplerContext = {
        ...listing.item,
        pattern: listing.pattern,
        float: listing.float
      };
      const explicitPhase = extractExplicitDopplerPhase(
        listing.item.skinBidsApiName || listing.item.dopplerPhase || listing.item.phase || listing.item.finishStyle || listing.item.name || ""
      );
      if (!listing.item.skinBidsApiName) {
        listing.item.skinBidsApiName = getExactDopplerApiName(dopplerContext);
      }
      if (!listing.item.dopplerPhase) {
        listing.item.dopplerPhase = explicitPhase || deriveDopplerPhaseLabel(dopplerContext);
      }
    });
  }

  // Force re-generation if market is blank to prevent blank popup on refresh
  if (!state.bidSkinListings || state.bidSkinListings.length === 0) {
    const isSpecial = (s) => (s.name || "").includes("★") || (s.type || "").toLowerCase().includes("knife") || (s.name || "").toLowerCase().includes("gloves");
    
    // Priority rare skins list
    const prioritySkins = ["AWP | Gungnir", "AWP | Medusa", "AWP | Dragon Lore", "M4A4 | Howl", "AK-47 | Fire Serpent", "AWP | Desert Hydra", "AWP | The Prince", "AK-47 | Wild Lotus", "AK-47 | Gold Arabesque"];

    // Preserve pinned listings
    const pinnedItems = (state.bidSkinListings || []).filter(l => state.pinnedListingIds.includes(l.id));

    // Case Hardened Pool: Include every weapon that can have the finish
    const chWeapons = allSkins.filter(s => s.name.toLowerCase().includes("case hardened"));

    // Market Criteria: guns, knives, gloves, Katowice 2014, Katowice 2015
    const highTierPool = allSkins.filter(s => {
      const n = (s.name || "").toLowerCase();
      const isStickerTarget = isKatoMarketSticker(s);
      const isWeapon = isWeaponMarketItem(s) || String(s.name || "").includes("★") || String(s.type || "").toLowerCase().includes("knife");
      const isBanned = n.includes("agent") || n.includes("music kit") || n.includes("charm") || n.includes("graffiti") || n.includes("capsule") || n.includes("storage unit");
      
      return (isWeapon || isStickerTarget) && !isBanned;
    });

    // Ensure at least one of every gun model
    const gunModels = ["AK-47", "M4A4", "M4A1-S", "AWP", "USP-S", "Glock-18", "Desert Eagle", "P250", "Five-SeveN", "Tec-9", "CZ75-Auto", "Galil AR", "FAMAS", "AUG", "SG 553", "SSG 08", "SCAR-20", "G3SG1", "MP9", "MAC-10", "MP7", "MP5-SD", "UMP-45", "P90", "PP-Bizon", "Nova", "XM1014", "MAG-7", "Sawed-Off", "Negev", "M249", "R8 Revolver"];
    const modelPicks = [];
    gunModels.forEach(m => {
       const modelPool = allSkins.filter(s => s.name.startsWith(m + " |"));
       if (modelPool.length) modelPicks.push(modelPool[Math.floor(Math.random()*modelPool.length)]);
    });

    const finalSelection = [...new Set([...highTierPool, ...chWeapons, ...modelPicks])];
    prioritySkins.forEach(psName => {
      if (!finalSelection.some(s => s.name === psName)) {
        const found = allSkins.find(s => s.name === psName);
        if (found) finalSelection.push(found);
      }
    });

    const anyStickers = allSkins.filter(s => {
      const n = String(s?.name || "").toLowerCase();
      return n.includes("sticker") && !n.includes("capsule");
    });
    const cheapRandomStickers = anyStickers.filter(s => {
