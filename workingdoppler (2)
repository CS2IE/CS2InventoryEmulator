function applyInventorySort(items, sort) {
  const list = Array.isArray(items) ? items : [];
  if (sort === "recent" || sort === "equipped" || sort === "favorites") {
    list.sort((a, b) => (b.acquiredAt || 0) - (a.acquiredAt || 0));
  } else if (sort === "name") {
    list.sort((a, b) => a.name.localeCompare(b.name));
  } else if (sort === "quality") {
    list.sort((a, b) => getItemValue(b) - getItemValue(a));
  } else if (sort === "type") {
    list.sort((a, b) => (a.type || "").localeCompare(b.type || "") || a.name.localeCompare(b.name));
  } else if (sort === "collection") {
    list.sort((a, b) => (a.source || "").localeCompare(b.source || "") || a.name.localeCompare(b.name));
  } else if (sort === "priceDesc") {
    list.sort((a, b) => getItemValue(b) - getItemValue(a));
  } else if (sort === "priceAsc") {
    list.sort((a, b) => getItemValue(a) - getItemValue(b));
  }
  return list;
}

function clearPersistentStateCaches() {
  try {
    [
      STORAGE_KEY,
      STORAGE_BACKUP_KEY,
      STORAGE_CRITICAL_KEY,
      STORAGE_EXPORT_MIRROR_KEY,
      STORAGE_REFRESH_SAFE_KEY
    ].forEach(key => {
      try { localStorage.removeItem(key); } catch (e) {}
      try { clearChunkedStorage(key, localStorage); } catch (e) {}
    });
  } catch (e) {}

  try {
    [STORAGE_SESSION_KEY, `${STORAGE_KEY}_session`, `${STORAGE_BACKUP_KEY}_session`, `${STORAGE_EXPORT_MIRROR_KEY}_session`, `${STORAGE_REFRESH_SAFE_KEY}_session`].forEach(key => {
      try { sessionStorage.removeItem(key); } catch (e) {}
      try { clearChunkedStorage(key, sessionStorage); } catch (e) {}
    });
  } catch (e) {}

  try { window.name = ""; } catch (e) {}

  return deleteFromIDB(STORAGE_KEY);
}

