  }

  const titleEl = modal.querySelector("#__randomQtyTitle");
  const labelEl = modal.querySelector("#__randomQtyLabel");
  const previewEl = modal.querySelector("#__randomQtyPreview");
  const countInput = modal.querySelector("#__randomQtyCount");
  const slider = modal.querySelector("#__randomQtySlider");
  const confirmBtn = modal.querySelector("#__randomQtyConfirm");
  const closeBtn = modal.querySelector("#__randomQtyClose");
  const cancelBtn = modal.querySelector("#__randomQtyCancel");

  titleEl.textContent = title;
  labelEl.textContent = label;
  countInput.value = 5;
  slider.value = 5;

  const sync = () => {
    const val = Math.max(1, Math.min(100, parseInt(countInput.value) || 1));
    countInput.value = val;
    slider.value = val;
    previewEl.textContent = `${previewPrefix} ${val} items.`;
  };

  countInput.oninput = sync;
  slider.oninput = () => { countInput.value = slider.value; sync(); };
  sync();

  const cleanup = () => {
    modal.classList.add("hidden");
    confirmBtn.onclick = null;
  };

  confirmBtn.onclick = () => {
    const qty = Math.max(1, Math.min(100, parseInt(countInput.value) || 1));
    onConfirm(qty);
    cleanup();
  };

  closeBtn.onclick = cancelBtn.onclick = cleanup;
  modal.classList.remove("hidden");
}

