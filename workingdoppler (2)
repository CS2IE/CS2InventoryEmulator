   * Export all custom price overrides and a mapping of which inventory items use those overrides to the clipboard.
   * Format:
   * {
   *   priceOverrides: { "Item Name": 12.34, ... },
   *   items: [ { accountId, itemId, name }, ... ]
   * }
   */
  async function exportEconomyToClipboard() {
    try {
      // Ensure we export every manually edited price override
      const out = {
        priceOverrides: { ...(state.priceOverrides || {}) },
        items: []
      };
      
      // Also scrape PRICE_FIXES for any entries that were mutated at runtime
      Object.keys(PRICE_FIXES).forEach(k => {
          if (PRICE_FIXES[k] !== undefined && !out.priceOverrides[k]) {
              // We only want user-specific overrides or recently set ones
          }
      });

      const overrides = out.priceOverrides;
      state.accounts.forEach(acc => {
        const check = (it) => {
          if (!it || !it.name) return;
          if (overrides[it.name] !== undefined) {
            out.items.push({ accountId: acc.id, itemId: it.id, name: it.name });
          }
          if (Array.isArray(it.contents)) it.contents.forEach(check);
        };
        acc.items.forEach(check);
      });

      await navigator.clipboard.writeText(JSON.stringify(out, null, 2));
      alert("Economy export copied to clipboard (custom prices + affected items).");
    } catch (err) {
      console.error("Export economy failed:", err);
      alert("Export economy failed: " + err);
    }
  }

