  if (dupTarget) {
    dupTarget.oncontextmenu = (e) => {
      e.preventDefault();
      e.stopPropagation();
      const current = purchaseResultList[currentPurchaseResultIdx];
      if (!current) return;
      
      const clone = JSON.parse(JSON.stringify(current));
      clone.id = "it_dup_" + Date.now() + "_" + Math.random().toString(16).slice(2);
      clone._seenKey = clone.id;
      
      // Add to popup list so user can see it
      purchaseResultList.splice(currentPurchaseResultIdx + 1, 0, clone);
      
      // Add to inventory
      addItemToAccount(clone);
      saveState(); // Explicit save on duplication
      
      // Refresh UI
      updatePurchaseResultView();
      try { playTickSound(600, 0.1); } catch(err){}
    };
  }
  
  if (priceEl) {
    // Market price and profit removed from New Items popup per user request
    priceEl.innerHTML = "";
  }
  
  // Counter no longer caps at 20; shows real total.
  counterEl.textContent = `${currentPurchaseResultIdx + 1} / ${purchaseResultList.length}`;

  document.getElementById("prevPurchaseItem").disabled = currentPurchaseResultIdx === 0;
  document.getElementById("nextPurchaseItem").disabled = currentPurchaseResultIdx === purchaseResultList.length - 1;

  // Ensure Inspect Result button carries the collection/case context for this unlocked item
  try {
    const inspectResBtn = document.getElementById("inspectResultBtn");
    if (inspectResBtn) {
      // Attach the item payload and explicitly set its source/collection to the resolved containerName
      const payload = {
        name: item.name,
