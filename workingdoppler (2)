        </div>
        <div style="color:#94a3b8; font-size:11px; margin-top:2px;">
          Dice Wagered: <span style="color:#fff">${formatPrice(acc.diceWagered || 0)}</span> • 
          Profit: <span style="color:${(acc.diceProfit || 0) >= 0 ? '#a4d007' : '#eb4b4b'}">${formatPrice(acc.diceProfit || 0)}</span>
        </div>
      </div>
      <div style="text-align:right;">
