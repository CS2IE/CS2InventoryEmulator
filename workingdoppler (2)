function getSnapshotRichnessScore(snapshot) {
  try {
    const parsed = snapshot?.parsed;
    if (!parsed || typeof parsed !== "object") return 0;
    const accounts = Array.isArray(parsed.accounts) ? parsed.accounts : [];
    const accountCount = accounts.length;
    let itemCount = 0;
    accounts.forEach(acc => {
      if (acc && Array.isArray(acc.items)) itemCount += acc.items.length;
    });
    let score = 0;
    if (accountCount > 0) score += 1000;
    if (itemCount > 0) score += 100000;
    score += Math.min(accountCount, 999);
    score += Math.min(itemCount, 99999);
    return score;
  } catch (err) {
    return 0;
  }
}

function mirrorSnapshotToAllStores(snapshotStr) {
  if (typeof snapshotStr !== "string" || !snapshotStr) return;
  try { writeStringWithFallback(STORAGE_KEY, snapshotStr); } catch (e) {}
  try { writeStringWithFallback(STORAGE_BACKUP_KEY, snapshotStr); } catch (e) {}
  try { writeStringWithFallback(STORAGE_EXPORT_MIRROR_KEY, snapshotStr); } catch (e) {}
  try { writeStringWithFallback(STORAGE_REFRESH_SAFE_KEY, snapshotStr); } catch (e) {}
  try { localStorage.setItem(STORAGE_CRITICAL_KEY, snapshotStr); } catch (e) {}
  try { sessionStorage.setItem(STORAGE_SESSION_KEY, snapshotStr); } catch (e) {}
  try { writeWindowNameSnapshot(snapshotStr); } catch (e) {}
}

