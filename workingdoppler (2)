function applyDopplerPhasePricePremium(name, basePrice) {
  const safeBase = Number(basePrice) || 0;
  const lower = String(name || "").toLowerCase();
  if (!lower.includes("doppler")) return safeBase;
  if (lower.includes("black pearl")) return safeBase * 7.5;
  if (lower.includes("sapphire")) return safeBase * 3.0;
  if (lower.includes("ruby")) return safeBase * 2.7;
  if (lower.includes("emerald")) return safeBase * 3.2;
  if (lower.includes("phase 2")) return safeBase * 1.65;
  if (lower.includes("phase 4")) return safeBase * 1.35;
  if (lower.includes("phase 1")) return safeBase * 1.12;
  if (lower.includes("phase 3")) return safeBase * 1.08;
  return safeBase * 1.15;
}

