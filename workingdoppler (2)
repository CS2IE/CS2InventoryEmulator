function equipItemToLoadoutSide(account, item, side) {
  if (!account || !item || !state.loadout?.[side]) return { ok: false, reason: "invalid" };
  const slotEl = findLoadoutSlotForItem(side, item);
  if (!slotEl) return { ok: false, reason: "no-slot" };
  const slotId = slotEl.dataset.slot;
  
  // Logic: When an item is replaced, remove equipped status from previous item if not used elsewhere
  const previousId = state.loadout[side][slotId];
  state.loadout[side][slotId] = item.id;
  
  if (previousId && previousId !== item.id) {
    // Check both sides' loadouts to see if the previousId is still equipped anywhere
    const isStillEquippedOnCT = Object.values(state.loadout.ct).includes(previousId);
    const isStillEquippedOnT = Object.values(state.loadout.t).includes(previousId);
    
    if (!isStillEquippedOnCT && !isStillEquippedOnT) {
      account.equippedItemIds = (account.equippedItemIds || []).filter(id => id !== previousId);
    }
  }

  if (!Array.isArray(account.equippedItemIds)) account.equippedItemIds = [];
  if (!account.equippedItemIds.includes(item.id)) account.equippedItemIds.push(item.id);
  return { ok: true, slotId };
}

