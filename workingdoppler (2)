function runInCardCoinflip(flip, entry) {
  const coinInner = entry.querySelector(".cf-coin-inner");
  const watchBtn = entry.querySelector(".cf-watch-btn");
  if (!coinInner) return;

  // Decide result
  let winnerSide = Math.random() < 0.5 ? "heads" : "tails";
  if (flip.forceWin) winnerSide = flip.userSide;
  const userWon = flip.userSide === winnerSide;
  
  coinInner.classList.add("flipping");
  
  // 5 second countdown sequence
  let countdown = 5;
  const timerInterval = setInterval(() => {
    countdown--;
    if (watchBtn) watchBtn.textContent = `FLIPPING (${countdown}s)...`;
    if (countdown <= 0) {
      clearInterval(timerInterval);
    }
  }, 1000);

  // Play flip sound looping if possible
  try {
    const coinSfx = new AudioContext();
    fetch('/asset_name.mp3').then(r => r.arrayBuffer()).then(b => coinSfx.decodeAudioData(b)).then(buf => {
       const s = coinSfx.createBufferSource(); s.buffer = buf; s.connect(coinSfx.destination); s.start();
    });
  } catch(e) {}

  setTimeout(() => {
    // End flipping and land on side
    coinInner.classList.remove("flipping");
    const baseRot = 1800; // ensures enough spins during loop to land smoothly
    const targetRot = baseRot + (winnerSide === "tails" ? 180 : 0);
    coinInner.style.transition = "transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275)";
    coinInner.style.transform = `rotateY(${targetRot}deg)`;
    
    if (watchBtn) watchBtn.textContent = "RESULT!";

    setTimeout(() => {
      // Highlight winner
      const userSideEl = entry.querySelector(".user-side");
      const botSideEl = entry.querySelector(".bot-side");
      
      if (userWon) {
        userSideEl.classList.add("winner-highlight");
        botSideEl.classList.add("loser-dim");
      } else {
        botSideEl.classList.add("winner-highlight");
        userSideEl.classList.add("loser-dim");
      }
      
      setTimeout(() => {
        showCoinflipResult(flip, userWon);
      }, 1000);
    }, 1000);
  }, 5000);
}

