    "safecracker", "little kev", "getaway sally", "rezan", "dragomir", "cmdr.",
    "lieutenant", "lt.", "officer", "sergeant", "special agent"
  ];
  return agentKeywords.some(keyword => name.includes(keyword) || type.includes(keyword));
