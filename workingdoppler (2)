function seededRandomFromName(name, min, max) {
  // Simple deterministic hash from item name
  let hash = 0;
  for (let i = 0; i < name.length; i++) {
    hash = ((hash << 5) - hash) + name.charCodeAt(i);
    hash |= 0;
  }
  // Map hash to 0..1
  const norm = (hash >>> 0) / 4294967295;
  // No random offset for consistency with CS2 market prices
  return min + norm * (max - min);
}

function mockPrice(item) {
  const stickerSlabPrice = getStickerSlabReferencePrice(item);
  if (Number.isFinite(stickerSlabPrice) && stickerSlabPrice > 0) {
    return stickerSlabPrice;
  }

  // If a real API or explicit price is already present on the item, always prefer it.
  if (item) {
    // Prefer explicit numeric price fields set from Steam or elsewhere
    if (typeof item.price === "number" && !isNaN(item.price) && item.price > 0) {
      return item.price;
    }
    if (typeof item.numericPrice === "number" && !isNaN(item.numericPrice) && item.numericPrice > 0) {
      return item.numericPrice;
    }
    if (typeof item.steamPrice === "number" && !isNaN(item.steamPrice) && item.steamPrice > 0) {
      return item.steamPrice;
    }
  }

  const name = item.name || "";
  const baseName = name.split(' (')[0].trim();
  if (name.toLowerCase().includes("storage unit")) return 0;

  // 1. Check global price fixes (Katowice 2014 etc) first to ensure consistency
  if (PRICE_FIXES[name] !== undefined) return PRICE_FIXES[name];
  if (PRICE_FIXES[baseName] !== undefined) return PRICE_FIXES[baseName];

  // 2. Check user-defined overrides
  if (state.priceOverrides && state.priceOverrides[name]) return state.priceOverrides[name];
  if (state.priceOverrides && state.priceOverrides[baseName]) return state.priceOverrides[baseName];

  const hardcodedKey = MARKET_KEYS.find(k => k.name === name);
  if (hardcodedKey && hardcodedKey.price > 0) return hardcodedKey.price;

  const r = item.rarity?.name || "";

  const isSpecial = name.includes("★") || 
                    name.includes("Knife") || 
                    name.includes("Gloves") || 
                    (item.category?.name && item.category.name.toLowerCase().includes("knife")) ||
                    (item.category?.name && item.category.name.toLowerCase().includes("gloves"));

  const n = name.toLowerCase();
  if (isSpecial) {
    // Case Hardened special treatment: ensure it has a range if it was missed
    if (n.includes("case hardened") && !n.includes("★")) {
      return seededRandomFromName(name, 15, 450);
    }
    // Base floor for generic special items (knives / gloves) – toned down
    let min = 40, max = 700;

    // Specific Knife Type Base Floors (still ordered, but cheaper overall)
    if (n.includes("vanilla") && !n.includes("|")) {
      return seededRandomFromName(name, 400, 1600);
  }
  if (n.includes("karambit") || n.includes("butterfly") || n.includes("m9 bayonet")) {
      min = 1200; max = 4500;
    } else if (n.includes("bayonet") || n.includes("skeleton") || n.includes("nomad") || n.includes("talon")) {
      min = 300; max = 1200;
    } else if (n.includes("stiletto") || n.includes("ursus") || n.includes("paracord") || n.includes("classic knife")) {
      min = 150; max = 600;
    } else if (n.includes("navaja") || n.includes("shadow daggers") || n.includes("gut knife") || n.includes("falchion")) {
      min = 40; max = 220;
    } else if (n.includes("huntsman") || n.includes("bowie") || n.includes("survival")) {
      min = 90; max = 420;
    }

    // Finish Tier Overrides (Gems, High Tier, etc) – also reduced
    if (n.includes("sapphire") || n.includes("ruby") || n.includes("emerald") || n.includes("blue gem") || n.includes("black pearl")) {
      min = 2500; max = 16000;
    } else if (n.includes("doppler") || n.includes("fade") || n.includes("lore") || n.includes("marble fade")) {
      min = Math.max(min, 600); max = Math.max(max, 5500);
    } else if (n.includes("slaughter") || n.includes("tiger tooth") || n.includes("autotronic") || n.includes("crimson web")) {
      min = Math.max(min, 300); max = Math.max(max, 2800);
    } else if (n.includes("vanilla") || (!n.includes("|") && (n.includes("knife") || n.includes("bayonet")))) {
      min = Math.max(min, 180); max = Math.max(max, 1500);
    } else if (n.includes("case hardened")) {
      min = Math.max(min, 220); max = Math.max(max, 4500);
    } else if (n.includes("safari mesh") || n.includes("boreal forest") || n.includes("forest ddpat") || n.includes("scorched") || n.includes("urban masked")) {
      // Keep low for "shit tier" finishes
      max = Math.min(max, 260);
    }

    return seededRandomFromName(name, min, max);
  }
  if (n.includes("package")) {
     // Packages start at $20, older = more expensive
     const yearMatch = n.match(/20(\d{2})/);
     const year = yearMatch ? parseInt(yearMatch[1]) : 25;
     const age = 25 - year;
     const basePkg = 20 + (age * 15);
     return seededRandomFromName(name, basePkg, basePkg * 2.5);
  }

  if (r.includes("Covert") || r.includes("Extraordinary")) {
    // Tightened to prevent "125 gun at 414"
    return seededRandomFromName(name, 15, 180);
  }
  if (r.includes("Classified")) {
    return seededRandomFromName(name, 6, 45);
  }
  if (r.includes("Restricted")) {
    return seededRandomFromName(name, 1.5, 12);
  }
  if (r.includes("Mil-Spec")) {
    return seededRandomFromName(name, 0.4, 4.5);
  }
  return seededRandomFromName(name, 0.03, 1.20);
}

// Helpers to create fake CS2 data that isn't in the API
function mockRarity(name, price) {
  // For guns/knives/gloves, choose a truly random rarity from the canonical list so each draw is random.
  const n = String(name || "").toLowerCase();

  const isWeaponLike = n.includes("|") || n.includes("★") || n.includes("knife") || n.includes("gloves") ||
                       n.includes("ak-47") || n.includes("m4a4") || n.includes("awp") || n.includes("glock") ||
                       n.includes("usp-s") || n.includes("desert eagle") || n.includes("p90") || n.includes("karambit") ||
                       n.includes("butterfly") || n.includes("m9") || n.includes("bayonet") || n.includes("falchion");

  // If it's weapon-like, pick a random rarity uniformly from RARITIES (truly random per item).
  if (isWeaponLike) {
    if (n.includes("m4a4 | howl")) return "Covert";
    if (n.includes("case hardened")) return n.includes("★") ? "Covert" : "Classified";
    const idx = Math.floor(Math.random() * RARITIES.length);
    return RARITIES[idx];
  }

  // Non-weapon fallback: preserve price-based heuristic for non-weapon items.
  const isGreyType = !n.includes("capsule") && (
    n.includes("key") || 
    n.includes("case") || 
    n.includes("tool") || 
    n.includes("pass") || 
    n.includes("storage unit") ||
    n.includes("package")
  );
  if (isGreyType) return "Base Grade";

  if (price > 35) return "Covert";
  if (price > 10) return "Classified";
  if (price > 3) return "Restricted";
  if (price > 0.8) return "Mil-Spec";
  return "Industrial";
}

