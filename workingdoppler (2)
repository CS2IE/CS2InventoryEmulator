function renderCoinflipPickerItems(query = "") {
  const account = getActiveAccount();
  const invDiv = document.getElementById("coinflipPickerInventory");
  invDiv.innerHTML = "";

  const equippedIds = Array.isArray(account.equippedItemIds) ? account.equippedItemIds : [];
  const pool = account.items.filter(it => {
    // Protection: Blacklist equipped items from gambling deposit systems
    if (equippedIds.includes(it.id)) return false;

    const n = it.name.toLowerCase();
    const t = (it.type || it.category?.name || "").toLowerCase();
    const isBad = n.includes("music kit") || n.includes("charm") || n.includes("collectible") || 
                  n.includes("package") || n.includes("case") || n.includes("storage unit") || 
                  n.includes("sticker") || n.includes("agent") || n.includes("pin") || n.includes("graffiti") ||
                  n.includes("capsule");
    if (isBad) return false;
    const isGun = t.includes("rifle") || t.includes("pistol") || t.includes("smg") || 
                  t.includes("sniper") || t.includes("shotgun") || t.includes("machine") || 
                  n.includes("|");
    const isKnife = t.includes("knife") || n.includes("★") || n.includes("knife") || n.includes("gloves") || t.includes("gloves");
    if (query && !it.name.toLowerCase().includes(query)) return false;
    return (isGun || isKnife);
  }).sort((a,b) => getItemValue(b) - getItemValue(a));

  pool.forEach(it => {
    const card = createTradeCard(it, () => {
      const idx = coinflipSelectedSkins.findIndex(s => s.id === it.id);
      if (idx === -1) {
        if (coinflipSelectedSkins.length >= 10) return alert("You can only deposit up to 10 items in a Coinflip.");
