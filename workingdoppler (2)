function getDisplayNameWithPhase(itemOrName) {
  const rawName = typeof itemOrName === "string"
    ? itemOrName
    : String(itemOrName?.name || itemOrName?.hash_name || "");
  if (!rawName) return "";

  let displayName = getDisplayItemName(rawName);
  if (/doppler/i.test(rawName)) {
    const item = (typeof itemOrName === "string") ? { name: rawName } : (itemOrName || { name: rawName });
    const phase = getExplicitDopplerPhaseLabel(item) || deriveDopplerPhaseLabel(item) || extractExplicitDopplerPhase(rawName) || "";
    if (phase && !displayName.toLowerCase().includes(phase.toLowerCase())) {
      displayName = displayName.replace(/(Gamma Doppler|Doppler)$/i, `$1 (${phase})`);
    }
  }
  return displayName;
}

