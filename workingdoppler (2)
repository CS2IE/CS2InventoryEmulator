}

/**
 * Generate a float value appropriate for a given wear and rarity.
 * For rarer outcomes we allow a small chance to produce extremely small floats
 * with many leading zeros (up to 5 zero digits after the decimal).
 *
 * - name: item name (string)
 * - wear: wear string (Factory New, Minimal Wear, ...)
 * - rarity: rarity string ("Mil-Spec","Restricted","Classified","Covert","Gold", etc.)
 *
 * Returns a number between 0 and 1 (or null if wear is falsy).
 */
function generateFloatForWear(name, wear, rarity) {
  if (!wear) return null;

  let min = 0, max = 1;
  if (wear === "Factory New") { min = 0.0001; max = 0.0699; } 
  else if (wear === "Minimal Wear") { min = 0.0701; max = 0.1499; }
  else if (wear === "Field-Tested") { min = 0.1501; max = 0.3799; }
  else if (wear === "Well-Worn") { min = 0.3801; max = 0.4499; }
  else if (wear === "Battle-Scarred") { min = 0.4501; max = 0.9999; }
  else { min = 0.0001; max = 0.9999; }

  let val;
  if (wear === "Factory New" && Math.random() < 0.03) {
    val = min + (Math.random() * Math.min(max - min, 0.009999999999));
  } else if (wear === "Battle-Scarred" && Math.random() < 0.03) {
    val = Math.max(min, 0.9) + (Math.random() * (max - Math.max(min, 0.9)));
  } else {
    val = min + (Math.random() * (max - min));
  }
  return parseFloat(val.toFixed(12));
}

function getBotTradeFloatForWear(name, wear, rarity) {
  const floatVal = generateFloatForWear(name, wear, rarity);
  if (floatVal === null || floatVal === undefined || isNaN(floatVal)) return null;

  if (wear === "Factory New") return Math.max(floatVal, 0.02 + (Math.random() * 0.035));
  if (wear === "Minimal Wear") return Math.max(floatVal, 0.08 + (Math.random() * 0.05));
  if (wear === "Field-Tested") return Math.max(floatVal, 0.18 + (Math.random() * 0.12));
  return floatVal;
}

