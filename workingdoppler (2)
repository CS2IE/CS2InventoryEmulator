          e.preventDefault();
          forcedCaseWinner = item.name;
          forcedCaseRarity = r;
        });

        grid.appendChild(card);
      });
    });
  } else {
    // If the case DB lacks a detailed listing, try to show any compatible keys/cases instead of a dismissive message.
    // Build a helpful fallback that surfaces mapped keys or the first matching cases in KEY_CASE_MAP.
    grid.innerHTML = "";
    const hint = document.createElement("div");
    hint.style.gridColumn = "1/-1";
    hint.style.color = "#94a3b8";
    hint.style.padding = "12px";
    hint.style.textAlign = "left";

    // Attempt to find compatible keys that map to this case (reverse lookup)
    const mappedKeys = [];
    for (const [keyName, cases] of Object.entries(KEY_CASE_MAP || {})) {
      if (!Array.isArray(cases)) continue;
      if (cases.some(cn => cn && cn.toLowerCase().trim() === caseName.toLowerCase().trim() ||
                          (caseName.toLowerCase().trim().includes((cn || "").toLowerCase().trim())))) {
        mappedKeys.push(keyName);
      }
    }

    // Prefer showing related CASES/containers (never surface keys in the unlock contents fallback).
      const relatedPool = Array.from(new Set([
        ...Object.keys(CASE_CONTENTS_DB || {}),
        ...apiCrates.map(crate => crate?.name).filter(Boolean)
      ]));
      const relatedCandidates = relatedPool.filter(cn => {
        const base = cn.toLowerCase();
        const target = caseName.toLowerCase();
        // prefer close textual matches or generic container names
        const shared = target.split(/\s+/).some(tok => tok.length > 2 && base.includes(tok));
        return shared || base.includes('case') || base.includes('capsule') || base.includes('package') || base.includes('crate');
      });

    const fallbackCandidates = relatedCandidates.length ? relatedCandidates.slice(0,6) : relatedPool.slice(0,6);

    if (fallbackCandidates.length > 0) {
      hint.innerHTML = `<div style="font-weight:800; margin-bottom:8px;">No detailed contents found for \"${escapeHtml(caseName)}\" — showing related containers:</div>`;
      const list = document.createElement("div");
      list.style.display = "flex";
      list.style.flexWrap = "wrap";
      list.style.gap = "10px";
      fallbackCandidates.forEach(cn => {
        const card = document.createElement("div");
        card.style.display = "flex";
        card.style.flexDirection = "column";
        card.style.alignItems = "center";
        card.style.width = "140px";
        card.style.padding = "8px";
        card.style.background = "rgba(0,0,0,0.25)";
        card.style.border = "1px solid rgba(255,255,255,0.03)";
        card.style.borderRadius = "8px";
        card.innerHTML = `
          <img src="${getDisplayImage({name: cn})}" style="width:100%; height:90px; object-fit:contain; margin-bottom:8px;">
          <div style="font-size:12px; font-weight:700; text-align:center;">${escapeHtml(cn)}</div>
        `;
        card.onclick = () => showCaseConfirmForCaseName(cn);
        list.appendChild(card);
      });
      hint.appendChild(list);
    } else {
      hint.innerHTML = `<div style="color:#94a3b8;">No related containers found for this case.</div>`;
    }

    grid.appendChild(hint);
  }

  confirmModal.classList.remove("hidden");
  
  // Hide Open button if user doesn't own the case/key and is just viewing contents
  const ownedCasesCount = account ? account.items.filter(it => (it.name || "").split(' (')[0].trim() === caseName).length : 0;
  if (previewOnly || ownedCasesCount === 0) {
    confirmBtn.classList.add("hidden");
  } else {
    confirmBtn.classList.remove("hidden");
  }

  // Right-click behavior: open case normally but rig the odds to gold
  confirmBtn.oncontextmenu = (e) => {
    e.preventDefault();
    e.stopPropagation();
    guaranteedKnifeNext = true;
    confirmBtn.click();
  };

  // Bind confirm behavior: when confirmed, create the case item in inventory and open it immediately (consuming a key if available)
  confirmBtn.onclick = () => {
      playCaseUnlockSound();
    // Defensive guard: ensure modal is hidden and we have a valid active account & case before trying to open.
    try {
      document.querySelectorAll('.modal-overlay').forEach(m => m.classList.add("hidden"));
    } catch (e) {}

    try {
      const acc = getActiveAccount();
      if (!acc) {
        console.warn("openCase aborted: no active account.");
        return;
      }

      // Validate caseItem exists and has a name
      if (!caseItem || !caseItem.name) {
        console.warn("openCase aborted: caseItem is missing or invalid.", { caseItem });
        return;
      }

      // Try to find an OWNED instance of this case first (do NOT consume anything yet).
      // We will call openCase(..., true) to actually consume when the user confirmed.
      const ownedCase = acc.items.find(it => {
        const itBase = (it.name || "").split(' (')[0].trim();
        const targetBase = caseName.split(' (')[0].trim();
        return it.name === caseName || itBase === targetBase;
      });

      if (ownedCase) {
        // Use the existing owned case and open it (this call will consume the case/key)
        openCase(ownedCase.id, true, sourceKeyId, 1);
        // Ensure NEW ITEMS popup shows after confirming an owned-case open
        try { showGroupedPurchaseResult(); } catch (e) { console.warn("showGroupedPurchaseResult failed after confirmOpen:", e); }
        return;
      }

      // If user doesn't own the case, create it then open (creation only happens upon explicit confirm)
      const newCase = {
        id: "it_case_temp_" + Date.now() + "_" + Math.random().toString(16).slice(2),
        name: caseName,
        img: getDisplayImage({ name: caseName }),
        price: PRICE_FIXES[caseName] || mockPrice({ name: caseName }),
        rarity: "Base Grade",
        type: "Container",
        contents: []
      };
      acc.items.push(newCase);
      saveState();
      // Now open and consume the newly created case
      openCase(newCase.id, true, sourceKeyId, 1);
    } catch (err) {
      console.error("Error in case confirm handler:", err);
      // Ensure the modal is closed and UI remains stable
      try { confirmModal.classList.add("hidden"); } catch (e) {}
    }
  };

  // Cancel closes the modal
  cancelBtn.onclick = () => {
    confirmModal.classList.add("hidden");
  };
}

/**
 * Opens a modal to edit all properties of a specific item instance.
 */
function showEditItemModal(item) {
  const modal = document.getElementById("editItemModal");
  const rawName = item.name || "";
  const baseName = rawName.replace(/^StatTrak™\s+/i, "");
  document.getElementById("editItemName").value = baseName;
  const stattrakCheckbox = document.getElementById("editItemStatTrak");
  if (stattrakCheckbox) stattrakCheckbox.checked = rawName.includes("StatTrak™");
  const nametagField = document.getElementById("editItemNametag");
  if (nametagField) nametagField.value = item.nametag || "";
  const rarityField = document.getElementById("editItemRarity");
  if (rarityField) rarityField.value = item.rarity || "Consumer";
  document.getElementById("editItemWear").value = item.wear || "";
  const frSelect = document.getElementById("editItemFloatRank");
  if (frSelect) frSelect.value = item.floatRank || 0;
  
  const poInput = document.getElementById("editMarketPrevOwners");
  if (poInput) poInput.value = item.prevOwners || 0;

  // Format float to a readable fixed representation if present, otherwise show empty so user knows it's optional
  const floatField = document.getElementById("editItemFloat");
  if (floatField) {
    if (typeof item.floatVal === "number" && !isNaN(item.floatVal)) {
      floatField.value = formatFloat(item.floatVal);
    } else {
      floatField.value = "";
    }
  }

  // Prefill quantity input if present; leave empty to indicate "no change"
  const qtyField = document.getElementById("editItemQty");
  if (qtyField) {
    let existingQty = (typeof item.qty === "number" && !isNaN(item.qty)) ? item.qty : (item.qty || 1);
    try {
      const acc = getActiveAccount();
      const containerInfo = findItemContainer(acc, item.id);
      const container = containerInfo?.container || acc?.items || [];
      if (item._stackGroupId) {
        const groupedCount = container.filter(it => it && it._stackGroupId === item._stackGroupId).length;
        if (groupedCount > 0) existingQty = groupedCount;
      }
    } catch (e) {}
    // show existing qty so user can edit; allow blank to keep unchanged if desired
    qtyField.value = existingQty;
  }

  document.getElementById("editItemSource").value = item.source || "";
  // Show price formatted with 2 decimals when available, otherwise empty so saving doesn't overwrite with 0
  const priceField = document.getElementById("editItemPrice");
  if (priceField) {
    if (typeof item.price === "number" && !isNaN(item.price) && item.price > 0) {
      priceField.value = Number(item.price).toFixed(2);
    } else {
      priceField.value = "";
      priceField.placeholder = "Leave blank to keep existing";
    }
  }

  document.getElementById("editItemImg").value = item.img || "";
  
  // Set pattern template template field
  const pattField = document.getElementById("editItemPattern");
  if (pattField) {
      pattField.value = (item.pattern !== undefined && item.pattern !== null) ? item.pattern : "";
  }

  // Set specific pattern image field
  const pattImgField = document.getElementById("editItemPatternImg");
  if (pattImgField) {
      pattImgField.value = (state.patternImageOverrides?.[rawName]?.[item.pattern]) || "";
  }

  // Store target ID in the button for the save handler
  document.getElementById("saveEditItemBtn").dataset.targetId = item.id;
  modal.classList.remove("hidden");

  // Focus the name field for convenience
  setTimeout(() => {
    const nameInput = document.getElementById("editItemName");
    if (nameInput) nameInput.focus();
  }, 50);
}

/**
 * Persists the changes from the Edit Item modal to the state.
 */
function saveEditedItem() {
  const itemId = document.getElementById("saveEditItemBtn").dataset.targetId;
  const account = getActiveAccount();
  if (!account || !itemId) return;

  const item = findItemById(account, itemId);
  if (!item) return;
  const containerInfo = findItemContainer(account, itemId);
  const previousName = item.name || "";

  // Update properties from inputs
  const newName = document.getElementById("editItemName").value.trim();
  const stattrakChecked = !!document.getElementById("editItemStatTrak")?.checked;
  const nametagInput = document.getElementById("editItemNametag")?.value || "";
  const newWear = document.getElementById("editItemWear").value || null;
  const newRarity = document.getElementById("editItemRarity").value;

  // Float: accept empty to leave unchanged; otherwise parse and clamp
  const floatInput = document.getElementById("editItemFloat").value;
  let newFloat = null;
  if (floatInput !== null && floatInput !== undefined && String(floatInput).trim() !== "") {
    const parsedFloat = parseFloat(floatInput);
    newFloat = (!isNaN(parsedFloat)) ? Math.max(0, Math.min(0.999999999, parsedFloat)) : null;
  } else {
    // preserve existing float if user left field blank
    newFloat = (item.floatVal !== undefined && item.floatVal !== null) ? item.floatVal : null;
  }

  const newSource = document.getElementById("editItemSource").value.trim();

  // Price: if left blank, do not overwrite existing price; if provided, parse
  const priceInputRaw = document.getElementById("editItemPrice").value;
  const newImg = document.getElementById("editItemImg").value.trim();
  const newPatternVal = parseInt(document.getElementById("editItemPattern")?.value);
  const newPatternImg = document.getElementById("editItemPatternImg")?.value.trim();

  // Apply pattern image override if provided
  if (!isNaN(newPatternVal) && newPatternImg) {
      if (!state.patternImageOverrides) state.patternImageOverrides = {};
      if (!state.patternImageOverrides[newName || item.name]) state.patternImageOverrides[newName || item.name] = {};
      state.patternImageOverrides[newName || item.name][newPatternVal] = newPatternImg;
  }

  // Apply edits to this item instance strictly
  let finalName = newName || item.name || "";
  const cleanBaseName = finalName.replace(/^StatTrak™\s+/i, "").trim();
  if (cleanBaseName) {
    finalName = stattrakChecked ? `StatTrak™ ${cleanBaseName}` : cleanBaseName;
  }
  if (previousName !== finalName) {
    moveNamedOverride(state.imageOverrides, previousName, finalName);
    moveNamedOverride(state.rarityOverrides, previousName, finalName);
    moveNamedOverride(state.patternImageOverrides, previousName, finalName);
  }
  item.name = finalName || item.name;
  item.wear = newWear;
  item.rarity = newRarity;
  item.floatVal = newFloat;
  if (!isNaN(newPatternVal)) item.pattern = newPatternVal;
  item.source = newSource || item.source;
  item.nametag = String(nametagInput).trim() || null;
  item.floatRank = parseInt(document.getElementById("editItemFloatRank")?.value) || 0;
  if (newImg) {
    item.img = newImg;
    item.image = newImg;
    setPersistentImageOverride(finalName || item.name, newImg);
  } else {
    item.img = "";
    item.image = "";
    setPersistentImageOverride(finalName || item.name, "");
  }
  syncItemWearImage(item);

  // Add pattern randomization/sync if float changed
  if (newFloat !== null && item.pattern === null) {
    item.pattern = Math.floor(Math.random() * 1000);
  }

  // Update quantity strictly for this instance by appending new unique clones
  try {
    const qtyInputVal = document.getElementById("editItemQty")?.value;
    if (qtyInputVal !== null && qtyInputVal !== undefined && String(qtyInputVal).trim() !== "") {
      const parsedQty = parseInt(qtyInputVal, 10);
      if (!isNaN(parsedQty) && parsedQty > 1) {
        const container = containerInfo?.container || account.items;
        const toAdd = parsedQty - 1;
        for (let i = 0; i < toAdd; i++) {
          const clone = JSON.parse(JSON.stringify(item));
          clone.id = "it_" + Date.now() + "_" + Math.random().toString(16).slice(2) + "_clone" + i;
          clone.qty = 1;
          container.push(clone);
        }
      }
    }
  } catch (e) {
    console.warn("Edit qty failed:", e);
  }

  // Only update price if user provided a value; leaving blank keeps current price
  if (priceInputRaw !== null && priceInputRaw !== undefined && String(priceInputRaw).trim() !== "") {
    const priceVal = parseFloat(priceInputRaw);
    if (!isNaN(priceVal) && priceVal > 0) {
      item.price = priceVal;
    }
  }

  saveState();
  refreshInventoryView();
  showDetails(item);
  document.getElementById("editItemModal").classList.add("hidden");
}

function populateDetailsDOM(root, item) {
  if (!item) return;
  const img = root.querySelector("#detailsImage");
  
  // Logic Fix: Ensure StatTrak™ is included in the name display in details if missing
  if (String(item.name || "").toLowerCase().includes("stattrak") && !String(item.name || "").includes("StatTrak™")) {
      item.name = item.name.replace(/stattrak/i, "StatTrak™");
