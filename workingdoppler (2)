      if (state.realMarket) {
          state.bidSkinListings.splice(idx, 1);
          state.pinnedListingIds = state.pinnedListingIds.filter(x => x !== id);
      }

      bsConfirmModal.remove();
      saveState();
      refreshInventoryView();
      updateWalletDisplay();
      openBidSkinMarket();
      if (gridEl) gridEl.scrollTop = currentScroll;
      showGroupedPurchaseResult();
    };

    bsConfirmModal.querySelector("#bsFinalConfirm").onclick = () => finalize(false);
    bsConfirmModal.querySelector("#bsFreeOkay").onclick = () => finalize(true);
    bsConfirmModal.querySelector("#bsFinalCancel").onclick = () => bsConfirmModal.remove();
  };

  setTimeout(renderModal, 0);

  setTimeout(() => {
    const historyBtn = document.getElementById("showMarketHistoryBtn");
    if (historyBtn) historyBtn.onclick = () => window.showMarketPurchaseHistory();
  }, 10);

  // Track close event to clear blur
  const closeBtn = modal.querySelector(".close-snippet-modal");
  if (closeBtn) {
    const oldOnclick = closeBtn.onclick;
    closeBtn.onclick = () => {
       if (oldOnclick) oldOnclick();
       updateModalBlurState();
    };
  }
  
  // Logic Fix: Same for database modal
  const dbModal = document.getElementById("databaseModal");
  if (dbModal) {
    const dbClose = dbModal.querySelector(".steam-btn.grey");
    if (dbClose) {
      const old = dbClose.onclick;
      dbClose.onclick = () => {
        if (old) old();
        updateModalBlurState();
      };
    }
  }

  const refreshBtn = document.getElementById("bsRefreshBtn");
  if (refreshBtn) {
    refreshBtn.onclick = () => {
      openBidSkinMarket(true);
    };
  }

  const addBtn = modal.querySelector("#addMarketItemBtn");
  if (addBtn) {
    addBtn.onclick = () => {
      alert("Item listed as 1-of-1 (#1) on BidSkin.com!");
    };
  }

  modal.classList.remove("hidden");
}

