async function generateCompositeImage(item, positions) {
  const c = document.createElement("canvas");
  c.width = 1024;
  c.height = 768;
  const ctx = c.getContext("2d");
  
  const loadImage = (src) => new Promise(res => {
    const i = new Image();
    i.crossOrigin = "anonymous";
    i.onload = () => res(i);
    i.onerror = () => res(null);
    i.src = src;
  });

  const baseImgSrc = getStableDisplayImage({ ...item, customLayout: { enabled: false } });
  const gunImgObj = await loadImage(baseImgSrc);
  
  if (gunImgObj) {
    const aspect = gunImgObj.width / gunImgObj.height;
    let drawW = c.width * 0.9;
    let drawH = drawW / aspect;
    if (drawH > c.height * 0.9) {
      drawH = c.height * 0.9;
      drawW = drawH * aspect;
    }
    ctx.drawImage(gunImgObj, (c.width - drawW)/2, (c.height - drawH)/2, drawW, drawH);
  }

  const stickers = item.stickers || [];
  for (const pos of positions) {
    const sData = stickers[pos.idx];
    if (!sData) continue;
    const sImgObj = await loadImage(sData.img);
    if (sImgObj) {
      const sw = 100 * pos.scale;
      const sh = (sImgObj.height / sImgObj.width) * sw;
      const cx = (pos.x / 100) * c.width;
      const cy = (pos.y / 100) * c.height;
      ctx.drawImage(sImgObj, cx - sw/2, cy - sh/2, sw, sh);
    }
  }
  return c.toDataURL("image/png");
}

