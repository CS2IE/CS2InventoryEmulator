function accountHasItemName(account, names) {
  const targetNames = (Array.isArray(names) ? names : [names]).map(name => String(name || "").toLowerCase().trim()).filter(Boolean);
  if (!account || !targetNames.length) return false;
  const stack = Array.isArray(account.items) ? [...account.items] : [];
  while (stack.length) {
    const current = stack.pop();
    const currentName = String(current?.name || "").toLowerCase().split(" (")[0].trim();
    if (targetNames.includes(currentName)) return true;
    if (Array.isArray(current?.contents)) stack.push(...current.contents);
  }
  return false;
}

function itemMatchesLoadoutType(item, slotId, typeFilter) {
  const n = String(item?.name || "").toLowerCase();
  const t = String(item?.type || item?.category?.name || "").toLowerCase();
  const filter = String(typeFilter || slotId || "").toLowerCase();
  const hasKnifeStar = n.includes("★") || n.includes("â˜…");

  if (slotId === "knife" && (t.includes("knife") || hasKnifeStar || n.includes("knife"))) return true;

  if (slotId === "agent") return t.includes("agent") || n.includes("agent");
  if (slotId === "knife") return t.includes("knife") || n.includes("★") || n.includes("knife");
  if (slotId === "gloves") return t.includes("gloves") || n.includes("gloves");
  if (slotId === "music") return n.includes("music kit");
  if (slotId === "charm") return n.includes("charm") || n.includes("keychain");
  if (slotId === "pin") return n.includes("pin") || n.includes("collectible");

  if (n.includes("knife") || n.includes("★") || n.includes("gloves") || t.includes("knife") || t.includes("gloves")) {
    return false;
  }

  if (filter === "usp-s") return n.includes("usp-s");
  if (filter === "glock-18") return n.includes("glock-18");
  if (filter === "m4a4") return n.includes("m4a4");
  if (filter === "m4a1-s") return n.includes("m4a1-s");
  if (filter === "ak-47") return n.includes("ak-47");
  if (filter === "awp") return n.includes("awp");
  if (filter === "galil ar") return n.includes("galil ar") || n.includes("galil");

  return n.includes(filter) || t.includes(filter);
}

