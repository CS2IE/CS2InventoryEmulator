    const isGun =
      type.includes("rifle") ||
      type.includes("pistol") ||
      type.includes("smg") ||
      type.includes("sniper") ||
      type.includes("shotgun") ||
      type.includes("machine") ||
      n.includes("ak-47") || n.includes("m4a4") || n.includes("m4a1-s") ||
      n.includes("awp") || n.includes("glock") || n.includes("usp-s") ||
      n.includes("desert eagle") || n.includes("p250") || n.includes("five-seven") ||
      n.includes("tec-9") || n.includes("p90") || n.includes("mp9") ||
      n.includes("mac-10") || n.includes("famas") || n.includes("galil") ||
      n.includes("sg 553") || n.includes("aug") || n.includes("scout") ||
      n.includes("scar-20") || n.includes("g3sg1") || n.includes("mag-7") ||
      n.includes("nova") || n.includes("sawed-off") || n.includes("xm1014") ||
      n.includes("m249") || n.includes("negev");

    const isKnife = type.includes("knife") || n.includes("★") || n.includes("knife");
    const isGloves = n.includes("gloves");
    const isBadCategory =
      n.includes("case") || n.includes("key") || n.includes("sticker") ||
      n.includes("charm") || n.includes("capsule") || n.includes("crate") ||
      n.includes("package") || n.includes("storage unit") || n.includes("music kit") ||
      n.includes("pass") || n.includes("graffiti") || n.includes("agent") ||
      n.includes("pin") || n.includes("tool") || type.includes("container");

    const isEquippable = (isGun || isKnife || isGloves) && !isBadCategory;

    const activeAccount = getActiveAccount();
    const itemBelongsToActive =
      activeAccount && Array.isArray(activeAccount.items) &&
      activeAccount.items.some(i => i.id === item.id);

    if (!itemBelongsToActive || !activeAccount) {
      // You can only equip items on the currently active account
      equipBtn.classList.add("hidden");
    } else {
      if (!Array.isArray(activeAccount.equippedItemIds)) {
        activeAccount.equippedItemIds = [];
      }
      // Keep equipped set authoritative for this account (remove stale ids and dedupe)
      const activeEquippedSet = new Set(activeAccount.equippedItemIds.filter(id => activeAccount.items.some(it => it.id === id)));
      const equippedCount = activeEquippedSet.size;
        const equippedSides = getLoadoutSidesForItem(item.id);
        const isEquipped = activeEquippedSet.has(item.id) || equippedSides.length > 0;

      if (isEquippable) {
        equipBtn.classList.remove("hidden");
        equipBtn.textContent = isEquipped ? "UNEQUIP" : "EQUIP";
        equipBtn.style.background = isEquipped ? "#1a44c2" : "#2a475e";
        equipBtn.onclick = (e) => {
          e.stopPropagation();
          // Refresh authoritative list before mutating
          activeAccount.equippedItemIds = Array.from(activeEquippedSet);
            if (equippedSides.length || activeEquippedSet.has(item.id)) {
              activeAccount.equippedItemIds = activeAccount.equippedItemIds.filter(id => id !== item.id);
              ["ct", "t"].forEach(side => {
                Object.keys(state.loadout?.[side] || {}).forEach(slotId => {
                  if (state.loadout[side][slotId] === item.id) state.loadout[side][slotId] = null;
                });
              });
              saveState();
              refreshInventoryView();
              populateDetailsDOM(root, item);
              if (state.realEquip) renderLoadoutUI();
            } else {
              showEquipSidePicker(item, (side) => {
                const sidesToEquip = side === "both" ? ["t", "ct"] : [side];
                const failedSide = sidesToEquip.find(targetSide => !equipItemToLoadoutSide(activeAccount, item, targetSide).ok);
                if (failedSide) return;
                playTickSound(880, 0.1);
                saveState();
                refreshInventoryView();
                populateDetailsDOM(root, item);
                if (state.realEquip) renderLoadoutUI();
              });
              return;
            }
          };
      } else {
        equipBtn.classList.add("hidden");
      }
    }
  }

  const editBtn = root.querySelector("#editItemBtn");
  if (editBtn) {
    if (item.name.toLowerCase().includes("storage unit")) {
      editBtn.textContent = "Edit Name Tag";
      editBtn.onclick = () => showNametagModal(item.id);
    } else {
      editBtn.textContent = "Edit Item Data";
      editBtn.onclick = () => {
        // User requested: Edit button must always open the global "Edit Market Item" popup
        selectedSearchItem = {
          name: item.name,
          originalName: item.name,
          image: item.img || getDisplayImage(item),
          price: item.price,
          rarity: item.rarity,
          raw: null
        };
        showEditMarketModal();
      };
    }
  }

  const openBtn = root.querySelector("#openCaseBtn");
  const getBtn = root.querySelector("#getCounterpartBtn");
  const viewStorageBtn = root.querySelector("#viewStorageBtn");
  const isStorage = item.name.toLowerCase().includes("storage unit");
  
  if (viewStorageBtn) {
    if (isStorage) {
      viewStorageBtn.classList.remove("hidden");
      viewStorageBtn.onclick = () => {
        resetInventoryToDefaultView();
        state.viewingStorageUnitId = item.id;
        saveState();
        refreshInventoryView();
        // Close view modal if open
        document.getElementById("viewItemModal").classList.add("hidden");
      };
    } else {
      viewStorageBtn.classList.add("hidden");
    }
  }

  if (openBtn) {
    const isCase = isContainer(item);
    const baseName = item.name.split(' (')[0];
    const isKey = isKeyItem(item);
    const n = item.name.toLowerCase();
    const accountRef = getActiveAccount();

    if (getBtn) getBtn.classList.add('hidden');

    if (isKey) {
      // Normalization check for key-to-case mapping
      const matchedKeyName = Object.keys(KEY_CASE_MAP).find(k => k.toLowerCase() === baseName.toLowerCase());
      const caseNames = KEY_CASE_MAP[matchedKeyName] || [];
      const ownedCase = accountRef?.items.find(it => {
        const itName = it.name;
        if (matchedKeyName === "CS:GO Case Key" && itName.includes("CS:GO Weapon Case")) return true;
        return isContainer(it) && caseNames.some(cn => itName.startsWith(cn));
      });

      if (ownedCase) {
        openBtn.textContent = "Use Key on " + (ownedCase.nametag || ownedCase.name);
        openBtn.classList.remove('hidden');
        openBtn.onclick = () => {
          // Key popup logic: if item is selected, show its pairs
          openKeyCaseSelector(item);
        };
      } else {
        openBtn.classList.add('hidden');
        if (getBtn) {
          getBtn.textContent = "Get Case";
          getBtn.classList.remove('hidden');
          getBtn.onclick = () => {
             // Instead of a direct purchase, show the new selector layout
             openKeyCaseSelector(item);
          };
        }
      }
    } else if (isCase) {
      const requiredKeys = getRequiredKeysForCase(item.name);
      
      const isSouvenir = n.includes('souvenir') || n.includes('package');
      const isCapsule = n.includes('capsule') || n.includes('sticker') || n.includes('mlg columbus 2016');
      
      openBtn.textContent = isCapsule ? "Open Capsule" : "Open Case";
      openBtn.classList.remove('hidden');

      openBtn.oncontextmenu = (e) => {
        e.preventDefault();
        guaranteedKnifeNext = true;
      };
      
      openBtn.onclick = () => {
        let hasKey = false;
        if (requiredKeys.length > 0) {
           hasKey = accountRef?.items.some(it => {
             const itName = it.name.toLowerCase().split(' (')[0].trim();
             return requiredKeys.some(rk => rk.toLowerCase().trim() === itName);
           });
        } else {
           hasKey = true; 
        }

        if (hasKey) {
          // Show the Unlock Container confirmation modal instead of immediately opening the case
          showCaseConfirmForCaseName(item.name);
        } else {
          // If user has NO key, we show the Get Key popup directly or redirect
          if (requiredKeys.length > 0) {
             const keyName = requiredKeys[0];
             const keyItem = MARKET_KEYS.find(k => k.name === keyName) || allSkins.find(s => s.name === keyName);
             if (keyItem) {
               promptWearSelection(keyItem, keyItem.price || 2.50, (wear, qty, finalPrice, isCustom, extra = {}) => {
                 addItemToAccount({
                   name: keyItem.name,
                   img: keyItem.image || keyItem.img || getDisplayImage(keyItem),
                   price: finalPrice,
                   rarity: keyItem.rarity?.name || "Base Grade",
                   wear: wear,
                   type: keyItem.type || "Key",
                   qty,
                   isCustomPrice: isCustom,
                   source: "Purchased",
                   nametag: extra.nametag || null
                 });
                 setTimeout(() => {
                   showCaseConfirmForCaseName(item.name);
                 }, 150);
               }, { confirmMode: "purchase" });
             } else {
               alert("Key not found in database.");
             }
          } else {
             alert("Cannot determine key for this case.");
          }
        }
      };

      // Hide the separate Get Key button if we handle it in Open
      if (getBtn) getBtn.classList.add('hidden');

    } else if (isStorage) {
      openBtn.textContent = "Deposit / Retrieve Items";
      openBtn.classList.remove('hidden');
      openBtn.onclick = () => openStorageUnit(item.id);
    } else {
      openBtn.classList.add('hidden');
    }
  }

  // Bind all Inspect buttons to open details popup
  const inspectBtns = root.querySelectorAll(".steam-btn.grey");
  inspectBtns.forEach(btn => {
    if (btn.textContent.includes("Inspect")) {
      btn.onclick = () => showInspect(item);
    }
  });
}

/**
 * Toggle the 'modal-open' class on #app based on active modals.
 * Used for the CS2 background blur effect.
 */
function updateModalBlurState() {
  const app = document.getElementById("app");
  if (!app) return;
  
  // Find all active modal overlays. Consider hidden or display:none as inactive.
  const overlays = document.querySelectorAll(".modal-overlay");
  let hasVisible = false;
  
  overlays.forEach(m => {
    const isActuallyHidden = m.classList.contains("hidden") || m.style.display === "none";
    if (!isActuallyHidden) {
      // Ignore specific results popups from causing blur if they are empty
      if (m.id === "purchaseResultModal" && purchaseResultList.length === 0) return;
      hasVisible = true;
    }
  });

  if (hasVisible) {
    app.classList.add("modal-open");
  } else {
    app.classList.remove("modal-open");
  }
}

// Global cleanup: ensure all Close clicks trigger a blur recalculation
document.addEventListener("click", (e) => {
  if (e.target.closest(".close-snippet-modal") || e.target.closest(".close-modal-btn") || e.target.closest(".btn-close-text")) {
    setTimeout(updateModalBlurState, 10);
  }
});

// Intercept Modal hidden states to update blur
const observer = new MutationObserver((mutations) => {
  let needsUpdate = false;
  mutations.forEach((mutation) => {
    if (mutation.type === "attributes" && mutation.attributeName === "class") {
      needsUpdate = true;
    } else if (mutation.type === "childList") {
      needsUpdate = true;
    }
  });
  if (needsUpdate) updateModalBlurState();
});

document.querySelectorAll(".modal-overlay").forEach(modal => {
  observer.observe(modal, { attributes: true });
});
observer.observe(document.body, { childList: true, subtree: false });

let guaranteedKnifeNext = false;
let forcedCaseWinner = null; // name chosen by right-click in case contents UI (silent)
let forcedCaseRarity = null; // recorded rarity (e.g. "Classified") for forcedCaseWinner

/**
 * Opens a case.
 * itemId: The ID of the container to open.
 * skipConfirm: If true, opens immediately.
 * keyToUseId: If provided, the specific ID of the key item to consume.
 */
async function openCase(itemId, skipConfirm = false, keyToUseId = null, openCount = 1) {
  const account = getActiveAccount();
  if (!account) return;

  // #region agent log
  try {
    fetch('http://127.0.0.1:7571/ingest/973990e6-fc1f-4f11-86a9-49eb649b9afe',{
      method:'POST',
      headers:{'Content-Type':'application/json','X-Debug-Session-Id':'6488ae'},
      body:JSON.stringify({
        sessionId:'6488ae',
        runId:'pre-fix',
        hypothesisId:'H1',
        location:'app.js:7047',
        message:'openCase entry',
        data:{itemId,skipConfirm,keyToUseId,openCount,hasAccount:!!account},
        timestamp:Date.now()
      })
    }).catch(()=>{});
  } catch(_) {}
  // #endregion agent log

  // ensure a safe caseName variable is available for downstream logic
  const caseName = (() => {
    try {
      const ci = account.items.find(it => it.id === itemId);
      return ci ? (ci.name || "").split(' (')[0].trim() : "";
    } catch (e) {
      return "";
    }
  })();

  // 1. Verify Case Existence
  const caseIndex = account.items.findIndex(it => it.id === itemId);

  // #region agent log
  try {
    fetch('http://127.0.0.1:7571/ingest/973990e6-fc1f-4f11-86a9-49eb649b9afe',{
      method:'POST',
      headers:{'Content-Type':'application/json','X-Debug-Session-Id':'6488ae'},
      body:JSON.stringify({
        sessionId:'6488ae',
        runId:'pre-fix',
        hypothesisId:'H2',
        location:'app.js:7062',
        message:'openCase caseIndex computed',
        data:{itemId,caseIndex,caseName},
        timestamp:Date.now()
      })
    }).catch(()=>{});
  } catch(_) {}
  // #endregion agent log

  // If the exact instance isn't found, defensively close any open case/case-opening UI,
  // attempt to fall back to a same-name instance; if none exists, abort and reset state so UI can continue.
  if (caseIndex === -1) {
    console.warn("openCase: case instance not found (id:", itemId, "). Attempting fallback by name.");
    // try fallback by name match (some callers may pass a case name as itemId)
    let fallbackCase = account.items.find(it => {
      const base = String(it.name || "").split(' (')[0].trim().toLowerCase();
      const passed = String(itemId || "").toLowerCase();
      return base === passed || it.id === itemId;
    });
    if (fallbackCase) {
      // if we found a same-named owned case, use it
      itemId = fallbackCase.id;
    } else {
      // No owned instance found: hide any case modals and reset opening flags so user can open other cases
      try {
        const confirmModal = document.getElementById("caseConfirmModal");
        if (confirmModal) confirmModal.classList.add("hidden");
        const openingModal = document.getElementById("caseOpeningModal");
        if (openingModal) openingModal.classList.add("hidden");
        // Reset transient reveal timers/flags
        if (window._caseRevealTimer) { clearTimeout(window._caseRevealTimer); window._caseRevealTimer = null; }
        if (window._caseStartTimer) { clearTimeout(window._caseStartTimer); window._caseStartTimer = null; }
        window._caseRevealNow = null;
        window._caseIsGoldReveal = false;
      } catch (e) { console.warn("openCase fallback cleanup failed:", e); }
      // No case to open; abort gracefully so user can continue.
      return;
    }
  }
  const caseItem = account.items.find(it => it.id === itemId);

  // #region agent log
  try {
    fetch('http://127.0.0.1:7571/ingest/973990e6-fc1f-4f11-86a9-49eb649b9afe',{
      method:'POST',
      headers:{'Content-Type':'application/json','X-Debug-Session-Id':'6488ae'},
      body:JSON.stringify({
        sessionId:'6488ae',
        runId:'pre-fix',
        hypothesisId:'H3',
        location:'app.js:7094',
        message:'openCase caseItem resolved',
        data:{itemId,hasCaseItem:!!caseItem,name:caseItem && caseItem.name},
        timestamp:Date.now()
      })
    }).catch(()=>{});
  } catch(_) {}
  // #endregion agent log

  // Defensive guard: if caseItem couldn't be resolved (race / caller passed wrong id), abort gracefully
  if (!caseItem) {
    try {
      console.warn('openCase aborted: caseItem missing or invalid', { itemId, accountId: account && account.id });
    } catch (e) { /* silent */ }
    // Hide any case-related UI that might be open to keep the UI stable
    try {
      const confirmModal = document.getElementById("caseConfirmModal");
      if (confirmModal) confirmModal.classList.add("hidden");
      const openingModal = document.getElementById("caseOpeningModal");
      if (openingModal) openingModal.classList.add("hidden");
      // Clear any transient timers/handlers used by case opening flow
      if (window._caseRevealTimer) { clearTimeout(window._caseRevealTimer); window._caseRevealTimer = null; }
      if (window._caseStartTimer) { clearTimeout(window._caseStartTimer); window._caseStartTimer = null; }
      window._caseRevealNow = null;
      window._caseIsGoldReveal = false;
    } catch (cleanupErr) {
      // ignore cleanup errors
    }
    return;
  }



  // 2. Determine and Verify Key Existence
  let keyIdx = -1;
  let noKeyNeeded = false;
  const n = caseItem.name.toLowerCase();
  const isSouvenir = n.includes('souvenir') || n.includes('package');

  // Explicitly treat DreamHack 2014 Legends (Holo/Foil) as keyless
  if (n.includes("dreamhack 2014 legends")) noKeyNeeded = true;

  // Special-case: treat sticker capsules as keyless by default (they're capsules),
  // but keep specific "Sticker Capsule 1/2" requiring keys.
  // This makes items like "Katowice 2019 Minor Challengers" openable without keys.
  const lowerName = n.toLowerCase();
  const looksLikeStickerCapsule = lowerName.includes("sticker") || lowerName.includes("capsule");
  const isExplicitCommunityOrSpecial = lowerName.includes("sticker capsule 1") ||
                                       lowerName.includes("sticker capsule 2");
  
  if (!noKeyNeeded) {
    noKeyNeeded = looksLikeStickerCapsule && !isExplicitCommunityOrSpecial;
  }
  // Havoc is keyless
  if (lowerName.includes("havoc collection")) noKeyNeeded = true;
  // Treat any container with "collection" in its name as keyless (explicit user rule)
  if (lowerName.includes("collection")) noKeyNeeded = true;
  // Ensure Katowice and similar historic sticker capsules/capsule-style containers are treated as keyless
  if (lowerName.includes("katowice")) noKeyNeeded = true;
  // Treat ESL One Cologne 2014 sticker capsules (Legends / Challengers) as keyless (no dedicated key or wear)
  if (lowerName.includes("esl one cologne") || lowerName.includes("esl one cologne 2014") || lowerName.includes("esl one cologne 2014 challengers") || lowerName.includes("esl one cologne 2014 legends")) {
    noKeyNeeded = true;
  }
  // Explicitly treat the 10 Year Birthday Sticker Capsule as keyless
  if (lowerName.includes("10 year birthday sticker capsule")) noKeyNeeded = true;
  // Explicitly treat the MLG Columbus 2016 Challengers capsule as keyless
  if (lowerName.includes("mlg columbus 2016")) noKeyNeeded = true;
  // False Odds takes no key
  if (lowerName.includes("false odds")) noKeyNeeded = true;
  // Norse Case takes no key
  if (lowerName.includes("norse")) noKeyNeeded = true;
  // Sealed terminals are keyless and should never prompt for a key
  if (lowerName.includes("genesis terminal") || lowerName.includes("dead hand terminal")) noKeyNeeded = true;
  // Achroma is keyless
  if (lowerName.includes("achroma collection")) noKeyNeeded = true;
  // The Radiant Collection is keyless
  if (lowerName.includes("radiant collection")) {
    noKeyNeeded = true;
  }

  if (!isSouvenir && !noKeyNeeded) {
    if (keyToUseId) {
      keyIdx = account.items.findIndex(it => it.id === keyToUseId);
    } else {
      // Find any valid key
      const requiredKeys = getRequiredKeysForCase(caseItem.name);
      if (requiredKeys.length > 0) {
        keyIdx = account.items.findIndex(it => {
          const itName = it.name.toLowerCase().split(' (')[0].trim();
          return requiredKeys.some(rk => rk.toLowerCase().trim() === itName);
        });
      }
    }

    if (keyIdx === -1) {
      // Show an in-screen non-blocking popup instead of a browser alert
      try {
        showInScreenConfirm(`You need a key to open "${caseItem.name}". Would you like to buy a key?`, () => {
          // If user confirms in the in-screen modal, open the Get Key flow for this case
          try {
            const reqKeys = getRequiredKeysForCase(caseItem.name);
            if (reqKeys.length > 0) {
              const kName = reqKeys[0];
              const kData = MARKET_KEYS.find(k => k.name === kName) || allSkins.find(s => s.name === kName);
              if (kData) {
                promptWearSelection(kData, kData.price || 2.50, (wear, qty, finalPrice, isCustom) => {
                  addItemToAccount({ name: kData.name, img: kData.image || kData.img, price: finalPrice, rarity: "Base Grade", qty, isCustomPrice: isCustom, source: "Purchased" });
                }, { confirmMode: "purchase" });
              } else {
                // fallback info if key not found
                showInScreenConfirm(`Key "${kName}" not found in database.`, () => {});
              }
            } else {
              showInScreenConfirm("No specific key detected for this container.", () => {});
            }
          } catch (e) {
            console.warn("Failed to start Get Key flow from in-screen popup:", e);
          }
        });
      } catch (e) {
        // Final fallback to alert if the in-screen confirm helper is missing
        alert("You need a key to open this container.");
      }
      return;
    }
  } else {
    // If noKeyNeeded is true, ensure we treat the container as openable without keys.
    keyIdx = -1;
  }

  const fullName = (caseItem.name || "").trim();
  const baseName = fullName.split(' (')[0].trim();
  
  // Resolve case contents from the CSGO API first, then fall back to local overrides.
  let caseDataRaw = resolveCaseContentsData(fullName) ||
               resolveCaseContentsData(baseName) ||
               resolveCaseContentsData(fullName.replace(/'/g, "")) ||
               resolveCaseContentsData(baseName.replace(/'/g, ""));
    
  // Scrub souvenirs from case contents pools before selecting winners (cloning for safety)
  let caseData = null;
  if (caseDataRaw) {
    caseData = JSON.parse(JSON.stringify(caseDataRaw));
    Object.keys(caseData).forEach(rarity => {
      if (Array.isArray(caseData[rarity])) {
        caseData[rarity] = caseData[rarity].filter(it => it && it.name && !it.name.toLowerCase().includes("souvenir"));
      }
    });
  }

  // If the case has no valid contents configured, abort early to avoid running the opening animation on an invalid container.
  if (!caseData || (Object.keys(caseData).length === 0) || Object.values(caseData).every(arr => !Array.isArray(arr) || arr.length === 0)) {
    try {
      const fallbackMsg = `No valid contents available for "${caseName}". Opening cancelled.`;
      console.warn(fallbackMsg);
      // show a gentle in-screen notice if available
      showInScreenConfirm(fallbackMsg, () => {});
    } catch (e) {
      // fallback to alert if in-screen helper isn't available
      alert(`No valid contents available for "${caseName}".`);
    }
    return;
  }
  // Only skip wear assignment for sticker/capsule-type containers (stickers don't have weapon wear)
  const nameLower = fullName.toLowerCase();
  const noWearForCase = nameLower.includes('sticker') || nameLower.includes('capsule') || nameLower.includes('katowice');

  // Determine how many cases we can actually open given available cases & keys
  const allCasesSame = account.items.filter(it => it.name === caseItem.name);
  const caseCount = allCasesSame.length;
  let keyCount = Infinity;
  // If container is a souvenir OR explicitly marked as noKeyNeeded (e.g. sticker capsules like EMS Katowice 2014),
  // don't require keys when computing how many can be opened.
  if (!isSouvenir && !noKeyNeeded) {
    const requiredKeysForThis = getRequiredKeysForCase(caseItem.name);
    if (requiredKeysForThis.length > 0) {
      keyCount = account.items.filter(it => {
        const itName = it.name.toLowerCase().split(' (')[0].trim();
        return requiredKeysForThis.some(rk => rk.toLowerCase().trim() === itName);
      }).length;
    }
  }
  const maxOpenable = (isSouvenir || noKeyNeeded) ? caseCount : Math.min(caseCount, keyCount);
  const requestedCount = Math.max(1, Number(openCount) || 1);
  const numToOpen = Math.min(requestedCount, maxOpenable);

  // Logic to consume both items safely (for numToOpen cases)
  const consumeKeyAndCase = () => {
    const account = getActiveAccount();
    if (!account) return false;
    // Prefer consuming a specific key ID (keyToUseId) when provided (user clicked the key).
    // Otherwise fall back to the existing lookup by matching required key names.
    let remainingToOpen = numToOpen;
    while (remainingToOpen > 0) {
      // 1. Find a case to consume (pick any matching case instance)
      const cIdx = account.items.findIndex(it => it.name === caseItem.name);
      if (cIdx === -1) break;

      // 2. Determine which key index to consume for this case iteration
      let kIdx = -1;

      // If the caller supplied a specific key instance id, try to consume that exact key first.
      if (!isSouvenir && !noKeyNeeded && keyToUseId) {
        // Find the key by ID, ensure it's not the same element as the selected case index
        const explicitIdx = account.items.findIndex(it => it.id === keyToUseId);
        if (explicitIdx !== -1 && explicitIdx !== cIdx) {
          kIdx = explicitIdx;
        }
      }

      // If we didn't get an explicit key, fall back to matching required key names as before.
      if (!isSouvenir && !noKeyNeeded && kIdx === -1) {
        const requiredKeysForThis = getRequiredKeysForCase(caseItem.name);
        if (requiredKeysForThis.length > 0) {
          const keyItem = account.items.find((it, idx) => {
            if (idx === cIdx) return false;
            const itName = (it.name || "").toLowerCase().split(' (')[0].trim();
            return requiredKeysForThis.some(rk => rk.toLowerCase().trim() === itName);
          });
          if (keyItem) {
            kIdx = account.items.findIndex(it => it.id === keyItem.id);
            if (kIdx === cIdx) kIdx = -1;
          }
        }
      }

      // 3. Remove the case and exactly one key (if found).
      // Logic Fix: user requested 1 key per case. We ensure exactly one case and one key are spliced.
      const indicesToRemove = [cIdx];
      if (kIdx !== -1 && kIdx !== cIdx) {
        indicesToRemove.push(kIdx);
      }
      indicesToRemove.sort((a, b) => b - a);
      indicesToRemove.forEach(idx => {
        if (idx >= 0 && idx < account.items.length) {
          account.items.splice(idx, 1);
        }
      });

      // If we successfully consumed an explicit key, clear keyToUseId so subsequent loops don't keep trying to remove it again.
      if (keyToUseId && kIdx !== -1) {
        keyToUseId = null;
      }

      remainingToOpen--;
    }

    if (remainingToOpen > 0) return false;
    saveState();

    // Immediately update the Unlock Container modal footer counts so UI reflects consumed cases/keys.
    try {
      const accountRef = getActiveAccount();
      const base = (caseItem && caseItem.name) ? (caseItem.name.split(' (')[0].trim()) : (caseName || "");
      const ownedCasesNow = accountRef ? accountRef.items.filter(it => (it.name || "").split(' (')[0].trim() === base).length : 0;
      const requiredKeysNow = getRequiredKeysForCase(caseItem.name);
      let ownedKeysNow = 0;
      if (accountRef && requiredKeysNow.length > 0) {
        ownedKeysNow = accountRef.items.filter(it => {
          const itBase = (it.name || "").toLowerCase().split(' (')[0].trim();
          return requiredKeysNow.some(rk => rk.toLowerCase().trim() === itBase);
        }).length;
      }
      const caseOwnedEl = document.getElementById("caseOwnedCount");
      const caseKeyEl = document.getElementById("caseKeyCount");
      if (caseOwnedEl) caseOwnedEl.textContent = ownedCasesNow;
      if (caseKeyEl) caseKeyEl.textContent = ownedKeysNow;
    } catch (e) {
      // silent
    }

    return true;
  };

  const doOpen = () => {
    const modal = document.getElementById("caseOpeningModal");
    const resultArea = document.getElementById("caseOpeningResult");
    const spinnerResult = resultArea;
    const title = document.getElementById("caseOpeningTitle");

    // Keep the opening title at the top; center the loading block instead.
    if (title) {
      title.style.position = "absolute";
      title.style.top = "40px";
      title.style.bottom = "auto";
      title.style.left = "50%";
      title.style.transform = "translateX(-50%)";
      title.style.zIndex = "100";
      title.style.textAlign = "center";
      title.style.width = "100%";
    }

    // If the core modal nodes are missing, abort safely (no alert spam).
    if (!modal || !resultArea || !title) {
      console.warn("openCase: missing core case opening UI nodes.", {
        hasModal: !!modal,
        hasResult: !!resultArea,
        hasTitle: !!title
      });
      return;
    }

    // Ensure optional nodes exist so later style/access calls don't crash.
    const ensureEl = (id, parent, tag = "div") => {
      let el = document.getElementById(id);
      if (!el) {
        el = document.createElement(tag);
        el.id = id;
        if (parent) parent.appendChild(el);
      }
      return el;
    };

    const tracksContainer = ensureEl("spinnerTracksContainer", resultArea.parentElement || modal, "div");
    const spinnerUI = ensureEl("caseOpeningSpinner", resultArea.parentElement || modal, "div");
    const actions = ensureEl("caseOpeningActions", modal, "div");
    const nextBtn = ensureEl("openNextCaseBtn", actions, "button");
    const countSpan = ensureEl("remainingCasesCount", nextBtn, "span");
    
    // Ensure other buttons destroyed by previous revealNow rebuilds are restored
    ensureEl("inspectResultBtn", actions, "button");
    ensureEl("closeCaseOpeningBtn", actions, "button");

    // Ensure expected classes for styling if elements were re-created.
    nextBtn.classList.add("steam-btn", "highlight");

    // Store cost before consumption
    const keyItem = (keyIdx !== -1 && account.items[keyIdx]) ? account.items[keyIdx] : null;
    const costPerCase = (caseItem.price || 0) + (keyItem && typeof keyItem.price === "number" ? keyItem.price : 0);
    const totalOpeningCost = costPerCase * numToOpen;

    // ACTUAL CONSUMPTION HAPPENS HERE
    if (!consumeKeyAndCase()) {
      alert("Error: Could not verify items in inventory. Opening aborted.");
      return;
    }

    // Defensive: if this case requires the local "Custom key", ensure one top-level Custom key is consumed
    // (some flows previously failed to remove the custom key instance; this forcibly removes one if present).
    try {
      const accountRef = getActiveAccount();
      const requiredKeysNow = getRequiredKeysForCase(caseItem.name);
      if (Array.isArray(requiredKeysNow) && requiredKeysNow.includes("Custom key") && accountRef) {
        // Remove one top-level Custom key only (do not remove keys stored inside storage units)
        const keyIndex = accountRef.items.findIndex(it => {
          if (!it || !it.name) return false;
          const base = (it.name || "").toLowerCase().split(' (')[0].trim();
          return base === "custom key";
        });
        if (keyIndex !== -1) {
          accountRef.items.splice(keyIndex, 1);
          saveState();
        }
      }
    } catch (e) {
      // silent fallback
    }
    // Update Cases/Keys owned counters in the Unlock Container footer immediately after consumption
    try {
      updateCaseConfirmCounts(caseItem.name);
    } catch (e) {
      // silent - best-effort update
    }
    
    // Reset modal background to transparent for opening animation
    modal.style.background = "transparent";
    modal.classList.remove("hidden");
    // Removed duplicate unlock start sound per request
    title.textContent = "Opening " + caseItem.name + "...";
    resultArea.innerHTML = `
      <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; min-height:60vh; gap:16px;">
        <div class="spinner"></div>
        <p style="margin:0; color:#d7e9f7; font-size:16px; font-weight:700; letter-spacing:0.5px;">Loading...</p>
      </div>
    `;
    nextBtn.classList.add("hidden");

    // Define revealNow at top of scope so skip-animation logic can call it
    let hasRevealed = false;
    const revealNow = () => {
      if (hasRevealed) return;
      hasRevealed = true;
      lensState.active = false; // STOP MAGNIFIER

      const isRealistic = !!state.realisticCaseOpening;
      
      // Restore DOM components visibility for the result reveal
      const tContainer = document.getElementById("spinnerTracksContainer");
      if (tContainer) tContainer.style.opacity = "1";
      const sLine = document.getElementById("spinnerLine");
      if (sLine) sLine.style.display = "block";

      try {
        if (window._caseRevealTimer) clearTimeout(window._caseRevealTimer);
      } catch (e) {}
      // Defensive: if core UI nodes vanished mid-open, abort reveal cleanly.
      if (!modal || !spinnerUI || !spinnerResult) {
        console.warn("openCase: reveal aborted (missing UI nodes).", {
          hasModal: !!modal,
          hasSpinnerUI: !!spinnerUI,
          hasSpinnerResult: !!spinnerResult
        });
        return;
      }
      // Switch to solid background for result screen
      modal.style.background = "#0b0f1a";
      // hide spinner visuals and show result immediately
      spinnerUI.style.display = "none";
      
      // Fix: Explicitly hide the yellow spinner line and tracks to remove the "yellow pixel" glitch
      const tracks = document.getElementById("spinnerTracksContainer");
      if (tracks) tracks.style.display = "none";
      const line = document.getElementById("spinnerLine");
      if (line) line.style.display = "none";
      
      spinnerResult.style.display = "block";

      // If multiple cases were opened, ensure the "Items Earned" style is clearly labeled
      if (numToOpen > 1) {
        title.textContent = ""; 
      }

      // Determine highest rarity among winners (rank: Mil-Spec < Restricted < Classified < Covert < Gold)
      const rarityRank = { "Mil-Spec": 1, "Restricted": 2, "Classified": 3, "Covert": 4, "Gold": 5 };
      let highest = "Mil-Spec";
      winners.forEach(w => {
        // Reset and churn randomness for every item to prevent biased drops
        Math.random(); 
        const r = normalizeRarityName(w, (w.rarity && (w.rarity.name || w.rarity)) ? (w.rarity.name || w.rarity) : null);
        if ((rarityRank[r] || 0) > (rarityRank[highest] || 0)) highest = r;
      });
      playAwardSound(highest);

      let totalValue = 0;
      // Pre-resolve images and StatTrak prefixing to ensure labels are correct in result screen
      winners.forEach(winner => {
        if (!winner.img || winner.img === KNIFE_PLACEHOLDER_IMG) {
          winner.img = getDisplayImage(winner);
        }
      });

      const winnerDataList = winners.map(winner => {
        const override = (typeof winner.name === "string" && PRICE_FIXES[winner.name] !== undefined)
          ? PRICE_FIXES[winner.name]
          : ((typeof winner.hash_name === "string" && PRICE_FIXES[winner.hash_name] !== undefined) ? PRICE_FIXES[winner.hash_name] : undefined);
        const price = (override !== undefined) ? override : ((typeof winner.price === "number" && !isNaN(winner.price)) ? winner.price : mockPrice(winner));
        totalValue += price;
        const winnerImg = getDisplayImage(winner);
        const finalWear = noWearForCase ? null : mockWear(winner.name, (winner.rarity?.name || winner.rarity));
        
        // Generate a float compatible with the selected wear for unboxing results
        const finalFloat = generateFloatForWear(winner.name, finalWear, (winner.rarity && (winner.rarity.name || winner.rarity)) ? (winner.rarity.name || winner.rarity) : null);

        // StatTrak already decided before animation for consistency
        let finalName = winner.name;
        let finalPriceAdjusted = price;

        // Ensure price reflects StatTrak if decided early but price hasn't been updated
        if (finalName.includes("StatTrak™") && finalPriceAdjusted === price) {
            finalPriceAdjusted = Math.round((price * 1.15) * 100) / 100;
        }

        // Apply prefix immediately to winner object so UI reflects it correctly in all popups
        winner.name = finalName;

        const finalItemData = {
          name: finalName,
          img: winnerImg,
          price: finalPriceAdjusted,
          rarity: winner.rarity?.name || "Consumer",
          wear: finalWear,
          floatVal: finalFloat,
          qty: 1,
          source: `Pulled from ${caseItem.name}`,
          prevOwners: 0 // User requested pulled items have 0 owners
        };

        // record whether account already owned this item BEFORE we add it
        let hadOwnedBefore = false;
        try {
          hadOwnedBefore = Array.isArray(account.items) && account.items.some(it => it && it.name === winner.name);
        } catch (e) { hadOwnedBefore = false; }

        const created = addItemToAccount(finalItemData);
        // Track unboxing stats per account
        account.totalCasesOpened = (account.totalCasesOpened || 0) + 1;
        account.totalUnboxingProfit = (account.totalUnboxingProfit || 0) + (price - costPerCase);
        if (!account.bestPulledValue || price > account.bestPulledValue) {
          account.bestPulledValue = price;
          account.bestPulledName = finalName;
        }

        return { ...winner, name: finalName, winnerImg, price: finalPriceAdjusted, finalWear, floatVal: finalFloat, createdId: created?.id, hadOwnedBefore };
      });

      const profit = totalValue - totalOpeningCost;
      const profitColor = profit >= 0 ? "#a4d007" : "#eb4b4b";
      const rewardData = winnerDataList[0] || {}; // Fix ReferenceError: rewardData is not defined

      // Track Golds pulled historically
      if (highest === "Gold") {
        account.totalGoldsPulled = (account.totalGoldsPulled || 0) + 1;
        const cBase = (caseItem.name || "").split(' (')[0].trim();
        if (!account.goldsPerCase) account.goldsPerCase = {};
        account.goldsPerCase[cBase] = (account.goldsPerCase[cBase] || 0) + 1;
      }

      // Track cases opened historically for favorite case stat
      if (!account.openedCaseCounts) account.openedCaseCounts = {};
      const caseBaseName = (caseItem.name || "").split(' (')[0].trim();
      account.openedCaseCounts[caseBaseName] = (account.openedCaseCounts[caseBaseName] || 0) + numToOpen;

      if (numToOpen === 1) {
        const winner = winnerDataList[0];
        const rarityColor = RARITY_COLORS[winner.rarity?.name] || RARITY_COLORS["Consumer"];
        title.textContent = ""; 

        // Update Owned Status label
        const ownedLabel = document.getElementById("ownedStatusLabel");
        if (ownedLabel) {
            ownedLabel.textContent = winner.hadOwnedBefore ? "OWNED: YES" : "OWNED: NO";
            ownedLabel.style.color = winner.hadOwnedBefore ? "#a4d007" : "#eb4b4b";
            ownedLabel.style.display = "block";
        }
        
        const displayName = winner.nametag ? `"${winner.nametag}"` : winner.name;
        const nameColor = winner.nametag ? "#eb4b4b" : "#fff";

        let containerName = caseItem && caseItem.name ? caseItem.name : "Unknown Collection";
        if ((!containerName || containerName === "Unknown Collection") && winner.source && winner.source.includes("from ")) {
          containerName = winner.source.split("from ")[1];
        }

        const wearText = winner.finalWear || winner.wear || "Factory New";
        const displayFloat = (typeof winner.floatVal === 'number') ? winner.floatVal.toFixed(6) : "0.000000";

        // Specific profit for this unbox
        const itemProfit = winner.price - costPerCase;
        const itemProfitColor = itemProfit >= 0 ? "#a4d007" : "#eb4b4b";

        winner._costPerCase = costPerCase; // Pass cost context for tooltip profit
        
        // Consistent sticker list excluding StatTrak for Unlocked Popup (moved to dedicated badge)
        const unboxedStickers = Array.isArray(winner.stickers) ? [...winner.stickers] : [];
        
        if (winner.name.includes("StatTrak™") && state.showStatTrakOverlay !== false) {
           // Display StatTrak module ABOVE the image by centering and setting negative bottom offset
           statTrakBadgeHtml = `<div class="purchase-result-stattrak" style="bottom: 85%;"><img src="https://i.imgur.com/TRtzFCo.png" alt="StatTrak"></div>`;
        }

        const unboxedStickersHtml = unboxedStickers.map(s => `<img src="${s.img}" class="popup-sticker-mini" title="${s.name}">`).join('');
        const finalRevealImg = winner.winnerImg;

        spinnerResult.innerHTML = `
          <div style="display:flex; flex-direction:column; align-items:center; position: relative; width: 100%; height: 680px; padding-top: 0; box-sizing: border-box;">
            <!-- Top Header -->
            <div style="text-align: center; margin-top: 24px; z-index: 10;">
              <h1 style="color: ${nameColor}; font-size: 42px; font-weight: 900; margin: 0 0 8px 0; text-transform: none; letter-spacing: 1px; line-height: 1.12; padding: 0 18px;">${displayName}</h1>
              <div style="display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 8px; color: #d1d5db; font-size: 18px; font-weight: 700;">
                <img src="${getDisplayImage({name: containerName})}" style="width:30px; height:30px; object-fit:contain;"> ${containerName}
              </div>
              <div style="width: 620px; max-width: 90vw; height: 4px; background: ${rarityColor}; margin: 14px auto 0 auto; border-radius: 2px; box-shadow: none;"></div>
            </div>
            
            <!-- Central Item Image -->
            <div id="unlocked3dWrapper" class="unlocked-3d-container" style="height: 520px; max-height: 520px; background: none; border: none; box-shadow: none; display: flex; align-items: center; justify-content: center; transform: scale(1.1); position: relative; margin: 0 auto;">
              <div class="unlocked-inner-3d" style="transform-style: preserve-3d; display: flex; align-items: center; justify-content: center; width: 100%; height: 100%;">
                <img src="${finalRevealImg}" class="inspect-face" draggable="false" style="max-width: 88%; max-height: 88%; object-fit: contain; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5));">
              </div>
              <div id="unlockedStickers" style="bottom: 40px;"></div>
            </div>
            
            <!-- Attributes area removed from absolute and moved to actions container -->
          </div>
        `;

        // Populate the unlocked stickers tray
        const unlockedTray = spinnerResult.querySelector("#unlockedStickers");
        if (unlockedTray) {
          if (winner.name.includes("StatTrak") && state.showStatTrakOverlay !== false) {
            const stattrakWrapper = document.createElement("div");
            stattrakWrapper.className = "sticker-wrapper stattrak-tray-icon";
            stattrakWrapper.style.pointerEvents = "none";
            stattrakWrapper.innerHTML = `<img src="https://i.imgur.com/TRtzFCo.png" class="applied-sticker-icon" title="StatTrak" style="width: 80px; height: 80px;">`;
            unlockedTray.appendChild(stattrakWrapper);
          }
          unboxedStickers.forEach(s => {
            const wrapper = document.createElement("div");
            wrapper.className = "sticker-wrapper";
            wrapper.style.pointerEvents = "auto";
            wrapper.setAttribute('data-tooltip', s.name);
            wrapper.innerHTML = `<img src="${s.img}" class="applied-sticker-icon" title="${s.name}" style="width: 80px; height: 80px;">`;
            unlockedTray.appendChild(wrapper);
          });
        }
      } else {
        title.textContent = "";
        spinnerResult.innerHTML = `
          <div style="display:flex; flex-direction:column; align-items:center; gap:8px; width: 100%;">
