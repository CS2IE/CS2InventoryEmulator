/**
 * Sample a rarity using specific probability tables based on user settings.
 */
function sampleCaseRarity() {
  try {
    // When improved odds setting is enabled:
    if (state && (state.pureRandomOdds || window._boostedOdds)) {
      const boost = window._boostedOdds ? 1.5 : 1;
      const dist = [
        { rarity: "Consumer", rate: 0.40 },
        { rarity: "Industrial", rate: 0.25 },
        { rarity: "Mil-Spec", rate: 0.20 / boost },
        { rarity: "Restricted", rate: 0.10 },
        { rarity: "Classified", rate: 0.03 * boost },
        { rarity: "Covert", rate: 0.015 * boost },
        { rarity: "Gold", rate: 0.005 * boost }
      ];
      const p = Math.random();
      let acc = 0;
      for (const o of dist) {
        acc += o.rate;
        if (p < acc) return o.rarity;
      }
      return "Mil-Spec";
    }

    // Base Case Odds (when Improved Odds is disabled):
    const baseOdds = [
      { rarity: "Consumer", rate: 0.50 },
      { rarity: "Industrial", rate: 0.30 },
      { rarity: "Mil-Spec", rate: 0.15 },
      { rarity: "Restricted", rate: 0.0398 },
      { rarity: "Classified", rate: 0.008 },
      { rarity: "Covert", rate: 0.0016 },
      { rarity: "Gold", rate: 0.0006 }
    ];

    const p = Math.random();
    let acc = 0;
    for (const o of baseOdds) {
      acc += o.rate;
      if (p < acc) return o.rarity;
    }
    return "Mil-Spec";
  } catch (e) {
    return "Mil-Spec";
  }
}

/**
 * Sample a rarity for sticker capsules (no Gold).
 */
function sampleCapsuleRarity() {
  const p = Math.random();
  let acc = 0;
  const table = CAPSULE_ODDS || [];
  const total = table.reduce((s, o) => s + (o.rate || 0), 0) || 1;
  for (const o of table) {
    acc += (o.rate || 0) / total;
    if (p < acc) return o.rarity;
  }
  return "High Grade";
}

