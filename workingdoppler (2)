function renderLoadoutUI() {
  const activeAccount = getActiveAccount();
  const viewingProfile = state.viewingProfileId ? state.accounts.find(a => a.id === state.viewingProfileId) : null;
  const account = viewingProfile || activeAccount;
  if (!account) return;

  const loadoutBtn = document.getElementById("loadoutBtn");
  if (loadoutBtn) loadoutBtn.textContent = "Loadout";

  if (state.realEquip && account === activeAccount) {
    const allLoadoutIds = [];
    ["ct", "t"].forEach(side => {
      Object.values(state.loadout[side]).forEach(id => { if(id) allLoadoutIds.push(id); });
    });
    const uniqueIds = [...new Set(allLoadoutIds)];
    uniqueIds.forEach(id => {
      if (!account.equippedItemIds.includes(id)) account.equippedItemIds.push(id);
    });
    saveState();
  }

  const sides = ["ct", "t"];
  sides.forEach(side => {
    const sideEl = side === "ct" ? document.getElementById("loadoutSideCT") : document.getElementById("loadoutSideT");
    renderCollapsedLoadoutPreview(side, sideEl, account);
    const sideLoadout = state.loadout[side];
    const slots = sideEl.querySelectorAll(".loadout-slot");
    
    slots.forEach(slotEl => {
      const slotId = slotEl.dataset.slot;
      const typeFilter = slotEl.dataset.type;
      const slotLabel = getLoadoutSlotDisplayName(slotEl);
      const itemId = sideLoadout[slotId];
      const item = itemId ? findItemById(account, itemId) : null;
      
      slotEl.innerHTML = "";
      if (item) {
        const rarityCol = RARITY_COLORS[item.rarity] || "#fff";
        const stickersHtml = (item.stickers || []).slice(0, 5).map(s => `<img src="${s.img}" title="${s.name}" style="width:26px; height:20px; object-fit:contain; margin-right:2px; filter: drop-shadow(0 2px 4px #000);">`).join('');
        const displayName = item.nametag ? `"${item.nametag}"` : item.name;
        slotEl.innerHTML = `
          <div class="loadout-slot-type-hint">${escapeHtml(slotLabel)}</div>
          <img src="${getStableDisplayImage(item)}" style="width:75%; height:75%; object-fit:contain; margin-top:-10px;">
          <div class="loadout-slot-equipped"></div>
          <div class="loadout-slot-stickers" style="position:absolute; bottom:28px; left:8px; right:auto; display:flex; gap:4px; flex-direction:row;">${stickersHtml}</div>
          <div class="loadout-slot-label" style="background: rgba(0,0,0,0.75); padding: 6px; font-size: 13px; font-weight:900; color:#fff; text-shadow:0 1px 3px #000; bottom:0; height:auto; display:block; position:absolute; left:0; right:0;">${displayName}</div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:6px; background:${rarityCol}; box-shadow: 0 -2px 10px ${rarityCol}66;"></div>
        `;
      } else {
        slotEl.innerHTML = `
          <div class="slot-empty-icon" style="font-size:24px; color:rgba(255,255,255,0.2);">+</div>
          <div class="loadout-slot-type-hint">${escapeHtml(slotLabel)}</div>
          <div class="loadout-slot-label" style="background: rgba(0,0,0,0.6); padding: 6px; font-size: 13px; font-weight:900; color:rgba(255,255,255,0.92); text-shadow:0 1px 3px #000; bottom:0; height:auto; display:block; position:absolute; left:0; right:0;">${escapeHtml(slotLabel)}</div>
        `;
      }
      slotEl.onclick = (e) => {
        e.stopPropagation();
        if (viewingProfile) return; 
        openLoadoutPicker(side, slotId, typeFilter || slotId);
      };
      slotEl.oncontextmenu = (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (viewingProfile || !item) return;
        showInspect(item);
      };
    });
  });
}

function openLoadoutPicker(side, slotId, typeFilter) {
  const account = getActiveAccount();
  if (!account) return;

  const overlay = document.createElement("div");
  overlay.className = "modal-overlay";
  overlay.style.zIndex = "2500";
  overlay.innerHTML = `
    <div class="user-snippet-modal" style="max-width: 900px; height: 85vh; padding: 25px; text-align: left;">
      <button class="close-snippet-modal" id="closeLoadoutPicker">✕</button>
      <h2 style="margin-bottom: 15px;">Select ${typeFilter} for ${side.toUpperCase()}</h2>
      <div id="loadoutPickerGrid" class="trade-items-grid" style="flex: 1; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));"></div>
      <div style="margin-top: 15px; display:flex; gap:10px;">
        <button id="clearLoadoutSlot" class="steam-btn grey" style="flex:1;">Unequip Slot</button>
        <button id="closePickerBtn" class="steam-btn highlight" style="flex:1;">Done</button>
      </div>
    </div>
  `;
  document.body.appendChild(overlay);

  const grid = overlay.querySelector("#loadoutPickerGrid");

  const isAgentSlot = slotId === "agent";
  const isKnifeSlot = slotId === "knife";
  const isGlovesSlot = slotId === "gloves";
  const isMusicSlot = slotId === "music";
  const isCharmSlot = slotId === "charm";
  const isPinSlot = slotId === "pin";

  const pool = account.items.filter(it => {
    const n = (it.name || "").toLowerCase();
    const t = (it.type || it.category?.name || "").toLowerCase();
    const hasKnifeStar = n.includes("★") || n.includes("â˜…");

    if (isKnifeSlot && !(t.includes("gloves") || n.includes("gloves")) && (t.includes("knife") || hasKnifeStar || n.includes("knife"))) return true;
    
    if (isKnifeSlot && (t.includes("gloves") || n.includes("gloves"))) return false;
    if (isAgentSlot) return t.includes("agent") || n.includes("agent");
    if (isKnifeSlot) return t.includes("knife") || n.includes("★");
    if (isGlovesSlot) return t.includes("gloves") || n.includes("gloves");
    if (isMusicSlot) return n.includes("music kit");
    if (isCharmSlot) return n.includes("charm") || n.includes("keychain");
    if (isPinSlot) return n.includes("pin") || n.includes("collectible");
    if (!isKnifeSlot && !isGlovesSlot && !isAgentSlot && (hasKnifeStar || n.includes("gloves") || t.includes("knife") || t.includes("gloves"))) return false;

    // Weapon slots: strict name check (Aug only matches AUG, M4A1-S matches M4A1-S)
    const filter = typeFilter.toLowerCase();
    
    // Explicit exclusions for knives/gloves being picked in weapon slots
    if (!isKnifeSlot && !isGlovesSlot && !isAgentSlot) {
       if (n.includes("knife") || n.includes("★") || n.includes("gloves") || t.includes("knife") || t.includes("gloves")) return false;
    }

    if (filter === "usp-s") return n.includes("usp-s");
    if (filter === "glock-18") return n.includes("glock-18");
    if (filter === "m4a4") return n.includes("m4a4");
    if (filter === "m4a1-s") return n.includes("m4a1-s");
    if (filter === "ak-47") return n.includes("ak-47");
    if (filter === "awp") return n.includes("awp");
    if (filter === "galil ar") return n.includes("galil ar") || n.includes("galil");

    return n.includes(filter) || t.includes(filter);
  }).sort((a,b) => getItemValue(b) - getItemValue(a));

  pool.forEach(it => {
    const card = createTradeCard(it, () => {
      state.loadout[side][slotId] = it.id;
      if (!account.equippedItemIds.includes(it.id)) {
        account.equippedItemIds.push(it.id);
      }
      saveState();
      renderLoadoutUI();
      refreshInventoryView();
      overlay.remove();
    });

    // Adjust images for picker
    const img = card.querySelector("img");
    if (img) {
      img.style.width = "110px";
      img.style.height = "80px";
    }
    // Show stickers in selection popup
    const stickerLabel = card.querySelector("div:last-child");
    if (stickerLabel) {
        stickerLabel.style.display = "block";
        stickerLabel.style.fontSize = "10px";
    }

    if (state.loadout[side][slotId] === it.id) {
      card.style.outline = "3px solid #66c0f4";
      card.style.background = "rgba(102, 192, 244, 0.1)";
    }
    grid.appendChild(card);
  });

  if (pool.length === 0) {
    grid.innerHTML = `<div style="grid-column:1/-1; padding:40px; text-align:center; color:#475569;">No matching items found in your inventory.</div>`;
  }

  overlay.querySelector("#clearLoadoutSlot").onclick = () => {
    state.loadout[side][slotId] = null;
    saveState();
    renderLoadoutUI();
    overlay.remove();
  };

  overlay.querySelector("#closePickerBtn").onclick = () => overlay.remove();
  overlay.querySelector("#closeLoadoutPicker").onclick = () => overlay.remove();
}

function openDatabaseModal() {
  const searchSheet = document.getElementById("searchSheet");
  if (searchSheet) searchSheet.classList.add("hidden");

  let modal = document.getElementById("databaseModal");
  if (!modal) {
    modal = document.createElement("div");
    modal.id = "databaseModal";
    modal.className = "modal-overlay";
    modal.style.zIndex = 3000;
    document.body.appendChild(modal);
  }

  let allUserItems = [];
  state.accounts.forEach(acc => {
    acc.items.forEach(it => {
      // Filter out capsules/cases from the global database listing
      if (isContainer(it)) return;
      allUserItems.push({ ...it, ownerName: acc.name, ownerPfp: acc.pfp });
      if (it.contents) {
        it.contents.forEach(sub => {
          if (!isContainer(sub)) allUserItems.push({ ...sub, ownerName: acc.name, ownerPfp: acc.pfp });
        });
      }
    });
  });

  // Default sort: lowest float
  allUserItems = allUserItems.filter(it => it.floatVal !== undefined && it.floatVal !== null);
  allUserItems.sort((a, b) => a.floatVal - b.floatVal);

  modal.innerHTML = `
    <div class="user-snippet-modal" style="max-width: 95vw; width: 95vw; height: 95vh; display: flex; flex-direction: row; padding: 0; overflow: hidden;">
      <div style="width: 280px; background: #0f172a; border-right: 1px solid #334155; padding: 15px; display: flex; flex-direction: column; gap: 15px; flex-shrink: 0;">
        <h2 style="font-size: 18px; margin: 0; color: #8b5cf6; text-align:left;">Database</h2>
        <div style="display:flex; flex-direction:column; gap:6px;">
          <label style="font-size:11px; color:#94a3b8; text-transform:uppercase;">Search:</label>
          <input type="text" id="dbSearchInput" class="steam-input" placeholder="Search weapons, owners, stickers..." style="width:100%; font-size:12px; flex-grow:0;">
        </div>
        <div style="text-align:left;">
          <label style="font-size:11px; color:#94a3b8; text-transform:uppercase;">Sort By:</label>
          <select id="dbSortSelect" class="steam-select" style="width:100%; font-size:11px; padding:8px;">
            <option value="floatAsc">Float: Lowest</option>
            <option value="newest">Newest First</option>
            <option value="floatDesc">Float: Highest</option>
            <option value="priceDesc">Price: Highest</option>
            <option value="priceAsc">Price: Lowest</option>
            <option value="rarityDesc">Rarity: Rare First</option>
            <option value="rarityAsc">Rarity: Common First</option>
            <option value="nameAsc">Alphabetical (A-Z)</option>
            <option value="nameDesc">Alphabetical (Z-A)</option>
            <option value="ownersDesc">Most Owners</option>
            <option value="stickersDesc">Most Stickers</option>
          </select>
        </div>
        <button class="steam-btn grey" style="padding:10px; font-size:13px; font-weight:900;" onclick="const m = document.getElementById('databaseModal'); m.classList.add('hidden'); updateModalBlurState();">CLOSE DATABASE</button>
      </div>
      <div style="flex: 1; padding: 15px; overflow-y: auto; background: #0b0f1a;">
        <table style="width: 100%; border-collapse: collapse; text-align: left; min-width: 800px;">
          <thead style="border-bottom: 1px solid #334155; color: #94a3b8; font-size: 11px; text-transform:uppercase;">
            <tr>
              <th style="padding: 10px;">Weapon</th>
              <th style="padding: 10px;">Identity</th>
              <th style="padding: 10px;">Float / Pattern</th>
              <th style="padding: 10px;">Loadout</th>
              <th style="padding: 10px;">Owner</th>
            </tr>
          </thead>
          <tbody id="dbTableBody"></tbody>
        </table>
      </div>
    </div>
  `;

  const renderTable = () => {
    const query = document.getElementById("dbSearchInput").value.toLowerCase();
    const sort = document.getElementById("dbSortSelect").value;
    const body = document.getElementById("dbTableBody");
    body.innerHTML = "";

    let filtered = allUserItems.filter(it => {
      const stickersMatch = (it.stickers || []).some(s => s.name.toLowerCase().includes(query));
      return it.name.toLowerCase().includes(query) || 
             (it.nametag && it.nametag.toLowerCase().includes(query)) ||
             it.ownerName.toLowerCase().includes(query) ||
             stickersMatch;
    });

    if (sort === "floatAsc") filtered.sort((a,b) => (a.floatVal||0) - (b.floatVal||0));
    else if (sort === "newest") filtered.sort((a,b) => (b.acquiredAt || 0) - (a.acquiredAt || 0));
    else if (sort === "floatDesc") filtered.sort((a,b) => (b.floatVal||0) - (a.floatVal||0));
    else if (sort === "priceDesc") filtered.sort((a,b) => getItemValue(b) - getItemValue(a));
    else if (sort === "priceAsc") filtered.sort((a,b) => getItemValue(a) - getItemValue(b));
    else if (sort === "nameAsc") filtered.sort((a,b) => (a.name||"").localeCompare(b.name||""));
    else if (sort === "nameDesc") filtered.sort((a,b) => (b.name||"").localeCompare(a.name||""));
    else if (sort === "ownersDesc") filtered.sort((a,b) => (b.prevOwners||0) - (a.prevOwners||0));
    else if (sort === "stickersDesc") filtered.sort((a,b) => (b.stickers?.length||0) - (a.stickers?.length||0));
    else if (sort === "rarityDesc" || sort === "rarityAsc") {
       const ranks = {"Base Grade":0,"Consumer":1,"Industrial":2,"Mil-Spec":3,"Restricted":4,"Classified":5,"Covert":6,"Gold":7};
       filtered.sort((a,b) => {
         const ra = ranks[a.rarity]||0;
         const rb = ranks[b.rarity]||0;
         return sort === "rarityDesc" ? rb - ra : ra - rb;
       });
    }

    filtered.slice(0, 100).forEach(it => {
      const tr = document.createElement("tr");
      tr.style.borderBottom = "1px solid rgba(255,255,255,0.03)";
      tr.style.cursor = "pointer";
      tr.onclick = () => showInspect(it);
      
      const rarityName = it.rarity?.name || it.rarity || "Consumer";
      // Logic Fix: stickers dont show for lowest float on stats popup (Database Modal acts as stats too)
      const stickersHtml = (sort === "floatAsc") ? "" : (it.stickers || []).map(s => {
          const wear = s.scratchPercent || 0;
          const grey = wear / 100;
          return `<div class="db-sticker-wrap" style="position:relative; display:inline-block; margin-right:6px;">
            <img src="${s.img}" class="db-sticker-img" style="width:42px; height:32px; object-fit:contain; background:rgba(0,0,0,0.2); border-radius:4px; filter: grayscale(${grey}) brightness(${1 - grey*0.4});" data-name="${s.name}" data-wear="${wear}">
            ${wear > 0 ? `<div style="position:absolute; bottom:-2px; right:-2px; background:#eb4b4b; color:#fff; font-size:8px; font-weight:900; padding:1px 3px; border-radius:3px;">${wear}%</div>` : ''}
          </div>`;
      }).join('');
      
      const dupeItems = allUserItems.filter(x => x.floatVal === it.floatVal && x.name === it.name);
      const isDupe = dupeItems.length > 1;
      const stickerVal = getStickerValueTotal(it);

      // Pattern can sometimes be an object from ByMykel if not cast correctly
      const patternNum = (typeof it.pattern === 'object' && it.pattern !== null) ? (it.pattern.id || 0) : (it.pattern || 0);

      tr.innerHTML = `
        <td style="padding: 10px;"><img src="${getStableDisplayImage(it)}" style="width: 85px; height: 60px; object-fit: contain;"></td>
        <td style="padding: 10px;">
          <div style="font-weight: 800; font-size: 13px; color: ${it.nametag ? '#eb4b4b' : (RARITY_COLORS[rarityName] || '#fff')}">${it.nametag ? '"'+it.nametag+'"' : it.name}</div>
          <div style="font-size: 10px; color: #94a3b8;">${it.nametag ? it.name : (it.wear || '')}</div>
          ${isDupe ? `<div style="color: #facc15; font-size: 9px; font-weight: 900; margin-top: 4px; background: rgba(250, 204, 21, 0.1); padding: 2px 5px; border-radius: 4px; display: inline-block;">DUPE FOUND (${dupeItems.length})</div>` : ""}
        </td>
        <td style="padding: 10px; font-size:12px;">
          <div style="color: #fff; font-family: monospace;">${formatFloat(it.floatVal)}</div>
          ${!state.hidePrices ? `
            <div style="color:#a4d007;font-weight:900;font-size:12px;margin-top:2px;">${formatPrice(getItemValue(it))}</div>
            ${stickerVal > 0 ? `<div style="color:#66c0f4;font-size:10px;font-weight:800;">Stickers: ${formatPrice(stickerVal)}</div>` : ''}
          ` : ''}
          <div style="color: #64748b;">Seed Pattern: ${patternNum}</div>
        </td>
        <td style="padding: 10px;">${stickersHtml || '<span style="color:#475569;font-size:10px;">None</span>'}</td>
        <td style="padding: 10px;">
          <div style="display: flex; align-items: center; gap: 8px;">
            <img src="${it.ownerPfp || 'https://i.imgur.com/zFydkgL.png'}" style="width: 24px; height: 24px; border-radius: 50%;">
            <span style="font-size: 12px; color: #94a3b8;">${it.ownerName}</span>
          </div>
        </td>
      `;
      body.appendChild(tr);
    });
  };

  document.getElementById("dbSearchInput").oninput = renderTable;
  document.getElementById("dbSortSelect").onchange = renderTable;
  
  const sortSelect = document.getElementById("dbSortSelect");
  if (sortSelect) {
    if (state.dbSortLowestFloat) {
        sortSelect.value = "floatAsc";
    } else {
        sortSelect.value = "floatAsc"; // Default sort for database popup requested
    }
  }

  renderTable();

  // On-screen tooltip for DB stickers
  modal.addEventListener('mouseover', (e) => {
    const target = e.target.closest('.db-sticker-img');
    if (target) {
        const name = target.getAttribute('data-name');
        const wear = target.getAttribute('data-wear');
        let tooltip = document.getElementById("dbStickerTooltip");
        if (!tooltip) {
            tooltip = document.createElement("div");
            tooltip.id = "dbStickerTooltip";
            tooltip.style.cssText = "position:fixed; background:#111; border:1px solid #444; color:#fff; padding:6px 12px; border-radius:6px; font-size:12px; z-index:10000; pointer-events:none;";
            document.body.appendChild(tooltip);
        }
        tooltip.innerHTML = `<strong>${name}</strong>${wear > 0 ? '<br><span style="color:#eb4b4b">Scraped: ' + wear + '%</span>' : ''}`;
        tooltip.style.display = "block";
        const move = (ev) => {
            tooltip.style.left = (ev.clientX + 10) + "px";
            tooltip.style.top = (ev.clientY + 10) + "px";
        };
        move(e);
        target.onmousemove = move;
    }
  });
  modal.addEventListener('mouseout', (e) => {
      const target = e.target.closest('.db-sticker-img');
      if (target) {
          const tooltip = document.getElementById("dbStickerTooltip");
          if (tooltip) tooltip.style.display = "none";
      }
  });

  modal.classList.remove("hidden");
}

