  function generateBotTradeOffers() {
    const account = getActiveAccount();
    if (!account) return;
    
    // Ensure we have a valid list of items in the tradable box
    const tradableItems = account.items.filter(it => (state.botTradeTradableIds || []).includes(it.id));
    
    // If user has items in box, proceed with generation. If box empty, clear offers.
    if (tradableItems.length === 0) {
        botTradeOffers = [];
        const grid = document.getElementById("botTradeGrid");
        if (grid) grid.innerHTML = "<div style='grid-column:1/-1; padding:40px; color:#475569;'>Add items to the Tradable Items box above to see bot offers.</div>";
        return;
    }

    botTradeOffers = [];
    for (let i = 0; i < 20; i++) {
      const count = Math.floor(Math.random() * tradableItems.length) + 1;
      const shuffled = [...tradableItems].sort(() => 0.5 - Math.random());
      const userItems = shuffled.slice(0, count);
      const userValue = userItems.reduce((s, it) => s + getItemValue(it), 0);

      const variance = 0.96 + (Math.random() * 0.08);
      const targetBotValue = userValue * variance;
      const minBotTarget = userValue * 0.92;
      const maxBotTarget = userValue * 1.08;

      const botItems = clampBotTradeItemsToRange(generateBotItems(targetBotValue), minBotTarget, maxBotTarget);
      botTradeOffers.push({
        id: "bo_" + Date.now() + "_" + Math.random().toString(36).substr(2, 9),
        userItems,
        botItems
      });
    }
    renderBotTradeOffers();
  }

