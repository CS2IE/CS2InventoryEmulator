  const confirmMode = options.confirmMode || (options.skipBuyConfirm ? "none" : "add");
  let isSubmittingSelection = false;
  let partnerPrice = 0;
  let partnerName = null;

  if (!isSkin) {
    const isCase = name.toLowerCase().includes("case") || name.toLowerCase().includes("capsule");
    const foundKeyEntry = Object.entries(KEY_CASE_MAP).find(([k, cases]) => cases.includes(name));
    const isMappedKey = name in KEY_CASE_MAP;

    if (isMappedKey) {
      partnerName = Array.isArray(KEY_CASE_MAP[name]) ? KEY_CASE_MAP[name][0] : null;
    } else if (foundKeyEntry) {
      partnerName = foundKeyEntry[0];
    } else if (isCase) {
      const keys = Object.entries(KEY_CASE_MAP).filter(([k, cases]) => cases.includes(name)).map(([k]) => k);
      partnerName = keys[0];
    }

    if (partnerName) {
      const pData = allSkins.find(s => s.name === partnerName) || MARKET_KEYS.find(k => k.name === partnerName);
      partnerPrice = pData?.price || (pData ? mockPrice(pData) : 2.50);
    }
  }
  const runSelectionAction = ({ title, body, confirmLabel, action }) => {
    const wrappedAction = () => {
      if (isSubmittingSelection) return;
      isSubmittingSelection = true;
      try {
        action();
      } finally {
        setTimeout(() => { isSubmittingSelection = false; }, 200);
      }
    };
    wrappedAction();
  };

  const updateButtons = (data = []) => {
    list.innerHTML = "";
    const rawQty = String(qtyInput.value ?? "").trim();
    const qty = rawQty === "" ? 1 : (parseInt(rawQty, 10) || 1);
    const customPriceVal = parseFloat(priceInput.value);
    const isCustom = !isNaN(customPriceVal);

    if (!isSkin) {
        const currentPrice = isCustom ? customPriceVal : basePrice;
        const normalizedQty = qty;
        const total = currentPrice * normalizedQty;
        const nt = nametagField.value.trim() || null;
        const fVal = parseFloat(floatInput?.value);
        const partnerItemData = partnerName ? (() => {
          const partnerData = allSkins.find(s => s.name === partnerName) || MARKET_KEYS.find(k => k.name === partnerName);
          return {
            name: partnerName,
            img: partnerData?.image || partnerData?.img || getDisplayImage({ name: partnerName }),
            price: partnerPrice,
            rarity: partnerData?.rarity?.name || partnerData?.rarity || "Base Grade",
            qty: normalizedQty,
            isCustomPrice: false,
            source: "Purchased",
            nametag: null,
            floatVal: undefined
          };
        })() : null;

        const appendActionButton = ({ label, totalPrice, title, body, confirmLabel, action, className = "steam-btn highlight" }) => {
          const actionBtn = document.createElement("button");
          actionBtn.className = className;
          actionBtn.style.width = "100%";
          actionBtn.style.marginTop = list.children.length ? "8px" : "0";
          actionBtn.innerHTML = `<span>${label}</span> <span class="price-related" style="float:right">${formatPrice(totalPrice)}</span>`;
          actionBtn.onclick = () => {
            runSelectionAction({ title, body, confirmLabel, action });
          };
          list.appendChild(actionBtn);
        };

        const openLegacyBuyConfirm = (includePartner = false) => {
          const itemsToConfirm = [{
            name,
            img: itemImg?.src || imgUrl || getDisplayImage({ name }),
            price: currentPrice,
            cost: (state && state.walletlessMode) ? 0 : currentPrice,
            rarity: item?.rarity?.name || item?.rarity || "Base Grade",
            wear: null,
            type: item?.type || "Container",
            qty: normalizedQty,
            isCustomPrice: isCustom,
            source: "Purchased",
            nametag: nt,
            floatVal: hideWearControls || isNaN(fVal) ? undefined : fVal
          }];
          if (includePartner && partnerItemData) {
            itemsToConfirm.push({
              ...partnerItemData,
              cost: (state && state.walletlessMode) ? 0 : partnerPrice,
              source: "Purchased"
            });
          }
          showBuyConfirm(itemsToConfirm, () => {
            modal.classList.add("hidden");
          });
        };

        if (confirmMode !== "purchase") {
          appendActionButton({
            label: "Add to Inventory",
            totalPrice: total,
            title: "Add to Inventory",
            body: `Add ${normalizedQty} ${escapeHtml(name)} to your inventory?`,
            confirmLabel: "Add Item",
            action: () => openLegacyBuyConfirm(false)
          });
        } else {
          appendActionButton({
            label: "Confirm Purchase",
            totalPrice: total,
            title: "Confirm Purchase",
            body: `Purchase ${normalizedQty} ${escapeHtml(name)} for ${formatPrice(total)}?`,
            confirmLabel: "Purchase",
            action: () => openLegacyBuyConfirm(false)
          });
          if (partnerItemData) {
            const bundleTotal = total + (partnerPrice * normalizedQty);
            appendActionButton({
              label: "Add Both",
              totalPrice: bundleTotal,
              title: "Confirm Purchase",
              body: `Purchase ${normalizedQty} ${escapeHtml(name)} and ${normalizedQty} ${escapeHtml(partnerName)} for ${formatPrice(bundleTotal)}?`,
              confirmLabel: "Purchase",
              action: () => openLegacyBuyConfirm(true),
              className: "steam-btn grey"
            });
          }
        }

      if (partnerItemData && confirmMode !== "purchase") {
        const bundleTotal = total + (partnerPrice * normalizedQty);
        appendActionButton({
          label: "Add Both",
          totalPrice: bundleTotal,
          title: "Add Both",
          body: `Add ${normalizedQty} ${escapeHtml(name)} and ${normalizedQty} ${escapeHtml(partnerName)} to your inventory?`,
          confirmLabel: "Add Both",
          action: () => openLegacyBuyConfirm(true),
          className: "steam-btn grey"
        });

      }

    } else {
      data.forEach(res => {
        if (res === "__RANDOM_WEAR__") return;
        const btn = document.createElement("button");
        btn.className = "steam-btn highlight";
        btn.style.width = "100%";
        btn.style.textAlign = "left";
        const unitPrice = isCustom ? customPriceVal : res.numericPrice;
        const total = unitPrice * qty;
        btn.innerHTML = `<span>${res.wear}</span> <span class="price-related" style="float:right">${formatPrice(total)}</span>`;
        btn.onclick = () => {
          const nt = nametagField.value.trim() || null;
          
          // Collect StatTrak and Stickers from UI
          const stCheck = document.getElementById("purchaseStatTrakCheck");
          const isST = stCheck ? stCheck.checked : false;
          const stickerSlots = document.querySelectorAll("#purchaseStickerSlots .sticker-slot");
          const stickers = [];
          stickerSlots.forEach(slot => {
            if (slot.dataset.stickerData) {
              stickers.push(JSON.parse(slot.dataset.stickerData));
            }
          });
          
          const decoratedOnSelected = (wearVal, q, p, c) => {
            let finalName = name;
            let finalPrice = p;
            if (isST && !name.includes("StatTrak™")) {
              finalName = "StatTrak™ " + name;
              finalPrice = Math.round((p * 1.15) * 100) / 100;
            }
            const fVal = parseFloat(floatInput?.value);
            // Ensure nametag from input field is passed through
            const currentNametag = document.getElementById("purchaseNametagInput")?.value.trim() || nt;
            const charmData = document.getElementById("purchaseCharmSlot")?.dataset.charmData;
            onSelected(wearVal, q, finalPrice, c, { 
              nametag: currentNametag, 
              stickers: stickers,
              charm: charmData ? JSON.parse(charmData) : null,
              nameOverride: finalName,
              floatVal: hideWearControls || isNaN(fVal) ? undefined : fVal
            });
          };
          runSelectionAction({
            title: confirmMode === "purchase" ? "Confirm Purchase" : "Add to Inventory",
            body: confirmMode === "purchase"
              ? `Purchase ${qty} ${escapeHtml(name)} (${escapeHtml(res.wear)}) for ${formatPrice(total)}?`
              : `Add ${qty} ${escapeHtml(name)} (${escapeHtml(res.wear)}) to your inventory?`,
            confirmLabel: confirmMode === "purchase" ? "Purchase" : "Add Item",
            action: () => {
              modal.classList.add("hidden");
              decoratedOnSelected(res.wear, qty, unitPrice, isCustom);
            }
          });
        };
        list.appendChild(btn);
      });

      // Add Charm logic to random wear button too
      const randomWearBtn = document.createElement("button");
      randomWearBtn.className = "steam-btn grey";
      randomWearBtn.style.width = "100%";
      randomWearBtn.style.textAlign = "left";
      randomWearBtn.style.marginBottom = "10px";
      randomWearBtn.innerHTML = `<span>Random Wear</span> <span class="price-related" style="float:right">Each item random</span>`;
      randomWearBtn.onclick = () => {
        const nt = nametagField.value.trim() || null;
        const stCheck = document.getElementById("purchaseStatTrakCheck");
        const isST = stCheck ? stCheck.checked : false;
        const stickerSlots = document.querySelectorAll("#purchaseStickerSlots .sticker-slot");
        const stickers = [];
        stickerSlots.forEach(slot => {
          if (slot.dataset.stickerData) stickers.push(JSON.parse(slot.dataset.stickerData));
        });
        runSelectionAction({
          title: confirmMode === "purchase" ? "Confirm Purchase" : "Add Random Wear",
          body: confirmMode === "purchase"
            ? `Purchase ${qty} ${escapeHtml(name)} with random wear for ${formatPrice(basePrice * qty)}?`
            : `Add ${qty} ${escapeHtml(name)} with a random wear on each item?`,
          confirmLabel: confirmMode === "purchase" ? "Purchase" : "Add Random Wear",
          action: () => {
            modal.classList.add("hidden");
            let finalName = name;
            let finalPrice = basePrice;
            if (isST && !name.includes("StatTrakâ„¢")) {
              finalName = "StatTrakâ„¢ " + name;
              finalPrice = Math.round((basePrice * 1.15) * 100) / 100;
            }
            const fVal = parseFloat(floatInput?.value);
            onSelected(null, qty, finalPrice, isCustom, {
              nametag: nt,
              stickers,
              nameOverride: finalName,
              floatVal: hideWearControls || isNaN(fVal) ? undefined : fVal,
              randomizeWearEach: true
            });
          }
        });
      };
      list.prepend(randomWearBtn);
    }
  };

  if (!isSkin) {
    if (partnerName) {
      const pData = allSkins.find(s => s.name === partnerName) || MARKET_KEYS.find(k => k.name === partnerName);
      partnerPrice = pData?.price || (pData ? mockPrice(pData) : 2.50);
      setMaxBothBtn.classList.remove("hidden");
    } else {
      setMaxBothBtn.classList.add("hidden");
    }

    if (name.toLowerCase().includes("storage unit")) {
      qtyInput.value = 1;
      qtySlider.value = 1;
      qtyInput.max = 1;
      qtySlider.max = 1;
      if (setMaxBtn) setMaxBtn.classList.add("hidden");
      if (setMaxBothBtn) setMaxBothBtn.classList.add("hidden");
    } else {
      qtyInput.max = 200;
      qtySlider.max = 200;
      if (setMaxBtn) setMaxBtn.classList.remove("hidden");
    }

    // NEW: show owned counterpart counts (keys for a case, cases for a key) at top of modal list
    try {
      const account = getActiveAccount();
      let ownedLabelHtml = "";
      const isActuallyKey = name.toLowerCase().includes("key");
      const isActuallyCase = (name.toLowerCase().includes("case") || name.toLowerCase().includes("capsule") || name.toLowerCase().includes("package")) && !isActuallyKey;

      if (isActuallyCase) {
        // count owned keys in top-level inventory (not inside storage)
        const requiredKeys = getRequiredKeysForCase(name);
        if (requiredKeys.length > 0 && account) {
          const ownedKeys = account.items.filter(it => {
            const itName = (it.name || "").toLowerCase().split(' (')[0].trim();
            return requiredKeys.some(rk => rk.toLowerCase().trim() === itName);
          }).length;
          ownedLabelHtml = `<div style="font-size:13px; color:#94a3b8; margin-bottom:8px;">Keys owned for this case: <strong style="color:#fff">${ownedKeys}</strong></div>`;
        }
      } else if (isActuallyKey) {
        // count mapped cases in top-level inventory
        let mappedCases = [];
        const baseKey = (name || "").split(' (')[0].trim();
        if (KEY_CASE_MAP[baseKey]) {
           mappedCases = KEY_CASE_MAP[baseKey];
        } else {
          // robust reverse lookup
          mappedCases = Object.entries(KEY_CASE_MAP).reduce((acc, [k, cases]) => {
            if (k.toLowerCase().trim().includes(baseKey.toLowerCase().trim()) || baseKey.toLowerCase().trim().includes(k.toLowerCase().trim())) {
              acc.push(...cases);
            }
            return acc;
          }, []);
        }

        if (mappedCases.length > 0 && account) {
          const ownedCases = account.items.filter(it => {
            const itBase = (it.name || "").split(' (')[0].trim().toLowerCase();
            return mappedCases.some(mc => mc.toLowerCase().trim().includes(itBase) || itBase.includes(mc.toLowerCase().trim()));
          }).length;
          ownedLabelHtml = `<div style="font-size:13px; color:#94a3b8; margin-bottom:8px;">Cases owned for this key: <strong style="color:#fff">${ownedCases}</strong></div>`;
        }
      }
      // If an ownedLabel is available, inject it above list to inform user
      if (ownedLabelHtml) {
        // create a small helper header inside the modal list area
        const infoNode = document.createElement('div');
        infoNode.id = "__wearModalCounterInfo";
        infoNode.style.padding = "6px 0 10px 0";
        infoNode.style.width = "100%";
        infoNode.innerHTML = ownedLabelHtml;
        // remove pre-existing info node if present
        const existingInfo = document.getElementById("__wearModalCounterInfo");
        if (existingInfo && existingInfo.parentElement) existingInfo.parentElement.removeChild(existingInfo);
        const wearListParent = list.parentElement || list;
        wearListParent.insertBefore(infoNode, list);
      } else {
        const existingInfo = document.getElementById("__wearModalCounterInfo");
        if (existingInfo && existingInfo.parentElement) existingInfo.parentElement.removeChild(existingInfo);
      }
    } catch (e) {
      console.warn("Failed to compute owned counterpart counts:", e);
    }

    setMaxBtn.onclick = () => {
      const acc = getActiveAccount();
      const customVal = parseFloat(priceInput.value);
      const unitP = !isNaN(customVal) ? customVal : basePrice;
      if (acc && unitP > 0) {
        qtyInput.value = Math.max(1, Math.floor(acc.walletBalance / unitP));
        updateButtons();
      }
    };

    setMaxBothBtn.onclick = () => {
      const acc = getActiveAccount();
      const customVal = parseFloat(priceInput.value);
      const unitP = !isNaN(customVal) ? customVal : basePrice;
      const bundleP = unitP + partnerPrice;
      if (acc && bundleP > 0) {
        qtyInput.value = Math.max(1, Math.floor(acc.walletBalance / bundleP));
        updateButtons();
      }
    };

    const handleQtyChange = () => {
      if (String(qtyInput.value ?? "") === "") {
        updateButtons();
        return;
      }
      const val = Math.max(1, Math.min(100, parseInt(qtyInput.value, 10) || 1));
      qtyInput.value = val;
      qtySlider.value = val;
      updateButtons();
    };
    qtyInput.oninput = handleQtyChange;
    qtySlider.oninput = () => {
      qtyInput.value = qtySlider.value;
      updateButtons();
    };
    updateButtons();
    priceInput.oninput = () => updateButtons();
  } else {
    setMaxBothBtn.classList.add("hidden");
    setMaxBtn.onclick = () => {
      const acc = getActiveAccount();
      const customVal = parseFloat(priceInput.value);
      // For skins, we use the average/base price for a quick guess if specific wear isn't picked yet
      const unitP = !isNaN(customVal) ? customVal : basePrice; 
      if (acc && unitP > 0) {
        qtyInput.value = Math.max(1, Math.floor(acc.walletBalance / unitP));
      }
    };

    const pricePromises = WEARS.map(async (wear) => {
      const wearName = name + " (" + wear + ")";
      const steamPrice = await fetchSteamPrice(wearName);
      const numericPrice = parsePriceText(steamPrice) || (basePrice * (WEAR_PRICE_MODS[wear] || 1.0));
      return { wear, steamPrice, numericPrice };
    });
    const results = await Promise.all(pricePromises);
    
    const handleQtyChangeSkin = () => {
      if (String(qtyInput.value ?? "") === "") {
        updateButtons(results);
        return;
      }
      const val = Math.max(1, Math.min(100, parseInt(qtyInput.value, 10) || 1));
      qtyInput.value = val;
      qtySlider.value = val;
      updateButtons(results);
    };
    
    qtyInput.oninput = handleQtyChangeSkin;
    qtySlider.oninput = () => {
      qtyInput.value = qtySlider.value;
      updateButtons(results);
    };
    updateButtons(results);
    priceInput.oninput = () => updateButtons(results);
  }
}

function showGunStickerManager(gunId) {
  const account = getActiveAccount();
  const gun = account.items.find(it => it.id === gunId);
  if (!gun) return;

  if ((gun.name || "").toLowerCase().includes("storage unit")) {
    alert("Cannot manage stickers for a Storage Unit.");
    return;
  }

  directApplyTargetId = gunId;
  const modal = document.getElementById("gunStickerManagerModal");
  document.getElementById("gunStickerTitle").textContent = "Skins/Charm: " + (gun.nametag || gun.name);
  
  const grid = document.getElementById("gunStickerSlotGrid");
  grid.innerHTML = "";

  // Stickers 1-5
  const appliedStickers = gun.stickers || [];
  for (let i = 0; i < 5; i++) {
    const slot = document.createElement("div");
    slot.className = "sticker-slot";
    if (i < appliedStickers.length) {
      const s = appliedStickers[i];
      slot.innerHTML = `<img src="${s.img}" title="${s.name} - Click to Remove">`;
      slot.onclick = () => {
        showInScreenConfirm(`Remove ${s.name}?`, () => {
          addItemToAccount({ name: s.name, img: s.img, price: s.price, rarity: s.rarity || "High Grade", type: "Sticker", source: "Removed from weapon" });
          gun.stickers.splice(i, 1);
          saveState(); showGunStickerManager(gunId); refreshInventoryView();
        });
      };
    } else {
      slot.classList.add("empty");
      slot.onclick = () => showStickerPickerForGun(gunId);
    }
    grid.appendChild(slot);
  }

  // Charm Slot
  const charmSlot = document.createElement("div");
  charmSlot.className = "sticker-slot";
  charmSlot.style.marginLeft = "20px";
  charmSlot.style.borderColor = "#66c0f4";
  if (gun.charm) {
    charmSlot.innerHTML = `<img src="${gun.charm.img}" title="${gun.charm.name} - Click to Remove">`;
    charmSlot.onclick = () => {
      showInScreenConfirm(`Remove charm ${gun.charm.name}?`, () => {
        addItemToAccount({ name: gun.charm.name, img: gun.charm.img, price: gun.charm.price, rarity: "Base Grade", type: "Charm", source: "Removed from weapon" });
        gun.charm = null;
        saveState(); showGunStickerManager(gunId); refreshInventoryView();
      });
    };
  } else {
    charmSlot.classList.add("empty");
    charmSlot.style.background = "rgba(102, 192, 244, 0.1)";
    charmSlot.onclick = () => {
      showStickerPickerForWearModal((s) => {
        gun.charm = { name: s.name, img: s.img, price: s.price };
        saveState(); showGunStickerManager(gunId); refreshInventoryView();
      }, "Charm |");
    };
  }
  grid.appendChild(charmSlot);

  modal.classList.remove("hidden");
}

function showStickerTargetModal(stickerId) {
  const account = getActiveAccount();
  const stickerItem = account.items.find(it => it.id === stickerId);
  if (!stickerItem) return;

  const modal = document.getElementById("stickerModal");
  const list = document.getElementById("stickerTargetList");
  list.innerHTML = "";

  // Update modal header/description for "pick gun" mode
  const titleEl = modal.querySelector("h2");
  const descEl = modal.querySelector("p");
  if (titleEl) titleEl.textContent = "Apply Sticker";
  if (descEl) descEl.textContent = "Select a gun to apply this sticker to:";

  // Prevent applying stickers to storage units (they are containers only)
  let eligibleGuns = account.items.filter(it => {
    const n = it.name.toLowerCase();
    const type = (it.type || "").toLowerCase();

    // Exclude storage units explicitly
    if (n.includes("storage unit")) return false;

    const isExcluded = (!n.includes('|') && (n.includes('case') || n.includes('package') || n.includes('crate') || n.includes('capsule'))) || 
                       n.includes('sticker') || n.includes('knife') || n.includes('★') || n.includes('glove') || 
                       n.includes('agent') || n.includes('pin') || n.includes('music kit') || n.includes('graffiti') || 
                       n.includes('key') || n.includes('charm') || n.includes('tool') || n.includes('pass') || 
                       type.includes('knife') || type.includes('gloves') || type.includes('agent') || type.includes('container') || type.includes('key');
    
    const stickerCount = (it.stickers || []).length;
    return it.id !== stickerId && !isExcluded && stickerCount < 5;
  });

  // Sort eligible guns most expensive -> least expensive for Apply Sticker modal
  eligibleGuns.sort((a, b) => getItemValue(b) - getItemValue(a));

  if (eligibleGuns.length === 0) {
    list.innerHTML = "<p style='grid-column: 1/-1; padding: 20px;'>No eligible guns with space for stickers found.</p>";
  }

  eligibleGuns.forEach(gun => {
    const card = document.createElement('div');
    card.className = "card";
    card.style.cursor = "pointer";
    card.style.padding = "10px";
    card.style.display = "flex";
    card.style.flexDirection = "column";
    card.style.alignItems = "center";
    
    // Create 5 small slots for stickers in the gun selector
    let slotsHtml = '';
    const stickers = gun.stickers || [];
    for (let i = 0; i < 5; i++) {
      if (i < stickers.length) {
        slotsHtml += `<img src="${stickers[i].img}" style="width:20px; height:20px; object-fit:contain; background:rgba(0,0,0,0.3); border-radius:2px;" title="${stickers[i].name}">`;
      } else {
        slotsHtml += `<div style="width:20px; height:20px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:2px;"></div>`;
      }
    }

    const gunPrice = getItemValue(gun);
    const gunRarityName = gun.rarity?.name || gun.rarity || "Consumer";
    const rarityColor = RARITY_COLORS[gunRarityName] || "#fff";

    card.innerHTML = `
      <img src="${gun.img}" style="height: 65px; margin-bottom: 5px;">
      <div style="font-size: 11px; text-align:center; height: 28px; overflow: hidden; line-height: 1.1; font-weight: bold;">${gun.name}</div>
      <div style="color: ${rarityColor}; font-size: 10px; margin-bottom: 2px;">${gunRarityName}</div>
      <div class="price-related" style="color: #a4d007; font-size: 11px; font-weight: bold;">${formatPrice(gunPrice)}</div>
      <div style="display: flex; gap: 3px; margin-top: 8px; justify-content: center; width: 100%;">
        ${slotsHtml}
      </div>
    `;
    card.onclick = () => {
      if (!gun.stickers) gun.stickers = [];
      gun.stickers.push({ 
        name: stickerItem.name, 
        img: stickerItem.img, 
        price: stickerItem.price,
        rarity: stickerItem.rarity
      });
      
      // Remove the sticker from inventory
      account.items = account.items.filter(it => it.id !== stickerId);
      
      modal.classList.add("hidden");
      state.selectedItemId = gun.id;
      saveState();
      refreshInventoryView();
    };
    list.appendChild(card);
  });

  modal.classList.remove("hidden");
}

function showStickerPickerForGun(gunId) {
