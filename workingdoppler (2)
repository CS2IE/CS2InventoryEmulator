function spinJackpot() {
  if (jackpotBet.length === 0) {
    alert("Add items to bet!");
    return;
  }
  
  const account = getActiveAccount();
  if (!account) return;

  // Determine result before animation starts for consistent behavior
  let finalRoll;
  let won = false;

  const mult = state.diceMultiplier || 1;
  const winChances = { 1: 0.85, 2: 0.65, 3: 0.45, 4: 0.30, 5: 0.20 };
  const targetWinChance = winChances[mult] || 0.50;

  if (state.cheatWinActive) {
    won = true;
    finalRoll = state.diceTarget === "over" ? 75 : 25;
    state.cheatWinActive = false;
  } else {
    won = Math.random() < targetWinChance;
    if (won) {
      finalRoll = state.diceTarget === "over" ? (51 + Math.floor(Math.random() * 49)) : Math.floor(Math.random() * 51);
    } else {
      finalRoll = state.diceTarget === "over" ? Math.floor(Math.random() * 51) : (51 + Math.floor(Math.random() * 49));
    }
  }

  // Track participation in Dice gamble
  account.hasGambledDice = true;
  
  const betValue = jackpotBet.reduce((sum, it) => sum + getItemValue(it), 0);
  account.diceWagered = (account.diceWagered || 0) + betValue;
  const spinLabel = state.hidePrices ? "SPIN" : `SPIN (${formatPrice(betValue)})`;
  document.getElementById("spinBtn").innerHTML = spinLabel;
  
  // Preserve exact bet objects so we can reliably return them if the user wins.
  const removedBetItems = jackpotBet.slice();

  // IMMEDIATELY remove items from inventory on spin start
  removedBetItems.forEach(it => {
    account.items = account.items.filter(i => i.id !== it.id);
  });
  saveState();
  refreshInventoryView();

  document.querySelectorAll(".dice-mult-btn").forEach(btn => btn.classList.remove("highlight"));
  document.getElementById("diceMultDisplay").textContent = "";

  const diceEl = document.getElementById("diceValue");
  let spins = 0;
  const totalSpins = 25;
  const rollInterval = setInterval(() => {
    diceEl.textContent = Math.floor(Math.random() * 100);
    spins++;
    if (spins >= totalSpins) {
      clearInterval(rollInterval);
      
      // Force immediate display of predetermined final roll and do not tick further
      diceEl.textContent = String(finalRoll);
      
      const resultText = document.getElementById("jackpotResultText");
      const winningsDiv = document.getElementById("jackpotWinnings");
      document.getElementById("jackpotResult").style.display = "block";
      winningsDiv.innerHTML = "";

      if (won) {
        // Respect the user-selected multiplier from state
        const mult = state.diceMultiplier || 1;

        document.querySelectorAll(".dice-mult-btn").forEach(btn => {
            if (parseInt(btn.dataset.mult) === mult) btn.classList.add("highlight");
            else btn.classList.remove("highlight");
        });
        document.getElementById("diceMultDisplay").textContent = `Multiplier Applied: ${mult}x!`;

        // Return the exact bet objects back into the account
        removedBetItems.forEach(it => {
          if (!account.items.some(ai => ai.id === it.id)) {
            account.items.push(it);
          }
        });

        if (!state.jackKnife) {
          let totalWinValue = 0;
          removedBetItems.forEach(it => {
            for(let i=0; i < mult; i++) {
              const sanitized = {
                name: it.name, img: it.img || getStableDisplayImage(it), price: it.price || mockPrice(it),
                rarity: it.rarity || "Consumer", wear: null, floatVal: null, pattern: null, qty: 1, type: it.type || "Item",
                stickers: Array.isArray(it.stickers) ? it.stickers.map(s => ({ name: s.name, img: s.img, price: s.price })) : [],
                source: "Dice Game Win", isReturn: true
              };
              addItemToAccount(sanitized, { skipPriceFix: true, skipPopup: false });
              totalWinValue += (sanitized.price || 0);
            }
          });

          resultText.textContent = state.hidePrices ? `🎉 WON! MULTIPLIER ${mult}x!` : `🎉 WON! MULTIPLIER ${mult}x! (${formatPrice(totalWinValue)})`;
          resultText.style.color = "#a4d007";
          account.diceProfit = (account.diceProfit || 0) + (totalWinValue - betValue);

          hasShownNewItemPopup = false;
          showGroupedPurchaseResult();
        } else {
          // jackKnife is ON -> previous behavior: also award additional winnings (potentially knives) totaling ~2x bet
          const targetWinAmount = betValue * 2;
          let currentWinValue = 0;
          const chosen = [];

          // Filter skins pool for high quality weapons/knives/gloves
          const weaponFilter = (s) => {
            const n = s.name.toLowerCase();
            const type = (s.weapon?.name || s.category?.name || "").toLowerCase();
            return type.includes("rifle") || type.includes("pistol") || type.includes("smg") || 
                   type.includes("sniper") || type.includes("shotgun") || type.includes("machine") || 
                   type.includes("knife") || n.includes("★") || n.includes("gloves");
          };

          // Choose source pool based on bet size: for bets > $100 prefer knife/glove pool; otherwise pick weapons that fit range.
          const isKnifeLikeFilter = (s) => {
            const n = (s.name || "").toLowerCase();
            const t = (s.type || s.category?.name || "").toLowerCase();
            return n.includes("★") || n.includes("knife") || n.includes("gloves") || t.includes("knife") || t.includes("gloves");
          };

          const poolSource = (betValue > 100)
            ? allSkins.filter(isKnifeLikeFilter)
            : allSkins.filter(weaponFilter);

          const pool = poolSource
            .map(s => ({ skin: s, price: mockPrice(s) }))
            .filter(e => e.price > 0.5)
            .sort((a, b) => b.price - a.price);

          // Multiplier logic check: multiplier already chosen above. Ensure items returned + extra mult results.
  // Note: code above handles mult items if !state.jackKnife
  while (currentWinValue < targetWinAmount * 0.95 && chosen.length < 15) {
            const remaining = targetWinAmount - currentWinValue;
            // Prefer picks that fit inside the remaining target to avoid large overshoot; fallback to cheapest available.
            let possible = pool.filter(e => e.price <= remaining);
            if (possible.length === 0) {
              // if no single item fits remaining budget, try to pick the smallest available to progress
              const smallest = pool[pool.length - 1];
              if (smallest) {
                chosen.push(smallest);
                currentWinValue += smallest.price;
              }
              break;
            }
            
            const topPick = Math.min(possible.length, 10);
            const choice = possible[Math.floor(Math.random() * topPick)];
            chosen.push(choice);
            currentWinValue += choice.price;
          }

          chosen.forEach(entry => {
            const skin = entry.skin;
            const itemData = {
              name: skin.name,
              img: getDisplayImage(skin),
              price: entry.price,
              rarity: skin.rarity?.name || "Covert",
              wear: null, // Force re-randomization in addItemToAccount
              floatVal: null,
              pattern: null,
              qty: 1,
              source: "Gambled"
            };
            // IMPORTANT: Do not let global PRICE_FIXES / state.priceOverrides override the awarded item's price.
            // Pass skipPriceFix so addItemToAccount will use the explicit entry.price (or mockPrice) and won't write
            // or consult PRICE_FIXES for this awarded item.
            addItemToAccount(itemData, { skipPriceFix: true });

            const img = document.createElement("img");
            img.src = itemData.img;
            img.style.width = "80px";
            img.style.height = "60px";
            img.style.objectFit = "contain";
            img.style.background = "rgba(255,255,255,0.05)";
            img.style.borderRadius = "4px";
            img.style.padding = "5px";
            winningsDiv.appendChild(img);
          });

          resultText.textContent = state.hidePrices ? `🎉 WON! REGAINED BET!` : `🎉 WON! REGAINED BET + WON ${formatPrice(currentWinValue)}`;
          resultText.style.color = "#a4d007";
          account.diceProfit = (account.diceProfit || 0) + currentWinValue;

          // Show NEW ITEM popup for awarded items
          hasShownNewItemPopup = false;
          showGroupedPurchaseResult();
        }
      } else {
        document.querySelectorAll(".dice-mult-btn").forEach(btn => btn.classList.remove("highlight"));
        document.getElementById("diceMultDisplay").textContent = "";

        // If they lost, do not return removedBetItems to inventory (they were consumed).
        logUsedToHaveItems(account, removedBetItems, "Gambled Away");
        resultText.textContent = state.hidePrices ? `❌ LOST!` : `❌ LOST! YOU LOST ${formatPrice(betValue)}!`;
        resultText.style.color = "#eb4b4b";
        winningsDiv.innerHTML = "<p>Unlucky roll.</p>";
        // Track gambling loss per account
        account.totalLost = (account.totalLost || 0) + betValue;
        account.diceProfit = (account.diceProfit || 0) - betValue;
      }
      
      jackpotBet = [];
      renderJackpotBet();
      initJackpotModal();
      saveState();
      refreshInventoryView();
    }
  }, 80);
}

