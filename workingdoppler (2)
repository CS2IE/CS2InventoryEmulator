/**
 * Robustly finds an item by ID anywhere within an account (root or nested in storage units).
 */
function findItemById(account, id) {
  if (!account || !account.items) return null;
  // Check top level
  const rootItem = account.items.find(it => it.id === id);
  if (rootItem) return rootItem;
  
  // Check inside storage units
  for (const it of account.items) {
    if (it.contents && Array.isArray(it.contents)) {
      const found = it.contents.find(c => c.id === id);
      if (found) return found;
    }
  }
  return null;
}

/**
 * Find the container array (top-level or storage contents) that holds a given item id.
 */
function findItemContainer(account, id) {
  if (!account || !Array.isArray(account.items)) return null;
  const rootIdx = account.items.findIndex(it => it && it.id === id);
  if (rootIdx !== -1) return { container: account.items, index: rootIdx, unit: null };
  for (const u of account.items) {
    if (u && Array.isArray(u.contents)) {
      const idx = u.contents.findIndex(c => c && c.id === id);
      if (idx !== -1) return { container: u.contents, index: idx, unit: u };
    }
  }
  return null;
}

/**
 * Count matching items that are located inside any storage unit across the given account.
 * Matches by name and nametag (if applicable) to produce a storage-only quantity.
 */
function countItemsInStorageUnits(account, matchName, matchNametag) {
  if (!account || !Array.isArray(account.items)) return 0;
  let count = 0;
  account.items.forEach(u => {
    if (!u || !Array.isArray(u.contents)) return;
    u.contents.forEach(c => {
      if (!c || !c.name) return;
      if (c.name === matchName && ((c.nametag || "") === (matchNametag || ""))) {
        count += (c.qty || 1);
      }
    });
  });
  return count;
}

function countItemsInAccount(account, predicate) {
  if (!account || !account.items) return 0;
  let count = 0;
  account.items.forEach(it => {
    if (predicate(it)) count += (it.qty || 1);
    if (it.contents && Array.isArray(it.contents)) {
      it.contents.forEach(sub => {
        if (predicate(sub)) count += (sub.qty || 1);
      });
    }
  });
  return count;
}

function parsePriceText(text) {
  if (!text) return 0;
  // Match user snippet's approach to handle currency symbols and commas
  const clean = text.replace("$", "").replace(",", "").replace(/[^0-9.]/g, "");
  const val = parseFloat(clean);
  return isNaN(val) ? 0 : val;
}

