  if (!canvas) return;
  const ctx = canvas.getContext("2d");
  if (!ctx) return;
  ctx.fillStyle = "#f8fafc";
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  tradeUpSignatureDrawn = false;
  refreshTradeUpSignButtonState();
}

function initTradeUpSignaturePad() {
  const canvas = document.getElementById("tradeUpSignaturePad");
  if (!canvas) return;
  const ctx = canvas.getContext("2d");
  if (!ctx) return;

  clearTradeUpSignaturePad();
  ctx.strokeStyle = "#2563eb";
  ctx.lineWidth = 4;
  ctx.lineCap = "round";
  ctx.lineJoin = "round";

  let drawing = false;

  const getPoint = (evt) => {
    const rect = canvas.getBoundingClientRect();
    const source = evt.touches ? evt.touches[0] : evt;
    return {
      x: (source.clientX - rect.left) * (canvas.width / rect.width),
      y: (source.clientY - rect.top) * (canvas.height / rect.height)
    };
  };

  const start = (evt) => {
    evt.preventDefault();
    drawing = true;
    const point = getPoint(evt);
    ctx.beginPath();
    ctx.moveTo(point.x, point.y);
  };

  const move = (evt) => {
    if (!drawing) return;
    evt.preventDefault();
    const point = getPoint(evt);
    ctx.lineTo(point.x, point.y);
    ctx.stroke();
    if (!tradeUpSignatureDrawn) {
      tradeUpSignatureDrawn = true;
      refreshTradeUpSignButtonState();
    }
  };

  const end = () => {
    drawing = false;
  };

  canvas.onpointerdown = start;
  canvas.onpointermove = move;
  canvas.onpointerup = end;
  canvas.onpointerleave = end;
  canvas.ontouchstart = start;
  canvas.ontouchmove = move;
  canvas.ontouchend = end;
}

