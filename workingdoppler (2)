// Helper to copy entire inventory as formatted text
function copyInventoryToClipboard() {
    const acc = getActiveAccount();
    if (!acc) return;
    
    // Group and count items
    const itemMap = new Map();
    
    const processItem = (it) => {
        if (!it || it.name.toLowerCase().includes("storage unit")) return;
        const stickers = (it.stickers || []).map(s => s.name).join(", ");
        const key = `${it.name}|${stickers}`;
        const existing = itemMap.get(key) || { count: 0, name: it.name, stickers };
        existing.count += (it.qty || 1);
        itemMap.set(key, existing);
    };

    acc.items.forEach(it => {
        processItem(it);
        if (it.contents && Array.isArray(it.contents)) {
            it.contents.forEach(processItem);
        }
    });

    const lines = Array.from(itemMap.values()).map(data => {
        return `(${data.count}) ${data.name}${data.stickers ? ' [' + data.stickers + ']' : ''}`;
    });

    if (lines.length === 0) {
        alert("Inventory is empty!");
        return;
    }

    navigator.clipboard.writeText(lines.join(", ")).then(() => {
        alert("Inventory list copied to clipboard!");
    }).catch(err => {
        console.error("Clipboard copy failed:", err);
    });
}

// Helper to copy entire inventory as formatted text
function copyInventoryToClipboard() {
    const acc = getActiveAccount();
    if (!acc) return;
    
    // Include top-level and storage unit contents
    const allItems = [...acc.items];
    acc.items.forEach(it => {
        if (it.contents && Array.isArray(it.contents)) {
            allItems.push(...it.contents);
        }
    });

    const lines = allItems.map(it => {
        if (it.name.toLowerCase().includes("storage unit")) return null;
        const stickers = (it.stickers || []).map(s => s.name).join(", ");
        return `(1) ${it.name} ${stickers ? '[' + stickers + ']' : ''}`;
    }).filter(Boolean);

    navigator.clipboard.writeText(lines.join(", ")).then(() => {
        alert("Inventory exported to clipboard!");
    }).catch(err => {
        console.error("Clipboard copy failed:", err);
    });
}

