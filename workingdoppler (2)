}

function getDopplerSearchQueries(itemOrName) {
  const exactName = typeof itemOrName === "string"
    ? normalizeMarketHashName(itemOrName)
    : getExactDopplerLookupName(itemOrName);
  if (!exactName) return [];

  const noStar = exactName.replace(/^★\s*/u, "").trim();
  const noStatTrak = exactName.replace(/^StatTrak™\s+/i, "").trim();
  const noStarNoStatTrak = noStar.replace(/^StatTrak™\s+/i, "").trim();
  const phase = extractExplicitDopplerPhase(exactName);
  const baseNoPhase = exactName
    .replace(/\s+\((Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)\)$/i, "")
    .replace(/\s+(Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)$/i, "")
    .trim();
  const phaseSuffix = phase ? ` ${phase}` : "";

  return Array.from(new Set([
    exactName,
    noStar,
    noStatTrak,
    noStarNoStatTrak,
    `${baseNoPhase}${phaseSuffix}`.trim(),
    `${noStarNoStatTrak.replace(/\s+\((Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)\)$/i, "").trim()}${phaseSuffix}`.trim()
  ].filter(Boolean)));
}

async function fetchExactDopplerSteamImage(itemOrName) {
  const exactName = typeof itemOrName === "string"
    ? normalizeMarketHashName(itemOrName)
    : getExactDopplerLookupName(itemOrName);
  if (!exactName || !/doppler/i.test(exactName)) return "";
  if (dopplerSteamImageCache[exactName]) return dopplerSteamImageCache[exactName];
  if (dopplerSteamImagePending[exactName]) return dopplerSteamImagePending[exactName];

  dopplerSteamImagePending[exactName] = (async () => {
    try {
      const normalizedExact = normalizeSteamDopplerLookupName(exactName);
      const steamData = await fetchSteamSearch(exactName);
      const results = Array.isArray(steamData?.results) ? steamData.results : [];
      const exactResult = results.find(result => (
        normalizeSteamDopplerLookupName(result?.hash_name || result?.name || "") === normalizedExact
      ));
      const resolvedImage = getSteamMarketResultImage(exactResult || null);
      if (resolvedImage) {
        dopplerSteamImageCache[exactName] = resolvedImage;
        return resolvedImage;
      }
      return "";
    } catch (e) {
      console.warn("fetchExactDopplerSteamImage failed:", exactName, e);
      return "";
    } finally {
      delete dopplerSteamImagePending[exactName];
    }
  })();

  return dopplerSteamImagePending[exactName];
}

async function hydrateExactDopplerImage(item) {
  if (!item) return "";
