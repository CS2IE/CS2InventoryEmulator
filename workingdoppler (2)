async function exportStateToClipboard() {
  const fallbackCopy = (text) => {
    const ta = document.createElement("textarea");
    ta.value = text;
    ta.setAttribute("readonly", "");
    ta.style.position = "fixed";
    ta.style.opacity = "0";
    ta.style.pointerEvents = "none";
    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    ta.setSelectionRange(0, ta.value.length);
    let ok = false;
    try { ok = document.execCommand("copy"); } catch (e) {}
    ta.remove();
    return ok;
  };
  const showManualExportFallback = (text) => {
    try {
      const existing = document.getElementById("manualExportFallbackModal");
      if (existing) existing.remove();
      const overlay = document.createElement("div");
      overlay.id = "manualExportFallbackModal";
      overlay.className = "modal-overlay";
      overlay.style.zIndex = "10001";
      overlay.innerHTML = `
        <div class="steam-modal" style="max-width: 760px; width: min(92vw, 760px); padding: 20px;">
          <div style="font-size: 22px; font-weight: 900; margin-bottom: 12px;">Export Save</div>
          <div style="font-size: 14px; color: #cbd5e1; margin-bottom: 12px;">Clipboard copy was blocked, so your full save JSON is shown below and selected for manual copy.</div>
          <textarea id="manualExportFallbackText" class="steam-input" style="width:100%; min-height:320px; resize:vertical;">${text.replace(/</g, "&lt;")}</textarea>
          <div style="display:flex; gap:10px; margin-top:12px;">
            <button id="manualExportFallbackCopy" class="steam-btn">Copy Again</button>
            <button id="manualExportFallbackClose" class="steam-btn grey">Close</button>
          </div>
        </div>
      `;
      document.body.appendChild(overlay);
      const textEl = overlay.querySelector("#manualExportFallbackText");
      const closeBtn = overlay.querySelector("#manualExportFallbackClose");
      const copyBtn = overlay.querySelector("#manualExportFallbackCopy");
      if (textEl) {
        textEl.focus();
        textEl.select();
        textEl.setSelectionRange(0, textEl.value.length);
      }
      if (closeBtn) closeBtn.onclick = () => overlay.remove();
      if (copyBtn) copyBtn.onclick = async () => {
        const value = textEl?.value || text;
        if (navigator.clipboard && navigator.clipboard.writeText) {
          try {
            await navigator.clipboard.writeText(value);
            alert("Save JSON copied to clipboard.");
            return;
          } catch (err) {}
        }
        if (textEl) {
          textEl.focus();
          textEl.select();
          textEl.setSelectionRange(0, textEl.value.length);
        }
        if (fallbackCopy(value)) {
          alert("Save JSON copied to clipboard.");
        } else {
          alert("Clipboard is blocked. The save JSON is selected so you can copy it manually.");
        }
      };
    } catch (err) {
      alert("Clipboard is blocked. Please allow clipboard access and try again.");
    }
  };
  try {
    const snapshotObj = buildStateSnapshotObject();
    const compactSnapshot = JSON.stringify(snapshotObj);
    state.__lastSavedAt = snapshotObj.__lastSavedAt;
    mirrorSnapshotToAllStores(compactSnapshot);
    const json = JSON.stringify(snapshotObj, null, 2);
    if (navigator.clipboard && navigator.clipboard.writeText) {
      try {
        await navigator.clipboard.writeText(json);
        alert("Current application state (Accounts, Items, and Prices) copied to clipboard!");
        return;
      } catch (err) {}
    }
    if (fallbackCopy(json)) {
      alert("Current application state (Accounts, Items, and Prices) copied to clipboard!");
      return;
    }
    showManualExportFallback(json);
  } catch (err) {
    alert("Failed to copy state: " + err);
  }
}

