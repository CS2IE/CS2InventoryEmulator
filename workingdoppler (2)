/**
 * Resolves which keys can open a specific case.
 */
function getRequiredKeysForCase(caseName) {
  const lowerCaseName = String(caseName || "").toLowerCase();
  // MLG Columbus 2016 capsules are keyless
  if (lowerCaseName.includes("mlg columbus 2016")) return [];
  if ((lowerCaseName.includes("capsule") || lowerCaseName.includes("sticker")) &&
      !lowerCaseName.includes("sticker capsule 1") &&
      !lowerCaseName.includes("sticker capsule 2")) {
    return [];
  }

  return Object.entries(KEY_CASE_MAP)
    .filter(([keyName, caseNames]) => {
      if (keyName === "CS:GO Case Key" && lowerCaseName.includes("cs:go weapon case")) return true;
      return caseNames.some(cn => lowerCaseName.includes(cn.toLowerCase()) || cn.toLowerCase().includes(lowerCaseName));
    })
    .map(([keyName]) => keyName);
}

/**
 * Show the Unlock Container confirmation UI for a case name (not necessarily owned).
 * This mirrors openCase's confirmation flow but uses a case name to populate the caseConfirmModal.
 */
function showCaseConfirmForCaseName(caseName, sourceKeyId = null, caseItemId = null, previewOnly = false) {
  // Defensive guard: ensure required DOM elements exist; if not, fallback to opening the case directly.
  const confirmModal = document.getElementById("caseConfirmModal");
  const caseImg = document.getElementById("caseConfirmImage");

  if (!confirmModal || !caseImg) {
    console.warn("caseConfirmModal or caseConfirmImage not found; falling back to openCase for", caseName);
    try {
      // Try to open an owned instance of the named case, otherwise create a temporary case and open it.
      const acc = getActiveAccount();
      if (acc) {
        const ownedCase = acc.items.find(it => (it.name || "").split(' (')[0].trim() === caseName || it.name === caseName);
        if (ownedCase) {
          openCase(ownedCase.id, true, sourceKeyId, 1);
          return;
        }
      }
      // Create temporary case and open immediately as a last-resort fallback
      const acc2 = getActiveAccount();
      if (!acc2) return;
      const newCase = {
        id: "it_case_temp_fallback_" + Date.now() + "_" + Math.random().toString(16).slice(2),
        name: caseName,
        img: getDisplayImage({ name: caseName }),
        price: PRICE_FIXES[caseName] || mockPrice({ name: caseName }),
        rarity: "Base Grade",
        type: "Container",
        contents: []
      };
      acc2.items.push(newCase);
      saveState();
      openCase(newCase.id, true, sourceKeyId, 1);
    } catch (err) {
      console.error("Fallback openCase failed:", err);
    }
    return;
  }

  // If caller accidentally passed a key name, map it to its case(s) so the modal shows the case contents.
  try {
    const base = (caseName || "").split(' (')[0].trim();
    // If this name is a known key in KEY_CASE_MAP, pick its first mapped case for display
    if (KEY_CASE_MAP && KEY_CASE_MAP[base]) {
      const mapped = KEY_CASE_MAP[base];
      if (Array.isArray(mapped) && mapped.length > 0) {
        caseName = mapped[0];
      }
    } else {
      // Reverse lookup: if the provided string looks like a key (contains "key") try to find a matching mapping
      const lower = base.toLowerCase();
      if (lower.includes("key")) {
        const found = Object.entries(KEY_CASE_MAP || {}).find(([k, cases]) => {
          // match by key id or close name
          return k.toLowerCase().trim() === lower || k.toLowerCase().includes(lower) || lower.includes(k.toLowerCase());
        });
        if (found && Array.isArray(found[1]) && found[1].length > 0) {
          caseName = found[1][0];
        }
      }
    }
  } catch (e) {
    // fallback: keep original caseName
  }

  // HARDCODE FIX: Always show the CASE image (never the key) for the unlock container popup.
  caseImg.src = getDisplayImage({ name: caseName });

  // Also ensure the case-opening modal background is set to this case so any subsequent opens use the correct art
