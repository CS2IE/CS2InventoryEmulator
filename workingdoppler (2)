function adjustSelectedQty(delta) {
  const account = getActiveAccount();
  if (!account || !state.selectedItemId) return;

  // If viewing a storage unit, operate inside its contents; otherwise on account items
  let container = account.items;
  if (state.viewingStorageUnitId) {
    const unit = account.items.find(it => it.id === state.viewingStorageUnitId);
    if (unit) container = unit.contents;
  }

  const itemIndex = container.findIndex(it => it.id === state.selectedItemId);
  if (itemIndex === -1) return;

  const item = container[itemIndex];

  if (delta > 0) {
    // Clone as a new completely independent item (deep copy)
    const newItem = JSON.parse(JSON.stringify(item));
    newItem.id = "it_" + Date.now() + "_" + Math.random().toString(16).slice(2);
    newItem.qty = 1;
    newItem.nametag = (item.nametag) ? item.nametag : null;
    newItem.acquiredAt = Date.now();
    // Re-generate float/pattern so it's a truly distinct instance
    newItem.floatVal = generateFloatForWear(item.name, item.wear || "Factory New", item.rarity);
    newItem.pattern = Math.floor(Math.random() * 1000);
    syncItemWearImage(newItem);
    container.push(newItem);
    saveState();
    refreshInventoryView();
    // Keep the original item selected (show updated details)
    showDetails(item);
  } else {
    // Remove only this single instance (decrease quantity by one)
    container.splice(itemIndex, 1);

    // Try to keep another identical item selected (match by name + nametag)
    const replacement = container.find(it => it.name === item.name && (it.nametag || "") === (item.nametag || ""));
    state.selectedItemId = replacement ? replacement.id : null;

    saveState();
    refreshInventoryView();

    // If still a selection, update sidebar to show new selected item
    if (state.selectedItemId) {
      const acct = getActiveAccount();
      const newItemObj = (state.viewingStorageUnitId ? acct.items.find(u=>u.id===state.viewingStorageUnitId)?.contents : acct.items)?.find(i=>i.id===state.selectedItemId);
      if (newItemObj) showDetails(newItemObj);
    }
  }
}

function changeItemPrice(itemName) {
  const account = getActiveAccount();
  const item = account?.items.find(it => it.name === itemName);
  const currentBase = state.priceOverrides?.[itemName] || PRICE_FIXES[itemName] || 0;
  
  // Visual Hint: Show user what the price would look like in Factory New
  const fnPrice = currentBase * 1.15;
  const val = prompt(`Enter new BASE price for "${itemName}" (System will auto-adjust for wear):\n(Currently ${formatPrice(fnPrice)} in FN)`, currentBase.toFixed(2) || "");
  
  if (val === null) return;
  const num = parseFloat(val);
  if (isNaN(num)) return;

  if (!state.priceOverrides) state.priceOverrides = {};
  state.priceOverrides[itemName] = num;

  // Make this override authoritative everywhere by writing into PRICE_FIXES
  PRICE_FIXES[itemName] = num;

  // Update all instances of this item globally to match the new authoritative override
  state.accounts.forEach(acc => {
    acc.items.forEach(it => {
      if (it.name === itemName) it.price = num;
      if (it.contents) it.contents.forEach(sub => { if (sub.name === itemName) sub.price = num; });
    });
  });

  // Update case DB entries
  Object.keys(CASE_CONTENTS_DB || {}).forEach(caseName => {
    const caseGroups = CASE_CONTENTS_DB[caseName];
    if (!caseGroups) return;
    Object.keys(caseGroups).forEach(rarity => {
      const list = caseGroups[rarity];
      if (Array.isArray(list)) list.forEach(it => { if (it && it.name === itemName) it.price = num; });
    });
  });

  saveState();
  try { applyPriceFixes(); } catch (e) {}
  refreshInventoryView();
  
  if (account) {
    const selected = account.items.find(it => it.id === state.selectedItemId);
    if (selected && selected.name === itemName) showDetails(selected);
  }
}

function removeSelectedItem(count = 1) {
  const account = getActiveAccount();
  if (!account || !state.selectedItemId) return;

  // Choose container: inside viewed storage unit, or top-level inventory.
  let container = account.items;
  let unit = null;
  if (state.viewingStorageUnitId) {
    unit = account.items.find(i => i.id === state.viewingStorageUnitId) || null;
    if (unit && Array.isArray(unit.contents)) container = unit.contents;
  }

  const targetItem = container.find(it => it.id === state.selectedItemId);
  if (!targetItem) return;

  // Mirror requested behavior:
  // - If count is 1, sell the exact instance selected by ID
  // - Else, remove up to `count` matching items (name + nametag)
  const toRemove = Math.max(1, Math.min(9999, parseInt(count) || 1));
  let remaining = Array.isArray(container) ? container.slice() : [];

  if (toRemove === 1) {
    const exactIdx = remaining.findIndex(it => it.id === state.selectedItemId);
    if (exactIdx !== -1) {
      const removedItem = remaining.splice(exactIdx, 1)[0];
      const credit = getItemValue(removedItem);
      account.walletBalance = (account.walletBalance || 0) + credit;
    }
  } else {
    let removed = 0;
    const remainingItems = [];
    for (let i = 0; i < remaining.length; i++) {
      const it = remaining[i];
      if (removed < toRemove && it.name === targetItem.name && (it.nametag || "") === (targetItem.nametag || "")) {
        removed++;
        const credit = getItemValue(it);
        account.walletBalance = (account.walletBalance || 0) + credit;
        continue;
      }
      remainingItems.push(it);
    }
    remaining = remainingItems;
  }

  // Write back the remaining items.
  if (unit) {
    unit.contents = remaining;
    unit.lastUpdated = Date.now();
  } else {
    account.items = remaining;
  }

  // Keep another matching instance selected if one remains; otherwise clear selection.
  const retainedNextId = remaining.find(it => it && it.name === targetItem.name && ((it.nametag || "") === (targetItem.nametag || "")))?.id || null;
  state.selectedItemId = retainedNextId;

  saveState();
  updateWalletDisplay();
  refreshInventoryView();
}


