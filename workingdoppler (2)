/**
 * Walks CASE_CONTENTS_DB and state.accounts and sets item.price when names match our PRICE_FIXES keys.
 * This will overwrite any existing prices for matching items.
 */
function applyPriceFixes() {
  // Preserve any already-set float values so we don't overwrite them while applying price/image/rarity fixes.
  const preservedFloats = [];
  if (Array.isArray(state.accounts)) {
    state.accounts.forEach(acc => {
      if (!acc || !Array.isArray(acc.items)) return;
      acc.items.forEach(it => {
        if (!it) return;
        if (it.floatVal !== undefined && it.floatVal !== null) {
          preservedFloats.push({ id: it.id, floatVal: it.floatVal });
        }
        if (it.contents && Array.isArray(it.contents)) {
          it.contents.forEach(child => {
            if (child && child.floatVal !== undefined && child.floatVal !== null) {
              preservedFloats.push({ id: child.id, floatVal: child.floatVal });
            }
          });
        }
      });
    });
  }

  // Update case database entries
  Object.keys(CASE_CONTENTS_DB || {}).forEach(caseName => {
    const caseGroups = CASE_CONTENTS_DB[caseName];
    if (!caseGroups || typeof caseGroups !== "object") return;
    // ensure semi-colon placement as requested in snippets
    Object.keys(caseGroups).forEach(rarity => {
      const list = caseGroups[rarity];
      if (!Array.isArray(list)) return;
      list.forEach(it => {
        if (!it || !it.name) return;
        const fix = PRICE_FIXES[it.name] ?? state.priceOverrides?.[it.name];
        if (typeof fix === "number") {
          it.price = fix;
        }
        // Apply image overrides to database entries
        if (state.imageOverrides?.[it.name]) it.img = state.imageOverrides[it.name];
      });
    });
  });

  // Update all items in all accounts (top-level and inside storage unit contents)
  if (Array.isArray(state.accounts)) {
    state.accounts.forEach(acc => {
      if (!acc || !Array.isArray(acc.items)) return;
      acc.items.forEach(it => {
        if (!it || !it.name) return;
        
        // Price override
        const priceFix = PRICE_FIXES[it.name] ?? state.priceOverrides?.[it.name];
        if (priceFix !== undefined) it.price = priceFix;
        
        // Image override
        if (state.imageOverrides?.[it.name]) it.img = state.imageOverrides[it.name];
        
        // Rarity override
        if (state.rarityOverrides?.[it.name]) it.rarity = state.rarityOverrides[it.name];

        if (it && Array.isArray(it.contents)) {
          it.contents.forEach(child => {
            if (!child || !child.name) return;
            const subPrice = PRICE_FIXES[child.name] ?? state.priceOverrides?.[child.name];
            if (subPrice !== undefined) child.price = subPrice;
            if (state.imageOverrides?.[child.name]) child.img = state.imageOverrides[child.name];
            if (state.rarityOverrides?.[child.name]) child.rarity = state.rarityOverrides[child.name];
          });
        }
      });
    });
  }

  // Re-apply preserved floats to ensure no float was unintentionally overwritten.
  if (preservedFloats.length > 0 && Array.isArray(state.accounts)) {
    const map = new Map(preservedFloats.map(p => [p.id, p.floatVal]));
    state.accounts.forEach(acc => {
      if (!acc || !Array.isArray(acc.items)) return;
      acc.items.forEach(it => {
        if (!it) return;
        if (map.has(it.id)) it.floatVal = map.get(it.id);
        if (it.contents && Array.isArray(it.contents)) {
          it.contents.forEach(child => {
            if (child && map.has(child.id)) child.floatVal = map.get(child.id);
          });
        }
      });
    });
  }

  saveState();
}

