    div.innerHTML = `
      <img src="${p.avatar}" style="width: 32px; height: 32px; border-radius: 50%;">
      <div style="flex: 1;">
        <div style="font-weight: 800; font-size: 13px;">${escapeHtml(p.name)}</div>
        <div style="font-size: 11px; color: #94a3b8; margin-bottom: 6px;">${formatPrice(p.value)}</div>
        <div class="p-item-boxes" style="display: flex; flex-wrap: wrap; gap: 4px;"></div>
      </div>
      <div style="text-align: right; font-weight: 900; color: #e4ae39;">${p.chance.toFixed(1)}%</div>
    `;

    const itemBoxesContainer = div.querySelector(".p-item-boxes");
    p.items.forEach(it => {
      const itemBox = document.createElement("div");
      itemBox.style.display = "flex";
      itemBox.style.flexDirection = "column";
      itemBox.style.alignItems = "center";
      itemBox.style.background = "rgba(0,0,0,0.4)";
      itemBox.style.padding = "2px";
      itemBox.style.borderRadius = "4px";
      itemBox.style.borderBottom = `2px solid ${RARITY_COLORS[it.rarity] || '#ccc'}`;
      itemBox.style.cursor = "pointer";

