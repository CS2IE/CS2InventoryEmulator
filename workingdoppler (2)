function getFloatRankBorderDecoration(rank) {
  const numericRank = parseInt(rank, 10) || 0;
  if (numericRank < 1 || numericRank > 6) return null;

  const medalIndex = numericRank <= 3 ? numericRank : numericRank - 3;
  const borderColors = {
    1: "#f6d365",
    2: "#d8dee9",
    3: "#cd7f32"
  };
  const glowColors = {
    1: "rgba(246, 211, 101, 0.55)",
    2: "rgba(216, 222, 233, 0.45)",
    3: "rgba(205, 127, 50, 0.45)"
  };
  const borderColor = borderColors[medalIndex];
  const glowColor = glowColors[medalIndex];
  const isHighest = numericRank >= 4;
  return {
    borderColor,
    boxShadow: isHighest
      ? `0 0 0 1px rgba(255,255,255,0.06), inset 0 0 0 1px ${borderColor}, inset 0 0 18px rgba(127, 29, 29, 0.35), 0 0 18px ${glowColor}`
      : `0 0 0 1px rgba(255,255,255,0.06), inset 0 0 0 1px ${borderColor}, 0 0 18px ${glowColor}`
  };
}

function getFloatRankBadgeHtml(rank) {
  const numericRank = parseInt(rank, 10) || 0;
  if (numericRank < 1 || numericRank > 6) return "";
  const medalRank = numericRank <= 3 ? numericRank : numericRank - 3;
  const isHigh = numericRank >= 4;
  return `<div class="float-rank-badge rank-${medalRank}" style="${isHigh ? "background:#ef4444; color:#fff;" : ""}">${isHigh ? "HIGH" : "LOW"} #${medalRank}</div>`;
}

