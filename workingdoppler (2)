    const acc = getActiveAccount();
    if (!acc) return;
    const base = acc.name || "Account";
    let idx = 2;
    let newName = `${base} ${idx}`;
    // increment suffix until unique
    while (state.accounts.some(a => a.name === newName)) {
      idx++;
      newName = `${base} ${idx}`;
    }

    // create new account and receive reference directly (createAccount now returns the new account)
    const newAcc = createAccount(newName);
    if (!newAcc) return;

    // deep-copy items but ensure new unique IDs and maintain mapping from oldId -> newId
    const idMap = new Map();

    newAcc.items = [];
    (acc.items || []).forEach(it => {
      // deep clone
      const copy = JSON.parse(JSON.stringify(it || {}));

      // generate new unique id for top-level item
      const newId = "it_" + Date.now() + "_" + Math.random().toString(16).slice(2) + "_" + Math.random().toString(16).slice(2);
      idMap.set(it.id, newId);
      copy.id = newId;

      // regenerate ids for nested contents (storage unit contents) and map them too
      if (Array.isArray(copy.contents)) {
        copy.contents = copy.contents.map(c => {
          const newChildId = "it_" + Date.now() + "_" + Math.random().toString(16).slice(2) + "_" + Math.random().toString(16).slice(2);
          idMap.set(c.id, newChildId);
          return { ...c, id: newChildId };
        });
      }

      // push the cloned item into the new account
      newAcc.items.push(copy);
    });

    // Copy wallet, pfp and non-identifying stats to match original account snapshot
    newAcc.walletBalance = acc.walletBalance || 0;
    newAcc.pfp = acc.pfp;
    newAcc.moneySpent = acc.moneySpent || 0;
