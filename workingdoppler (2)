async function showGetCounterpartPopup(item, targetType) {
  let targets = [];
  if (targetType === 'case') {
    const baseKeyName = item.name.split(' (')[0];
    const caseNames = KEY_CASE_MAP[baseKeyName] || [];
    targets = caseNames.map(name => allSkins.find(s => s.name === name)).filter(Boolean);
  } else {
    const keyNames = Object.entries(KEY_CASE_MAP)
      .filter(([k, cases]) => {
        if (k === "CS:GO Case Key" && item.name.includes("CS:GO Weapon Case")) return true;
        return cases.some(cn => item.name.startsWith(cn));
      }).map(([k]) => k);
    targets = keyNames.map(name => MARKET_KEYS.find(k => k.name === name) || allSkins.find(s => s.name === name)).filter(Boolean);
  }

  if (targets.length === 0) {
    alert("No matching items found in database.");
    return;
  }

  // If only one target, just jump to wear selection
  const t = targets[0];
  const price = t.price || mockPrice(t);
  promptWearSelection(t, price, (wear, qty, finalPrice, isCustom, extra = {}) => {
    addItemToAccount({
      name: t.name,
      img: t.image || t.img || getDisplayImage(t),
      price: finalPrice,
      rarity: t.rarity?.name || "Base Grade",
      wear: wear,
      type: t.type || (targetType === 'case' ? "Container" : "Key"),
      qty: qty,
      isCustomPrice: isCustom,
      source: "Purchased",
      nametag: extra.nametag || null
    });
    refreshInventoryView();
  });
}

