function encodeShareCode(payload) {
  try {
    const json = JSON.stringify(payload);
    return btoa(unescape(encodeURIComponent(json)));
  } catch (e) {
    return "";
  }
}

function decodeShareCode(code) {
  try {
    const json = decodeURIComponent(escape(atob(code.trim())));
    return JSON.parse(json);
  } catch (e) {
    return null;
  }
}

function buildSharePayload(item) {
  if (!item) return null;
  const isStatTrak = String(item.name || "").includes("StatTrak™");
  return {
    v: 1,
    name: item.name || "",
    img: item.img || getDisplayImage(item),
    price: typeof item.price === "number" ? item.price : (PRICE_FIXES[item.name] ?? mockPrice(item)),
    rarity: item.rarity?.name || item.rarity || "Consumer",
    wear: item.wear || null,
    floatVal: (typeof item.floatVal === "number" && !isNaN(item.floatVal)) ? item.floatVal : null,
    pattern: (item.pattern !== undefined && item.pattern !== null) ? item.pattern : null,
    nametag: item.nametag || null,
    stickers: Array.isArray(item.stickers) ? item.stickers.map(s => ({
      name: s.name,
      img: s.img,
      price: s.price,
      rarity: s.rarity
    })) : [],
    stattrak: isStatTrak
  };
}

