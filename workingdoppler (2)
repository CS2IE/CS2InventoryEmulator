        shareSvg.onclick = (e) => {
          e.stopPropagation();
          lastInspectItem = item;
          openShareItemModal();
        };
        wrap.appendChild(shareSvg);
      }
    } catch (e) {}

    if (isOwner) {
      const openBtn = document.getElementById("inspectOpenBtn");
      if (openBtn) openBtn.onclick = () => {
        modal.classList.add("hidden");
        showCaseConfirmForCaseName(item.name);
      };

      const equipBtn = document.getElementById("inspectEquipBtn");
      if (equipBtn) equipBtn.onclick = () => {
        const equippedSides = getLoadoutSidesForItem(item.id);
        const equippedSet = new Set(Array.isArray(account.equippedItemIds) ? account.equippedItemIds : []);
        if (equippedSides.length || equippedSet.has(item.id)) {
          account.equippedItemIds = account.equippedItemIds.filter(id => id !== item.id);
          ["ct", "t"].forEach(side => {
            Object.keys(state.loadout?.[side] || {}).forEach(slotId => {
              if (state.loadout[side][slotId] === item.id) state.loadout[side][slotId] = null;
            });
          });
          saveState();
          refreshInventoryView();
          showInspect(item);
        } else {
          showEquipSidePicker(item, (side) => {
            const sidesToEquip = side === "both" ? ["t", "ct"] : [side];
            const failedSide = sidesToEquip.find(targetSide => !equipItemToLoadoutSide(account, item, targetSide).ok);
            if (failedSide) return;
            saveState();
            refreshInventoryView();
            showInspect(item);
          });
        }
      };

      const ddBtn = statsContainer.querySelector(".action-dropdown-btn");
      const ddMenu = statsContainer.querySelector(".action-dropdown-menu");
      if (ddBtn && ddMenu) {
        ddBtn.onclick = (e) => {
          e.stopPropagation();
          ddMenu.style.display = ddMenu.style.display === "flex" ? "none" : "flex";
        };
      }

      const sellBtn = document.getElementById("inspectSellBtn");
      if (sellBtn) sellBtn.onclick = () => {
        state.selectedItemId = item.id;
        modal.classList.add("hidden");
