      };

      const editBtn = document.getElementById("inspectEditBtn");
      if (editBtn) editBtn.onclick = () => {
        showEditItemModal(item);
        ddMenu.style.display = "none";
      };
    }
  }

  // stickersArea already declared at the top of showInspect function
  
  // Prepare stickers for Inspect view including StatTrak™ module
  const inspectStickers = Array.isArray(item.stickers)
    ? item.stickers.map((s, i) => ({ ...s, _sourceIndex: i }))
    : [];
  if (item.name.includes("StatTrak™")) {
      inspectStickers.unshift({
          name: "StatTrak™ Module",
          img: "https://i.imgur.com/TRtzFCo.png",
          isStatTrakModule: true,
          price: 0.05
      });
  }

  // Integrated 3D Drag behavior with Inertia
  const updateGloss = (rotY) => {
     const gloss = document.querySelector("#inspectModal .gloss-overlay");
     if (gloss) {
       // Offset gloss gradient based on rotation to simulate a static light source
       const shift = (rotY % 360);
       gloss.style.background = `linear-gradient(${135 + shift}deg, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0) 60%)`;
       gloss.style.setProperty('--mask-url', `url(${displayUrl})`);
     }
  };

  const inertiaLoop = () => {
    if (isDraggingInspect) return;
    inspectRotY += inspectVelX;
    inspectRotX += inspectVelY;
    inspectVelX *= 0.95; // Dampening
    inspectVelY *= 0.95;
    
    const wrapper = document.getElementById("inspect3dWrapper");
    if (wrapper) wrapper.style.transform = `perspective(1200px) rotateX(${inspectRotX}deg) rotateY(${inspectRotY}deg)`;
    updateGloss(inspectRotY);

    if (Math.abs(inspectVelX) > 0.01 || Math.abs(inspectVelY) > 0.01) {
      inspectRafId = requestAnimationFrame(inertiaLoop);
    } else {
      document.getElementById("inspectBox").classList.remove("is-dragging");
    }
  };

  const handleStart = (e) => {
    if (isStickerPlacingMode) return;
    if (inspectRafId) cancelAnimationFrame(inspectRafId);
    isDraggingInspect = true;
    inspectMoved = false;
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    inspectLastX = clientX;
    inspectLastY = clientY;
    inspectVelX = 0;
    inspectVelY = 0;
  };

  const handleMove = (e) => {
    if (!isDraggingInspect) return;
    inspectMoved = true;
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    
    const deltaX = clientX - inspectLastX;
    const deltaY = clientY - inspectLastY;
    
    inspectVelX = deltaX * 0.4;
    inspectVelY = -deltaY * 0.4;
    
    inspectRotY += inspectVelX;
    inspectRotX += inspectVelY;
    
    const inspectWrapper = document.getElementById("inspect3dWrapper");
    if (inspectWrapper) {
      inspectWrapper.style.transform = `perspective(1200px) rotateX(${inspectRotX}deg) rotateY(${inspectRotY}deg)`;
      box.classList.add("is-dragging");
      updateGloss(inspectRotY);
    }
    
    inspectLastX = clientX;
    inspectLastY = clientY;
  };

  const handleEnd = () => {
    if (!isDraggingInspect) return;
    isDraggingInspect = false;
    inertiaLoop();
  };

  box.onmousedown = handleStart;

  // Use managed global listeners instead of assigning to window.onmousemove to avoid clobbering other modules
  if (box._inspectListeners) {
    window.removeEventListener('mousemove', box._inspectListeners.move);
    window.removeEventListener('mouseup', box._inspectListeners.end);
    window.removeEventListener('touchmove', box._inspectListeners.move);
    window.removeEventListener('touchend', box._inspectListeners.end);
  }
  const boundMove = handleMove.bind(box);
  const boundEnd = handleEnd.bind(box);
  window.addEventListener('mousemove', boundMove);
  window.addEventListener('mouseup', boundEnd);
  window.addEventListener('touchmove', boundMove);
  window.addEventListener('touchend', boundEnd);
  box._inspectListeners = { move: boundMove, end: boundEnd };

  box.ontouchstart = handleStart;

  // Only close if user clicked the background overlay, not the box content itself.
  // This allows interacting with header text, info icons, and stickers without accidental closes.
  modal.onclick = (e) => {
    if (e.target === modal) {
      modal.classList.add("hidden");
      // If closing without submit, reset placements
      isStickerPlacingMode = false;
      window.onmousemove = null;
      window.onmouseup = null;
      window.ontouchmove = null;
      window.ontouchend = null;
    }
  };

  // Prevent clicks inside the content area from closing the detailed view
  box.onclick = (e) => {
    e.stopPropagation();
  };
  stickersArea.innerHTML = "";

  if (inspectStickers.length > 0) {
    inspectStickers.forEach((s, sIdx) => {
      if (typeof s.scratchPercent !== 'number') s.scratchPercent = 0;

      const wrapper = document.createElement("div");
      wrapper.className = "sticker-wrapper-inspect";
      wrapper.style.display = "flex";
      wrapper.style.flexDirection = "column";
      wrapper.style.alignItems = "center";
      wrapper.style.margin = "0 8px";
      wrapper.style.pointerEvents = "auto";
      wrapper.style.transition = "transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275)";
      wrapper.style.position = "relative";

      const sImg = document.createElement("img");
      sImg.src = s.img;
      sImg.style.width = "110px";
      sImg.style.height = "110px";
      sImg.style.objectFit = "contain";
      sImg.style.filter = "drop-shadow(0 4px 8px rgba(0,0,0,0.6))";
      const gVal = (s.scratchPercent || 0) / 100;
      sImg.style.filter += ` grayscale(${gVal})`;
      sImg.style.cursor = "pointer";

      // Hover Interaction: Enlarge and Tooltip - restricted to icon only
      sImg.onmouseenter = () => {
          wrapper.style.transform = "scale(1.25) translateY(-10px)";
          tooltip.style.opacity = "1";
      };
      sImg.onmouseleave = () => {
          wrapper.style.transform = "scale(1)";
          tooltip.style.opacity = "0";
      };

      // Hover Interaction: Enlarge and Tooltip
      const tooltip = document.createElement("div");
      const sPrice = (s.price || 0.5);
      const sPriceText = (!state.hidePrices) ? ` (${formatPrice(sPrice)})` : "";
      tooltip.textContent = s.name + sPriceText;
      tooltip.style.position = "absolute";
      tooltip.style.bottom = "110%";
      tooltip.style.left = "50%";
      tooltip.style.transform = "translateX(-50%)";
      tooltip.style.background = "#171a21";
      tooltip.style.color = "#fff";
      tooltip.style.padding = "4px 10px";
      tooltip.style.borderRadius = "4px";
      tooltip.style.fontSize = "11px";
      tooltip.style.whiteSpace = "nowrap";
      tooltip.style.border = "1px solid #334155";
      tooltip.style.opacity = "0";
      tooltip.style.pointerEvents = "none";
      tooltip.style.transition = "opacity 0.2s";

      wrapper.onmouseenter = () => {
          // Handled by hover on the image/wrapper below
      };
      wrapper.onmouseleave = () => {
          if (!wrapper.classList.contains("active-size")) {
             wrapper.style.transform = "scale(1)";
          }
          tooltip.style.opacity = "0";
      };

      const pct = document.createElement("div");
      pct.style.marginTop = "6px";
      pct.style.fontSize = "12px";
      pct.style.color = "#94a3b8";
      pct.textContent = (s.scratchPercent || 0) > 0 ? `Scratched: ${s.scratchPercent}%` : "";

      if (!s.isStatTrakModule) {
        sImg.addEventListener("click", (e) => {
            e.stopPropagation();
            showInScreenConfirm(`Remove ${s.name}?`, () => {
                addItemToAccount({
                    name: s.name, img: s.img, price: s.price,
                    rarity: s.rarity || "High Grade", type: "Sticker",
                    source: "Removed from weapon"
                });
                const sourceIndex = (typeof s._sourceIndex === "number") ? s._sourceIndex : sIdx;
                if (Array.isArray(item.stickers) && sourceIndex >= 0 && sourceIndex < item.stickers.length) {
                  item.stickers.splice(sourceIndex, 1);
                }
                saveState();
                refreshInventoryView();
                modal.classList.add("hidden");
            });
        });

        sImg.addEventListener("contextmenu", (ev) => {
            ev.preventDefault();
            ev.stopPropagation();
            showInScreenConfirm(`Scrape ${s.name}? This will remove 10% of the sticker visuals.`, () => {
                s.scratchPercent = Math.min(100, (s.scratchPercent || 0) + 10);
                const gVal = (s.scratchPercent || 0) / 100;
                sImg.style.filter = `grayscale(${gVal}) contrast(${1 - gVal * 0.3})`;
                sImg.style.opacity = "1";
                pct.textContent = `Scratched: ${s.scratchPercent}%`;
                saveState();
                refreshInventoryView();
            });
        }, { passive: false });
      }

      wrapper.appendChild(tooltip);
      wrapper.appendChild(sImg);
      wrapper.appendChild(pct);
      stickersArea.appendChild(wrapper);
    });
  }

  modal.classList.remove("hidden");
}

function openStorageUnit(unitId) {
  const account = getActiveAccount();
  const unit = account.items.find(it => it.id === unitId);
  if (!unit) return;

  const modal = document.getElementById("storageModal");
  const totalInside = Array.isArray(unit.contents) ? unit.contents.length : 0;
  let totalValueInside = 0;
  (unit.contents || []).forEach(it => { totalValueInside += getItemValue(it); });

  document.getElementById("storageTitle").textContent =
    "Storage Unit: " + (unit.nametag || unit.name) +
    (totalInside > 0 ? ` — ${totalInside} items, ${formatPrice(totalValueInside)}` : " — empty");

  // Track which unit is currently being managed in the modal
  const moveBtn = document.getElementById("moveAllIntoStorageBtn");
  if (moveBtn) moveBtn.dataset.unitId = unitId;

  renderStorageContents(unit, account);
  modal.classList.remove("hidden");
}

function renderStorageContents(unit, account) {
  const invList = document.getElementById("storageInventoryList");
  const contList = document.getElementById("storageContentsList");
  const sortSelect = document.getElementById("storageSortSelect");
  const modal = document.getElementById("storageModal");
  const selectedLabel = document.getElementById("storageSelectedLabel");
  
  if (!invList || !contList || !modal) return;
  
  // Keep dataset selection for compatibility but clicks will now prompt immediate move
  modal.dataset.selectedItemId = modal.dataset.selectedItemId || "";
  if (selectedLabel) selectedLabel.textContent = modal.dataset.selectedItemId ? `Selected: ${modal.dataset.selectedItemName || 'item'}` : "Selected: none";

  const sortVal = sortSelect ? sortSelect.value : "all";
  invList.innerHTML = "";
  contList.innerHTML = "";

  // Inventory available to deposit (top-level only)
  let depositables = account.items.filter(it => it.id !== unit.id && !it.name.toLowerCase().includes("storage unit"));
  
  // Filter depositables by rarity dynamically (user requested behavior)
  if (sortVal !== "all" && sortVal !== "none") {
    depositables = depositables.filter(it => it.rarity === sortVal);
  }

  // Sort by value desc for easier selection
  depositables.sort((a, b) => getItemValue(b) - getItemValue(a));
  if (!unit.contents) unit.contents = [];
  unit.contents.sort((a, b) => getItemValue(b) - getItemValue(a));

  // Helper: create a mini card that moves item into the storage unit on click (with confirmation)
  const createDepositCard = (it) => {
    const div = document.createElement("div");
    div.className = "storage-item-mini";
    const rarityColor = RARITY_COLORS[it.rarity] || "#b0c3d9";
    div.style.borderColor = rarityColor;
    div.style.borderWidth = "2px";
    div.style.borderStyle = "solid";
    div.style.cursor = "pointer";
    div.innerHTML = `
      <img src="${getStableDisplayImage(it)}" title="${it.name}">
      <span class="mini-price-tag">${formatPrice(getItemValue(it))}</span>
    `;

    div.onclick = (e) => {
      e.stopPropagation();
      // Directly move without confirmation (storage unit actions no longer ask "Are you sure?")
      const idx = account.items.findIndex(ai => ai.id === it.id);
      if (idx !== -1) {
        const [moved] = account.items.splice(idx, 1);
        if (!unit.contents) unit.contents = [];
        unit.contents.push(moved);
        unit.lastUpdated = Date.now();
        saveState();
        renderStorageContents(unit, account);
        refreshInventoryView();
        if (selectedLabel) selectedLabel.textContent = `Selected: ${moved.name}`;
      } else {
        alert("Item not found in inventory (it may have been moved).");
      }
    };
    return div;
  };

  // Helper: create a mini card that withdraws item back to account on click (with confirmation)
  const createWithdrawCard = (it) => {
    const div = document.createElement("div");
    div.className = "storage-item-mini";
    const rarityColor = RARITY_COLORS[it.rarity] || "#b0c3d9";
    div.style.borderColor = rarityColor;
    div.style.borderWidth = "2px";
    div.style.borderStyle = "solid";
    div.style.cursor = "pointer";
    div.innerHTML = `
      <img src="${getStableDisplayImage(it)}" title="${it.name}">
      <span class="mini-price-tag">${formatPrice(getItemValue(it))}</span>
    `;

    div.onclick = (e) => {
      e.stopPropagation();
      // Directly withdraw without confirmation (storage unit actions no longer ask "Are you sure?")
      const parent = account.items.find(u => Array.isArray(u.contents) && u.contents.some(c => c.id === it.id));
      if (parent) {
        parent.contents = parent.contents.filter(c => c.id !== it.id);
        account.items.push(it);
        parent.lastUpdated = Date.now();
        saveState();
        renderStorageContents(unit, account);
        refreshInventoryView();
        if (selectedLabel) selectedLabel.textContent = `Selected: ${it.name}`;
      } else {
        // fallback: try to remove from unit.contents (defensive)
        unit.contents = (unit.contents || []).filter(c => c.id !== it.id);
        account.items.push(it);
        saveState();
        renderStorageContents(unit, account);
        refreshInventoryView();
      }
    };
    return div;
  };

  // Populate left (main inventory visible) with depositable items
  depositables.forEach(it => {
    const card = createDepositCard(it);
    invList.appendChild(card);
  });

  // Populate right side (inside container) with withdrawable items
  (unit.contents || []).forEach(it => {
    const card = createWithdrawCard(it);
    contList.appendChild(card);
  });

  // Update the selected label to reflect current filter dynamic results
  if (sortVal && sortVal !== "all") {
    // show how many matching on left under current filter
    const matchCount = depositables.length;
    if (selectedLabel) selectedLabel.textContent = `Filter: ${sortVal} • ${matchCount} visible`;
  } else {
    if (selectedLabel && (!modal.dataset.selectedItemId || modal.dataset.selectedItemId === "")) {
      selectedLabel.textContent = "Selected: none";
    }
  }
}

function addRandomCheapItem() {
  if (!allSkins.length) return;
  
  // Weights: Guns (70%), Stickers (15%), Sprays/Graffiti (10%), Charms/Collectibles (5%)
  const r = Math.random();
  let pool = [];
  
  if (r < 0.70) {
    // Guns
    pool = allSkins.filter(s => {
      const weaponTypes = ["rifle", "pistol", "smg", "sniper rifle", "shotgun", "machinegun"];
      return weaponTypes.some(t => s.weapon?.name?.toLowerCase().includes(t)) || 
             weaponTypes.some(t => s.category?.name?.toLowerCase().includes(t));
    });
  } else if (r < 0.85) {
    // Stickers
    pool = allSkins.filter(s => s.name.toLowerCase().includes("sticker"));
  } else if (r < 0.95) {
    // Sprays/Graffiti
    pool = allSkins.filter(s => s.name.toLowerCase().includes("graffiti") || s.name.toLowerCase().includes("sealed graffiti"));
  } else {
    // Charms/Collectibles
    pool = allSkins.filter(s => s.name.toLowerCase().includes("pin") || s.name.toLowerCase().includes("music kit") || s.name.toLowerCase().includes("agent") || s.name.toLowerCase().includes("charm") || s.name.toLowerCase().includes("keychain"));
  }

  const cheapItems = pool.filter(i => mockPrice(i) < 20);
  const finalPool = cheapItems.length > 0 ? cheapItems : allSkins.filter(i => mockPrice(i) < 20);
  
  if (!finalPool.length) return;
  const rand = finalPool[Math.floor(Math.random() * finalPool.length)];
  const price = mockPrice(rand);
  
  addItemToAccount({
    name: rand.name,
    img: rand.image,
    price: price,
    rarity: rand.rarity?.name || "Consumer",
    wear: mockWear(rand.name, rand.rarity?.name),
    qty: 1,
    source: "Purchased"
  });
}

/**
 * Graceful stop handler used by global Escape / quick-skip logic.
 * If an opening animation is in progress this will cancel timers and invoke the stored reveal callback.
 * Defensive: tolerates missing timers or missing UI nodes.
 */
function stopAnimationAndShowWinner() {
  try {
    // If a reveal function was registered by openCase(), call it directly
    if (typeof window._caseRevealNow === "function") {
      try {
        // clear any scheduled timers so reveal runs only once
        if (window._caseRevealTimer) { clearTimeout(window._caseRevealTimer); window._caseRevealTimer = null; }
        if (window._caseStartTimer) { clearTimeout(window._caseStartTimer); window._caseStartTimer = null; }
      } catch (e) { /* ignore */ }
      try {
        window._caseRevealNow();
      } catch (err) {
        console.warn("stopAnimationAndShowWinner: reveal invocation failed:", err);
      } finally {
        // cleanup flags
        window._caseRevealNow = null;
        window._caseIsGoldReveal = false;
        window._caseRevealTimer = null;
        window._caseStartTimer = null;
      }
      return;
    }

    // If there's a pending timer that would call reveal, just fire the reveal path manually.
    if (window._caseRevealTimer) {
      try { clearTimeout(window._caseRevealTimer); } catch (e) {}
      window._caseRevealTimer = null;
    }
    if (window._caseStartTimer) {
      try { clearTimeout(window._caseStartTimer); } catch (e) {}
      window._caseStartTimer = null;
    }

    // Fallback: try to find the caseOpening modal and immediately show the result area (best-effort)
    try {
      const openingModal = document.getElementById("caseOpeningModal");
      const spinner = document.getElementById("caseOpeningSpinner");
      const resultArea = document.getElementById("caseOpeningResult");
      const actions = document.getElementById("caseOpeningActions");
      if (openingModal) openingModal.classList.remove("hidden");
      if (spinner) spinner.style.display = "none";
      if (resultArea) resultArea.style.display = "block";
      if (actions) { actions.style.opacity = "1"; actions.style.pointerEvents = "auto"; }
    } catch (e) {
      // ignore DOM errors
    }
  } catch (e) {
    console.warn("stopAnimationAndShowWinner unexpected error:", e);
  } finally {
    // ensure flags cleared to avoid re-entrancy
    try { window._caseIsGoldReveal = false; } catch (e) {}
    try { window._caseRevealNow = null; } catch (e) {}
  }
}

