function extractExplicitDopplerPhase(name) {
  const text = String(name || "");
  const match = text.match(/\b(Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)\b/i);
  return match ? match[1].replace(/\b([a-z])/g, c => c.toUpperCase()) : "";
}

function getUniqueFloatForItem(item, usedFloats) {
  if (!item || !item.wear) return null;

  const fallbackBase = generateFloatForWear(item.name, item.wear || "Factory New", item.rarity);
  if (typeof fallbackBase !== "number" || Number.isNaN(fallbackBase)) return null;

  const idSeed = String(item.id || item.name || "");
  let hash = 0;
  for (let i = 0; i < idSeed.length; i++) {
    hash = ((hash * 31) + idSeed.charCodeAt(i)) >>> 0;
  }

  let candidate = Number(fallbackBase.toFixed(12));
  let step = ((hash % 997) + 1) / 1e12;
  if (!Number.isFinite(step) || step <= 0) step = 1 / 1e9;

  while (usedFloats.has(candidate.toFixed(12))) {
    candidate = Number((candidate + step).toFixed(12));
    if (candidate >= 1) candidate = Number((fallbackBase - step).toFixed(12));
    if (candidate <= 0) candidate = Number(fallbackBase.toFixed(12));
  }

  usedFloats.add(candidate.toFixed(12));
  return candidate;
}

