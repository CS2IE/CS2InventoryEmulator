function showStatsModal() {
  // Always target the actively logged in account for the main "Stats" button.
  // We only show other profiles if specifically viewing via viewingProfileId context (e.g. from leaderboard).
  const viewingProfile = state.viewingProfileId ? state.accounts.find(a => a.id === state.viewingProfileId) : null;
  const acc = viewingProfile || getActiveAccount();
  if (!acc) {
    console.warn("showStatsModal: no account found");
    return;
  }

  const modal = document.getElementById("statsModal");
  const grid = document.getElementById("statsGrid");

  let lowestFloat = 2.0; // Start above max float
  let highestFloat = -1.0; // Start below min float
  let lowestFloatWeapon = "None";
  let highestFloatWeapon = "None";
  let mostExpensiveItemName = "None";
  let mostExpensiveItemValue = 0;
  let inventoryCount = 0;
  let mostExpensivePulledName = "None";
  let mostExpensivePulledValue = 0;

  const isWeaponLikeStat = (it) => {
    if (!it || !it.name) return false;
    const n = String(it.name).toLowerCase();
    const t = String(it.type || it.category?.name || "").toLowerCase();
    if (n.includes("storage unit")) return false;
    if (n.includes("case") || n.includes("capsule") || n.includes("package") || n.includes("key") || n.includes("sticker") || n.includes("graffiti") || n.includes("music kit")) return false;
    return n.includes("|") || n.includes("★") || n.includes("knife") || n.includes("gloves") ||
           t.includes("knife") || t.includes("gloves") || t.includes("rifle") || t.includes("pistol") ||
           t.includes("smg") || t.includes("sniper") || t.includes("shotgun") || t.includes("machine");
  };

  const checkItem = (it) => {
    if (!it) return;
    const qty = it.qty || 1;
    inventoryCount += qty;
    
    const val = getItemValue(it);
    if (isWeaponLikeStat(it) && val > mostExpensiveItemValue) {
      mostExpensiveItemValue = val;
      mostExpensiveItemName = it.nametag ? `"${it.nametag}"` : it.name;
    }
    
    // Scoped float check ensures stats are individual to the account being rendered
    if (typeof it.floatVal === 'number' && !isNaN(it.floatVal) && isWeaponLikeStat(it)) {
      if (it.floatVal < lowestFloat) {
        lowestFloat = it.floatVal;
        lowestFloatWeapon = it.name;
      }
      if (it.floatVal > highestFloat) {
        highestFloat = it.floatVal;
        highestFloatWeapon = it.name;
      }
    }

    const src = (it.source || "").toString().toLowerCase();
    if (src.includes("pulled")) {
      const marketVal = Number(PRICE_FIXES[it.name] ?? it.price ?? mockPrice(it)) || 0;
      if (marketVal > mostExpensivePulledValue) {
        mostExpensivePulledValue = marketVal;
        mostExpensivePulledName = it.name;
      }
    }
  };

  acc.items.forEach(it => {
    checkItem(it);
    if (it.contents && Array.isArray(it.contents)) it.contents.forEach(checkItem);
  });

  let favoriteCase = "None";
  let maxOpens = 0;
  // Calculate favorite case based on golds pulled (user requirement)
  let favCaseGolds = 0;
  if (acc.goldsPerCase) {
    for (const [cname, count] of Object.entries(acc.goldsPerCase)) {
      if (count > favCaseGolds) {
        favCaseGolds = count;
        favoriteCase = cname;
      }
    }
  }
  // Fallback to most opened if no golds found
  if (favoriteCase === "None" && acc.openedCaseCounts) {
    for (const [cname, count] of Object.entries(acc.openedCaseCounts)) {
      if (count > maxOpens) {
        maxOpens = count;
        favoriteCase = cname;
      }
    }
  }

  const stats = [
    { label: "Account Name", value: acc.name, color: "#66c0f4" },
    { label: "USD Spent", value: formatPrice(acc.moneySpent || 0) },
    { label: "USD Profit", value: formatPrice(acc.totalUnboxingProfit || 0), color: (acc.totalUnboxingProfit || 0) >= 0 ? "#a4d007" : "#eb4b4b" },
    { label: "USD Added to Wallet", value: formatPrice(acc.totalDeposited || 0) },
    { label: "Inventory Amount", value: inventoryCount },
    { label: "Lowest Float", value: lowestFloat > 1.0 ? "N/A" : formatFloat(lowestFloat) },
    { label: "Weapon (Lowest Float)", value: lowestFloat > 1.0 ? "N/A" : lowestFloatWeapon, color: "#66c0f4" },
    { label: "Highest Float", value: highestFloat < 0.0 ? "N/A" : formatFloat(highestFloat) },
    { label: "Weapon (Highest Float)", value: highestFloat < 0.0 ? "N/A" : highestFloatWeapon, color: "#66c0f4" },
    // Keep the current most expensive item (what the user currently owns at market value)
    { label: "Most Expensive Item", value: mostExpensiveItemName, color: "#e4ae39" },
    // New: show the most expensive item the user has ever pulled (market value)
    { label: "Most Expensive Pulled (Market)", value: mostExpensivePulledName + (mostExpensivePulledValue ? ` • ${formatPrice(mostExpensivePulledValue)}` : ""), color: "#eb4b4b" },
    { label: "Total Cases Opened", value: acc.totalCasesOpened || 0 },
    { label: "Favorite Case", value: favoriteCase + (favCaseGolds > 0 ? ` (${favCaseGolds} Golds)` : ""), color: "#66c0f4" },
    { label: "Total Golds Pulled", value: acc.totalGoldsPulled || 0, color: "#e4ae39" },
    { label: "Gambled on Jackpot", value: acc.hasGambledJackpot ? "Yes" : "No", color: acc.hasGambledJackpot ? "#a4d007" : "#94a3b8" },
    { label: "Gambled on Dice", value: acc.hasGambledDice ? "Yes" : "No", color: acc.hasGambledDice ? "#a4d007" : "#94a3b8" },
    { label: "Jackpot Wagered", value: formatPrice(acc.jackpotWagered || 0) },
    { label: "Jackpot Profit", value: formatPrice(acc.jackpotProfit || 0), color: (acc.jackpotProfit || 0) >= 0 ? "#a4d007" : "#eb4b4b" },
    { label: "Dice Wagered", value: formatPrice(acc.diceWagered || 0) },
    { label: "Dice Profit", value: formatPrice(acc.diceProfit || 0), color: (acc.diceProfit || 0) >= 0 ? "#a4d007" : "#eb4b4b" }
  ];

  grid.innerHTML = stats.map(s => `
    <div style="display: flex; justify-content: space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding: 8px 0;">
      <span style="color: #94a3b8; font-size: 13px; text-transform: uppercase;">${s.label}</span>
      <span style="color: ${s.color || '#fff'}; font-weight: 800; font-size: 14px; text-align: right; max-width: 60%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${s.value}</span>
    </div>
  `).join("");

  modal.classList.remove("hidden");
}

