function getPurchaseCost(it) {
  // Walletless Mode makes all CS2 market purchases free (wallet is effectively disabled).
  if (state && state.walletlessMode) return 0;
  // Support an explicit per-item cost while keeping item.price as the item's value.
  if (it && typeof it.cost === "number" && !isNaN(it.cost)) return Math.max(0, it.cost);
  if (it && typeof it.price === "number" && !isNaN(it.price)) return Math.max(0, it.price);
  return 0;
}

