function getExplicitDopplerPhaseLabel(item) {
  const joined = [
    item?.skinBidsApiName,
    item?.dopplerPhase,
    item?.phase,
    item?.finishStyle,
    item?.name
  ].filter(Boolean).join(" ").toLowerCase();

  if (!joined.includes("doppler")) return "";
  if (joined.includes("black pearl")) return "Black Pearl";
  if (joined.includes("sapphire")) return "Sapphire";
  if (joined.includes("ruby")) return "Ruby";
  if (joined.includes("emerald")) return "Emerald";
  const phaseMatch = joined.match(/phase\s*([1-4])/i);
  if (phaseMatch) return `Phase ${phaseMatch[1]}`;
  return "";
}

function deriveDopplerPhaseLabel(item) {
  const explicit = getExplicitDopplerPhaseLabel(item);
  if (explicit) return explicit;

  const name = String(item?.name || "").toLowerCase();
  if (!name.includes("doppler")) return "";

  const patternSeed = Number(item?.pattern);
  const floatSeed = Number(String(item?.float || "0").replace(/[^\d.]/g, "")) || 0;
  const seedBase = Number.isFinite(patternSeed) && patternSeed > 0
    ? patternSeed
    : Math.max(1, Math.floor(floatSeed * 1000000) || 1);

  if (name.includes("gamma doppler")) {
    const gammaPhases = ["Phase 1", "Phase 2", "Phase 3", "Phase 4"];
    return gammaPhases[seedBase % gammaPhases.length];
  }

  const classicPhases = ["Phase 1", "Phase 2", "Phase 3", "Phase 4"];
  return classicPhases[seedBase % classicPhases.length];
}

function getExactDopplerApiName(item) {
  if (!item) return "";
  const rawName = normalizeMarketHashName(item.skinBidsApiName || item.name || "");
  if (!/doppler/i.test(rawName)) return "";

  const statTrakPrefixMatch = rawName.match(/^StatTrak(?:â„¢|Ã¢â€žÂ¢)?\s+/i);
  const statTrakPrefix = statTrakPrefixMatch ? statTrakPrefixMatch[0] : "";
  const baseName = rawName
    .replace(/^StatTrak(?:â„¢|Ã¢â€žÂ¢)?\s+/i, "")
    .replace(/\s+\((Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)\)$/i, "")
    .replace(/\s+(Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)$/i, "")
    .trim();

  const phaseLabel = deriveDopplerPhaseLabel(item);
  if (!phaseLabel) return `${statTrakPrefix}${baseName}`;

  if (/gamma doppler/i.test(baseName) || phaseLabel === "Emerald") {
    return `${statTrakPrefix}${baseName} (${phaseLabel})`;
  }
  if (/^(Phase [1-4]|Ruby|Sapphire|Black Pearl)$/i.test(phaseLabel)) {
    return `${statTrakPrefix}${baseName} (${phaseLabel})`;
  }
  return `${statTrakPrefix}${baseName}`;
}

function getDopplerVariantMatch(item) {
  if (!item) return null;
  const exactName = getExactDopplerApiName(item);
  if (!exactName) return null;
  const normalizedExactName = normalizeMarketHashName(exactName).toLowerCase();
  const exactVariant = allSkins.find(s => normalizeMarketHashName(s?.name || s?.hash_name || "").toLowerCase() === normalizedExactName);
  if (exactVariant) return exactVariant;

  const normalizedBase = normalizeImageLookupName(exactName).toLowerCase();
  const variantPool = allSkins.filter(s => {
    const sName = String(s?.name || s?.hash_name || "").trim();
    return /doppler/i.test(sName) && normalizeImageLookupName(sName).toLowerCase() === normalizedBase;
  });

  if (!variantPool.length) return null;

  const explicitPhase = deriveDopplerPhaseLabel(item);
  const phaseOrder = /gamma doppler/i.test(exactName)
    ? ["Phase 1", "Phase 2", "Phase 3", "Phase 4", "Emerald"]
    : ["Phase 1", "Phase 2", "Phase 3", "Phase 4", "Ruby", "Sapphire", "Black Pearl"];

  const byPhase = new Map();
  variantPool.forEach(variant => {
    const phase = extractExplicitDopplerPhase(variant.name) || "";
    if (phase && !byPhase.has(phase)) byPhase.set(phase, variant);
  });

  if (explicitPhase && byPhase.has(explicitPhase)) {
    return byPhase.get(explicitPhase);
  }

  if (explicitPhase) {
    const loosePhaseMatch = variantPool.find(variant => {
      const normalizedVariantName = normalizeMarketHashName(variant?.name || variant?.hash_name || "").toLowerCase();
      return normalizedVariantName.includes(explicitPhase.toLowerCase());
    });
    if (loosePhaseMatch) return loosePhaseMatch;
  }

  const patternSeed = Number(item?.pattern);
  const stableIndex = Number.isFinite(patternSeed) && patternSeed > 0 ? patternSeed : 1;
  const normalPhaseOrder = phaseOrder.filter(label => /^Phase [1-4]$/i.test(label));
  const fallbackPhase = normalPhaseOrder[(stableIndex - 1) % normalPhaseOrder.length];
  if (byPhase.has(fallbackPhase)) return byPhase.get(fallbackPhase);

  const exact = variantPool.find(s => normalizeMarketHashName(s?.name || s?.hash_name || "").toLowerCase() === normalizedExactName);
  if (exact) return exact;

  const nonGemFallback = variantPool.find(variant => {
    const phase = extractExplicitDopplerPhase(variant.name) || "";
    return !/^(Ruby|Sapphire|Black Pearl|Emerald)$/i.test(phase);
  });
  return nonGemFallback || variantPool[0] || null;
}

function getExactDopplerApiImage(item) {
  const variant = getDopplerVariantMatch(item);
  return variant ? (variant.image || variant.img || "") : "";
}

/**
 * Remove stale or duplicate equipped IDs on each account so equipped count reflects actual items owned.
 * Keeps only IDs that are present in the account.items array and deduplicates.
 */
function sanitizeEquippedLists() {
  if (!Array.isArray(state.accounts)) return;
  state.accounts.forEach(acc => {
    if (!Array.isArray(acc.equippedItemIds)) acc.equippedItemIds = [];
    // Keep only IDs that still exist in this account's items
    const valid = acc.equippedItemIds.filter(id => acc.items.some(it => it.id === id));
    // Deduplicate while preserving order
    const seen = new Set();
    acc.equippedItemIds = valid.filter(id => {
      if (seen.has(id)) return false;
      seen.add(id);
      return true;
    });
  });
  saveState();
}

