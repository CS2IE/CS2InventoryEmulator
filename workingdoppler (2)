    const sampleInferredRarity = () => {
      const p = Math.random();
      let acc = 0;
      
      // Determine base odds table
      let table = [...CASE_ODDS];
      if (isCapsuleLocal) table = CAPSULE_ODDS;
      if (nLower.includes("souvenir") || nLower.includes("package")) table = SOUVENIR_ODDS;

      // Logic: If container has Whites (Base Grade/Consumer/Terminal), they must be the majority (roughly 80% total)
      const hasWhites = caseData && (caseData["Base Grade"] || caseData["Consumer"] || caseData["Terminal"] || caseData["Industrial"]);
      if (hasWhites && !isCapsuleLocal) {
          table = [
            { rarity: "Consumer", rate: 0.60 },
            { rarity: "Base Grade", rate: 0.60 },
            { rarity: "Terminal", rate: 0.60 },
            { rarity: "Industrial", rate: 0.20 },
            { rarity: "Mil-Spec", rate: 0.12 },
            { rarity: "Restricted", rate: 0.05 },
            { rarity: "Classified", rate: 0.02 },
            { rarity: "Covert", rate: 0.008 },
            { rarity: "Gold", rate: 0.002 }
          ];
      }

      // Filter table to only include rarities actually present in this case (or fallbacks)
      const availableRarities = new Set(Object.keys(caseData));
      let activeTable = table.filter(o => availableRarities.has(o.rarity) || o.rarity === "Gold");
      if (activeTable.length === 0) activeTable = table;

