      if (!item.skinBidsApiName) item.skinBidsApiName = getExactDopplerApiName(item) || item.name;
      if (!item.dopplerPhase) item.dopplerPhase = getExplicitDopplerPhaseLabel(item) || deriveDopplerPhaseLabel(item) || "";
      if (!item.image && !item.img && !item.steamPhaseImage) {
        const phaseImg = getDisplayImage({ ...item, skinBidsApiName: item.skinBidsApiName });
