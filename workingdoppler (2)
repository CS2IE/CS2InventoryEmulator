      const acc = getActiveAccount();
      if (!acc) return alert("No active account.");

      // Ensure a storage unit is chosen (pick first if none)
      // If we aren't viewing a specific unit in breadcrumb mode, look for the first available unit in the account
      let unitToUseId = state.viewingStorageUnitId;
      if (!unitToUseId) {
        const firstUnit = acc.items.find(it => (it.name || "").toLowerCase().includes("storage unit"));
        if (firstUnit) {
          unitToUseId = firstUnit.id;
        }
      }

      if (!unitToUseId) return alert("No Storage Unit found in this account. Create or add a Storage Unit first.");
      
      const unit = findItemById(acc, unitToUseId);
      if (!unit) return alert("Storage unit not found.");

      // Build the SAME visible-item filter the main grid uses.
      const filterVal = (document.getElementById("filterInput") && document.getElementById("filterInput").value) ? document.getElementById("filterInput").value.toLowerCase() : "";
      const activeRarityFilter = state.rarityFilter || "all";

      // Weapon-like detection used across the app
      const isWeaponLike = (it) => {
        if (!it || !it.name) return false;
        const n = (it.name || "").toLowerCase();
        const type = (it.type || "").toLowerCase();
        if (n.includes("storage unit") || n.includes("case") || n.includes("key") || n.includes("sticker") || n.includes("capsule") || n.includes("charm") || n.includes("agent") || n.includes("graffiti") || n.includes("package") ) return false;
        return (type.includes("rifle") || type.includes("pistol") || type.includes("smg") ||
                type.includes("sniper") || type.includes("shotgun") || type.includes("machine") ||
                type.includes("knife") || n.includes("★") || n.includes("knife") || n.includes("gloves") || n.includes("|") ||
                n.includes("ak-47") || n.includes("m4a4") || n.includes("awp") || n.includes("karambit") || n.includes("butterfly"));
      };

      // Exclude any item that is already inside ANY storage unit in the account
      const isInsideAnyUnit = (candidate) => {
        return acc.items.some(u => Array.isArray(u.contents) && u.contents.some(c => c.id === candidate.id));
      };

      // IMPORTANT: only consider top-level account.items (main inventory). Items stored inside other containers are not in acc.items,
      // so this preserves behavior of "visible in the main inventory".
      // Apply search + rarity filtering exactly like refreshInventoryView, then pick only weapon-like entries.
      const isViewingStorage = !!state.viewingStorageUnitId || (state.viewingProfileId && !!state.viewingProfileId);
      let visibleItems = acc.items.filter(it => {
        const matchesSearch = isViewingStorage ? true : (it.name.toLowerCase().includes(filterVal) || (it.nametag && it.nametag.toLowerCase().includes(filterVal)));
        const matchesRarity = activeRarityFilter === "all" || it.rarity === activeRarityFilter;
        return matchesSearch && matchesRarity;
      });

      // If pagination is enabled, restrict to the current page slice (so only actually visible cards move)
      if (!state.disablePagination) {
        const totalItems = visibleItems.length;
        const totalPages = Math.max(1, Math.ceil(totalItems / PAGE_SIZE));
        if (state.currentPage > totalPages) state.currentPage = totalPages;
        const start = (state.currentPage - 1) * PAGE_SIZE;
        visibleItems = visibleItems.slice(start, start + PAGE_SIZE);
      }

      // Now from those visible items select only weapon-like items and exclude any already inside any storage unit or inside target unit
      const candidates = visibleItems.filter(it => {
        if (!isWeaponLike(it)) return false;
        if (equippedIds.includes(it.id)) return false; // Exclude equipped items from bulk move
        if (unit.contents && unit.contents.some(c => c.id === it.id)) return false;
        if (isInsideAnyUnit(it)) return false;
        return true;
      });

      if (candidates.length === 0) return alert("No visible weapons match the current filters to move.");

      const candidateIds = new Set(candidates.map(c => c.id));

      // 1. Add candidates to unit contents
      if (!unit.contents) unit.contents = [];
      candidates.forEach(it => {
        unit.contents.push(it);
      });

      // 2. Remove candidates from main account inventory
      acc.items = acc.items.filter(it => !candidateIds.has(it.id));

      unit.lastUpdated = Date.now();
      saveState();
      refreshInventoryView();
      
      // Only attempt to render storage modal contents if it's currently being displayed
      if (!document.getElementById("storageModal").classList.contains("hidden")) {
        renderStorageContents(unit, acc);
      }
    });
