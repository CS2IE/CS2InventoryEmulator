    const acc = getActiveAccount();
    if (!acc || state.storageSelectedIds.length === 0) return;
    
    let targetUnit = acc.items.find(it => it.id === state.storageSelectionTargetId);
    if (!targetUnit) {
      alert("Target storage unit not found.");
      return;
    }

    const mode = state.storageSelectionMode;
    const performMove = () => {
      if (mode === 'deposit') {
        const selectedItems = acc.items.filter(it => state.storageSelectedIds.includes(it.id));
        const availableSpace = Math.max(0, 1000 - ((targetUnit.contents || []).length));
        if (selectedItems.length > availableSpace) {
          alert(`This storage unit only has room for ${availableSpace} more item${availableSpace === 1 ? "" : "s"}.`);
          return;
        }
        acc.items = acc.items.filter(it => !state.storageSelectedIds.includes(it.id));
        if (!targetUnit.contents) targetUnit.contents = [];
        
        selectedItems.forEach(it => {
            targetUnit.contents.push(it);
        });
      } else {
        if (!targetUnit.contents) targetUnit.contents = [];
        const selectedItems = targetUnit.contents.filter(it => state.storageSelectedIds.includes(it.id));
        targetUnit.contents = targetUnit.contents.filter(it => !state.storageSelectedIds.includes(it.id));
        acc.items.push(...selectedItems);
      }
      targetUnit.lastUpdated = Date.now();
      state.storageSelectionMode = null;
      state.storageSelectedIds = [];
      saveState();
      refreshInventoryView();
    };

    if (state.storageNoConfirm) {
      // Skips the artificial loading confirmation delay but still requires the manual confirm click
      performMove();
    } else {
      const overlay = document.getElementById("transferOverlay");
      const statusText = document.getElementById("transferStatusText");
      overlay.classList.remove("hidden");
      overlay.style.display = "flex";
      statusText.textContent = mode === 'deposit' ? "Moving to Storage Unit..." : "Moving to Inventory...";
      setTimeout(() => {
        performMove();
        overlay.classList.add("hidden");
        overlay.style.display = "none";
      }, 1000);
    }
  };

  document.getElementById("cancelSelectionBtn").onclick = () => {
    state.storageSelectionMode = null;
    state.storageSelectedIds = [];
    refreshInventoryView();
  };
  } catch (e) {
    console.warn('attachUIHandlers error:', e);
  }
}

function renderAccountSelect() {
  // Ensure there is a <select id="accountSelect"> to work with (legacy callers)
  let sel = document.getElementById("accountSelect");
  if (!sel) {
    sel = document.createElement("select");
    sel.id = "accountSelect";
    sel.style.display = "none";
    document.body.appendChild(sel);
  }

  // Populate the hidden select so legacy code still works
  sel.innerHTML = "";
  state.accounts.forEach(acc => {
    const opt = document.createElement("option");
    opt.value = acc.id;
    opt.textContent = acc.name;
    if (acc.id === state.activeAccountId) opt.selected = true;
    sel.appendChild(opt);
  });

  // Update the new profile trigger area (pfp + text)
  const trigger = document.getElementById("profileTrigger");
  const headerName = document.getElementById("headerUsername");
  const headerPfp = document.getElementById("headerUserPfp");
  const dropdown = document.getElementById("accountDropdown");

  const acc = getActiveAccount();
  const usernameText = acc ? acc.name : "User";
  const pfpSrc = acc ? (acc.pfp || "https://i.imgur.com/zFydkgL.png") : "https://i.imgur.com/zFydkgL.png";

  // Update DOM
  if (headerName) headerName.textContent = usernameText;
  if (headerPfp) headerPfp.src = pfpSrc;

  // Build dropdown contents (replace children)
  if (dropdown) {
    dropdown.innerHTML = "";
    // Primary account area (static)
    const header = document.createElement("div");
    header.style.padding = "8px";
    header.style.borderBottom = "1px solid rgba(255,255,255,0.04)";
    header.innerHTML = `<div style="font-weight:900; color:#fff;">${escapeHtml(usernameText)}</div><div style="color:#94a3b8; font-size:12px;">Manage your accounts</div>`;
    dropdown.appendChild(header);

    // Populate accounts list
    state.accounts.forEach(a => {
      const row = document.createElement("div");
      row.className = "acc-item";
      const img = document.createElement("img");
      img.src = a.pfp || "https://i.imgur.com/zFydkgL.png";
      const name = document.createElement("div");
      name.className = "acc-name";
      name.textContent = a.name;
      const sub = document.createElement("div");
      sub.className = "acc-sub";
      sub.textContent = formatPrice(a.items ? a.items.reduce((s,it)=>s+getItemValue(it),0) : 0);

      row.appendChild(img);
      row.appendChild(name);
      row.appendChild(sub);

      row.onclick = (e) => {
        e.stopPropagation();
        // Switch active account
        state.activeAccountId = a.id;
        saveState();
        // refresh UI
        renderAccountSelect();
        refreshInventoryView();
        // Close dropdown
        dropdown.classList.add("hidden");
      };
      dropdown.appendChild(row);
    });

    // Divider
    const div = document.createElement("div");
    div.className = "ctx-divider";
    div.style.margin = "8px 0";
    dropdown.appendChild(div);

    // Actions: Manage / Duplicate / Delete / Add Account
    const actions = [
      { id: "manageAccount", text: "Manage Account" },
      { id: "duplicateAccount", text: "Duplicate Account" },
      { id: "deleteAccount", text: "Delete Account" },
      { id: "addNewAccount", text: "Add Account" }
    ];
    actions.forEach(act => {
      const btn = document.createElement("div");
      btn.className = "acc-item";
      btn.style.fontWeight = "700";
      btn.style.justifyContent = "center";
      btn.style.color = act.id === "deleteAccount" ? "#eb4b4b" : "#dcdedf";
      btn.textContent = act.text;
      btn.onclick = (e) => {
        e.stopPropagation();
        dropdown.classList.add("hidden");
        if (act.id === "manageAccount") {
          // open manage modal with active account prefilled
          const modal = document.getElementById("manageAccountModal");
          const accObj = getActiveAccount();
          if (modal && accObj) {
            document.getElementById("manageAccountNameInput").value = accObj.name;
            document.getElementById("manageAccountPfpInput").value = accObj.pfp || "https://i.imgur.com/zFydkgL.png";
            modal.classList.remove("hidden");
          }
        } else if (act.id === "duplicateAccount") {
          // duplicate active account
          const base = getActiveAccount()?.name || "Account";
          let idx = 2;
          let newName = `${base} ${idx}`;
          while (state.accounts.some(x => x.name === newName)) { idx++; newName = `${base} ${idx}`; }
          createAccount(newName);
          refreshInventoryView();
        } else if (act.id === "deleteAccount") {
          const accObj = getActiveAccount();
          if (!accObj) return;
          if (state.accounts.length <= 1) return alert("You must have at least one account.");
          if (!confirm(`Delete account "${accObj.name}"? This cannot be undone.`)) return;
          state.accounts = state.accounts.filter(a => a.id !== accObj.id);
          state.activeAccountId = state.accounts[0].id;
          saveState();
          renderAccountSelect();
          refreshInventoryView();
        } else if (act.id === "addNewAccount") {
          const addAccModal = document.getElementById("addAccountModal");
          document.getElementById("newAccountNameInput").value = "";
          document.getElementById("newAccountPfpInput").value = "";
          addAccModal.classList.remove("hidden");
        }
      };
      dropdown.appendChild(btn);
    });
  }

  // Bind the entire profile trigger to toggle the dropdown and ensure both pfp and username act as trigger
  if (trigger && dropdown) {
    const toggle = (e) => {
      e && e.stopPropagation && e.stopPropagation();
      const isVisible = !dropdown.classList.contains("hidden");
      document.querySelectorAll(".account-dropdown").forEach(d => d.classList.add("hidden"));
      if (!isVisible) {
        // Position the dropdown relative to the trigger (left-aligned)
        const rect = trigger.getBoundingClientRect();
        dropdown.style.top = (rect.bottom + 8) + "px";
        // align dropdown's left edge with the trigger's left edge for a left-positioned menu
        dropdown.style.left = Math.max(12, rect.left) + "px";
        dropdown.classList.remove("hidden");
        dropdown.classList.add("visible");
      } else {
        dropdown.classList.add("hidden");
        dropdown.classList.remove("visible");
      }
    };

    trigger.onclick = toggle;
    trigger.onkeypress = (e) => { if (e.key === "Enter" || e.key === " ") toggle(e); };

    // Clicking anywhere else hides the dropdown
    document.removeEventListener("click", window._accountDropdownCloseHandler);
    window._accountDropdownCloseHandler = (ev) => {
      if (!dropdown) return;
      if (!dropdown.classList.contains("hidden") && !dropdown.contains(ev.target) && !trigger.contains(ev.target)) {
        dropdown.classList.add("hidden");
        dropdown.classList.remove("visible");
      }
    };

    // Bind inventory value copy logic
    const invValEl = document.getElementById("headerInventoryValue");
    if (invValEl) {
        invValEl.onclick = (e) => {
            e.stopPropagation();
            copyInventoryToClipboard();
        };
    }
    document.addEventListener("click", window._accountDropdownCloseHandler);
  }
}

function changePage(delta) {
  const oldPage = state.currentPage;
  state.currentPage += delta;
  saveState();
  refreshInventoryView();
  
  const grid = document.getElementById("inventoryGrid");
  // Only animate if page actually changed (refreshInventoryView clamps the value)
  if (grid && state.currentPage !== oldPage) {
    const cls = delta > 0 ? "slide-left" : "slide-right";
    grid.classList.remove("slide-left", "slide-right");
    void grid.offsetWidth;
    grid.classList.add(cls);
    setTimeout(() => grid.classList.remove(cls), 800);
  }
}

// ---------- INVENTORY GRID ----------
 // Helper for item value including stickers, exterior multipliers and storage contents
const getStickerValueTotal = (it) => {
  if (!it || !Array.isArray(it.stickers)) return 0;
  return it.stickers.reduce((sum, sticker) => sum + (Number(sticker?.price) || 0), 0);
};

/**
 * Helper for item value for INVENTORY NET VALUE.
 * Inventory value excludes stickers unless the user enables the setting.
 */
const getInventoryItemValue = (it) => {
  if (!it) return 0;
  const isStorage = it.name && it.name.toLowerCase().includes("storage unit");
  if (isStorage) return 0; 

  let base = (typeof it.price === "number") ? it.price : 0;
  try {
    const wearName = it.wear ? String(it.wear) : null;
    if (wearName) {
      const itemName = String(it.name || "");
      const special = SPECIAL_WEAR_PRICE_MODS_BY_ITEM[itemName];
      if (special && special[wearName]) base *= special[wearName];
      else if (WEAR_PRICE_MODS[wearName]) base *= WEAR_PRICE_MODS[wearName];
    }
  } catch(e) {}
  
  if (state.countStickersInInventoryValue) {
    base += getStickerValueTotal(it);
  }
  
  base = applyDopplerPhasePricePremium(it.name, base);

  const rank = parseInt(it.floatRank, 10) || 0;
  if (rank >= 1 && rank <= 3) {
    const mult = [4.5, 3.1, 2.2][rank - 1] || 1;
    const flatBonus = [500, 300, 150][rank - 1] || 0;
    base = (base * mult) + flatBonus;
  } else if (rank >= 4 && rank <= 6) {
    const mult = [2.2, 3.1, 4.5][rank - 4] || 1;
    const flatBonus = [150, 300, 500][rank - 4] || 0;
    base = (base * mult) + flatBonus;
  }

  return clampCaseHardenedPrice(it.name, base);
};

const getItemValue = (it) => {
  if (!it) return 0;
  const isStorage = it.name && it.name.toLowerCase().includes("storage unit");
  // Storage units themselves have 0 value globally now
  if (isStorage) return 0;

  let base = (it && typeof it.price === "number") ? it.price : 0;

  try {
    const wearName = (it && it.wear) ? String(it.wear) : null;
    if (wearName) {
      const itemName = String(it && it.name ? it.name : "");
      const special = SPECIAL_WEAR_PRICE_MODS_BY_ITEM[itemName];
      if (special && special[wearName]) {
        base = base * (special[wearName] || 1);
      } else if (WEAR_PRICE_MODS && WEAR_PRICE_MODS[wearName]) {
        base = base * (WEAR_PRICE_MODS[wearName] || 1);
      }
    }
  } catch (e) {
    base = (it && typeof it.price === "number") ? it.price : base;
  }

  const rank = parseInt(it.floatRank, 10) || 0;
  if (rank >= 1 && rank <= 3) {
    const mult = [4.5, 3.1, 2.2][rank - 1] || 1;
    const flatBonus = [500, 300, 150][rank - 1] || 0;
    base = (base * mult) + flatBonus;
  } else if (rank >= 4 && rank <= 6) {
    const mult = [2.2, 3.1, 4.5][rank - 4] || 1;
    const flatBonus = [150, 300, 500][rank - 4] || 0;
    base = (base * mult) + flatBonus;
  }

  return clampCaseHardenedPrice(it.name, base);
};

const getInventoryAddedValueBreakdown = (it) => {
  if (!it || !it.name || String(it.name).toLowerCase().includes("storage unit")) return null;

  const rawBasePrice = (typeof it.price === "number") ? it.price : 0;
  let wearAdded = 0;
  let dopplerAdded = 0;
  let floatAdded = 0;
  const stickerAdded = getStickerValueTotal(it);

  try {
    const wearName = it.wear ? String(it.wear) : "";
    if (wearName) {
      const itemName = String(it.name || "");
      const special = SPECIAL_WEAR_PRICE_MODS_BY_ITEM[itemName];
      const wearMult = (special && special[wearName]) ? Number(special[wearName]) : Number(WEAR_PRICE_MODS?.[wearName] || 1);
      if (wearMult > 1) wearAdded = rawBasePrice * (wearMult - 1);
    }
  } catch (e) {}

  try {
    const dopplerAdjusted = applyDopplerPhasePricePremium(it.name, rawBasePrice + wearAdded);
    dopplerAdded = Math.max(0, dopplerAdjusted - (rawBasePrice + wearAdded));
  } catch (e) {}

  const rank = parseInt(it.floatRank, 10) || 0;
  if (rank >= 1 && rank <= 3) {
    const mult = [4.5, 3.1, 2.2][rank - 1] || 1;
    const flatBonus = [500, 250, 125][rank - 1] || 0;
    floatAdded = (rawBasePrice * Math.max(0, mult - 1)) + flatBonus;
  } else if (rank >= 4 && rank <= 6) {
    const mult = [2.2, 3.1, 4.5][rank - 4] || 1;
    const flatBonus = [125, 250, 500][rank - 4] || 0;
    floatAdded = (rawBasePrice * Math.max(0, mult - 1)) + flatBonus;
  }

  const parts = [];
  if (wearAdded > 0.01 && it.wear) parts.push(`${it.wear} ${formatPrice(wearAdded)}`);
  if (dopplerAdded > 0.01 && /doppler/i.test(String(it.name || ""))) {
    const phase = getExplicitDopplerPhaseLabel(it) || deriveDopplerPhaseLabel(it) || "Doppler";
    parts.push(`${phase} ${formatPrice(dopplerAdded)}`);
  }
  if (floatAdded > 0.01 && rank > 0) {
    parts.push(`${rank <= 3 ? "Low Float" : "High Float"} ${formatPrice(floatAdded)}`);
  }
  if (stickerAdded > 0.01 && Array.isArray(it.stickers) && it.stickers.length) {
    parts.push(`Stickers ${formatPrice(stickerAdded)}`);
  }

  if (!parts.length) return null;
  return {
    totalAdded: wearAdded + dopplerAdded + floatAdded + stickerAdded,
    parts
  };
};

