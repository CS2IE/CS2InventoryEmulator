  const descEl = modal.querySelector("p");
  if (titleEl) titleEl.textContent = "Select Sticker";
  if (descEl) descEl.textContent = "Select a sticker from your inventory to apply to this gun:";

  // All owned stickers in inventory (not already applied)
  const ownedStickers = account.items.filter(it => it.name.toLowerCase().includes("sticker"));

  if (ownedStickers.length === 0) {
    list.innerHTML = "<p style='grid-column: 1/-1; padding: 20px;'>You don't own any stickers. Use Get New Stickers to buy some.</p>";
  } else {
    ownedStickers.forEach(sticker => {
      const card = document.createElement("div");
      card.className = "card";
      card.style.cursor = "pointer";
      card.style.padding = "10px";
      card.style.display = "flex";
      card.style.flexDirection = "column";
      card.style.alignItems = "center";

      const price = getItemValue(sticker);
      card.innerHTML = `
        <img src="${getDisplayImage(sticker)}" style="height: 75px; margin-bottom: 5px;">
        <div style="font-size: 11px; text-align:center; height: 30px; overflow: hidden; line-height: 1.1; font-weight: bold;">${sticker.name}</div>
        <div class="price-related" style="color: #a4d007; font-size: 11px; font-weight: bold; margin-top: 4px;">${formatPrice(price)}</div>
      `;
      card.onclick = () => {
        if (!gun.stickers) gun.stickers = [];
        if (gun.stickers.length >= 5) {
          alert("This gun already has 5 stickers applied.");
          return;
        }
        gun.stickers.push({ 
          name: sticker.name, 
          img: sticker.img, 
          price: sticker.price,
          rarity: sticker.rarity
        });

        // Remove sticker item from inventory
        account.items = account.items.filter(it => it.id !== sticker.id);

        saveState();
        refreshInventoryView();
        modal.classList.add("hidden");
        showGunStickerManager(gunId);
      };

      list.appendChild(card);
    });
  }

  modal.classList.remove("hidden");
}

function addItemToAccount(input, options = {}) {
  let { name, img: originalImg, price, rarity, wear, type, qty, isCustomPrice, source, floatVal, stickers, charm, isReturn, nametag, pattern, prevOwners } = input;
  let img = originalImg;
  const explicitDopplerPhase = extractExplicitDopplerPhase(name);
  const carriedDopplerPhase = input?.dopplerPhase || explicitDopplerPhase || "";
  options = options || {};
  
  if (isReturn && !state.showBetReturnsInPopup) {
    options.skipPopup = true;
  }

  // 2 Storage Unit Bug Fix: Unified batch protection
  const batchId = options.batchId || ("batch_" + Date.now() + "_" + Math.random().toString(16).slice(2));
  const account = getActiveAccount();
  if (!account) return null;
  
  if (isCustomPrice) {
    if (!state.priceOverrides) state.priceOverrides = {};
    // Normalize the provided custom price to a base price (assume provided price is for the specified wear).
    // Store basePrice = providedPrice / wearMultiplier so that the override can be applied to other wears.
    try {
      const wearMult = (wear && WEAR_PRICE_MODS[wear]) ? WEAR_PRICE_MODS[wear] : 1;
      const basePrice = Number(price) / (wearMult || 1);
      state.priceOverrides[name] = Math.round(basePrice * 100) / 100;
    } catch (err) {
      // Fallback to storing raw price if anything goes wrong
      state.priceOverrides[name] = price;
    }
  }

  const rawInputName = String(name || "");
  if (rawInputName.toLowerCase().includes("sticker")) {
    name = rawInputName
      .replace(/^Souvenir\s+/i, "")
      .replace(/^StatTrak(?:™|â„¢)\s+/i, "")
      .replace(/^'Blue Gem'\s+/i, "")
      .trim();
    wear = null;
    floatVal = null;
    pattern = null;
    nametag = null;
    stickers = [];
  }

  // Remove Doppler phase names from item name
  name = String(name || "")
    .replace(/\s+\((Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)\)$/i, "")
    .replace(/\s+(Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)$/i, "")
    .trim();

  // Determine finalPrice:
  // - If caller asked to skip global price fixes (options.skipPriceFix), use the provided price or mockPrice only.
  // - Otherwise prefer PRICE_FIXES / state.priceOverrides, then provided price, then mockPrice.
  let finalPrice;
  if (options && options.skipPriceFix) {
    finalPrice = (typeof price === "number" && price > 0) ? price : mockPrice({ name });
  } else {
    finalPrice = (PRICE_FIXES[name] !== undefined) ? PRICE_FIXES[name] : (typeof price === "number" && price > 0 ? price : mockPrice({ name }));
  }
  if (!finalPrice || finalPrice <= 0) {
    finalPrice = mockPrice({ name });
  }
  finalPrice = clampCaseHardenedPrice(name, finalPrice);

  const isStoragePurchase = String(name || "").toLowerCase().includes("storage unit");
  const storagePurchaseTxnId = input?._purchaseTxnId || input?.purchaseTxnId || null;
  if (isStoragePurchase && storagePurchaseTxnId && processedStoragePurchaseTxns.has(storagePurchaseTxnId)) {
    return null;
  }
  if (isStoragePurchase && storagePurchaseTxnId) {
    processedStoragePurchaseTxns.add(storagePurchaseTxnId);
    setTimeout(() => processedStoragePurchaseTxns.delete(storagePurchaseTxnId), 5000);
  }

  const count = Math.max(1, qty || 1);
  const itemType = type || (name.includes("Case") ? "Container" : "Weapon Skin");
  const sourceText = String(source || "").toLowerCase();

  if (!img) {
    img = getDisplayImage({ ...input, name, wear });
  }

  // Apply global image and rarity overrides to newly added items
  if (state.imageOverrides?.[name]) img = state.imageOverrides[name];
  if (state.rarityOverrides?.[name]) rarity = state.rarityOverrides[name];
  
  // M4A4 Howl is strictly always Covert
  if (String(name).includes("M4A4 | Howl")) rarity = "Covert";

  // Remove Doppler phase names from item name
  name = String(name || "")
    .replace(/\s+\((Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)\)$/i, "")
    .replace(/\s+(Phase [1-4]|Ruby|Sapphire|Black Pearl|Emerald)$/i, "")
    .trim();

  const nLower = name.toLowerCase();
  const isGambleRewardSource = sourceText.includes("jackpot win") || sourceText.includes("coinflip win") || sourceText.includes("dice game win") || sourceText.includes("gambled");

  if (isGambleRewardSource && !nLower.includes("sticker") && !nLower.includes("agent")) {
    const canHaveBonusCosmetics = nLower.includes("|") || nLower.includes("★") || nLower.includes("knife") || nLower.includes("gloves");
    if (canHaveBonusCosmetics && !nametag && Math.random() < 0.14) {
      nametag = getUniqueBotNametag();
    }
    if (canHaveBonusCosmetics && (!Array.isArray(stickers) || stickers.length === 0) && Math.random() < 0.22) {
      const sPool = allSkins.filter(s => {
        const stickerName = String(s?.name || "").toLowerCase();
        return stickerName.includes("sticker") && !stickerName.includes("capsule");
      });
      const stickerCount = Math.min(4, Math.max(1, Math.floor(Math.random() * 4)));
      stickers = [];
      for (let i = 0; i < stickerCount; i++) {
        const s = sPool[Math.floor(Math.random() * sPool.length)];
        if (!s) continue;
        stickers.push({
          name: s.name,
          img: getDisplayImage(s),
          price: PRICE_FIXES[s.name] || mockPrice(s),
          rarity: s.rarity?.name || "High Grade",
          scratchPercent: 0
        });
      }
    }
  }
  
  // Logic Fix: If Souvenir is in name, force 4 random gold stickers
  const isActuallyWeapon = name.includes("|") || name.includes("★");
  if (String(name).includes("Souvenir") && isActuallyWeapon) {
    if (!stickers || stickers.length === 0) {
      const goldPool = allSkins.filter(s => {
          const sName = (s.name || "").toLowerCase();
          return sName.includes("sticker") && sName.includes("gold") && !sName.includes("champion") && !sName.includes("ems");
      }).filter(s => !s.name.toLowerCase().includes("ems katowice 2014"));
      if (goldPool.length > 0) {
        stickers = [];
        for (let j = 0; j < 4; j++) {
          const s = goldPool[Math.floor(Math.random() * goldPool.length)];
          stickers.push({
            name: s.name,
            img: getDisplayImage(s),
            price: (PRICE_FIXES[s.name] || mockPrice(s)),
            rarity: s.rarity?.name || "Extraordinary",
            scratchPercent: 0
          });
        }
      }
    }
  }

  const isGreyType = !nLower.includes("capsule") && !nLower.includes("case hardened") && (
    nLower.includes("key") || 
    nLower.includes("case") || 
    nLower.includes("tool") || 
    nLower.includes("pass") || 
    nLower.includes("storage unit") ||
    nLower.includes("package")
  );
  
  for (let i = 0; i < count; i++) {
    // Copy stickers with their scratch values preserved
    const stickersToApply = Array.isArray(stickers) ? stickers.map(s => ({
        ...s,
        scratchPercent: typeof s.scratchPercent === 'number' ? s.scratchPercent : 0
    })) : [];

    // Per-item wear: do not mutate the outer 'wear' variable so multiple adds don't inherit the same wear.
    const nameLower = (name || "").toLowerCase();
    const isStickerItem = nameLower.includes("sticker");
    // Case Hardened must have wear even though it has the word 'case' in it
    const isCaseHardened = nameLower.includes("case hardened");
    const isActuallyAContainer = !isCaseHardened && (isContainer({ name }) || nameLower.includes("storage unit") || nameLower.includes("case") || nameLower.includes("capsule") || nameLower.includes("crate") || nameLower.includes("package") || nameLower.includes("key") || isStickerItem || nameLower.includes("music kit") || nameLower.includes("agent") || nameLower.includes("graffiti") || nameLower.includes("tool") || nameLower.includes("pass"));
    
    // Determine finalWear for this specific item instance
    let finalWear = null;
    const shouldRandomizeWearEach = !!(input.randomizeWearEach || options.randomizeWearEach);
    if (shouldRandomizeWearEach && !isActuallyAContainer) {
      finalWear = mockWear(name, rarity);
    } else if (wear) {
      finalWear = wear;
    } else if (!isActuallyAContainer) {
      finalWear = mockWear(name, rarity);
      // If mockWear returned null for any reason, pick a non-FN wear by default (avoid always Factory New)
      if (!finalWear) {
        // Prefer Field-Tested / Minimal Wear as a safe default rather than Factory New
        finalWear = Math.random() < 0.5 ? "Field-Tested" : "Minimal Wear";
      }
    } else {
      finalWear = null;
    }

    // If a floatVal was supplied (e.g. from openCase/tradeUp) use it; otherwise generate a float for wearable items
    let finalFloat = (floatVal !== undefined && floatVal !== null) ? floatVal : null;
    if (options.floatVal !== undefined) finalFloat = options.floatVal;
    if (finalFloat === null) {
      if (finalWear) {
        finalFloat = generateFloatForWear(name, finalWear, (rarity || ""));
      } else {
        finalFloat = null;
      }
    }

    // Guarantee finalFloat is a decimal number (avoid exact integer 0 or 1)
    if (finalFloat !== null && finalFloat !== undefined) {
      finalFloat = Math.max(1e-9, Math.min(0.999999999, Number(finalFloat)));
      if (Math.floor(finalFloat) === finalFloat) finalFloat = finalFloat + 1e-9;
    }

    const finalPattern = isActuallyAContainer ? null : ((options.pattern !== undefined && options.pattern !== null && count === 1)
      ? options.pattern
      : ((pattern !== undefined && pattern !== null && count === 1) ? pattern : Math.max(1, Math.floor(Math.random() * 999) + 1)));

    // Logic for Souvenirs: Apply 4 gold stickers if souvenir
    const isActuallyWeapon = name.includes("|") || name.includes("★");
    if (String(name).includes("Souvenir") && isActuallyWeapon) {
      // Clear existing if any to force 4 gold rule
      stickersToApply.length = 0;
      const goldPool = allSkins.filter(s => {
          const sName = (s.name || "").toLowerCase();
          return sName.includes("sticker") && sName.includes("gold") && !sName.includes("champion") && !sName.includes("ems");
      });
      if (goldPool.length > 0) {
        for (let j = 0; j < 4; j++) {
          const s = goldPool[Math.floor(Math.random() * goldPool.length)];
          stickersToApply.push({
            name: s.name,
            img: getDisplayImage(s),
            price: PRICE_FIXES[s.name] || mockPrice(s),
            rarity: s.rarity?.name || "Extraordinary",
            scratchPercent: 0
          });
        }
      }
    }

    const isCasePull = sourceText.includes("pulled from");

    // Only non-case items can receive an automatic nametag.
    let finalNametag = nametag || null;
    const nametagAllowedSource = /bot trade|bidskin/i.test(sourceText);
    const allowExplicitStorageNametag = !!finalNametag && nameLower.includes("storage unit");
    if ((!nametagAllowedSource && !allowExplicitStorageNametag) || isCasePull || sourceText === "trade up contract") finalNametag = null;
    if (isStickerItem) finalNametag = null;
    if (!finalNametag && !isStickerItem && nametagAllowedSource && !isCasePull && finalPrice > 200 && isActuallyWeapon && Math.random() < 0.1) {
        finalNametag = getUniqueBotNametag();
    }
    if (finalNametag && nameLower.includes("storage unit") && count > 1) {
      finalNametag = `${finalNametag} ${i + 1}`;
    }

    // Calculate owners based on price (Higher price = fewer owners)
    let calculatedOwners = 1;
    if (prevOwners !== undefined) {
      calculatedOwners = prevOwners;
    } else {
      if (finalPrice > 5000) calculatedOwners = 1;
      else if (finalPrice > 1000) calculatedOwners = Math.floor(Math.random() * 2) + 1;
      else if (finalPrice > 500) calculatedOwners = Math.floor(Math.random() * 3) + 1;
      else calculatedOwners = Math.floor(Math.random() * 8) + 1;
    }

    const newItem = {
      ...input,
      id: "it_" + Date.now() + "_" + Math.random().toString(16).slice(2) + "_" + i,
      name,
      img,
      price: finalPrice,
      qty: 1,
      rarity: isGreyType ? "Base Grade" : (rarity || "Consumer"),
      wear: finalWear,
      floatVal: (finalFloat !== null && finalFloat !== undefined) ? finalFloat : null,
      pattern: (finalFloat !== null && finalFloat !== undefined) ? finalPattern : null,
      type: itemType,
      nametag: finalNametag,
      dopplerPhase: carriedDopplerPhase || null,
      stickers: stickersToApply,
      contents: Array.isArray(input.contents) ? JSON.parse(JSON.stringify(input.contents)) : [],
      source: source || "Purchased",
      acquiredAt: Date.now(),
      prevOwners: isCasePull ? 0 : calculatedOwners,
      charm: charm || input.charm || null
    };
    syncItemWearImage(newItem);
    account.items.push(newItem);
    lastAddedItem = newItem; // helper variable to return last created item
    addToConsoleLog(newItem);
    saveState(); // Ensure immediate persistence for every added item

    // Build individual result record for the popup
    const pendingEntry = {
      name,
      img: img || getDisplayImage({ name }),
      price: finalPrice || mockPrice({ name }),
      rarity: (rarity || (isGreyType ? "Base Grade" : "Consumer")),
      wear: finalWear || null,
      qty: 1, // Individual items in the slider
      type: itemType,
      source: source || "Purchased",
      createdId: newItem.id,
      batchId: batchId
    };

    // Queue items for the NEW ITEM popup if not explicitly skipped (e.g. gambling returns)
    if (!options.skipPopup) {
      // Ensure the popup shows fresh items
      hasShownNewItemPopup = false;
      pendingPurchaseResults.push(pendingEntry);
      // Show immediately (unless blocked by case opening modal)
      setTimeout(() => {
        try { showGroupedPurchaseResult(); } catch (e) {}
      }, 50);
    }

    // Sound is handled by high-level reveal logic to avoid flooding in multi-opens
  }
  
  // Mark items as untradable only if they are storage units (internal flag)
  const nLowCheck = name.toLowerCase();
  const isForbiddenType = nLowCheck.includes("storage unit");
  if (isForbiddenType) {
    if (lastAddedItem) lastAddedItem.isUntradable = true;
  }

  saveState();
  // Clear any active search filter so newly added items appear in the main grid right away
  try {
    const filterEl = document.getElementById("filterInput");
    if (filterEl) filterEl.value = "";
  } catch (e) {}
  // Clear CS2 Market Search input after adding items
  try {
    const searchEl = document.getElementById("search");
    if (searchEl) searchEl.value = "";
  } catch (e) {}
  refreshInventoryView();
  
  // Feedback in UI
  const btn = document.getElementById("openSearchBtn");
  if (btn) {
    const originalText = btn.textContent;
    btn.textContent = "Added!";
    setTimeout(() => btn.textContent = originalText, 1000);
  }

  // Note: do NOT auto-open the "New Item" popup here for each added item.
  // Callers (case openings, bundle purchases, trades, etc.) should call showGroupedPurchaseResult()
  // once after they've added all items so the popup shows grouped results instead of per-item floods.
  return lastAddedItem;
}

