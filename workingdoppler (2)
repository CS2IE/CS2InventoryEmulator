  }

  // Unified logic for collection/container name (reuse working New Item logic)
  const getCollectionName = (item) => {
    let containerName = null;
    if (item.source && String(item.source).includes("Pulled from ")) {
      containerName = String(item.source).split("Pulled from ")[1];
    } else if (item.source === "Traded") {
      containerName = "Traded Items";
    } else if (item.source === "Purchased") {
      containerName = "Market Purchase";
    }

    if (!containerName || containerName === "Unknown Collection") {
      const inName = (item.name || "").toString();
      for (const caseName of Object.keys(CASE_CONTENTS_DB || {})) {
        const groups = CASE_CONTENTS_DB[caseName];
        if (!groups) continue;
        for (const rarityGroup of Object.values(groups)) {
          if (!Array.isArray(rarityGroup)) continue;
          if (rarityGroup.some(ci => (ci && String(ci.name || "").trim()) === inName)) {
            containerName = caseName;
            break;
          }
        }
        if (containerName) break;
      }
    }
    return containerName || "Unknown Collection";
  };

  // Dedicated Equip Button (per-account)
  const equipBtn = root.querySelector("#equipItemBtn");
