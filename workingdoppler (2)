  }
  // Calculate combined price for details
  let combinedPrice = item.price;
  if (item.stickers) item.stickers.forEach(s => combinedPrice += (s.price || 0.5));
  root.querySelector("#detailsPrice").textContent = formatPrice(combinedPrice);

  // Display total price = unit combined price * displayed quantity (qty or items inside storage)
  const totalEl = root.querySelector("#detailsTotalPrice");
  try {
    const qtyForTotal = (displayQty && Number(displayQty)) ? Number(displayQty) : 1;
    if (totalEl) totalEl.textContent = formatPrice(combinedPrice * qtyForTotal);
  } catch (e) {
    if (totalEl) totalEl.textContent = formatPrice(combinedPrice);
  }

  const n = item.name.toLowerCase();
  const type = (item.type || "").toLowerCase();

  // Broader equippable detection used in details panel: include skins with '|' and knife/glove/★ names
  const isGun =
    !n.includes("storage unit") &&
    !n.includes("key") &&
    !n.includes("sticker") &&
    !n.includes("capsule") &&
    !n.includes("crate") &&
    !n.includes("tool") &&
    (type.includes("rifle") ||
     type.includes("pistol") ||
     type.includes("smg") ||
     type.includes("sniper") ||
     type.includes("shotgun") ||
     type.includes("machine") ||
     type.includes("knife") ||
     n.includes("★") ||
     n.includes("knife") ||
     n.includes("gloves") ||
     n.includes("|") ||
     n.includes("ak-47") ||
     n.includes("m4a4") ||
     n.includes("awp") ||
     n.includes("karambit") ||
     n.includes("butterfly"));

  const canStickerTarget = canItemReceiveStickers(item) && !isKnifeOrGloveItem(item);
  const applyBtn = root.querySelector("#applyStickerBtn");
  if (applyBtn) {
    const isStorageUnit = item.name.toLowerCase().includes('storage unit');
    
    if (canStickerTarget && !isStorageUnit) {
      applyBtn.classList.remove('hidden');
      applyBtn.textContent = "Apply Sticker...";
      applyBtn.onclick = () => showGunStickerManager(item.id);
    } else {
      applyBtn.classList.add('hidden');
