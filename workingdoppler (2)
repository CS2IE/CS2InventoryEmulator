function isKatoMarketSticker(item) {
  const name = String(item?.name || "").toLowerCase();
  return name.includes("sticker") &&
    !name.includes("capsule") &&
    (name.includes("katowice 2014") || name.includes("katowice 2015"));
}

function isWeaponMarketItem(item) {
  const name = String(item?.name || "").toLowerCase();
  const type = String(item?.type || item?.category?.name || "").toLowerCase();
  if (!name || name.includes("sticker") || name.includes("capsule") || name.includes("storage unit")) return false;
  return name.includes("|") ||
    name.includes("â˜…") ||
    name.includes("knife") ||
    name.includes("gloves") ||
    type.includes("knife") ||
    type.includes("gloves") ||
    type.includes("rifle") ||
    type.includes("pistol") ||
    type.includes("smg") ||
    type.includes("sniper") ||
    type.includes("shotgun") ||
    type.includes("machine");
}

function canBeUserMarketListed(item) {
  return !!item && (isWeaponMarketItem(item) || isKatoMarketSticker(item));
}

function canItemReceiveStickers(item) {
  if (!item) return false;
  const name = String(item?.name || "").toLowerCase();
  const type = String(item?.type || item?.category?.name || item?.weapon?.name || "").toLowerCase();
  if (!name) return false;
  const blockedKeywords = ["sticker", "capsule", "case", "crate", "package", "key", "tool", "pass", "agent", "graffiti", "music kit", "charm", "keychain", "storage unit"];
  if (blockedKeywords.some(keyword => name.includes(keyword) || type.includes(keyword))) return false;
  if (name.includes("â˜…") || name.includes("knife") || name.includes("gloves") || type.includes("knife") || type.includes("gloves")) return false;
  return isWeaponMarketItem(item);
}

function canItemHaveAppliedStickers(item) {
  return canItemReceiveStickers(item) && !isKnifeOrGloveItem(item);
}

function matchesSearchCategoryStrict(item, catId) {
  const rawCat = String(catId || "").toLowerCase();
  const cat = rawCat === "filled_cases" ? "charm" : rawCat;
  if (!cat) return true;

  const name = String(item?.name || "").toLowerCase();
  const catName = String(item?.category?.name || "").toLowerCase();
  const weapon = String(item?.weapon?.name || "").toLowerCase();
  const type = String(item?.type || item?.category?.name || "").toLowerCase();
  const actualKeyNames = new Set(Object.keys(KEY_CASE_MAP || {}).map(k => String(k || "").toLowerCase().trim()));

  if (cat === "custom") return true;
  if (cat === "stickers") return (name.includes("sticker") || catName.includes("sticker") || type.includes("sticker")) && !name.includes("capsule");
  if (cat === "case") return (name.includes("case") || name.includes("capsule") || name.includes("package") || name.includes("collection") || catName.includes("case") || catName.includes("capsule")) && !name.includes("|") && !name.includes("sticker |");
  if (cat === "key") {
    return actualKeyNames.has(name.trim());
  }
  if (cat === "knife") return name.includes("â˜…") || name.includes("knife") || catName.includes("knife") || type.includes("knife");
  if (cat === "gloves") return name.includes("gloves") || catName.includes("gloves") || type.includes("gloves");
  if (cat === "agent") return name.includes("agent") || catName.includes("agent") || type.includes("agent");
  if (cat === "music_kit") return name.includes("music kit") || catName.includes("music") || type.includes("music");
  if (cat === "graffiti") return name.includes("graffiti") || catName.includes("graffiti") || type.includes("graffiti");
  if (cat === "charm") {
    return name.includes("charm") ||
      name.includes("keychain") ||
      name.includes("sticker slab") ||
      catName.includes("charm") ||
      catName.includes("keychain") ||
      catName.includes("sticker slab") ||
      type.includes("charm") ||
      type.includes("keychain") ||
      type.includes("sticker slab");
  }
  if (cat === "tool") return catName.includes("tool") || type.includes("tool") || name.includes("storage unit") || name.includes("name tag");
  if (cat === "shotgun") {
    return (weapon.includes("shotgun") || catName.includes("shotgun") || type.includes("shotgun") || name.includes("nova") || name.includes("xm1014") || name.includes("mag-7") || name.includes("sawed-off")) && !name.includes("sticker");
  }
  if (cat === "sniper") {
    return (weapon.includes("sniper") || catName.includes("sniper") || type.includes("sniper") || name.includes("awp") || name.includes("ssg 08") || name.includes("scar-20") || name.includes("g3sg1")) && !name.includes("sticker");
  }
  if (["rifle", "pistol", "smg", "shotgun", "sniper"].includes(cat)) {
    return (weapon.includes(cat) || catName.includes(cat) || type.includes(cat)) && !name.includes("sticker");
  }
  return name.includes(cat) || catName.includes(cat) || weapon.includes(cat) || type.includes(cat);
}

function getActualContainerKeyResults(queryWords = []) {
  return [...new Set(Object.keys(KEY_CASE_MAP || {}).map(k => String(k || "").trim()).filter(Boolean))]
    .filter(name => {
      const lower = name.toLowerCase();
      return queryWords.every(word => lower.includes(word));
    })
    .map(name => {
      const match = MARKET_KEYS.find(k => k.name === name) || allSkins.find(s => s.name === name) || { name, type: "Key" };
      const price = PRICE_FIXES[name] !== undefined ? PRICE_FIXES[name] : (match.price || mockPrice(match));
      return {
        name,
        image: match.img || match.image || getDisplayImage({ name }),
        price,
        price_text: formatPrice(price),
        rarity: { name: match.rarity?.name || match.rarity || "Base Grade" },
        type: match.type || match.category?.name || "Key"
      };
    });
}

function getStorageHeaderMarkup(unit) {
  if (!unit) return "";
  return `
    <div class="storage-header-layout" style="align-items:center; margin: 10px auto;">
      <div class="storage-header-main" style="flex-direction:row; gap:20px;">
        <img src="${getDisplayImage(unit)}" class="storage-header-icon" style="width:64px; height:64px;">
        <div class="storage-header-details">
          <div style="font-size: 22px; font-weight: 900; color: #fff; text-align:center;">Viewing contents of ${escapeHtml(unit.nametag || unit.name)}</div>
          <div style="font-size:12px; color:#94a3b8; margin-top:4px;">Storage Unit • ${unit.contents?.length || 0} items</div>
        </div>
      </div>
