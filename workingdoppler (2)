      { key: 'caseAwardedMythicalBuffer', path: 'case_awarded_mythical.wav' },
      { key: 'caseAwardedLegendaryBuffer', path: 'case_awarded_legendary.wav' },
      { key: 'caseDropBuffer', path: 'case_drop.wav' },
      { key: 'caseUnlockBuffer', path: 'case_unlock.wav' },
      { key: 'caseUBuffer', path: 'case_u.mp3' }
    ];

    const isLocal = window.location.protocol === 'file:';

    for (const asset of soundAssets) {
      try {
        if (isLocal) {
          const htmlAudio = new Audio(asset.path);
          htmlAudio.preload = "auto";
          htmlAudio.load();
          window[asset.key + "_audio"] = htmlAudio;
        } else {
          const response = await fetch(asset.path);
          const arrayBuffer = await response.arrayBuffer();
          audioCtx.decodeAudioData(arrayBuffer, (decodedData) => {
            if (asset.key === 'caseScrollBuffer') caseScrollBuffer = decodedData;
            if (asset.key === 'caseAwardedRareBuffer') caseAwardedRareBuffer = decodedData;
            if (asset.key === 'caseAwardedMythicalBuffer') caseAwardedMythicalBuffer = decodedData;
            if (asset.key === 'caseAwardedLegendaryBuffer') caseAwardedLegendaryBuffer = decodedData;
            if (asset.key === 'caseDropBuffer') caseDropBuffer = decodedData;
            if (asset.key === 'caseUnlockBuffer') caseUnlockBuffer = decodedData;
            if (asset.key === 'caseUBuffer') caseUBuffer = decodedData;
          });
        }
      } catch (err) {
        console.warn(`Failed to load sound: ${asset.path}`, err);
      }
    }
  } catch (e) {
    console.warn("Failed to initialize audio context", e);
  }
}

function getMasterVolume() {
  return (state && typeof state.masterVolume === "number") ? state.masterVolume : 1;
}

function playAmplifiedHtmlAudio(src, {
  volume = 1,
  gainBoost = 1,
  delayMs = 0
} = {}) {
  const run = () => {
    const audio = new Audio(src);
    audio.volume = Math.min(1, Math.max(0, volume));
    audio.currentTime = 0;
    audio.preload = "auto";
    audio.muted = false;
    audio.playsInline = true;

    if (audioCtx && typeof audioCtx.createMediaElementSource === "function") {
      try {
        if (audioCtx.state === "suspended") audioCtx.resume();
        const source = audioCtx.createMediaElementSource(audio);
        const gain = audioCtx.createGain();
        gain.gain.setValueAtTime(Math.max(1, gainBoost), audioCtx.currentTime);
        source.connect(gain);
        gain.connect(audioCtx.destination);
      } catch (e) {
        // Fallback to plain element playback if media element routing fails.
      }
    }

    if (typeof audio.load === "function") audio.load();
    audio.play().catch(() => {});
  };

  if (delayMs > 0) setTimeout(run, delayMs);
  else run();
}

function playCaseScrollSound() {
  // quieter by default; getMasterVolume() still scales overall, but we only massively amplify when master slider is 200% (>=2)
  const loudFactor = getMasterVolume() >= 2 ? 3 : 1;
  if (window.caseScrollBuffer_audio) {
    const a = window.caseScrollBuffer_audio.cloneNode();
    a.volume = Math.min(1, Math.max(0, 0.12 * getMasterVolume() * loudFactor));
    a.play().catch(e=>{});
    return;
  }

  if (!caseScrollBuffer) {
    // Fallback to synthetic tick if buffer not ready
    playTickSound(180, 0.1 * getMasterVolume() * loudFactor);
    return;
  }
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();

  const source = audioCtx.createBufferSource();
  source.buffer = caseScrollBuffer;
  const gain = audioCtx.createGain();
  // quieter default level, amplified only when master >= 2
  gain.gain.setValueAtTime(0.12 * getMasterVolume() * loudFactor, audioCtx.currentTime);
  source.connect(gain);
  gain.connect(audioCtx.destination);
  source.start(0);
}

/**
 * Play award sound tuned to rarity.
 * rarity: string like "Mil-Spec","Restricted","Classified","Covert","Gold"
 * Rules:
 *  - If rarity is Covert or Gold -> play legendary buffer
 *  - Else if rarity is Restricted or Classified -> play mythical buffer
 *  - Else fallback to the 'rare' buffer
 */
function playAwardSound(rarity) {
  // Rate limit sounds: only play once per 200ms
  const now = Date.now();
  if (now - lastAwardSoundTime < 200) return;
  lastAwardSoundTime = now;

  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();

  try {
    const r = (String(rarity || "") || "").toLowerCase();
    // only massively amplify if master slider is at 200%
    const loudFactor = getMasterVolume() >= 2 ? 3 : 1;

    // Local file fallback
    if (window.caseAwardedRareBuffer_audio) {
      if (r === "restricted" || r === "classified") {
        if (window.caseAwardedMythicalBuffer_audio) {
          const a = window.caseAwardedMythicalBuffer_audio.cloneNode();
          a.volume = Math.min(1, Math.max(0, 0.6 * getMasterVolume() * loudFactor));
          a.play().catch(e=>{});
        }
      } else if (r === "covert" || r === "gold") {
        if (window.caseAwardedMythicalBuffer_audio) {
          const a1 = window.caseAwardedMythicalBuffer_audio.cloneNode();
          a1.volume = Math.min(1, Math.max(0, 0.5 * getMasterVolume() * loudFactor));
          a1.play().catch(e=>{});
        }
        if (window.caseAwardedLegendaryBuffer_audio) {
          setTimeout(() => {
            const a2 = window.caseAwardedLegendaryBuffer_audio.cloneNode();
            a2.volume = Math.min(1, Math.max(0, 0.9 * getMasterVolume() * loudFactor));
            a2.play().catch(e=>{});
          }, 120);
        }
      } else {
        const a = window.caseAwardedRareBuffer_audio.cloneNode();
        a.volume = Math.min(1, Math.max(0, 0.45 * getMasterVolume() * loudFactor));
        a.play().catch(e=>{});
      }
      return;
    }

    // Restricted (purple) or Classified (pink) => play mythical sound
    if (r === "restricted" || r === "classified") {
      if (caseAwardedMythicalBuffer) {
        const src = audioCtx.createBufferSource();
        src.buffer = caseAwardedMythicalBuffer;
        const g = audioCtx.createGain();
        g.gain.setValueAtTime(0.6 * getMasterVolume() * loudFactor, audioCtx.currentTime);
        src.connect(g);
        g.connect(audioCtx.destination);
        src.start(0);
      }
      return;
    }

    // Covert (red) or Gold => play mythical then legendary (if available) layered
    if (r === "covert" || r === "gold") {
      if (caseAwardedMythicalBuffer) {
        const srcM = audioCtx.createBufferSource();
        srcM.buffer = caseAwardedMythicalBuffer;
        const gM = audioCtx.createGain();
        gM.gain.setValueAtTime(0.5 * getMasterVolume() * loudFactor, audioCtx.currentTime);
        srcM.connect(gM);
        gM.connect(audioCtx.destination);
        srcM.start(0);
      }
      if (caseAwardedLegendaryBuffer) {
        // play legendary slightly after mythical for layering and emphasis
        const srcL = audioCtx.createBufferSource();
        srcL.buffer = caseAwardedLegendaryBuffer;
        const gL = audioCtx.createGain();
        gL.gain.setValueAtTime(0.9 * getMasterVolume() * loudFactor, audioCtx.currentTime + 0.12);
        srcL.connect(gL);
        gL.connect(audioCtx.destination);
        srcL.start(audioCtx.currentTime + 0.12);
      }
      return;
    }

    // Fallback: play rare buffer
    if (caseAwardedRareBuffer) {
      const src = audioCtx.createBufferSource();
      src.buffer = caseAwardedRareBuffer;
      const gain = audioCtx.createGain();
      gain.gain.setValueAtTime(0.45 * getMasterVolume() * loudFactor, audioCtx.currentTime);
      src.connect(gain);
      gain.connect(audioCtx.destination);
      src.start(0);
    }
  } catch (e) {
    // silent fail
  }
}

function playCaseDropSound() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();

  const loudFactor = getMasterVolume() >= 2 ? 3 : 1;

  if (window.caseDropBuffer_audio) {
    const a = window.caseDropBuffer_audio.cloneNode();
    a.volume = Math.min(1, Math.max(0, 0.25 * getMasterVolume() * loudFactor));
    a.play().catch(e=>{});
    return;
  }

  if (!caseDropBuffer) return;
  try {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (audioCtx.state === 'suspended') audioCtx.resume();

    // Ensure previous source is cleaned up if we were to loop, but for drop we just start fresh
    const source = audioCtx.createBufferSource();
    source.buffer = caseDropBuffer;
    const gain = audioCtx.createGain();
    gain.gain.setValueAtTime(0.25 * getMasterVolume() * loudFactor, audioCtx.currentTime);
    source.connect(gain);
    gain.connect(audioCtx.destination);
    source.start(0);
  } catch (e) {
    // silent fail
  }
}

/**
 * Play the dedicated 'case unlock' sound when the opening starts.
 */
function playCaseUnlockSound() {
  const master = getMasterVolume();
  const loudFactor = master >= 2 ? 10.5 : 8.5;
  // Make case_unlock sound significantly quieter as requested
  const unlockVolume = Math.min(1, Math.max(0.05, 0.04 * master * loudFactor));
  const followVolume = Math.max(4.5, 6.5 * master * loudFactor);
  let followTriggered = false;
  const caseUSrc = (window.caseUBuffer_audio && window.caseUBuffer_audio.src) ? window.caseUBuffer_audio.src : "case_u.mp3";

  const playFollowup = (delayMs = 0) => {
    if (followTriggered) return;
    followTriggered = true;
    if (caseUBuffer) {
      try {
        if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        if (audioCtx.state === 'suspended') audioCtx.resume();
        const when = audioCtx.currentTime + Math.max(0, delayMs / 1000);
        const sourceU = audioCtx.createBufferSource();
        sourceU.buffer = caseUBuffer;
        const gainU = audioCtx.createGain();
        gainU.gain.setValueAtTime(followVolume, when);
        sourceU.connect(gainU);
        gainU.connect(audioCtx.destination);
        sourceU.start(when);
        return;
      } catch (e) {
        console.warn("case_u follow-up failed:", e);
      }
    }
    if (window.caseUBuffer_audio) {
      const startHtml = () => {
        // Local file:// mode falls back to HTML audio, which is quieter than Web Audio gain nodes.
        // Route each copy through an amplified media-element path when possible.
        [0, 50, 100, 150, 200].forEach((offset) => {
          playAmplifiedHtmlAudio(caseUSrc, {
            volume: Math.min(1, master),
            gainBoost: Math.max(5.5, master * 7),
            delayMs: offset
          });
        });
      };
      if (delayMs > 0) {
        setTimeout(startHtml, delayMs);
      } else {
        startHtml();
      }
      return;
    }
    const startDirectHtml = () => {
      playAmplifiedHtmlAudio(caseUSrc, {
        volume: 1,
        gainBoost: Math.max(5.5, master * 7)
      });
    };
    if (delayMs > 0) {
      setTimeout(startDirectHtml, delayMs);
    } else {
      startDirectHtml();
    }
    return;
  };

  if (window.caseUnlockBuffer_audio) {
    const a = window.caseUnlockBuffer_audio.cloneNode();
    a.volume = unlockVolume;
    a.play().catch(() => {});
    playFollowup(0);
    return;
  }

  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') audioCtx.resume();

  if (!caseUnlockBuffer) {
    playTickSound(440, 0.2 * master * loudFactor);
    playFollowup(0);
    return;
  }
  try {
    const source = audioCtx.createBufferSource();
    source.buffer = caseUnlockBuffer;
    const gain = audioCtx.createGain();
    gain.gain.setValueAtTime(unlockVolume, audioCtx.currentTime);
    source.connect(gain);
    gain.connect(audioCtx.destination);
    
    source.start(0);
    playFollowup(0);
  } catch (e) {
    console.warn("playCaseUnlockSound failed:", e);
  }
}

function playTickSound(freq = 200, volume = 0.1) {
  try {
    const master = getMasterVolume();
    volume = volume * master;
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (audioCtx.state === 'suspended') audioCtx.resume();

    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    
    osc.type = 'sine';
    osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(freq * 0.5, audioCtx.currentTime + 0.1);
    
    gain.gain.setValueAtTime(volume, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.1);
    
    osc.connect(gain);
    gain.connect(audioCtx.destination);
    
    osc.start();
    osc.stop(audioCtx.currentTime + 0.1);

    // Click snap component
    const bufferSize = audioCtx.sampleRate * 0.02;
    const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < bufferSize; i++) data[i] = (Math.random() * 2 - 1) * Math.exp(-20 * i / bufferSize);
    
    const noise = audioCtx.createBufferSource();
    noise.buffer = buffer;
    const noiseGain = audioCtx.createGain();
    noiseGain.gain.setValueAtTime(volume * 0.8, audioCtx.currentTime);
    noiseGain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.02);
    
    const noiseFilter = audioCtx.createBiquadFilter();
    noiseFilter.type = 'highpass';
    noiseFilter.frequency.value = 1000;

    noise.connect(noiseFilter);
    noiseFilter.connect(noiseGain);
    noiseGain.connect(audioCtx.destination);
    noise.start();
  } catch(e) {}
}

/* ---------- In-screen confirmation helper ---------- */
/**
 * Shows an in-screen confirmation modal with message and calls onConfirm() if user confirms.
 */
function showInScreenConfirm(message, onConfirm) {
  const modal = document.getElementById("inScreenConfirmModal");
  const body = document.getElementById("inScreenConfirmBody");
  const yes = document.getElementById("inScreenConfirmYes");
  const no = document.getElementById("inScreenConfirmNo");
  const title = document.getElementById("inScreenConfirmTitle");

  if (!modal || !body || !yes || !no) {
    // fallback to browser confirm if modal is missing
    if (confirm(message)) {
      try { onConfirm(); } catch (e) {}
    }
    return;
  }

  title.textContent = "Are you sure?";
  body.textContent = message;
  modal.classList.remove("hidden");

  const cleanup = () => {
    modal.classList.add("hidden");
    yes.onclick = null;
    no.onclick = null;
  };

  yes.onclick = () => {
    cleanup();
    try { onConfirm(); } catch (e) {}
  };
  no.onclick = () => {
    cleanup();
  };
}

