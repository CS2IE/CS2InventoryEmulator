    appliedStickers.forEach((sticker, idx) => {
      // Ensure sticker scratchPercent exists
      if (typeof sticker.scratchPercent !== 'number') sticker.scratchPercent = 0;

      const wrapper = document.createElement('div');
      wrapper.className = 'sticker-wrapper';
      wrapper.setAttribute('data-tooltip', `${sticker.name} (${formatPrice(sticker.price || 0.5)})`);

      const sImg = document.createElement('img');
      sImg.src = sticker.img;
      sImg.className = 'applied-sticker-icon';
