async function importAndMergeStateFromClipboard() {
  try {
    const text = await navigator.clipboard.readText();
    const imported = JSON.parse(text);
    
    if (!imported || !Array.isArray(imported.accounts)) {
      alert("Invalid JSON data in clipboard.");
      return;
    }

    const overlay = document.createElement("div");
    overlay.className = "modal-overlay";
    overlay.style.zIndex = "10000";
    overlay.innerHTML = `
      <div class="user-snippet-modal" style="max-width: 400px; height: auto; min-height: auto; padding: 25px;">
        <h2 style="margin-bottom: 15px;">Import Data</h2>
        <p style="color: #94a3b8; font-size: 14px; margin-bottom: 20px; text-align: left;">
          Would you like to <strong>Merge</strong> the imported accounts into your existing ones, or <strong>Replace</strong> your current inventory entirely?
        </p>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          <button id="importMergeBtn" class="steam-btn highlight" style="padding: 12px; font-weight: bold;">MERGE ACCOUNTS</button>
          <button id="importReplaceBtn" class="steam-btn danger" style="padding: 12px; font-weight: bold; margin-top: 0;">REPLACE EVERYTHING</button>
          <button id="importCancelBtn" class="steam-btn grey" style="padding: 12px;">CANCEL</button>
        </div>
      </div>
    `;
    document.body.appendChild(overlay);

    const finalizeImport = async (mode) => {
      overlay.remove();
      if (mode === 'replace') {
        const importedClone = JSON.parse(JSON.stringify(imported));
        importedClone.__lastSavedAt = Date.now() + 10000;
        state = importedClone;
      } else {
        // Merge mode
        imported.accounts.forEach(acc => {
          // ensure fresh IDs to prevent collisions
          acc.id = "acc_" + Date.now() + "_" + Math.random().toString(16).slice(2);
          state.accounts.push(acc);
        });
        if (imported.tradeHistory) state.tradeHistory = [...state.tradeHistory, ...imported.tradeHistory];
        if (imported.priceOverrides) {
          state.priceOverrides = { ...state.priceOverrides, ...imported.priceOverrides };
        }
      }

      if (state.accounts.length > 0 && mode === 'replace') {
        state.activeAccountId = state.accounts[0].id;
      }

      normalizeState();
      sanitizeEquippedLists();
      resetInventoryToDefaultView();

      Object.assign(PRICE_FIXES, state.priceOverrides || {});

      isDirty = true;
      await clearPersistentStateCaches();
      try {
        const forcedSnapshotObj = buildStateSnapshotObject();
        forcedSnapshotObj.__lastSavedAt = Date.now() + 15000;
        state.__lastSavedAt = forcedSnapshotObj.__lastSavedAt;
        const forcedSnapshotStr = JSON.stringify(forcedSnapshotObj);
        mirrorSnapshotToAllStores(forcedSnapshotStr);
      } catch (e) {}
      await saveStateToDB();
      try {
        applyPriceFixes(); applyCS2InvColor(); applyCS2Background();
        applyHideSidebar(); applyHeaderTitleVisibility(); applyPriceVisibility();
        applyTabTitle(); initBackgroundRotation();
      } catch (e) {}

      refreshInventoryView();
      renderAccountSelect();
      alert(`Import complete (${mode.toUpperCase()}). Reloading with the new save now.`);
      document.getElementById("settingsModal").classList.add("hidden");
      window.location.reload();
    };

    overlay.querySelector("#importMergeBtn").onclick = () => finalizeImport('merge');
    overlay.querySelector("#importReplaceBtn").onclick = () => finalizeImport('replace');
    overlay.querySelector("#importCancelBtn").onclick = () => overlay.remove();

  } catch (err) {
    alert("Import failed: " + err.message);
  }
}

