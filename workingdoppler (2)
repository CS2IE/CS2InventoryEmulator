  html += `<h3 style="color: #66c0f4; margin-top: 12px; margin-bottom: 8px; border-bottom: 1px solid #334155; padding-bottom: 5px;">Per-Account Details</h3>`;

  perAccountStats.forEach(acc => {
    html += `<div style="display: grid; grid-template-columns: 1fr auto; gap: 8px; align-items:center; margin-bottom: 8px; background: rgba(255,255,255,0.02); padding: 10px; border-radius: 6px;">
