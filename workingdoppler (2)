/* ---------- CONSOLE SYSTEM ---------- */
function initConsoleUI() {
  const closeBtn = document.getElementById("closeConsoleBtn");
  const minBtn = document.getElementById("minimizeConsoleBtn");
  const win = document.getElementById("consoleWindow");
  const modal = document.getElementById("consoleModal");

  // Prevent drag initiation when clicking buttons
  const stopProp = (e) => e.stopPropagation();
  closeBtn.addEventListener("pointerdown", stopProp);
  minBtn.addEventListener("pointerdown", stopProp);

  closeBtn.onclick = (e) => {
    e.stopPropagation();
    modal.classList.add("hidden");
  };
  
  minBtn.onclick = (e) => {
    e.stopPropagation();
    const isMinimized = win.classList.toggle("minimized");
    if (isMinimized) {
      win.style.transform = "none";
      win.style.left = "20px";
      win.style.top = "auto";
      win.style.bottom = "20px";
      win.style.right = "auto";
    } else {
      win.style.bottom = "auto";
      win.style.left = "50%";
      win.style.top = "50%";
      win.style.transform = "translate(-50%, -50%)";
    }
  };

  // Re-inject "Show Log" trigger into console welcome
  const body = document.getElementById("consoleBody");
  const welcome = body.querySelector(".console-welcome");
  if (welcome) {
    welcome.innerHTML = `Initialized developer console... Tracking drops and transactions.<br>
      <span style="color:#8f98a0; font-size:11px;">Shortcut: Press Shift + - (underscore) to toggle this console.</span><br><br>
      <button id="manualShowLogBtn" class="steam-btn highlight" style="font-size:11px; padding:4px 12px;">SHOW LOG HISTORY</button>`;
    document.getElementById("manualShowLogBtn").onclick = renderConsoleLog;
  }

  // Resizing logic for console
  const handles = win.querySelectorAll(".resize-handle");
  handles.forEach(h => {
    h.addEventListener("mousedown", (e) => {
      e.preventDefault();
      const initialWidth = win.offsetWidth;
      const initialHeight = win.offsetHeight;
      const initialX = win.offsetLeft;
      const initialY = win.offsetTop;
      const mouseX = e.clientX;
      const mouseY = e.clientY;

      const onMouseMove = (moveEv) => {
        const dx = moveEv.clientX - mouseX;
        const dy = moveEv.clientY - mouseY;

        if (h.classList.contains("e")) win.style.width = (initialWidth + dx) + "px";
        if (h.classList.contains("w")) {
          win.style.width = (initialWidth - dx) + "px";
          win.style.left = (initialX + dx) + "px";
        }
        if (h.classList.contains("s")) win.style.height = (initialHeight + dy) + "px";
        if (h.classList.contains("n")) {
          win.style.height = (initialHeight - dy) + "px";
          win.style.top = (initialY + dy) + "px";
        }
        if (h.classList.contains("se")) {
          win.style.width = (initialWidth + dx) + "px";
          win.style.height = (initialHeight + dy) + "px";
        }
        if (h.classList.contains("sw")) {
          win.style.width = (initialWidth - dx) + "px";
          win.style.left = (initialX + dx) + "px";
          win.style.height = (initialHeight + dy) + "px";
        }
        if (h.classList.contains("nw")) {
          win.style.width = (initialWidth - dx) + "px";
          win.style.left = (initialX + dx) + "px";
          win.style.height = (initialHeight - dy) + "px";
          win.style.top = (initialY + dy) + "px";
        }
        if (h.classList.contains("ne")) {
          win.style.width = (initialWidth + dx) + "px";
          win.style.height = (initialHeight - dy) + "px";
          win.style.top = (initialY + dy) + "px";
        }
      };

      const onMouseUp = () => {
        window.removeEventListener("mousemove", onMouseMove);
        window.removeEventListener("mouseup", onMouseUp);
      };
      window.addEventListener("mousemove", onMouseMove);
      window.addEventListener("mouseup", onMouseUp);
    });
  });

  // Draggable logic for console
  const handle = document.getElementById("consoleDragHandle");
  let isDragging = false;
  let offsetX = 0, offsetY = 0;
  let pointerId = null;

  // Use named listener functions so we can remove them reliably
  function onPointerMove(e) {
    if (!isDragging || e.pointerId !== pointerId) return;
    // Prevent text selection or other side effects while dragging
    e.preventDefault();
    const clientX = e.clientX;
    const clientY = e.clientY;
    win.style.left = (clientX - offsetX) + "px";
    win.style.top = (clientY - offsetY) + "px";
  }

  function onPointerUp(e) {
    if (!isDragging || e.pointerId !== pointerId) return;
    
    isDragging = false;
    pointerId = null;
    
    // Clean up listeners
    window.removeEventListener("pointermove", onPointerMove, { passive: false });
    window.removeEventListener("pointerup", onPointerUp);
    
    // Explicitly release capture
    try { handle.releasePointerCapture(e.pointerId); } catch (err) {}
    
    handle.style.cursor = "grab";
  }

  handle.addEventListener("pointerdown", (e) => {
    // Only start drag with primary button / primary pointer
    if (win.classList.contains("minimized")) return;
    if (e.button && e.button !== 0) return;

    // Reset initial size/centering logic if we were previously full screen but started dragging
    if (!win.style.width || win.style.width === "100vw") {
       const rect = win.getBoundingClientRect();
       win.style.width = rect.width + "px";
       win.style.height = rect.height + "px";
       win.style.left = rect.left + "px";
       win.style.top = rect.top + "px";
       win.style.transform = "none";
    }
    
    isDragging = true;
    pointerId = e.pointerId;
    
    // Capture rect BEFORE removing transform to avoid jump
    const rect = win.getBoundingClientRect();
    offsetX = e.clientX - rect.left;
    offsetY = e.clientY - rect.top;
    
    win.style.position = "fixed";
    win.style.margin = "0";
    // Set actual pixel coords based on rect to avoid snap from transform center
    win.style.left = rect.left + "px";
    win.style.top = rect.top + "px";
    win.style.transform = "none"; 
    
    // Use setPointerCapture to ensure move/up events are captured even if leaving the handle
    try { handle.setPointerCapture(e.pointerId); } catch (err) {}
    
    // Add global listeners for consistent tracking
    window.addEventListener("pointermove", onPointerMove, { passive: false });
    window.addEventListener("pointerup", onPointerUp);
    
    handle.style.cursor = "grabbing";
  });

  // Safety: if the window gets blurred/hidden ensure drag ends
  window.addEventListener("blur", () => {
    if (isDragging) {
      isDragging = false;
      pointerId = null;
      window.removeEventListener("pointermove", onPointerMove, { passive: false });
      window.removeEventListener("pointerup", onPointerUp);
      handle.style.cursor = "grab";
    }
  });
}

