      tray.className = "inv-sticker-list purchase-result-stickers";
      tray.innerHTML = html;
      imageWrapForST.appendChild(tray);
    }
  }

  // Header context: NEW ITEM vs NEW ITEMS
  header.textContent = purchaseResultList.length > 1 
