async function fetchDopplerMarketImagePool(item) {
  const poolKey = getDopplerMarketPoolKey(item);
  if (!poolKey || !/doppler/i.test(poolKey)) return [];
  if (Array.isArray(dopplerMarketPoolCache[poolKey])) return dopplerMarketPoolCache[poolKey];

  try {
    const steamData = await fetchSteamSearch(poolKey);
    const results = Array.isArray(steamData?.results) ? steamData.results : [];
    const normalizedPoolKey = normalizeSteamDopplerLookupName(poolKey);
    const images = Array.from(new Set(results.filter(result => {
      const resultName = normalizeSteamDopplerLookupName(result?.hash_name || result?.name || "");
      return resultName.includes(normalizedPoolKey);
    }).map(getSteamMarketResultImage).filter(Boolean)));
    dopplerMarketPoolCache[poolKey] = images;
    return images;
  } catch (e) {
    console.warn("fetchDopplerMarketImagePool failed:", poolKey, e);
    dopplerMarketPoolCache[poolKey] = [];
    return [];
  }
}

function pickDeterministicDopplerMarketImage(item, images) {
  if (!item || !Array.isArray(images) || !images.length) return "";
  const seedSource = `${item.id || ""}|${item.pattern || ""}|${item.float || item.floatVal || ""}|${item.name || ""}`;
  let hash = 0;
  for (let i = 0; i < seedSource.length; i++) {
    hash = ((hash << 5) - hash) + seedSource.charCodeAt(i);
    hash |= 0;
  }
  const index = Math.abs(hash) % images.length;
  return images[index] || images[0] || "";
}

async function hydrateDopplerMarketListingImage(item) {
