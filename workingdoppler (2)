/**
 * Resolve the best display image for an item, preferring API images by exact name.
 * This prevents broken/invalid URLs and keeps guns aligned with CS2 artwork.
 */
function getDisplayImage(item) {
  if (!item) return KNIFE_PLACEHOLDER_IMG;
  
  // Sanitize images to remove broken GitHub raw links if present
  if (item.img && item.img.includes("raw.githubusercontent.com")) item.img = "";
  if (item.image && item.image.includes("raw.githubusercontent.com")) item.image = "";

  const name = (item.name || "").trim();
  if (!name) return item.image || item.img || "https://i.imgur.com/Vki8GHi.png";
  const betterKarambitImage = getBetterKarambitImage(item);
  if (betterKarambitImage) return betterKarambitImage;

  // Dead Mans Hand Gloves fix: Ensure specific image loads
  if ((name.toLowerCase().includes("dead mans hand") || name.toLowerCase().includes("dead man's hand")) && name.toLowerCase().includes("gloves")) {
      return "https://i.imgur.com/vHqB5P1.png";
  }

  const normalizedName = normalizeImageLookupName(name);
  const wearlessName = normalizedName.split(" (")[0].trim();
  const imageOverrideCandidates = getImageOverrideCandidates(name);
  const isDopplerName = /doppler/i.test(name);
  if (isDopplerName) {
    const directDopplerImage = [item.image, item.img, item.steamPhaseImage].find(src =>
      typeof src === "string" &&
      src &&
      !src.includes("raw.githubusercontent.com")
    );
    if (directDopplerImage) return directDopplerImage;
  }

  // 0.0) Highest priority: Specific Pattern Overrides
  if (item && item.pattern !== undefined && item.pattern !== null) {
      const pIdx = Number(item.pattern);
      if (state.patternImageOverrides?.[name]?.[pIdx]) return state.patternImageOverrides[name][pIdx];
      if (state.patternImageOverrides?.[normalizedName]?.[pIdx]) return state.patternImageOverrides[normalizedName][pIdx];
      if (state.patternImageOverrides?.[wearlessName]?.[pIdx]) return state.patternImageOverrides[wearlessName][pIdx];
  }

  const wearVariant = getApiWearVariant(item);
  if (wearVariant && (wearVariant.image || wearVariant.img)) {
    return wearVariant.image || wearVariant.img;
  }

  // Handle special trade-up collection icon
  if (name === "Trade Up Collection" || name === "Trade Up Contract") return "https://i.imgur.com/qQHgGvO.png";

  const hardcodedCollectionIcons = {
    "The Alpha Collection": "https://i.imgur.com/DQKBqMs.png",
    "The 2018 Nuke Collection": "https://i.imgur.com/XCoinoY.png",
    "The Nuke Collection": "https://i.imgur.com/1sYeNWn.png",
    "Budapest 2025 Ancient Souvenir Package": "https://i.imgur.com/QwKZMqF.png",
    "Howler Package": "https://i.imgur.com/ROd2jjW.png",
    "Fortune Case": "https://i.imgur.com/ROd2jjW.png",
    "Cobblestone Package": "https://i.imgur.com/qaCy0xR.png",
    "False Odds": "https://i.imgur.com/qaCy0xR.png"
  };
  if (hardcodedCollectionIcons[name]) return hardcodedCollectionIcons[name];

  if (item.image) return item.image;
  if (item.img) return item.img;

  // 0) Highest priority: explicit per-name image overrides saved in state (global edits)
  try {
    if (state && state.imageOverrides && typeof state.imageOverrides === "object") {
      for (const candidate of imageOverrideCandidates) {
        if (state.imageOverrides[candidate]) return state.imageOverrides[candidate];
      }
    }
  } catch (e) { }

  // Normalize StatTrak formatting for all display logic
  if (name.toLowerCase().includes("stattrak") && !name.includes("StatTrak™")) {
     const clean = name.replace(/StatTrak(?:™|â„¢|™| )*/gi, "").trim();
     return getDisplayImage({ ...item, name: `StatTrak™ ${clean}` });
  }

  // 2) Prefer explicit MARKET_KEYS images for exact key/case matches.
  if (Array.isArray(MARKET_KEYS) && MARKET_KEYS.length > 0) {
    let mk = MARKET_KEYS.find(k => imageOverrideCandidates.includes((k.name || "").trim()));
    if (!mk) {
      mk = MARKET_KEYS.find(k => imageOverrideCandidates.some(candidate => (k.name || "").toLowerCase() === candidate.toLowerCase()));
    }
    if (mk && mk.img) return mk.img;
  }

  const exactApiMatch = allSkins.find(s => {
    const sName = (s.name || s.hash_name || "").trim();
    return imageOverrideCandidates.includes(sName);
  }) || allSkins.find(s => {
    const sName = (s.name || s.hash_name || "").trim().toLowerCase();
    return imageOverrideCandidates.some(candidate => sName === candidate.toLowerCase());
  });
  if (exactApiMatch && (exactApiMatch.image || exactApiMatch.img)) return exactApiMatch.image || exactApiMatch.img;

  // Only fall back to gold icon if it's a generic "Rare Special Item" placeholder name, 
  if (name === "★ Rare Special Item" || name === "★ Rare Special Item ★" || name === "Mystery Item") {
    return getGoldIcon();
  }

  // 3) Try exact match from API/db (Ensure image consistency)
  let apiMatch = allSkins.find(s => {
    const sName = (s.name || "").trim();
    const nStr = name.replace(/^StatTrak(?:™|â„¢)\s+/i, "").trim()
                     .replace(/\s+\(Vanilla\)$/i, ""); // Strip Vanilla tag for matching
    return sName === nStr || sName === name;
  });
  if (apiMatch && (apiMatch.image || apiMatch.img)) return apiMatch.image || apiMatch.img;

  // 4) Try stricter fuzzy matching to avoid incorrect overlaps
  apiMatch = allSkins.find(s => {
    const sName = (s.name || "").trim();
    if (name.includes("★")) return false;
    // Check for exact start match which is safer for weapon family matches
    return sName.toLowerCase().startsWith(name.toLowerCase());
  });
  if (apiMatch && (apiMatch.image || apiMatch.img)) return apiMatch.image || apiMatch.img;

  // Placeholders for special items
  // Knife/glove logic improvements for Doppler/Gems
  if (false && name.includes("Doppler")) {
     const n = name.toLowerCase();
     // Use item's hash to deterministically assign a phase if not explicitly in name
     const seed = item.id ? item.id.charCodeAt(item.id.length-1) : Math.floor(Math.random()*10);
     const phases = ["phase 1", "phase 2", "phase 3", "phase 4", "ruby", "sapphire", "black pearl", "emerald"];
     const p = phases.find(ph => n.includes(ph)) || phases[seed % 4];

     if (p === "ruby") return "https://i.imgur.com/vHqB5P1.png";
     if (p === "sapphire") return "https://i.imgur.com/kP8U8mX.png";
     if (p === "emerald") return "https://i.imgur.com/0iCiwlD.png";
     if (p === "black pearl") return "https://i.imgur.com/X4yXWqC.png";
     if (p === "phase 1") return "https://i.imgur.com/pZzN1D5.png";
     if (p === "phase 2") return "https://i.imgur.com/mOaZlZq.png";
     if (p === "phase 3") return "https://i.imgur.com/j0CshxY.png";
     if (p === "phase 4") return "https://i.imgur.com/pZzN1D5.png";
     
     if (n.includes("gamma doppler")) {
        const gp = ["phase 1", "phase 2", "phase 3", "phase 4", "emerald"].find(ph => n.includes(ph)) || "phase 1";
        if (gp === "emerald") return "https://i.imgur.com/0iCiwlD.png";
        if (gp === "phase 1") return "https://i.imgur.com/XF38m9x.png";
        if (gp === "phase 2") return "https://i.imgur.com/WfH4R8L.png";
        if (gp === "phase 3") return "https://i.imgur.com/pZzN1D5.png";
        if (gp === "phase 4") return "https://i.imgur.com/mOaZlZq.png";
     }
  }

  if (name.includes("★") || name.toLowerCase().includes("knife") || name.toLowerCase().includes("gloves")) {
    return item.image || item.img || KNIFE_PLACEHOLDER_IMG;
  }

  // Final safe fallback: return the game's logo
  return item.image || item.img || "https://i.imgur.com/Vki8GHi.png";
}

function formatPrice(num) {
  const val = Number(num) || 0;
  return "$" + val.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

/**
 * Format float values for display.
 * Strips trailing zeros while maintaining up to 9 decimal places.
 * Example: 0.293900000 -> 0.2939
 */
function formatFloat(val) {
  if (val === undefined || val === null || isNaN(val)) return "0.000000000000";
  return Number(val).toFixed(12);
}

