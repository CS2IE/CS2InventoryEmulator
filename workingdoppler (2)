/**
 * Apply pagination setting by toggling scroll-mode on the grid and showing/hiding pagination controls.
 * Enforced rule: Inventory must always use strict pages of PAGE_SIZE (25). Ignore attempts to disable pagination.
 */
function applyPaginationSetting(disablePagination) {
  const grid = document.getElementById("inventoryGrid");
  const pagination = document.querySelector(".pagination-bottom");
  const wrapper = document.querySelector(".inventory-grid-wrapper");
  if (!grid) return;
  // When disablePagination is true -> enable continuous scroll (scroll-mode) and hide pagination controls.
  if (disablePagination) {
    grid.classList.add("scroll-mode");
    grid.classList.remove("paged-mode");
    document.body.classList.add("pagination-disabled");
    if (wrapper) wrapper.classList.remove("paged-inventory");
    if (pagination) pagination.style.display = "none";
  } else {
    grid.classList.remove("scroll-mode");
    grid.classList.add("paged-mode");
    document.body.classList.remove("pagination-disabled");
    if (wrapper) {
      wrapper.classList.add("paged-inventory");
      wrapper.scrollTop = 0;
    }
    grid.scrollTop = 0;
    if (pagination) pagination.style.display = "flex";
  }
}

