function logUsedToHaveItems(account, items, reason = "Lost") {
  if (!account || !Array.isArray(items) || items.length === 0) return;
  if (!Array.isArray(state.usedToHaveHistory)) state.usedToHaveHistory = [];
  items.forEach(it => {
    if (!it?.name) return;
    state.usedToHaveHistory.unshift({
      id: `used_${Date.now()}_${Math.random().toString(16).slice(2)}`,
      accountId: account.id,
      accountName: account.name,
      reason,
      timestamp: Date.now(),
      item: JSON.parse(JSON.stringify({
        ...it,
        qty: 1,
        source: reason
      }))
    });
  });
  if (state.usedToHaveHistory.length > 600) state.usedToHaveHistory.length = 600;
}

function getUsedToHaveItemsForAccount(account) {
  if (!account) return [];
  const entries = [];
  const seenIds = new Set();

  if (Array.isArray(state.tradeHistory)) {
    state.tradeHistory.forEach(entry => {
      if (entry.leftAccountId === account.id) {
        (entry.leftFullItems || entry.leftItems || []).forEach(it => {
          if (!it?.name) return;
          const eId = it.id || `trade_${entry.id}_${it.name}_left`;
          if (seenIds.has(eId)) return;
          seenIds.add(eId);
          entries.push({
            id: eId,
            reason: "Traded Away",
            timestamp: new Date(entry.timestamp).getTime() || Date.now(),
            item: { ...it, source: "Traded Away" }
          });
        });
      }
      if (entry.rightAccountId === account.id) {
        (entry.rightFullItems || entry.rightItems || []).forEach(it => {
          if (!it?.name) return;
          const eId = it.id || `trade_${entry.id}_${it.name}_right`;
          if (seenIds.has(eId)) return;
          seenIds.add(eId);
          entries.push({
            id: eId,
            reason: "Traded Away",
            timestamp: new Date(entry.timestamp).getTime() || Date.now(),
            item: { ...it, source: "Traded Away" }
          });
        });
      }
    });
  }

  if (Array.isArray(state.usedToHaveHistory)) {
    state.usedToHaveHistory
      .filter(entry => entry?.accountId === account.id && entry?.item?.name)
      .forEach(entry => {
        if (entry.item && entry.item.id && seenIds.has(entry.item.id)) return;
        entries.push({
          id: entry.id,
          reason: entry.reason || "Lost",
          timestamp: entry.timestamp || Date.now(),
          item: { ...entry.item }
        });
      });
  }

  return entries
    .sort((a, b) => (b.timestamp || 0) - (a.timestamp || 0))
    .slice(0, 300);
}

