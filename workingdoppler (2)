   * Import custom price overrides from clipboard and apply them to PRICE_FIXES, state.priceOverrides,
   * case DB entries, and all matching items in accounts.
   * Expected input shape same as exportEconomyToClipboard or a simple { priceOverrides: { ... } }.
   */
  async function importEconomyFromClipboard() {
    try {
      const text = await navigator.clipboard.readText();
      if (!text) return alert("Clipboard is empty.");
      let parsed = null;
      try { parsed = JSON.parse(text); } catch (e) { parsed = null; }
      if (!parsed || typeof parsed !== "object") {
        return alert("Clipboard does not contain valid JSON for economy import.");
      }

      const incoming = parsed.priceOverrides || parsed;
      if (!incoming || typeof incoming !== "object") {
        return alert("No priceOverrides object found in clipboard JSON.");
      }

      // MERGE into runtime overrides and PRICE_FIXES
      if (!state.priceOverrides) state.priceOverrides = {};
      Object.keys(incoming).forEach(k => {
        const v = Number(incoming[k]);
        if (!isNaN(v)) {
          // If already exists, we overwrite to match imported prices as requested (merge/update)
          state.priceOverrides[k] = v;
          PRICE_FIXES[k] = v;
        }
      });

      // Explicitly apply price fixes to all items after merging
      applyPriceFixes();

      saveState();
      refreshInventoryView();
      alert("Economy merged: " + Object.keys(incoming).length + " prices updated.");
