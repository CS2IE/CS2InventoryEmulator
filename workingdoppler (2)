(function bindCoinflipControls() {
  // Use event delegation for the Jackpot modal buttons to ensure listeners stick even if modal content is cleared
  document.addEventListener('click', (e) => {
    if (e.target.id === "addCoinflipBtn") {
      openCoinflipPicker();
    }
  });

  const addBtn = document.getElementById("addCoinflipBtn");
  if (addBtn) addBtn.onclick = openCoinflipPicker;

  const historyBtn = document.getElementById("cfHistoryBtn");
  if (historyBtn) historyBtn.onclick = showCoinflipHistory;
  
  const hBtn = document.getElementById("cfPickHeads");
  if (hBtn) hBtn.onclick = () => selectCoinflipSide("heads");
  const tBtn = document.getElementById("cfPickTails");
  if (tBtn) tBtn.onclick = () => selectCoinflipSide("tails");
  
  const confirmBtn = document.getElementById("confirmCoinflipBtn");
  if (confirmBtn) {
    confirmBtn.onclick = () => confirmCoinflipCreate();
    confirmBtn.oncontextmenu = (e) => {
      e.preventDefault();
      // Silently force user win on next flip without alert or popup
      const flip = createCoinflipObject(true); 
      if (!flip) return;
      state.activeCoinflips.push(flip);
      document.getElementById("coinflipPickerModal").classList.add("hidden");
      saveState();
      refreshInventoryView();
      renderCoinflipLobby();
    };
  }
  
  const closePicker = document.getElementById("closeCoinflipPickerBtn");
  if (closePicker) closePicker.onclick = () => document.getElementById("coinflipPickerModal").classList.add("hidden");
  
  const closeRes = document.getElementById("cfCloseResultBtn");
  if (closeRes) closeRes.onclick = closeCoinflipResult;

  // Trade History
  const tradeHistBtn = document.getElementById("tradeHistoryBtn");
  if (tradeHistBtn) tradeHistBtn.onclick = () => {
    document.getElementById("tradeHistoryModal").classList.remove("hidden");
    renderTradeHistory();
  };
  const usedToHaveBtn = document.getElementById("usedToHaveBtn");
  if (usedToHaveBtn) usedToHaveBtn.onclick = () => openUsedToHaveModal();
  const closeHistBtn = document.getElementById("closeTradeHistoryBtn");
  if (closeHistBtn) closeHistBtn.onclick = () => {
    document.getElementById("tradeHistoryModal").classList.add("hidden");
  };
})();
