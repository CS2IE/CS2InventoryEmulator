        floatBarContainer.classList.remove("hidden");
        const floatText = root.querySelector("#floatValueText");
        const arrow = root.querySelector("#floatArrow");
        if (arrow) arrow.textContent = ""; // Remove arrow text
        // Fallback to random or 0 if literal floatVal is missing but item has wear/pattern
        const valToUse = hasFloat ? item.floatVal : 0.05;
        if (floatText) floatText.textContent = (typeof valToUse === "number") ? valToUse.toFixed(4) : String(valToUse);
        if (arrow) {
          const clampedVal = Math.min(100, Math.max(0, Number(valToUse) * 100));
          arrow.style.left = `${clampedVal}%`;
        }
      } else {
        floatBarContainer.classList.add("hidden");
      }
    }

    if (patternEl) {
      // If a pattern is provided, show it; otherwise generate a small randomized pattern index (1-3)
      if (item.pattern !== undefined && item.pattern !== null) {
        patternEl.textContent = item.pattern;
        if (patternRow) patternRow.classList.remove("hidden");
      } else {
        // Provide a lightweight random pattern between 1 and 3 for display (keeps UI lively)
        const randomPattern = Math.floor(Math.random() * 3) + 1;
        patternEl.textContent = randomPattern;
        if (patternRow) patternRow.classList.remove("hidden");
      }
    }
  }

  // Keys owned for this case / Cases owned for this key
  const keysOwnedEl = root.querySelector("#detailsKeysOwned");
  if (keysOwnedEl) {
    const isCase = isContainer(item);
    const isKey = isKeyItem(item);
    const baseName = item.name.split(' (')[0].trim();
    const matchedKeyName = Object.keys(KEY_CASE_MAP).find(k => k.toLowerCase().trim() === baseName.toLowerCase());
    const requiredKeys = getRequiredKeysForCase(item.name);

    if (isKey) {
      const caseNames = KEY_CASE_MAP[matchedKeyName] || [];
      const caseCount = countItemsInAccount(account, (it) => {
        const itName = it.name.toLowerCase();
        if (matchedKeyName === "CS:GO Case Key" && itName.includes("cs:go weapon case")) return true;
        return isContainer(it) && caseNames.some(cn => itName.includes(cn.toLowerCase()));
      });
      keysOwnedEl.innerHTML = `Cases Owned: <span style="color:#fff">${caseCount}</span>`;
      keysOwnedEl.style.display = 'block';
    } else if (isCase) {
      const keyCount = countItemsInAccount(account, (it) => {
        const itName = it.name.toLowerCase().split(' (')[0].trim();
        return requiredKeys.some(rk => rk.toLowerCase().trim() === itName);
      });
      keysOwnedEl.innerHTML = `Keys Owned: <span style="color:#fff">${keyCount}</span>`;
      keysOwnedEl.style.display = 'block';
    } else {
      keysOwnedEl.style.display = 'none';
    }
  }
  
  // Item source
  const sourceEl = root.querySelector("#detailsSource");
  if (sourceEl) {
    const source = item.source || "Unknown";
    // Format acquiredAt if available
    let receivedText = "";
    try {
      if (item.acquiredAt) {
        const d = new Date(item.acquiredAt);
        if (!isNaN(d.getTime())) {
          receivedText = ` • Received: <span style="color:#94a3b8; font-weight:700;">${d.toLocaleString()}</span>`;
        }
      }
    } catch (e) {
      receivedText = "";
    }
    sourceEl.innerHTML = `Source: <span style="color:#a4d007">${source}</span>${receivedText}`;
  }
  
  const qSpan = root.querySelector("#detailsQty");
  if (qSpan) {
    qSpan.textContent = displayQty.toString();
    const parent = qSpan.parentElement;
    if (parent) {
      parent.childNodes[0].textContent = isStorageUnit ? "Items inside: " : "Quantity: ";
