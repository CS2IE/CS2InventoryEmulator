  // Get IDs of items already in bet
  const betIds = jackpotBet.map(it => it.id);
  const equippedIds = Array.isArray(account.equippedItemIds) ? account.equippedItemIds : [];

  // Only gamble knives and guns, sorted by most expensive
  const gamblableItems = account.items.filter(it => {
    if (equippedIds.includes(it.id)) return false;
    const n = it.name.toLowerCase();
    const t = (it.type || "").toLowerCase();
    // Broaden gun detection to ensure they show up in dice gamble
    const isGun = t.includes("rifle") || t.includes("pistol") || t.includes("smg") ||
                  t.includes("sniper") || t.includes("shotgun") || t.includes("machine") ||
                  n.includes("ak-47") || n.includes("m4a4") || n.includes("m4a1-s") || n.includes("awp") ||
                  n.includes("glock") || n.includes("usp-s") || n.includes("desert eagle") ||
                  n.includes("cz75") || n.includes("p250") || n.includes("five-seven") || n.includes("tec-9") ||
                  n.includes("p90") || n.includes("mp9") || n.includes("mac-10") || n.includes("famas") ||
                  n.includes("galil") || n.includes("sg 553") || n.includes("aug") || n.includes("scout") ||
                  n.includes("scar-20") || n.includes("g3sg1") || n.includes("mag-7") || n.includes("nova") ||
                  n.includes("sawed-off") || n.includes("xm1014") || n.includes("m249") || n.includes("negev");
    const isKnife = t.includes("knife") || n.includes("★") || n.includes("knife");
    return (isGun || isKnife);
  }).sort((a, b) => getItemValue(b) - getItemValue(a));

  gamblableItems.forEach(it => {
    const inBet = jackpotBet.some(bi => bi.id === it.id);
    const card = createTradeCard(it, () => {
      // Toggle logic
      const isCurrentlyInBet = jackpotBet.some(bi => bi.id === it.id);
      if (isCurrentlyInBet) {
        jackpotBet = jackpotBet.filter(bi => bi.id !== it.id);
        card.style.background = "";
        card.style.border = "2px solid " + (RARITY_COLORS[it.rarity] || "#b0c3d9");
        card.style.boxShadow = "";
      } else {
        jackpotBet.push(it);
        // Dynamic immediate feedback
        card.style.background = "rgba(34, 197, 94, 0.4)";
        card.style.border = "2px solid #22c55e";
        card.style.boxShadow = "inset 0 0 15px rgba(34, 197, 94, 0.5)";
      }
      renderJackpotBet();
    });

    // Right-click to inspect in Dice Game selection
    card.oncontextmenu = (e) => {
      e.preventDefault();
      showInspect(it);
    };

    // Initial state check for visual consistency
    if (inBet) {
      card.style.background = "rgba(34, 197, 94, 0.4)";
      card.style.border = "2px solid #22c55e";
      card.style.boxShadow = "inset 0 0 15px rgba(34, 197, 94, 0.5)";
    }

    itemsDiv.appendChild(card);
  });

  renderJackpotBet();
}

function renderJackpotBet() {
  const betDiv = document.getElementById("jackpotCurrentBet");
  const totalSpan = document.getElementById("jackpotBetTotal");
  const spinBtn = document.getElementById("spinBtn");

  betDiv.innerHTML = "";
  let total = 0;

  jackpotBet.forEach((it, idx) => {
    const mini = document.createElement("img");
    mini.src = getStableDisplayImage(it);
    mini.style.width = "40px";
    mini.style.height = "40px";
    mini.style.objectFit = "contain";
    mini.style.background = "rgba(0,0,0,0.35)";
    mini.style.borderRadius = "6px";
    mini.style.cursor = "pointer";
    mini.title = it.name + " - Click to return to inventory";

    // Bet tray items stay visually distinct but not overly green (per user 'NTO CURRENT BET')
    mini.style.border = "1px solid #444";
    mini.style.boxShadow = "0 4px 8px rgba(0,0,0,0.5)";

    mini.onclick = () => {
      jackpotBet.splice(idx, 1);
      renderJackpotBet();
      initJackpotModal(); // Refresh the inventory pool area
    };
    betDiv.appendChild(mini);
    total += getItemValue(it);
  });

  totalSpan.textContent = formatPrice(total);
  spinBtn.innerHTML = `SPIN (${formatPrice(total)})`;
}

function clearJackpotBet() {
  jackpotBet = [];
  renderJackpotBet();
}

async function renderLeaderboard() {
  const body = document.getElementById("leaderboardBody");
  body.innerHTML = "";

  // Calculate total values for all accounts
  const leaderboardData = state.accounts.map(acc => {
    let totalValue = 0;
    acc.items.forEach(it => {
      totalValue += getItemValue(it);
    });
    return {
      id: acc.id,
      name: acc.name,
      value: totalValue
    };
  });

  // Sort descending
  leaderboardData.sort((a, b) => b.value - a.value);

  leaderboardData.forEach((entry, index) => {
    const isActive = entry.id === state.activeAccountId;
    const tr = document.createElement("tr");
    tr.className = "leaderboard-row" + (isActive ? " current-user" : "");
    
    tr.innerHTML = `
      <td style="font-weight: bold; color: ${index < 3 ? '#e4ae39' : '#94a3b8'}">#${index + 1}</td>
      <td>
        <div style="display: flex; align-items: center; gap: 10px;">
          <img src="${escapeHtml(state.accounts.find(a=>a.id===entry.id)?.pfp || 'https://i.imgur.com/zFydkgL.png')}" style="width:32px; height:32px; border-radius:6px; object-fit:cover; border:1px solid rgba(0,0,0,0.5);">
          <span style="${isActive ? 'color: #66c0f4; font-weight: bold;' : ''}">${escapeHtml(entry.name)}</span>
        </div>
      </td>
      <td style="text-align: right;">
        <div style="color: #a4d007; font-weight: bold; font-size: 16px;">${formatPrice(entry.value)}</div>
        <div style="color: #94a3b8; font-size: 12px; margin-top: 4px;">Items: ${state.accounts.find(a=>a.id===entry.id)?.items.length || 0}</div>
      </td>
    `;

    tr.onclick = () => {
      state.viewingProfileId = entry.id;
      state.viewingStorageUnitId = null;
      state.selectedItemId = null;
      state.currentPage = 1;
      saveState();
      refreshInventoryView();
      document.getElementById("leaderboardModal").classList.add("hidden");
    };

    body.appendChild(tr);
  });
}

