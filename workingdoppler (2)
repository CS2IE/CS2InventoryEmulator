function initTradeModal() {
  const leftSel = document.getElementById("tradeLeftAccount");
  const rightSel = document.getElementById("tradeRightAccount");
  
  leftSel.innerHTML = "";
  rightSel.innerHTML = "";
  
  state.accounts.forEach(acc => {
    const opt1 = document.createElement("option");
    opt1.value = acc.id;
    opt1.textContent = acc.name;
    leftSel.appendChild(opt1);
    
    const opt2 = document.createElement("option");
    opt2.value = acc.id;
    opt2.textContent = acc.name;
    rightSel.appendChild(opt2);
  });
  
  // Set defaults
  if (state.accounts.length > 0) {
    leftSel.value = state.activeAccountId || state.accounts[0].id;
    rightSel.value = state.accounts[state.accounts.length > 1 ? 1 : 0].id;
  }
  
  tradeState = {
    leftAccount: leftSel.value,
    rightAccount: rightSel.value,
    leftOffer: [],
    rightOffer: []
  };
  
  renderTradeInventory();
  renderTradeHistory();

  // bind history buttons
  const exportBtn = document.getElementById("exportTradeBtn");
  if (exportBtn) exportBtn.onclick = exportTradeDetails;
  const clearHistBtn = document.getElementById("clearHistoryBtn");
  if (clearHistBtn) clearHistBtn.onclick = () => {
    if (!confirm("Clear all trade history?")) return;
    state.tradeHistory = [];
    saveState();
    renderTradeHistory();
  };
}

function renderTradeInventory() {
  tradeState.leftAccount = document.getElementById("tradeLeftAccount").value;
  tradeState.rightAccount = document.getElementById("tradeRightAccount").value;
  
  const leftAcc = state.accounts.find(a => a.id === tradeState.leftAccount);
  const rightAcc = state.accounts.find(a => a.id === tradeState.rightAccount);
  
  const leftItemsDiv = document.getElementById("tradeLeftItems");
  const rightItemsDiv = document.getElementById("tradeRightItems");
  
  leftItemsDiv.innerHTML = "";
  rightItemsDiv.innerHTML = "";
  
  if (leftAcc) {
    const leftEq = Array.isArray(leftAcc.equippedItemIds) ? leftAcc.equippedItemIds : [];
    // Sort items by price for easier trading and filter out Storage Units and Equipped items
    const sortedLeft = [...leftAcc.items]
      .filter(it => !it.name.toLowerCase().includes("storage unit") && !leftEq.includes(it.id))
      .sort((a,b) => getItemValue(b) - getItemValue(a));

    sortedLeft.forEach(it => {
      const isCurrentlyInOffer = tradeState.leftOffer.some(o => o.id === it.id);
      const card = createTradeCard(it, () => {
        // Prevent bots/non-weapon items from being selected for trade in bot mode
        if (it.isUntradable) {
          alert("This item is untradable.");
          return;
        }
        if (tradeState.leftOffer.some(o => o.id === it.id)) {
          tradeState.leftOffer = tradeState.leftOffer.filter(o => o.id !== it.id);
        } else {
          if (!it.name.toLowerCase().includes("storage unit")) {
            tradeState.leftOffer.push(it);
          } else {
            alert("Storage Units are not tradable.");
          }
        }
        renderTradeInventory(); // Re-render to update opacities and offers
      });
      
      if (isCurrentlyInOffer) {
        card.style.opacity = "0.4";
        card.style.filter = "grayscale(0.5)";
        card.title = (card.title || "") + " — Click to remove from offer";
      }
      leftItemsDiv.appendChild(card);
    });
  }
  
  if (rightAcc) {
    const rightEq = Array.isArray(rightAcc.equippedItemIds) ? rightAcc.equippedItemIds : [];
    // Sort items by price for easier trading and filter out Storage Units and Equipped items
    const sortedRight = [...rightAcc.items]
      .filter(it => !it.name.toLowerCase().includes("storage unit") && !rightEq.includes(it.id))
      .sort((a,b) => getItemValue(b) - getItemValue(a));

    sortedRight.forEach(it => {
      const isCurrentlyInOffer = tradeState.rightOffer.some(o => o.id === it.id);
      const card = createTradeCard(it, () => {
        if (tradeState.rightOffer.some(o => o.id === it.id)) {
          tradeState.rightOffer = tradeState.rightOffer.filter(o => o.id !== it.id);
        } else {
          tradeState.rightOffer.push(it);
        }
        renderTradeInventory();
      });

      if (isCurrentlyInOffer) {
        card.style.opacity = "0.4";
        card.style.filter = "grayscale(0.5)";
        card.title = (card.title || "") + " — Click to remove from offer";
      }
      rightItemsDiv.appendChild(card);
    });
  }
  
  renderTradeOffers();
}

/**
