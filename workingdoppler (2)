            // simple deterministic 32-bit hash -> normalized 0..1
            let h = 2166136261 >>> 0;
            for (let i = 0; i < str.length; i++) {
              h ^= str.charCodeAt(i);
              h = Math.imul(h, 16777619) >>> 0;
