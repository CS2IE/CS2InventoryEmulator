function populatePurchaseText(item) {
  // Ensure we don't show the share icon in the new item popup results per cleanup request
  const infoIconHtml = createInfoIconHtml(item, { includeShare: false });
  const accent = document.getElementById("newItemAccent");
  const header = document.getElementById("newItemHeader");
  const nameEl = document.getElementById("purchaseResultName");
  const rarityEl = document.getElementById("purchaseResultRarity");
  const priceEl = document.getElementById("purchaseResultPrice");
  const imgEl = document.getElementById("purchaseResultImage");

  // Ensure the purchase result image cannot be dragged as a native image (prevents ghost/drag image)
  if (imgEl) {
    try {
      imgEl.setAttribute('draggable', 'false');
      imgEl.style.pointerEvents = 'none';
      imgEl.style.maxWidth = "60%"; // Make image slightly smaller
      imgEl.style.maxHeight = "60%";
    } catch (e) {}
  }

  // Determine the case/collection name for collection display.
  // Prefer explicit source text, otherwise try to infer from CASE_CONTENTS_DB by finding a case that contains this item.
  let containerName = null;
  if (item.source && String(item.source).includes("Pulled from ")) {
    containerName = String(item.source).split("Pulled from ")[1];
  } else if (item.source === "Traded") {
    containerName = "Traded Items";
  } else if (item.source === "Purchased") {
    containerName = "Market Purchase";
  }

  // If not found yet, try to search our CASE_CONTENTS_DB for a matching case that contains this item name
  if (!containerName || containerName === "Unknown Collection") {
    const inName = (item.name || "").toString();
    try {
      for (const caseName of Object.keys(CASE_CONTENTS_DB || {})) {
        const groups = CASE_CONTENTS_DB[caseName];
        if (!groups) continue;
        for (const rarityGroup of Object.values(groups)) {
          if (!Array.isArray(rarityGroup)) continue;
          if (rarityGroup.some(ci => (ci && String(ci.name || "").trim()) === inName)) {
            containerName = caseName;
            break;
          }
        }
        if (containerName) break;
      }
    } catch (e) {
      // ignore and fallback to Unknown Collection below
    }
  }

  if (!containerName) containerName = "Unknown Collection";
  const counterEl = document.getElementById("purchaseResultCounter");

  const rarityColor = RARITY_COLORS[item.rarity] || "#4b69ff";

  // StatTrak Icon Tray for Purchase Result (Updated for consistency)
  const imageWrapForST = document.querySelector(".new-item-image-wrap");
