function executeTrade() {
  if (tradeState.leftOffer.length === 0 && tradeState.rightOffer.length === 0) {
    alert("Add items to trade!");
    return;
  }
  
  const leftAcc = state.accounts.find(a => a.id === tradeState.leftAccount);
  const rightAcc = state.accounts.find(a => a.id === tradeState.rightAccount);
  
  if (!leftAcc || !rightAcc) return;
  
  // Snapshot summary for history
  const leftSummary = tradeState.leftOffer.map(it => ({ id: it.id, name: it.name, price: getItemValue(it) }));
  const rightSummary = tradeState.rightOffer.map(it => ({ id: it.id, name: it.name, price: getItemValue(it) }));
  const leftTotal = leftSummary.reduce((s, x) => s + x.price, 0);
  const rightTotal = rightSummary.reduce((s, x) => s + x.price, 0);
  const entry = {
    id: "trade_" + Date.now() + "_" + Math.random().toString(16).slice(2),
    timestamp: new Date().toISOString(),
    leftAccountId: leftAcc.id,
    rightAccountId: rightAcc.id,
    leftAccountName: leftAcc.name,
    rightAccountName: rightAcc.name,
    leftItems: leftSummary,
    rightItems: rightSummary,
    leftFullItems: JSON.parse(JSON.stringify(tradeState.leftOffer)), // Save full objects for inspection
    rightFullItems: JSON.parse(JSON.stringify(tradeState.rightOffer)),
    leftTotal,
    rightTotal
  };
  
  const activeId = state.activeAccountId;
  const itemsIncomingToUser = [];

  // Remove items from left account and add to right
  tradeState.leftOffer.forEach(it => {
    leftAcc.items = leftAcc.items.filter(i => i.id !== it.id);
    it.source = "Traded";
    it.prevOwners = (parseInt(it.prevOwners, 10) || 0) + 1;
    it.acquiredAt = Date.now(); // Set acquired time for NEW badge
    rightAcc.items.push(it);
    if (rightAcc.id === activeId) itemsIncomingToUser.push(it);
  });
  
  // Remove items from right account and add to left
  tradeState.rightOffer.forEach(it => {
    rightAcc.items = rightAcc.items.filter(i => i.id !== it.id);
    it.source = "Traded";
    it.prevOwners = (parseInt(it.prevOwners, 10) || 0) + 1;
    it.acquiredAt = Date.now(); // Set acquired time for NEW badge
    leftAcc.items.push(it);
    if (leftAcc.id === activeId) itemsIncomingToUser.push(it);
  });

  logUsedToHaveItems(leftAcc, tradeState.leftOffer, "Traded Away");
  logUsedToHaveItems(rightAcc, tradeState.rightOffer, "Traded Away");

  // Show "NEW ITEM" popup for traded items entering active account
  if (itemsIncomingToUser.length > 0) {
    itemsIncomingToUser.forEach(it => {
      it.newlyReceived = true; // Mark as unseen for this account

      try {
        const payload = {
          name: it.name,
          img: it.img || getStableDisplayImage(it),
          price: it.price || mockPrice(it),
          rarity: it.rarity,
          wear: it.wear,
          qty: 1,
          type: it.type,
          source: "Traded",
          createdId: it.id
        };
        const seenKey = it.id || `${it.name}::${it.img || ''}`;
        if (!state.seenPurchaseIds.includes(seenKey)) {
          payload._seenKey = seenKey;
          pendingPurchaseResults.push(payload);
          state.seenPurchaseIds.push(seenKey);
        }
      } catch (err) {
        // fallback if anything goes wrong
        pendingPurchaseResults.push({
          name: it.name,
          img: it.img || getDisplayImage(it),
          price: it.price || mockPrice(it),
          rarity: it.rarity,
          wear: it.wear,
          qty: 1,
          type: it.type,
          source: "Traded"
        });
      }
    });
    
    // Close trade modal before showing results to prevent UI overlap
    document.getElementById("tradeModal").classList.add("hidden");
    showGroupedPurchaseResult();
  }
  
  // Save history entry
  if (!Array.isArray(state.tradeHistory)) state.tradeHistory = [];
  state.tradeHistory.unshift(entry); // newest at top
  if (state.tradeHistory.length > 200) state.tradeHistory.length = 200;
  
  saveState();
  refreshInventoryView();
  clearTradeOffers();
  renderTradeInventory();
  renderTradeHistory();
  
  // Explicitly ensure New Items popup shows for items received in normal trade
  hasShownNewItemPopup = false;
  showGroupedPurchaseResult();
  
  alert("Trade completed successfully!");
}

