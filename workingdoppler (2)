function spinPotWheel() {
  if (jackpotSpinning || jackpotPotParticipants.length === 0) return;
  jackpotSpinning = true;
  document.getElementById("potTimer").textContent = "SPINNING!";

  // Disable interacting with pot buttons during spin
  const potAddBtn = document.getElementById("potAddSkinsBtn");
  const optOutBtn = document.getElementById("optOutJackpotBtn");
  if (potAddBtn) potAddBtn.disabled = true;
  if (optOutBtn) optOutBtn.disabled = true;

  const canvas = document.getElementById("potWheelCanvas");
  let winner = null;

  // Decide winner BEFORE animation starts
  if (state.cheatWinActive) {
    const userP = jackpotPotParticipants.find(p => p.id === "user");
    if (userP) winner = userP;
    state.cheatWinActive = false;
  }

  if (!winner) {
    // Robust winner selection using fractional precision
    const roll = Math.random() * 100;
    let acc = 0;
    for (let i = 0; i < jackpotPotParticipants.length; i++) {
      const p = jackpotPotParticipants[i];
      acc += p.chance;
      // Last participant gets the remaining probability to avoid rounding errors
      if (roll <= acc || i === jackpotPotParticipants.length - 1) {
        winner = p;
        break;
      }
    }
  }

  // Final fallback
  if (!winner && jackpotPotParticipants.length > 0) winner = jackpotPotParticipants[0];
  if (!winner) {
    jackpotSpinning = false;
    return;
  }

  let startAngle = 0;
  for(const p of jackpotPotParticipants) {
    if (p === winner) break;
    startAngle += (p.chance / 100) * 360;
  }
  const endAngle = startAngle + (winner.chance / 100) * 360;
  const targetAngleInSlice = startAngle + (Math.random() * (endAngle - startAngle));
  const finalRotation = (360 * 10) + (270 - targetAngleInSlice);
  
  canvas.style.transform = `rotate(${finalRotation}deg)`;

  // Explicitly clear any existing timeout to avoid overlaps
  if (window._jackpotSpinTimeout) clearTimeout(window._jackpotSpinTimeout);

  window._jackpotSpinTimeout = setTimeout(() => {
    jackpotSpinning = false; 
    showJackpotWinner(winner);
    window._jackpotSpinTimeout = null;
  }, 6500);
}

